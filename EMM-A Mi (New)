void RefreshCachedShipDimensions()
{
    var blocks = new List<IMyTerminalBlock>();
    GridTerminalSystem.GetBlocksOfType(blocks, b => b.CubeGrid.EntityId == Me.CubeGrid.EntityId);
    if (blocks.Count == 0)
    {
        cachedShipHeight = 0;
        cachedShipWidth = 0;
        cachedShipLength = 0;
        return;
    }

    Vector3I min = blocks[0].Min;
    Vector3I max = blocks[0].Max;
    foreach (var b in blocks)
    {
        min.X = Math.Min(min.X, b.Min.X);
        min.Y = Math.Min(min.Y, b.Min.Y);
        min.Z = Math.Min(min.Z, b.Min.Z);
        max.X = Math.Max(max.X, b.Max.X);
        max.Y = Math.Max(max.Y, b.Max.Y);
        max.Z = Math.Max(max.Z, b.Max.Z);
    }
    double size = Me.CubeGrid.GridSize;
    cachedShipWidth = (Math.Abs(max.X - min.X) + 1) * size;
    cachedShipHeight = (Math.Abs(max.Y - min.Y) + 1) * size;
    cachedShipLength = (Math.Abs(max.Z - min.Z) + 1) * size;
}

double GetMinerHydrogenPercent()
{
    double filled = 0;
    int count = 0;
    foreach (var tank in hydrogenTanks)
    {
        if (!HasMinerTag(tank)) continue;
        filled += tank.FilledRatio;
        count++;
    }
    return count == 0 ? 0 : (filled / count) * 100.0;
}

bool HasMinerHydrogenTank()
{
    foreach (var tank in hydrogenTanks)
        if (tank != null && HasMinerTag(tank))
            return true;
    return false;
}

double GetMinerCargoFillPercent()
{
    _autoServiceCargoBlocks.Clear();
    GridTerminalSystem.GetBlocksOfType(_autoServiceCargoBlocks, b =>
        b.HasInventory &&
        b.CustomName.IndexOf(minerContainerTag, StringComparison.OrdinalIgnoreCase) >= 0);

    double current = 0;
    double max = 0;
    foreach (var block in _autoServiceCargoBlocks)
    {
        if (block == null || !block.IsFunctional)
            continue;

        for (int i = 0; i < block.InventoryCount; i++)
        {
            IMyInventory inv = block.GetInventory(i);
            if (inv == null)
                continue;
            current += (double)inv.CurrentVolume;
            max += (double)inv.MaxVolume;
        }
    }

    return max <= 0 ? 0 : MathHelper.Clamp(current / max * 100.0, 0, 100);
}

void RefreshTickPose()
{
    _tickRcMatrix = rc.WorldMatrix;
    _tickRcPosition = rc.GetPosition();
}

void Move ()
{
    movementResetApplied = false;
    MatrixD rcMatrix = _tickRcMatrix;
    Vector3D worldOffset = GetActiveTargetOffsetWorld(rcMatrix);
    Vector3D rcPosition = _tickRcPosition;
    Vector3D position = rcPosition + worldOffset;
    Vector3D toTarget = targetPosition - position;
    double tolerance = GetActiveArrivalTolerance();
    bool pointToPointPrecision = UsePointToPointPrecisionAutopilot();
    bool atPosition = toTarget.LengthSquared() < tolerance * tolerance;

    Vector3D forward = desiredForward;
    bool precisionTravelFacing = pointToPointPrecision &&
        desiredForward == Vector3D.Zero &&
        !atPosition &&
        toTarget.LengthSquared() > 0.001;
    if (precisionTravelFacing)
        forward = Vector3D.Normalize(toTarget);
    else if (forward == Vector3D.Zero && toTarget.LengthSquared() > 0.001)
        forward = Vector3D.Normalize(toTarget);

    Vector3D up = precisionTravelFacing ? Vector3D.Zero : desiredUp;
    if (up == Vector3D.Zero && !precisionTravelFacing)
    {
        Vector3D gravity = rc.GetNaturalGravity();
        if (gravity.LengthSquared() > 0.001)
            up = Vector3D.Normalize(-gravity);
        else
            up = rcMatrix.Up;
    }

    gyros.FaceVectors(rcMatrix, forward, up);

    bool aligned = IsOrientationAligned(rcMatrix, forward, up, orientationToleranceDeg);
    if (atPosition)
    {
        thrust.Reset();
        if (aligned)
            gyros.Reset();
        return;
    }

    double maxSpeedNow = activeMaxSpeed > 0 ? activeMaxSpeed : maxSpeed;
    Vector3D rcTarget = targetPosition - worldOffset;
    if (dockingState != DockingState.None)
    {
        // During docking/undocking: prioritize lateral and forward/backward over vertical.
        // Use desiredUp as the vertical axis; fall back to RC's current up if unset.
        Vector3D vertAxis = desiredUp.LengthSquared() > 0.001 ? Vector3D.Normalize(desiredUp) : rcMatrix.Up;
        thrust.ApplyAccel(thrust.ControlPositionPrioritizedFrom(rcPosition, rcTarget, Vector3D.Zero, maxSpeedNow, vertAxis));
    }
    else if (pointToPointPrecision)
    {
        if (!aligned)
        {
            thrust.Reset();
            return;
        }

        maxSpeedNow = Math.Min(maxSpeedNow, GetPointToPointSafeSpeed(toTarget, tolerance));
        maxSpeedNow = Math.Min(maxSpeedNow, maxSpeed);
        Vector3D accel = thrust.ControlPositionFrom(rcPosition, rcTarget, Vector3D.Zero, maxSpeedNow);
        ApplyPointToPointAccel(accel, ShouldUsePointToPointEmergencyThrust(toTarget, tolerance));
    }
    else
    {
        thrust.ApplyAccel(thrust.ControlPositionFrom(rcPosition, rcTarget, Vector3D.Zero, maxSpeedNow));
    }
}

bool UsePointToPointPrecisionAutopilot()
{
    return dockingState == DockingState.None &&
           !miningEnabled &&
           mineAreaAdjustStage == MineAreaAdjustStage.None;
}

double GetPointToPointSafeSpeed(Vector3D toTarget, double tolerance)
{
    double distance = Math.Max(0, toTarget.Length() - Math.Max(0.05, tolerance));
    if (distance <= 0)
        return 0;
    Vector3D dir = Vector3D.Normalize(toTarget);
    double brakeAccel = GetPointToPointPlannedAcceleration(-dir);
    if (brakeAccel <= 0)
        return Math.Max(1, maxSpeed);
    return Math.Sqrt(Math.Max(0, 2 * brakeAccel * distance));
}

bool ShouldUsePointToPointEmergencyThrust(Vector3D toTarget, double tolerance)
{
    Vector3D vel = rc.GetShipVelocities().LinearVelocity;
    double dist = Math.Max(0, toTarget.Length() - Math.Max(0.05, tolerance));
    if (dist <= 0 || vel.LengthSquared() < 0.01 || toTarget.LengthSquared() < 0.01)
        return false;
    Vector3D dir = Vector3D.Normalize(toTarget);
    double speedToward = Vector3D.Dot(vel, dir);
    if (speedToward <= 0)
        return false;
    double accel = GetPointToPointPlannedAcceleration(-dir);
    if (accel <= 0)
        return false;
    return (speedToward * speedToward) / (2 * accel) > dist;
}

double GetShipMass()
{
    return Math.Max(1, rc.CalculateShipMass().TotalMass);
}

double GetEffectiveThrustInDirection(Vector3D direction)
{
    if (direction.LengthSquared() < 0.001)
        return 0;
    Vector3D dir = Vector3D.Normalize(direction);
    RefreshEffectiveThrustCacheIfNeeded();
    double total = 0;
    for (int i = 0; i < effectiveThrustCache.Count; i++)
    {
        ThrusterForceSample sample = effectiveThrustCache[i];
        Vector3D worldForward = Vector3D.TransformNormal(sample.LocalForward, _tickRcMatrix);
        double dot = Vector3D.Dot(worldForward, dir);
        if (dot > 0)
            total += sample.MaxEffectiveThrust * dot;
    }
    return total;
}

void InvalidateEffectiveThrustCache()
{
    effectiveThrustCacheTicks = 0;
    effectiveThrustCache.Clear();
}

void RefreshEffectiveThrustCacheIfNeeded()
{
    if (effectiveThrustCacheTicks > 0)
    {
        effectiveThrustCacheTicks--;
        return;
    }

    effectiveThrustCache.Clear();
    foreach (var t in allThrusters)
    {
        if (t == null || !t.IsFunctional)
            continue;
        Vector3D localForward = Vector3D.TransformNormal(t.WorldMatrix.Forward, MatrixD.Transpose(rc.WorldMatrix));
        effectiveThrustCache.Add(new ThrusterForceSample(localForward, t.MaxEffectiveThrust));
    }
    effectiveThrustCacheTicks = effectiveThrustRefreshIntervalTicks;
}

double GetPointToPointPlannedThrustN(Vector3D direction)
{
    double thrustPercent = MathHelper.Clamp(pointToPointThrustUsePercent, 1, 100) / 100.0;
    return GetEffectiveThrustInDirection(direction) * thrustPercent;
}

double GetPointToPointPlannedAcceleration(Vector3D direction)
{
    double mass = GetShipMass();
    double force = GetPointToPointPlannedThrustN(direction);
    return Math.Min(Math.Max(0.1, pointToPointAccelerationLimit), force / mass);
}

void ApplyPointToPointAccel(Vector3D accel, bool emergency)
{
    if (emergency)
    {
        thrust.ApplyAccel(accel);
        return;
    }

    double maxForce = GetShipMass() * Math.Max(0.1, pointToPointAccelerationLimit);
    thrust.ApplyAccel(accel, maxForce);
}

