    OpenMinerMenu(MiLcdMenu.MineArea);
    miMenuIndex = 3;
}

void StartMineAreaCornerAdjustment(bool cornerA)
{
    ReleasePathRecordMineConfirmHold();
    if (!EnsureMineAreaAdjustmentPlanLoaded())
    {
        Echo("Adjust denied: no Excavation Zone is loaded.");
        return;
    }

    mineAreaAdjustCornerA = cornerA;
    mineAreaAdjustFromPath = pathMode && activeMineAreaRecordIndex >= 0;
    mineAreaAdjustSaveToCarrier = mineAreaAdjustFromPath && !pathRecordMineConfirmPending;
    mineAreaAdjustmentDirty = false;
    if (pathMode)
    {
        pathPaused = true;
        pathPausedNavResume = false;
    }
    if (miningEnabled || areaMiningMode)
    {
        mineAreaAdjustPendingAfterBackout = true;
        mineAreaAdjustPendingCornerA = cornerA;
        SetDrills(false);
        retryCurrentLane = false;
        stuckBackout = false;
        finishAreaAfterBackout = false;
        miningEnabled = true;
        areaMiningMode = true;
        miningState = MiningState.Backout;
        targetPosition = laneAnchor;
        desiredForward = drillAxis.LengthSquared() > 0.001 ? drillAxis : areaPlanForward;
        desiredUp = areaPlanUp;
        hasTarget = true;
        autopilotEnabled = true;
        activeMaxSpeed = SPEEDB;
        OpenMinerMenu(MiLcdMenu.MineArea);
        miMenuIndex = 3;
        Echo("Adjust Corner " + (cornerA ? "A" : "B") + ": backing out first.");
        return;
    }

    BeginMineAreaCornerAdjustmentFlight(cornerA);
}

bool EnsureMineAreaAdjustmentPlanLoaded()
{
    if (areaPlanValid)
        return true;

    if (!pathRecordMineConfirmPending)
        return false;

    if ((pathRecordMineCornerB - pathRecordMineCornerA).LengthSquared() <= 0.01 ||
        pathRecordMineUp.LengthSquared() < 0.001 ||
        pathRecordMineForward.LengthSquared() < 0.001)
        return false;

    Vector3D up = Vector3D.Normalize(pathRecordMineUp);
    Vector3D forward = Vector3D.Normalize(pathRecordMineForward);
    Vector3D right = Vector3D.Cross(forward, up);
    if (right.LengthSquared() < 0.001)
        return false;
    right = Vector3D.Normalize(right);

    CanonicalizeMineAreaCorners(ref pathRecordMineCornerA, ref pathRecordMineCornerB, forward, up);

    if (!ConfigureAreaLanePlan(pathRecordMineCornerA, pathRecordMineCornerB, up, right, MINEH, MINEW))
        return false;

    areaPlanValid = true;
    areaPlanCornerA = pathRecordMineCornerA;
    areaPlanCornerB = pathRecordMineCornerB;
    areaPlanUp = up;
    areaPlanForward = forward;
    areaPlanRight = right;
    areaMineEntryPos = GetInferredMineAreaEntryPose(areaPlanCornerA, areaPlanCornerB);
    areaMineEntryForward = forward;
    areaMineEntryUp = up;
    laneDepth = Math.Max(0.1, pathRecordMineDepth);
    pathRecordMineDepth = laneDepth;
    drillAxis = forward;
    return true;
}

void BeginMineAreaCornerAdjustmentFlight(bool cornerA)
{
    mineAreaAdjustCornerA = cornerA;
    mineAreaAdjustStage = MineAreaAdjustStage.ToMinePose;
    SetDrills(false);
    miningEnabled = false;
    miningState = MiningState.Idle;
    areaMiningMode = false;
    finishAreaAfterBackout = false;
    targetPosition = areaMineEntryPos;
    desiredUp = areaPlanUp;
    desiredForward = areaPlanForward;
    hasTarget = true;
    autopilotEnabled = true;
    activeMaxSpeed = SPEEDB;
    OpenMinerMenu(MiLcdMenu.SetAdjustCorner);
    miMenuIndex = 1;
    Echo("Adjust Corner " + (cornerA ? "A" : "B") + ": returning to mine pose.");
}

void CancelMineAreaAdjustment()
{
    mineAreaAdjustStage = MineAreaAdjustStage.None;
    mineAreaAdjustPendingAfterBackout = false;
    SetCockpitGyroControl(true);
}

bool UpdateMineAreaAdjustState()
{
    if (mineAreaAdjustStage == MineAreaAdjustStage.None)
        return false;

    SetCockpitGyroControl(false);
    HoldPathRecordMineOrientation(_tickRcMatrix, areaPlanForward, areaPlanUp);

    if (mineAreaAdjustStage == MineAreaAdjustStage.ToMinePose)
    {
        if (IsAtTargetPosition(areaMineEntryPos))
        {
            targetPosition = mineAreaAdjustCornerA ? areaPlanCornerA : areaPlanCornerB;
            desiredUp = areaPlanUp;
            desiredForward = areaPlanForward;
            hasTarget = true;
            autopilotEnabled = true;
            activeMaxSpeed = SPEEDB;
            mineAreaAdjustStage = MineAreaAdjustStage.ToCorner;
            Echo("Adjust Corner " + (mineAreaAdjustCornerA ? "A" : "B") + ": flying to corner.");
        }
        return false;
    }

    if (mineAreaAdjustStage == MineAreaAdjustStage.ToCorner)
    {
        Vector3D corner = mineAreaAdjustCornerA ? areaPlanCornerA : areaPlanCornerB;
        if (IsAtTargetPosition(corner))
        {
            autopilotEnabled = false;
            hasTarget = false;
            activeMaxSpeed = 0;
            mineAreaAdjustStage = MineAreaAdjustStage.Editing;
            Echo("Adjust Corner " + (mineAreaAdjustCornerA ? "A" : "B") + ": set new corner when ready.");
        }
        return false;
    }

    if (mineAreaAdjustStage == MineAreaAdjustStage.ReturnToMinePoseAfterSet)
    {
        if (IsAtTargetPosition(areaMineEntryPos))
        {
            autopilotEnabled = false;
            hasTarget = false;
            activeMaxSpeed = 0;
            mineAreaAdjustStage = MineAreaAdjustStage.None;
            SetCockpitGyroControl(true);
            OpenMinerMenu(MiLcdMenu.AdjustExcavationZone);
            miMenuIndex = 1;
            Echo("Excavation Zone adjusted. Confirm to rerun.");
        }
        return false;
    }

    return true;
}

void SetAdjustedMineAreaCorner()
{
    if (mineAreaAdjustStage != MineAreaAdjustStage.Editing || !areaPlanValid)
    {
        Echo("Corner adjustment is not ready.");
        return;
    }

    Vector3D controlPoint = GetTargetControlPointPosition();
    if (mineAreaAdjustCornerA)
        areaPlanCornerA = GetMineAreaFootprintCornerFromControlPoint(controlPoint, areaPlanCornerB, areaPlanForward, areaPlanUp);
    else
        areaPlanCornerB = GetMineAreaFootprintCornerFromControlPoint(controlPoint, areaPlanCornerA, areaPlanForward, areaPlanUp);

    CanonicalizeMineAreaCorners(ref areaPlanCornerA, ref areaPlanCornerB, areaPlanForward, areaPlanUp);
    areaMineEntryPos = GetInferredMineAreaEntryPose(areaPlanCornerA, areaPlanCornerB);
    Vector3D right = Vector3D.Cross(areaPlanForward, areaPlanUp);
    if (right.LengthSquared() > 0.001)
        right = Vector3D.Normalize(right);
    else
        right = areaPlanRight;
    ConfigureAreaLanePlan(areaPlanCornerA, areaPlanCornerB, areaPlanUp, right, MINEH, MINEW);
    areaPlanValid = true;
    areaPlanRight = right;
    mineAreaAdjustmentDirty = true;
    pathRecordMineDepth = Math.Max(0.1, pathRecordMineDepth);
    laneDepth = pathRecordMineDepth;
    mineAreaAdjustStage = MineAreaAdjustStage.ReturnToMinePoseAfterSet;
    RewriteCurrentMineAreaRecord(false);
    ClearAreaLaneSkipState();
    UpsertActiveMineAreaSkipMetaRecord();
    targetPosition = areaMineEntryPos;
    desiredUp = areaPlanUp;
    desiredForward = areaPlanForward;
    hasTarget = true;
    autopilotEnabled = true;
    activeMaxSpeed = SPEEDB;
    Echo("Corner " + (mineAreaAdjustCornerA ? "A" : "B") + " adjusted. Returning to mine pose.");
}

bool RewriteCurrentMineAreaRecord(bool saveToCarrier)
{
    if (!areaPlanValid)
        return false;

    Vector3D anchorPos, anchorForward, anchorUp;
    if (!TryGetOrInitPathTimerAnchor(out anchorPos, out anchorForward, out anchorUp))
        return false;

    string newLine = FormatMineAreaLine(areaPlanCornerA, areaPlanCornerB, anchorPos, areaPlanForward, areaPlanUp, pathRecordMineDepth);
    bool ok = false;
    if (pathRecordMineConfirmPending && !string.IsNullOrWhiteSpace(pathRecordPendingMineAreaLine))
    {
        ok = ReplacePathTimerLine(pathRecordPendingMineAreaLine, newLine);
        if (ok)
        {
            pathRecordPendingMineAreaLine = newLine;
            pathRecordMineEntry = GetInferredMineAreaEntryPose(areaPlanCornerA, areaPlanCornerB);
        }
    }
    else if (activeMineAreaRecordIndex >= 0)
    {
        ok = ReplacePathTimerRecord(activeMineAreaRecordIndex, newLine);
        if (ok && activeMineAreaRecordIndex < pathRecords.Count)
            pathRecords[activeMineAreaRecordIndex] = newLine;
        if (ok)
            activeMineAreaRecordLine = newLine;
    }

    if (ok && saveToCarrier)
    {
        suppressPathRuntimeWrite = true;
        SendCarrierCommand("UpdateAsteroid");
    }
    return ok;
}

bool ReplacePathTimerLine(string oldLine, string newLine)
{
    List<string> lines;
    string timerName;
    if (!TryReadPathTimerLines(out lines, out timerName))
        return false;
    for (int i = lines.Count - 1; i >= 0; i--)
    {
        if (!string.Equals(lines[i].Trim(), oldLine.Trim(), StringComparison.OrdinalIgnoreCase))
            continue;
        lines[i] = newLine;
        bool ok = RewritePathTimerLines(lines);
        if (ok)
            RecountPathTimerRecords(lines);
        return ok;
    }
    return false;
}

bool ReplacePathTimerRecord(int recordIndexToReplace, string newLine)
{
    List<string> lines;
    string timerName;
    if (!TryReadPathTimerLines(out lines, out timerName))
        return false;

    Vector3D ap, af, au;
    int anchorIndex;
    TryFindPathAnchor(lines, out anchorIndex, out ap, out af, out au);
    int recordIndex = -1;
    for (int i = 0; i < lines.Count; i++)
    {
        if (i == anchorIndex || LooksLikeRuntimeLine(lines[i]))
            continue;
        recordIndex++;
        if (recordIndex != recordIndexToReplace)
            continue;
        lines[i] = newLine;
        bool ok = RewritePathTimerLines(lines);
        if (ok)
            RecountPathTimerRecords(lines);
        return ok;
    }
    return false;
}

void StartRecallPath()
{
    if (recallActive)
    {
        Echo("Recall already active.");
        return;
    }

    if (!pathMode || pathRecords.Count == 0)
    {
        Echo("Recall ignored: no active path.");
        return;
    }

    recallActive = true;
    recallWaitingForAreaExit = false;
    recallWaitingForDock = false;
    recallIndex = 0;
    recallRecords.Clear();
    recallDisplayDone.Clear();
    recallLastDone = Math.Max(0, Math.Min(pathIndex, pathRecords.Count));
    recallLastTotal = pathRecords.Count;
    minerProgressBroadcastTicks = 0;
    pathPaused = false;
    pathPausedNavResume = false;
    pathCompleteBroadcastTicks = 0;
    saveAsteroidAfterDock = false;
    fullStateDirty = true;
    StopPathRunTimer();
    SendRecallProgress(recallLastDone, recallLastTotal);

    if (miningEnabled || areaMiningMode)
    {
        recallWaitingForAreaExit = true;
        NextHole(true);
        Echo("Recall: finishing current hole before path recall.");
        return;
    }

    BuildRecallRecords();
    if (recallReverseMode)
    {
        autopilotEnabled = false;
        hasTarget = false;
        activeMaxSpeed = 0;
    }
    Echo("Recall started.");
}

void UpdateRecallRunner()
{
    if (!recallActive)
        return;

    if (recallWaitingForAreaExit)
    {
        if (miningEnabled)
            return;
        if (autopilotEnabled && hasTarget)
        {
            if (IsAtTargetPose(targetPosition, desiredForward, desiredUp))
            {
                autopilotEnabled = false;
                hasTarget = false;
                activeMaxSpeed = 0;
                SendRecallProgress(Math.Max(0, Math.Min(pathIndex, pathRecords.Count)), pathRecords.Count);
            }
            return;
        }

        recallWaitingForAreaExit = false;
        BuildRecallRecords();
        if (recallReverseMode)
        {
            autopilotEnabled = false;
            hasTarget = false;
            activeMaxSpeed = 0;
        }
    }

    if (recallWaitingForDock)
    {
        if (dockingState != DockingState.None || dockRetryPending)
            return;
        if (IsMinerDocked() || IsMergerDocked())
        {
            CompleteRecallPath();
            return;
        }
        StartDock();
        return;
    }

    if (autopilotEnabled && hasTarget)
    {
        if (IsAtTargetPose(targetPosition, desiredForward, desiredUp))
        {
            autopilotEnabled = false;
            hasTarget = false;
            activeMaxSpeed = 0;
            if (!recallReverseMode)
                recallLastDone = Math.Max(0, Math.Min(pathIndex, pathRecords.Count));
            SendRecallProgress(recallLastDone, recallLastTotal);
        }
        return;
    }

    if (dockingState != DockingState.None || dockRetryPending)
        return;

    StartNextRecallTarget();
}

void BuildRecallRecords()
{
    recallRecords.Clear();
    recallDisplayDone.Clear();
    recallIndex = 0;
    recallLastTotal = pathRecords.Count;
    int current = Math.Max(0, Math.Min(pathIndex, pathRecords.Count));
    recallReverseMode = autoServicePreviewRecall || (pathRecords.Count > 0 && current * 3 < pathRecords.Count);

    if (recallReverseMode)
    {
        for (int i = current - 1; i >= 0; i--)
            AddRecallRecordIfRunnable(pathRecords[i], i);
        if (pathAnchorValid)
            AddRecallRecord(FormatPathPointLine(pathAnchorPos, pathAnchorPos, pathAnchorForward, pathAnchorUp), 0);
        AddRecallRecord("dock", 0);
        return;
    }

    for (int i = current; i < pathRecords.Count; i++)
        AddRecallRecordIfRunnable(pathRecords[i], Math.Min(i + 1, pathRecords.Count));
}

void AddRecallRecordIfRunnable(string rawRecord, int displayDone)
{
    string record = NormalizePathRecord(rawRecord);
    if (string.IsNullOrWhiteSpace(record))
        return;
    if (IsPathMetadataRecord(record))
        return;
    if (LineLooksLikeMineArea(record) && pathAnchorValid)
    {
        Vector3D cornerA, cornerB, areaUp, areaForward;
        double depth;
        if (TryParseMineAreaLine(record, pathAnchorPos, out cornerA, out cornerB, out areaUp, out areaForward, out depth))
            AddRecallRecord(FormatPathPointLine(GetInferredMineAreaEntryPose(cornerA, cornerB), pathAnchorPos, areaForward, areaUp), displayDone);
        return;
    }
    if (record.Equals("undock", StringComparison.OrdinalIgnoreCase) ||
        record.StartsWith("minearea;", StringComparison.OrdinalIgnoreCase))
        return;
    AddRecallRecord(record, displayDone);
}

void AddRecallRecord(string record, int displayDone)
{
    recallRecords.Add(record);
    recallDisplayDone.Add(Math.Max(0, Math.Min(displayDone, recallLastTotal)));
}

void StartNextRecallTarget()
{
    while (recallIndex < recallRecords.Count)
    {
        string record = recallRecords[recallIndex];
        int displayDone = recallIndex < recallDisplayDone.Count ? recallDisplayDone[recallIndex] : recallLastDone;
        recallIndex++;
        recallLastDone = displayDone;
        if (ExecuteRecallRecord(record))
            return;
    }

    CompleteRecallPath();
}

bool ExecuteRecallRecord(string rawRecord)
{
    string record = NormalizePathRecord(rawRecord);
    if (string.IsNullOrWhiteSpace(record))
        return false;

    if (record.Equals("dock", StringComparison.OrdinalIgnoreCase))
    {
        SendRecallProgress(recallLastDone, recallLastTotal);
        if (IsMinerDocked() || IsMergerDocked())
        {
            CompleteRecallPath();
            return true;
        }
        StartDock();
        recallWaitingForDock = true;
        return true;
    }

    Vector3D pos, fwd, up;
    string navCmd = null;
    if (record.StartsWith("Nav;", StringComparison.OrdinalIgnoreCase))
        navCmd = record.Substring(4).Trim();
    else if (record.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
        navCmd = record;

    if (navCmd != null)
    {
        if (!TryParseGpsCommand(navCmd, out pos, out fwd, out up))
            return false;
        targetPosition = pos;
        desiredForward = fwd;
        desiredUp = up;
        hasTarget = true;
        autopilotEnabled = true;
        activeMaxSpeed = recallReverseMode ? SPEEDB : 0;
        return true;
    }

    if (pathAnchorValid && TryParsePathPointLine(record, pathAnchorPos, out pos, out fwd, out up))
    {
        targetPosition = pos;
        desiredForward = fwd;
        desiredUp = up;
        hasTarget = true;
        autopilotEnabled = true;
        activeMaxSpeed = recallReverseMode ? SPEEDB : 0;
        return true;
    }

    return false;
}

string NormalizePathRecord(string rawRecord)
{
    if (string.IsNullOrWhiteSpace(rawRecord))
        return "";
    string record = rawRecord.Trim();
    if (record.StartsWith("\"") && record.EndsWith("\"") && record.Length >= 2)
        record = record.Substring(1, record.Length - 2).Trim();
    return record;
}

void CompleteRecallPath()
{
    if (autoServiceState == AutoServiceState.Returning)
    {
        CompleteAutoServiceRecall();
        return;
    }

    SendRecallProgress(recallLastTotal, recallLastTotal);
    StopPathRunTimer();
    pathMode = false;
    pathPaused = false;
    pathPausedNavResume = false;
    pathRecords.Clear();
    pathIndex = 0;
    pathCompleteBroadcastTicks = 0;
    saveAsteroidAfterDock = false;
    recallActive = false;
    recallWaitingForAreaExit = false;
    recallWaitingForDock = false;
    recallRecords.Clear();
    recallDisplayDone.Clear();
    recallIndex = 0;
    IGC.SendBroadcastMessage(minerPathCompleteTag, "Recall complete.");
    Echo("Recall complete.");
}

void ClearRecallState()
{
    recallActive = false;
    recallWaitingForAreaExit = false;
    recallWaitingForDock = false;
    recallReverseMode = false;
    recallRecords.Clear();
    recallDisplayDone.Clear();
    recallIndex = 0;
    recallLastDone = 0;
    recallLastTotal = 0;
}

void SendRecallProgress(int done, int total)
{
    done = Math.Max(0, done);
    total = Math.Max(0, total);
    if (total > 0)
        done = Math.Min(done, total);
    IGC.SendBroadcastMessage(minerProgressTag, "progress:" + done + "/" + total);
}

void UpdateAutoServiceReturn()
{
    if (autoServiceState != AutoServiceState.None)
    {
        UpdateAutoServiceState();
        return;
    }

    if (!ShouldCheckAutoServiceReturn())
        return;

    if (autoServiceCheckTicks > 0)
    {
        autoServiceCheckTicks = Math.Max(0, autoServiceCheckTicks - UpdateTickDelta());
        return;
    }
    autoServiceCheckTicks = Math.Max(1, autoServiceCheckIntervalTicks);

    double cargoPercent = GetMinerCargoFillPercent();
    if (cargoPercent >= autoServiceCargoTriggerPercent)
    {
        StartAutoServiceReturn("cargo " + cargoPercent.ToString("0.0") + "%");
        return;
    }

    if (HasMinerHydrogenTank())
    {
        double hydrogenPercent = GetMinerHydrogenPercent();
        if (hydrogenPercent <= autoServiceHydrogenTriggerPercent)
            StartAutoServiceReturn("hydrogen " + hydrogenPercent.ToString("0.0") + "%");
    }
}

bool ShouldCheckAutoServiceReturn()
{
    if (!autoServiceReturnEnabled ||
        recallActive ||
        dockingState != DockingState.None ||
        dockRetryPending ||
        pathDockPending ||
        appendPathActive ||
        autoServicePreviewReturnActive ||
        IsMinerDocked() ||
        IsMergerDocked() ||
        oreTransferStartDelayTicks > 0 ||
        oreTransferActive)
        return false;

    if (pathMode &&
        pathRecords.Count > 0 &&
        !pathPaused &&
        !pathRecordingEnabled)
        return true;

    return CanAutoServicePreviewMineArea();
}

void StartAutoServiceReturn(string reason)
{
    if (!ShouldCheckAutoServiceReturn())
        return;

    bool previewMineArea = CanAutoServicePreviewMineArea();
    if (previewMineArea && !PreparePreviewMineAreaAutoServiceReturn())
        return;

    autoServiceState = AutoServiceState.Returning;
    autoServiceReason = reason;
    autoServiceResumePathTimer = pathRunTimerActive;
    autoServiceResumeMineArea =
        areaMiningMode &&
        activeMineAreaRecordIndex >= 0 &&
        activeMineAreaRecordIndex < pathRecords.Count;
    autoServiceResumeMineAreaRecordIndex = autoServiceResumeMineArea ? activeMineAreaRecordIndex : -1;
    autoServiceResumeAreaLaneIndex = autoServiceResumeMineArea ? Math.Max(0, areaLaneIndex) : 0;
    autoServiceResumeMineEntryPos = autoServiceResumeMineArea ? areaMineEntryPos : Vector3D.Zero;
    autoServiceResumeMineEntryForward = autoServiceResumeMineArea ? areaMineEntryForward : Vector3D.Zero;
    autoServiceResumeMineEntryUp = autoServiceResumeMineArea ? areaMineEntryUp : Vector3D.Zero;
    autoServiceResumePathRecordingPreview = previewMineArea;
    autoServicePreviewRecall = previewMineArea;
    autoServicePreviewReturnActive = false;
    autoServiceActionRetryTicks = 0;
    saveAsteroidAfterDock = false;
    updateAsteroidAfterDock = false;
    fullStateDirty = true;

    StartRecallPath();
    if (!recallActive)
    {
        ClearAutoServiceState();
        return;
    }

    Echo("Auto service: returning for " + autoServiceReason + ".");
}

bool CanAutoServicePreviewMineArea()
{
    return pathRecordingEnabled &&
           pathRecordingPaused &&
           pathRecordMinePreviewActive &&
           resumePathRecordingAfterMineArea &&
           !pathRecordMineConfirmPending &&
           areaMiningMode &&
           activeMineAreaRecordIndex >= 0 &&
           (miningEnabled || autopilotEnabled || hasTarget);
}

bool PreparePreviewMineAreaAutoServiceReturn()
{
    List<string> loaded;
    string timerName;
    if (!TryLoadPathRecordsFromTimer(out loaded, out timerName))
    {
        Echo($"Auto service denied: unable to load path records from timer tag '{pathTimerTag}'.");
        return false;
    }
    if (activeMineAreaRecordIndex < 0 || activeMineAreaRecordIndex >= loaded.Count)
    {
        Echo("Auto service denied: active preview Excavation Zone is not in the path timer.");
        return false;
    }

    pathRecords = loaded;
    pathIndex = Math.Max(0, Math.Min(activeMineAreaRecordIndex, pathRecords.Count));
    pathMode = true;
    pathPaused = false;
    pathPausedNavResume = false;
    pathDockPending = false;
    pathCompleteBroadcastTicks = 0;
    appendPathActive = false;
    appendPathStopRecordIndex = -1;

    resumePathRecordingAfterMineArea = false;
    pathRecordMinePreviewActive = false;
    pathRecordingWaitReturn = false;
    pathRecordMineStage = PathRecordMineStage.Idle;
    return true;
}

void UpdateAutoServiceState()
{
    if (autoServiceState == AutoServiceState.Returning)
    {
        if (recallActive)
            return;
        if (IsMinerDocked() || IsMergerDocked())
        {
            CompleteAutoServiceRecall();
            return;
        }
        ClearAutoServiceState();
        return;
    }

    if (autoServiceState == AutoServiceState.WaitingService)
    {
        if (!IsMinerDocked() && !IsMergerDocked())
        {
            RetryAutoServiceDock();
            return;
        }

        if (oreTransferStartDelayTicks > 0 || oreTransferActive)
            return;

        double cargoPercent = GetMinerCargoFillPercent();
        double hydrogenPercent = HasMinerHydrogenTank() ? GetMinerHydrogenPercent() : 100.0;
        if (cargoPercent > autoServiceCargoResumePercent ||
            hydrogenPercent < autoServiceHydrogenResumePercent)
            return;

        RetryAutoServiceUndock();
        return;
    }

    if (autoServiceState == AutoServiceState.Undocking)
    {
        if (dockingState != DockingState.None)
            return;
        if (IsMinerDocked() || IsMergerDocked())
        {
            RetryAutoServiceUndock();
            return;
        }

        autoServiceState = AutoServiceState.None;
        autoServiceReason = "";
        autoServiceActionRetryTicks = 0;
        pathPaused = false;
        pathPausedNavResume = false;
        bool resumePreviewMineArea = autoServiceResumePathRecordingPreview;
        if (autoServiceResumePathTimer && pathRunTimerStarted)
            pathRunTimerActive = true;
        if (resumePreviewMineArea)
        {
            StartPreviewMineAreaPathReturn();
            return;
        }
        if (autoServiceResumeMineArea && ResumeAutoServiceMineArea())
        {
            ClearAutoServiceResumeTarget();
            autoServiceResumePathTimer = false;
            fullStateDirty = true;
            Echo("Auto service: resumed excavation zone.");
            return;
        }
        ClearAutoServiceResumeTarget();
        autoServiceResumePathTimer = false;
        fullStateDirty = true;
        Echo("Auto service: resumed path.");
    }
}

void StartPreviewMineAreaPathReturn()
{
    if (pathRecords.Count == 0)
    {
        List<string> loaded;
        string timerName;
        if (TryLoadPathRecordsFromTimer(out loaded, out timerName))
            pathRecords = loaded;
    }

    if (autoServiceResumeMineAreaRecordIndex < 0 ||
        autoServiceResumeMineAreaRecordIndex >= pathRecords.Count)
    {
        FailPreviewAutoServiceReturn("Auto service: preview Excavation Zone return failed; saved minearea record is missing.");
        return;
    }

    autoServiceState = AutoServiceState.None;
    autoServiceReason = "";
    autoServiceActionRetryTicks = 0;
    autoServicePreviewReturnActive = true;
    autoServicePreviewRecall = false;
    pathMode = true;
    pathPaused = false;
    pathPausedNavResume = false;
    pathDockPending = false;
    pathCompleteBroadcastTicks = 0;
    pathRecordingEnabled = false;
    pathRecordingPaused = false;
    pathRecordingWaitReturn = false;
    pathRecordMinePreviewActive = false;
    resumePathRecordingAfterMineArea = false;
    pathRecordMineStage = PathRecordMineStage.Idle;

    int startIndex = 0;
    while (startIndex < pathRecords.Count)
    {
        string record = NormalizePathRecord(pathRecords[startIndex]);
        if (IsPathMetadataRecord(record) ||
            record.Equals("dock", StringComparison.OrdinalIgnoreCase) ||
            record.Equals("undock", StringComparison.OrdinalIgnoreCase))
        {
            startIndex++;
            continue;
        }
        break;
    }
    pathIndex = Math.Max(0, Math.Min(startIndex, autoServiceResumeMineAreaRecordIndex));
    ResetPathRunTimer();
    fullStateDirty = true;
    Echo("Auto service: returning to preview Excavation Zone.");
    StartNextPathRecord();
}

void RestorePreviewMineAreaRecordingState()
{
    pathRecordingEnabled = true;
    pathRecordingPaused = true;
    pathRecordingWaitReturn = false;
    pathRecordMineStage = PathRecordMineStage.Idle;
    pathRecordMineConfirmPending = false;
    pathRecordMineConfirmHoldActive = false;
    resumePathRecordingAfterMineArea = true;
    pathRecordMinePreviewActive = true;
}

bool CompletePreviewAutoServiceReturnToMineArea()
{
    RestorePreviewMineAreaRecordingState();
    if (autoServiceResumeMineArea && ResumeAutoServiceMineArea())
    {
        ClearTemporaryPreviewPathMode();
        ClearAutoServiceResumeTarget();
        autoServiceResumePathTimer = false;
        fullStateDirty = true;
        Echo("Auto service: resumed preview Excavation Zone.");
        return miningEnabled || autopilotEnabled;
    }

    FailPreviewAutoServiceReturn("Auto service: preview Excavation Zone resume failed.");
    return false;
}

void FailPreviewAutoServiceReturn(string message)
{
    RestorePreviewMineAreaRecordingState();
    ClearTemporaryPreviewPathMode();
    ClearAutoServiceResumeTarget();
    autoServiceResumePathTimer = false;
    autoServiceState = AutoServiceState.None;
    autoServiceReason = "";
    autoServiceActionRetryTicks = 0;
    fullStateDirty = true;
    Echo(message);
}

void ClearTemporaryPreviewPathMode()
{
    if (!autoServiceResumePathRecordingPreview)
        return;

    autoServicePreviewReturnActive = false;
    pathMode = false;
    pathPaused = false;
    pathPausedNavResume = false;
    pathDockPending = false;
    pathRecords.Clear();
    pathIndex = 0;
    StopPathRunTimer();
    pathCompleteBroadcastTicks = 0;
}

void RetryAutoServiceDock()
{
    if (dockingState != DockingState.None || dockRetryPending)
        return;
    if (autoServiceActionRetryTicks > 0)
    {
        autoServiceActionRetryTicks = Math.Max(0, autoServiceActionRetryTicks - UpdateTickDelta());
        return;
    }
    autoServiceActionRetryTicks = autoServiceActionRetryIntervalTicks;
    StartDock();
}

void RetryAutoServiceUndock()
{
    if (dockingState != DockingState.None)
        return;
    if (autoServiceActionRetryTicks > 0)
    {
        autoServiceActionRetryTicks = Math.Max(0, autoServiceActionRetryTicks - UpdateTickDelta());
        return;
    }
    autoServiceActionRetryTicks = autoServiceActionRetryIntervalTicks;
    StartUndock();
    if (dockingState != DockingState.None)
    {
        autoServiceState = AutoServiceState.Undocking;
        fullStateDirty = true;
        Echo("Auto service: service complete, undocking.");
    }
}

void CompleteAutoServiceRecall()
{
    SendRecallProgress(recallLastTotal, recallLastTotal);
    StopPathRunTimer();
    pathPaused = true;
    pathPausedNavResume = false;
    pathCompleteBroadcastTicks = 0;
    saveAsteroidAfterDock = false;
    updateAsteroidAfterDock = false;
    recallActive = false;
    recallWaitingForAreaExit = false;
    recallWaitingForDock = false;
    recallRecords.Clear();
    recallDisplayDone.Clear();
    recallIndex = 0;
    autoServiceState = AutoServiceState.WaitingService;
    autoServiceActionRetryTicks = 0;
    fullStateDirty = true;
    if (oreTransferStartDelayTicks <= 0 && !oreTransferActive)
        ScheduleOreTransfer();
    Echo("Auto service: docked, unloading and refueling.");
}

bool ResumeAutoServiceMineArea()
{
    if (!autoServiceResumeMineArea ||
        autoServiceResumeMineAreaRecordIndex < 0 ||
        autoServiceResumeMineAreaRecordIndex >= pathRecords.Count)
        return false;

    string record = NormalizePathRecord(pathRecords[autoServiceResumeMineAreaRecordIndex]);
    if (string.IsNullOrWhiteSpace(record))
        return false;

    activeMineAreaRecordIndex = autoServiceResumeMineAreaRecordIndex;
    activeMineAreaRecordLine = record;
    int startLane = Math.Max(0, autoServiceResumeAreaLaneIndex);

    if (record.StartsWith("minearea;", StringComparison.OrdinalIgnoreCase))
    {
        if (!TryStartAreaMiningCommandFromLane(record, startLane))
            return false;
        RestoreAutoServiceMineEntry();
        return miningEnabled || autopilotEnabled;
    }

    if (!pathAnchorValid || !LineLooksLikeMineArea(record))
        return false;

    Vector3D cornerA, cornerB, areaUp, areaForward;
    double depth;
    if (!TryParseMineAreaLine(record, pathAnchorPos,
                              out cornerA, out cornerB, out areaUp, out areaForward, out depth))
        return false;

    StartAreaMiningWithCornersFromLane(cornerA, cornerB, areaUp, areaForward, depth, startLane);
    RestoreAutoServiceMineEntry();
    return miningEnabled || autopilotEnabled;
}

void RestoreAutoServiceMineEntry()
{
    if (autoServiceResumeMineEntryForward.LengthSquared() <= 0.001 ||
        autoServiceResumeMineEntryUp.LengthSquared() <= 0.001)
        return;

    areaMineEntryPos = autoServiceResumeMineEntryPos;
    areaMineEntryForward = autoServiceResumeMineEntryForward;
    areaMineEntryUp = autoServiceResumeMineEntryUp;
}

void ClearAutoServiceState()
{
    autoServiceState = AutoServiceState.None;
    autoServiceReason = "";
    autoServiceResumePathTimer = false;
    autoServiceResumePathRecordingPreview = false;
    autoServicePreviewRecall = false;
    autoServicePreviewReturnActive = false;
    autoServiceActionRetryTicks = 0;
    ClearAutoServiceResumeTarget();
}

void ClearAutoServiceResumeTarget()
{
    autoServiceResumeMineArea = false;
    autoServiceResumePathRecordingPreview = false;
    autoServicePreviewRecall = false;
    autoServicePreviewReturnActive = false;
    autoServiceResumeMineAreaRecordIndex = -1;
    autoServiceResumeAreaLaneIndex = 0;
    autoServiceResumeMineEntryPos = Vector3D.Zero;
    autoServiceResumeMineEntryForward = Vector3D.Zero;
    autoServiceResumeMineEntryUp = Vector3D.Zero;
}

void UpdateDockPoseFromBroadcast()
{
    if (dockListener == null)
        return;

    while (dockListener.HasPendingMessage)
    {
        MyIGCMessage msg = dockListener.AcceptMessage();
        string payload = msg.Data as string;
        Vector3D pos, forward, up;
        if (!TryParseDockPosePayload(payload, out pos, out forward, out up))
            continue;
        carrierConnectorPos = pos;
        carrierConnectorForward = Vector3D.Normalize(forward);
        carrierConnectorUp = Vector3D.Normalize(up);
        carrierPoseAgeSeconds = 0;
    }
}

void UpdateDockPoseAge()
{
    carrierPoseAgeSeconds += secondsPerTick;
}

bool TryParseDockPosePayload(string payload, out Vector3D pos, out Vector3D forward, out Vector3D up)
{
    pos = Vector3D.Zero;
    forward = Vector3D.Zero;
    up = Vector3D.Zero;
    if (string.IsNullOrWhiteSpace(payload))
        return false;

    string[] parts = payload.Split('|');
    if (parts.Length != 3)
        return false;
    return TryParseVector3(parts[0], out pos) && TryParseVector3(parts[1], out forward) && TryParseVector3(parts[2], out up);
}

bool HasFreshCarrierPose()
{
    return carrierConnectorForward.LengthSquared() > 0.001 &&
           carrierConnectorUp.LengthSquared() > 0.001 &&
           carrierPoseAgeSeconds <= dockPoseFreshSeconds;
}

Vector3D GetDockPosePosition()
{
    return GetCarrierConnectorPosition() + carrierConnectorForward * dockPoseDistance;
}

Vector3D GetCarrierConnectorPosition()
{
    return carrierConnectorPos - carrierConnectorForward * carrierPoseForwardOffset;
}

void UpdateConnectorOffsetLocal()
{
    if (rc == null || minerConnector == null)
        return;
    Vector3D delta = minerConnector.GetPosition() - rc.GetPosition();
    MatrixD wm = rc.WorldMatrix;
    connectorOffsetLocal = new Vector3D(Vector3D.Dot(delta, wm.Right), Vector3D.Dot(delta, wm.Up), Vector3D.Dot(delta, wm.Forward));
}

void SetDockingDesiredRcAxes()
{
    Vector3D targetConnectorForward = -carrierConnectorForward;
    Vector3D targetConnectorUp = carrierConnectorUp;
    Vector3D rcForward, rcUp;
    if (TryGetRcAxesForConnectorAlignment(targetConnectorForward, targetConnectorUp, out rcForward, out rcUp))
    {
        desiredForward = rcForward;
        desiredUp = rcUp;
    }
    else
    {
        // Fallback if connector transform cannot be solved.
        desiredForward = targetConnectorForward;
        desiredUp = targetConnectorUp;
    }
}

bool TryGetRcAxesForConnectorAlignment(Vector3D targetConnectorForward, Vector3D targetConnectorUp, out Vector3D rcForward, out Vector3D rcUp)
{
    rcForward = Vector3D.Zero;
    rcUp = Vector3D.Zero;
    if (rc == null || minerConnector == null)
        return false;

    Vector3D cF = Vector3D.Normalize(minerConnector.WorldMatrix.Forward);
    Vector3D cU = Vector3D.Normalize(minerConnector.WorldMatrix.Up);
    Vector3D cR = Vector3D.Cross(cF, cU);
    if (cR.LengthSquared() < 0.001)
        return false;
    cR = Vector3D.Normalize(cR);

    Vector3D tF = Vector3D.Normalize(targetConnectorForward);
    Vector3D tU = Vector3D.Normalize(targetConnectorUp);
    Vector3D tR = Vector3D.Cross(tF, tU);
    if (tR.LengthSquared() < 0.001)
        return false;
    tR = Vector3D.Normalize(tR);

    // Transform RC axes from current connector frame into target connector frame.
    rcForward = RemapVectorBetweenFrames(rc.WorldMatrix.Forward, cR, cU, cF, tR, tU, tF);
    rcUp = RemapVectorBetweenFrames(rc.WorldMatrix.Up, cR, cU, cF, tR, tU, tF);
    if (rcForward.LengthSquared() < 0.001 || rcUp.LengthSquared() < 0.001)
        return false;
    rcForward = Vector3D.Normalize(rcForward);
    rcUp = Vector3D.Normalize(rcUp);
    return true;
}

Vector3D RemapVectorBetweenFrames(Vector3D vectorWorld, Vector3D fromRight, Vector3D fromUp, Vector3D fromForward, Vector3D toRight, Vector3D toUp, Vector3D toForward)
{
    double r = Vector3D.Dot(vectorWorld, fromRight);
    double u = Vector3D.Dot(vectorWorld, fromUp);
    double f = Vector3D.Dot(vectorWorld, fromForward);
    return toRight * r + toUp * u + toForward * f;
}

bool IsConnectorAlignmentReady(double toleranceDeg)
{
    if (minerConnector == null)
        return false;
    double minDot = Math.Cos(Math.Max(0.1, toleranceDeg) * Math.PI / 180.0);
    Vector3D minerForward = Vector3D.Normalize(minerConnector.WorldMatrix.Forward);
    Vector3D minerUp = Vector3D.Normalize(minerConnector.WorldMatrix.Up);
    return Vector3D.Dot(minerForward, -carrierConnectorForward) >= minDot &&
           Vector3D.Dot(minerUp, carrierConnectorUp) >= minDot;
}

bool IsConnectorCloseEnoughToConnect()
{
    if (minerConnector == null)
        return false;
    return Vector3D.DistanceSquared(minerConnector.GetPosition(), GetCarrierConnectorPosition()) <= dockConnectDistance * dockConnectDistance;
}

bool IsMergerDocked()
{
    return minerMerger != null && minerMerger.IsConnected;
}

void SetMergerEnabled(bool enabled)
{
    if (minerMerger != null)
        minerMerger.Enabled = enabled;
}

void SetConnectorEnabled(bool enabled)
{
    if (minerConnector != null)
        minerConnector.Enabled = enabled;
}

void ForceMinerConnectorUnlatchedUntilMerge()
{
    RefreshDockHardware();
    if (minerConnector != null && minerConnector.Status == MyShipConnectorStatus.Connected && !IsMergerDocked())
        minerConnector.Disconnect();
    SetConnectorEnabled(false);
    SetMergerEnabled(true);
}

bool RefreshDockHardware()
{
    minerConnector = GetBlock<IMyShipConnector>(minerConnectorName, true);
    minerMerger = GetBlock<IMyShipMergeBlock>(minerMergerName, true);
    return minerConnector != null;
}

void RecompileFlightSystems()
{
    rcCanControlGyros = rc != null && rc.GetProperty("ControlGyros") != null;
    allGyros = GetBlocks<IMyGyro>().FindAll(b => HasMinerTag(b));
    allThrusters = GetBlocks<IMyThrust>().FindAll(b => HasMinerTag(b));
    InvalidateEffectiveThrustCache();
    thrust = new ThrusterControl(rc, tickSpeed, allThrusters);
    gyros = new GyroControl(rc, tickSpeed, allGyros);
}

void StartUndock()
{
    RefreshDockHardware();
    if (!HasFreshCarrierPose())
    {
        Echo("Undock denied: no fresh carrier connector pose broadcast.");
        return;
    }
    if (minerConnector == null)
    {
        Echo($"Undock denied: miner connector '{minerConnectorName}' not found.");
        return;
    }

    UpdateConnectorOffsetLocal();
    minerConnector.Disconnect();
    SetMergerEnabled(false);
    SetConnectorEnabled(false);
    undockRecompileTicksRemaining = undockRecompileTicks;
    dockMergeReadyTicks = 0;
    dockConnectRetryTicks = 0;
    dockConnectRecompileTicksRemaining = 0;
    dockConnectRecompileArmed = false;
    dockingState = DockingState.UndockingRecompile;
    miningEnabled = false;
    Echo("Undock started.");
}

void StartDock()
{
    RefreshDockHardware();
    if (!HasFreshCarrierPose())
    {
        Echo("Dock denied: no fresh carrier connector pose broadcast.");
        ArmDockRetry();
        return;
    }
    if (minerConnector == null)
    {
        Echo($"Dock denied: miner connector '{minerConnectorName}' not found.");
        ClearDockRetry();
        return;
    }
    if (minerMerger == null)
    {
        Echo($"Dock denied: miner merge block '{minerMergerName}' not found.");
        ClearDockRetry();
        return;
    }

    UpdateConnectorOffsetLocal();
    SetMergerEnabled(true);
    Vector3D dockPose = GetDockPosePosition();
    double distToPose = Vector3D.Distance(minerConnector.GetPosition(), dockPose);
    if (distToPose > dockPoseGateDistance)
    {
        Echo($"Dock waiting: {distToPose:0.0}m from dock pose (max {dockPoseGateDistance:0.0}m).");
        ArmDockRetry();
        return;
    }
    ForceMinerConnectorUnlatchedUntilMerge();

    SetDockingDesiredRcAxes();
    targetPosition = dockPose;
    hasTarget = true;
    autopilotEnabled = true;
    activeMaxSpeed = dockApproachSpeed;
    dockingState = DockingState.DockingToPose;
    dockMergeReadyTicks = 0;
    dockConnectRetryTicks = 0;
    dockConnectRecompileTicksRemaining = 0;
    dockConnectRecompileArmed = false;
    ClearDockRetry();
    miningEnabled = false;
    Echo("Dock started (phase 1: dock pose).");
}

void ArmDockRetry()
{
    dockRetryPending = true;
    if (dockRetryTicks <= 0)
        dockRetryTicks = dockRetryIntervalTicks;
}

void ClearDockRetry()
{
    dockRetryPending = false;
    dockRetryTicks = 0;
}

void UpdateDockRetry()
{
    if (!dockRetryPending || dockingState != DockingState.None)
        return;

    if (dockRetryTicks > 0)
    {
        dockRetryTicks = Math.Max(0, dockRetryTicks - UpdateTickDelta());
        return;
    }

    dockRetryTicks = dockRetryIntervalTicks;
    if (!HasFreshCarrierPose())
        return;

    Echo("Dock retry: carrier pose restored.");
    StartDock();
}

void UpdateDockingState()
{
    if (!HasFreshCarrierPose())
    {
        if (dockingPausedEchoTicks <= 0)
        {
            Echo("Docking paused: awaiting fresh carrier pose.");
            dockingPausedEchoTicks = dockingPausedEchoIntervalTicks;
        }
        else
            dockingPausedEchoTicks--;
        autopilotEnabled = false;
        return;
    }
    dockingPausedEchoTicks = 0;

    SetDockingDesiredRcAxes();
    if (dockingState == DockingState.UndockingRecompile)
    {
        autopilotEnabled = false;
        hasTarget = false;
        activeMaxSpeed = 0;
        if (undockRecompileTicksRemaining > 0)
        {
            undockRecompileTicksRemaining--;
            return;
        }

        RecompileFlightSystems();
        ApplyUndockedPowerState();
        targetPosition = GetDockPosePosition();
        hasTarget = true;
        autopilotEnabled = true;
        activeMaxSpeed = dockApproachSpeed;
        dockingState = DockingState.UndockingToPose;
        Echo("Undock recompile complete. Moving to dock pose.");
        return;
    }

    if (dockingState == DockingState.UndockingToPose)
    {
        if (!IsOrientationAligned(desiredForward, desiredUp, orientationToleranceDeg))
        {
            targetPosition = minerConnector.GetPosition();
            activeMaxSpeed = 0;
            autopilotEnabled = true;
            return;
        }
        targetPosition = GetDockPosePosition();
        activeMaxSpeed = dockApproachSpeed;
        autopilotEnabled = true;
        if (IsAtDockPose())
        {
            SetMergerEnabled(true);
            CompleteDocking("Undock complete (at dock pose).");
            if (pathRecordingStartPendingAfterUndock)
                BeginPathRecording();
        }
        return;
    }

    if (dockingState == DockingState.DockingToPose)
    {
        ForceMinerConnectorUnlatchedUntilMerge();
        if (!IsOrientationAligned(desiredForward, desiredUp, orientationToleranceDeg))
        {
            targetPosition = minerConnector.GetPosition();
            activeMaxSpeed = 0;
            autopilotEnabled = true;
            return;
        }
        targetPosition = GetDockPosePosition();
        activeMaxSpeed = dockApproachSpeed;
        autopilotEnabled = true;
        if (IsAtDockPose())
        {
            dockingState = DockingState.DockingFinalApproach;
            dockMergeReadyTicks = 0;
            dockConnectRetryTicks = 0;
            dockConnectRecompileTicksRemaining = 0;
            dockConnectRecompileArmed = false;
            Echo("Dock phase 2: final approach.");
        }
        return;
    }

    if (dockingState == DockingState.DockingFinalApproach)
    {
        targetPosition = GetCarrierConnectorPosition();
        activeMaxSpeed = dockFinalSpeed;
        autopilotEnabled = true;
        bool mergedNow = IsMergerDocked();
        if (mergedNow)
            dockMergeReadyTicks++;
        else
            dockMergeReadyTicks = 0;
        bool mergeReady = dockMergeReadyTicks >= 2; // wait one extra tick after first merge detection
        bool canAttemptConnect = mergeReady;
        if (!mergeReady)
            ForceMinerConnectorUnlatchedUntilMerge();
        if (mergeReady)
        {
            if (!dockConnectRecompileArmed)
            {
                dockConnectRecompileArmed = true;
                dockConnectRecompileTicksRemaining = dockConnectRecompileTicks;
                dockConnectRetryTicks = 0;
            }

            if (dockConnectRecompileTicksRemaining > 0)
            {
                SetConnectorEnabled(false);
                dockConnectRecompileTicksRemaining--;
                canAttemptConnect = false;
            }
            else if (dockConnectRecompileTicksRemaining == 0)
            {
                RefreshDockHardware(); // simulate post-merge recompile/rescan before connector retries
                SetConnectorEnabled(true);
                dockConnectRecompileTicksRemaining = -1;
            }
        }
        else
        {
            dockConnectRetryTicks = 0;
            dockConnectRecompileTicksRemaining = 0;
            dockConnectRecompileArmed = false;
            canAttemptConnect = false;
        }

        if (canAttemptConnect)
        {
            dockConnectRetryTicks++;
            if (dockConnectRetryTicks >= 10)
            {
                dockConnectRetryTicks = 0;
                SetConnectorEnabled(true);
                if (minerConnector != null && minerConnector.Status != MyShipConnectorStatus.Connected)
                    minerConnector.Connect();
            }
        }

        bool connectorDocked = minerConnector != null && minerConnector.Status == MyShipConnectorStatus.Connected;
        if (connectorDocked)
        {
            ApplyDockedPowerState();
            CompleteDocking("Dock complete (connected).", true);
        }
    }
}

bool IsAtDockPose()
{
    return Vector3D.DistanceSquared(minerConnector.GetPosition(), GetDockPosePosition()) <= dockPoseTolerance * dockPoseTolerance &&
           IsOrientationAligned(desiredForward, desiredUp, orientationToleranceDeg);
}

bool HasMinerTag(IMyTerminalBlock b)
{
    return b.CustomName.IndexOf("EMM-A Mi ", StringComparison.OrdinalIgnoreCase) >= 0;
}

void ApplyDockedPowerState()
{
    foreach (var g in allGyros)      if (HasMinerTag(g)) g.Enabled = false;
    foreach (var t in allThrusters)  if (HasMinerTag(t)) t.Enabled = false;
    InvalidateEffectiveThrustCache();
    foreach (var a in antennas)      if (HasMinerTag(a)) a.Enabled = false;
    foreach (var b in batteries)     if (HasMinerTag(b)) b.ChargeMode = ChargeMode.Recharge;
    foreach (var h in hydrogenTanks) if (HasMinerTag(h)) h.Stockpile = true;
}

void ApplyUndockedPowerState()
{
    foreach (var g in allGyros)      if (HasMinerTag(g)) g.Enabled = true;
    foreach (var t in allThrusters)  if (HasMinerTag(t)) t.Enabled = true;
    InvalidateEffectiveThrustCache();
    foreach (var a in antennas)      if (HasMinerTag(a)) a.Enabled = true;
    foreach (var b in batteries)     if (HasMinerTag(b)) b.ChargeMode = ChargeMode.Auto;
    foreach (var h in hydrogenTanks) if (HasMinerTag(h)) h.Stockpile = false;
}

void CompleteDocking(string message, bool transferOre = false)
{
    dockingState = DockingState.None;
    ClearDockRetry();
    undockRecompileTicksRemaining = 0;
    dockMergeReadyTicks = 0;
    dockConnectRetryTicks = 0;
    dockConnectRecompileTicksRemaining = 0;
    dockConnectRecompileArmed = false;
    autopilotEnabled = false;
    hasTarget = false;
    activeMaxSpeed = 0;
    ResetMovement();
    Echo(message);
    if (transferOre)
    {
        if (saveAsteroidAfterDock)
        {
            if (SendCarrierCommand("SaveAsteroid"))
                Echo("Requested carrier SaveAsteroid.");
            else
                Echo($"Warning: carrier PB '{carrierPbTag}' not found; skipping auto SaveAsteroid.");
            saveAsteroidAfterDock = false;
        }
        if (updateAsteroidAfterDock)
        {
            if (SendCarrierCommand("UpdateAsteroid"))
                Echo("Requested carrier UpdateAsteroid.");
            else
                Echo($"Warning: carrier PB '{carrierPbTag}' not found; skipping auto UpdateAsteroid.");
            updateAsteroidAfterDock = false;
        }
        ScheduleOreTransfer();
    }
}

bool SendCarrierCommand(string command)
{
    var allPbs = new List<IMyProgrammableBlock>();
    GridTerminalSystem.GetBlocksOfType(allPbs);
    foreach (var pb in allPbs)
    {
        if (pb == Me) continue;
        if (pb.CustomName.IndexOf(carrierPbTag, StringComparison.OrdinalIgnoreCase) >= 0)
            return pb.TryRun(command);
    }
    return false;
}

void ScheduleOreTransfer()
{
    oreTransferStartDelayTicks = oreTransferStartDelayAfterDockTicks;
    oreTransferActive = false;
    Echo("Ore transfer scheduled.");
}

void UpdateOreTransferStartDelay()
{
    if (oreTransferStartDelayTicks <= 0)
        return;

    oreTransferStartDelayTicks = Math.Max(0, oreTransferStartDelayTicks - UpdateTickDelta());
    if (oreTransferStartDelayTicks <= 0)
        StartOreTransfer();
}

void StartOreTransfer()
{
    _oreTransferSources.Clear();
    _oreTransferTargets.Clear();
    GridTerminalSystem.GetBlocksOfType(_oreTransferSources, b =>
        b.HasInventory &&
        b.CustomName.IndexOf(minerContainerTag, StringComparison.OrdinalIgnoreCase) >= 0);
    GridTerminalSystem.GetBlocksOfType(_oreTransferTargets, b =>
        b.HasInventory &&
        b.CustomName.IndexOf(carrierOreCargoTag, StringComparison.OrdinalIgnoreCase) >= 0);

    if (_oreTransferSources.Count == 0)
    {
        Echo($"TransferOre: no source inventories matching '{minerContainerTag}' found.");
        return;
    }
    if (_oreTransferTargets.Count == 0)
    {
        Echo($"TransferOre: no target cargo matching '{carrierOreCargoTag}' found.");
        return;
    }

    oreTransferSourceIdx = 0;
    oreTransferTargetStartIdx = 0;
    oreTransferCooldownTicks = 0;
    oreTransferActive = true;
    Echo($"Ore transfer started ({_oreTransferSources.Count} source, {_oreTransferTargets.Count} target).");
}

void UpdateOreTransfer()
{
    if (oreTransferCooldownTicks > 0)
    {
        oreTransferCooldownTicks--;
        return;
    }
    oreTransferCooldownTicks = oreTransferIntervalTicks - 1;

    if (oreTransferSourceIdx < _oreTransferSources.Count)
    {
        bool hadItems;
        if (TryTransferOneStackFromBlock(_oreTransferSources[oreTransferSourceIdx], out hadItems))
            return;
        if (hadItems)
        {
            oreTransferActive = false;
            Echo("TransferOre: carrier containers full or blocked.");
            return;
        }
        oreTransferSourceIdx++;
        return;
    }

    oreTransferActive = false;
    Echo("Ore transfer complete.");
}

bool TryTransferOneStackFromBlock(IMyTerminalBlock sourceBlock, out bool hadItems)
{
    hadItems = false;
    if (sourceBlock == null || !sourceBlock.HasInventory)
        return false;

    for (int invIdx = 0; invIdx < sourceBlock.InventoryCount; invIdx++)
    {
        IMyInventory src = sourceBlock.GetInventory(invIdx);
        if (src == null || src.CurrentVolume <= 0)
            continue;

        _oreTransferItems.Clear();
        src.GetItems(_oreTransferItems);
        if (_oreTransferItems.Count > 0)
            hadItems = true;
        for (int itemIdx = 0; itemIdx < _oreTransferItems.Count; itemIdx++)
        {
            int targetCount = _oreTransferTargets.Count;
            for (int attempt = 0; attempt < targetCount; attempt++)
            {
                int targetIdx = (oreTransferTargetStartIdx + attempt) % targetCount;
                var tgt = _oreTransferTargets[targetIdx];
                if (tgt == null || !tgt.HasInventory) continue;
                IMyInventory tgtInv = tgt.GetInventory(0);
                if (tgtInv == null) continue;
                if (TryTransferStackOrPartial(src, tgtInv, itemIdx, _oreTransferItems[itemIdx]))
                {
                    oreTransferTargetStartIdx = targetIdx;
                    return true;
                }
            }
        }
    }

    return false;
}

bool TryTransferStackOrPartial(IMyInventory src, IMyInventory tgtInv, int itemIdx, MyInventoryItem item)
{
    if (src.TransferItemTo(tgtInv, itemIdx, null, true))
        return true;

    double total = (double)item.Amount;
    if (total <= 0)
        return false;

    double low = 0;
    double high = total;
    for (int i = 0; i < 20; i++)
    {
        double mid = (low + high) * 0.5;
        if (mid <= 0)
            break;

        MyFixedPoint amount = (MyFixedPoint)mid;
        if (amount <= 0)
            break;

        if (tgtInv.CanItemsBeAdded(amount, item.Type))
            low = mid;
        else
            high = mid;
    }

    if (low <= 0)
        return false;

    double candidate = low;
    for (int i = 0; i < 8; i++)
    {
        MyFixedPoint partial = (MyFixedPoint)candidate;
        if (partial <= 0)
            return false;
        if (src.TransferItemTo(tgtInv, itemIdx, null, true, partial))
            return true;
        candidate *= 0.5;
    }

    return false;
}

void StartPathFromTimer()
{
    ClearRecallState();
    ClearAutoServiceState();
    List<string> loaded;
    string timerName;
    if (!TryLoadPathRecordsFromTimer(out loaded, out timerName))
    {
        Echo($"Unable to load path records from timer tag '{pathTimerTag}'.");
        return;
    }

    pathRecords = loaded;
    pathIndex = 0;
    pathMode = true;
    pathPaused = false;
    pathPausedNavResume = false;
    pathDockPending = false;
    pathCompleteBroadcastTicks = 0;
    appendPathActive = false;
    appendPathStopRecordIndex = -1;
    suppressPathRuntimeWrite = false;
    ResetPathRunTimer();
    Echo($"Loaded {pathRecords.Count} path records from timer '{timerName}'.");
    StartNextPathRecord();
}

void StartNextPathRecord()
{
    while (pathMode && pathIndex < pathRecords.Count)
    {
        string record = pathRecords[pathIndex];
        pathIndex++;
        if (IsPathMetadataRecord(record))
            continue;
        if (ExecutePathRecord(record))
        {
            if (pathMode)
                StartPathRunTimer();
            return;
        }
        if (autoServicePreviewReturnActive && IsMineAreaPathRecord(record))
            continue;
        Echo($"Skipping invalid path record #{pathIndex}.");
    }

    if (pathMode && pathIndex >= pathRecords.Count)
    {
        if (autoServicePreviewReturnActive)
        {
            FailPreviewAutoServiceReturn("Auto service: preview Excavation Zone return failed before reaching the saved minearea.");
            return;
        }

        pathMode = false;
        StopPathRunTimer();
        if (!suppressPathRuntimeWrite)
            WritePathRuntimeToTimer();
        suppressPathRuntimeWrite = false;
        Echo("Path execution complete.");
        pathCompleteBroadcastTicks = pathCompleteBroadcastRepeatTicks;
        SendPathCompleteBroadcast();
        ClearPathTimerAndCounters(false);
        if (miLcdMenu == MiLcdMenu.FollowPath)
            OpenMinerMenu(MiLcdMenu.Main);
    }
}

void StartPathRunTimer()
{
    if (pathRunTimerStarted)
        return;
    pathRunTimerStarted = true;
    pathRunTimerActive = true;
    pathRunElapsedTicks = 0;
}

void StopPathRunTimer()
{
    pathRunTimerActive = false;
}

void ResetPathRunTimer()
{
    pathRunTimerStarted = false;
    pathRunTimerActive = false;
    pathRunElapsedTicks = 0;
}

void UpdatePathRunTimer()
{
    if (pathRunTimerActive)
        pathRunElapsedTicks += UpdateTickDelta();
}

void WritePathRuntimeToTimer()
{
    IMyTimerBlock timer = FindPathTimer();
    if (timer == null)
        return;

    var lines = new List<string>();
    foreach (string rawLine in (timer.CustomData ?? "").Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
    {
        string line = rawLine.Trim();
        if (string.IsNullOrWhiteSpace(line) || LooksLikeRuntimeLine(line))
            continue;
        lines.Add(line);
    }
    lines.Add(FormatTicksAsMinutes(pathRunElapsedTicks));
    RewritePathTimerLines(lines);
}

bool LooksLikeRuntimeLine(string line)
{
    if (string.IsNullOrWhiteSpace(line))
        return false;
    string value = line.Trim();
    if (value.StartsWith("Runtime:", StringComparison.OrdinalIgnoreCase))
        value = value.Substring("Runtime:".Length).Trim();
    string[] parts = value.Split(':');
    int minutes, seconds;
    return parts.Length == 2 &&
           int.TryParse(parts[0].Trim(), out minutes) &&
           int.TryParse(parts[1].Trim(), out seconds) &&
           seconds >= 0 && seconds < 60;
}

string FormatTicksAsMinutes(int ticks)
{
    int totalSeconds = Math.Max(0, (int)Math.Round(ticks / 60.0));
    int minutes = totalSeconds / 60;
    int seconds = totalSeconds % 60;
    return minutes.ToString("00") + ":" + seconds.ToString("00");
}

int UpdateTickDelta()
{
    if (tickSpeed == UpdateFrequency.Update10)
        return 10;
    if (tickSpeed == UpdateFrequency.Update100)
        return 100;
    return 1;
}

void UpdatePathCompleteBroadcast()
{
    if (pathCompleteBroadcastTicks <= 0)
        return;

    if (runtime % igcPollIntervalTicks == 0)
        SendPathCompleteBroadcast();
    pathCompleteBroadcastTicks--;
}

void SendPathCompleteBroadcast()
{
    IGC.SendBroadcastMessage(minerPathCompleteTag, "Path execution complete.");
}

bool ExecutePathRecord(string rawRecord)
{
    if (string.IsNullOrWhiteSpace(rawRecord))
        return false;

    string record = rawRecord.Trim();
    if (record.StartsWith("\"") && record.EndsWith("\"") && record.Length >= 2)
        record = record.Substring(1, record.Length - 2).Trim();
    if (string.IsNullOrWhiteSpace(record))
        return false;
    if (IsPathMetadataRecord(record))
        return false;

    if (record.StartsWith("minearea;", StringComparison.OrdinalIgnoreCase))
    {
        if (autoServicePreviewReturnActive)
        {
            int recordIndex = Math.Max(0, pathIndex - 1);
            if (recordIndex == autoServiceResumeMineAreaRecordIndex)
                return CompletePreviewAutoServiceReturnToMineArea();
            return false;
        }

        activeMineAreaRecordIndex = Math.Max(0, pathIndex - 1);
        activeMineAreaRecordLine = record;
        StartAreaMining(record);
        return miningEnabled || autopilotEnabled;
    }
    if (record.Equals("dock", StringComparison.OrdinalIgnoreCase))
    {
        if (pathMode && pathAnchorValid)
        {
            targetPosition = pathAnchorPos;
            desiredForward = pathAnchorForward;
            desiredUp = pathAnchorUp;
            hasTarget = true;
            autopilotEnabled = true;
            pathDockPending = true;
            return true;
        }
        StartDock();
        return dockingState != DockingState.None || dockRetryPending;
    }
    if (record.Equals("undock", StringComparison.OrdinalIgnoreCase))
    {
        StartUndock();
        return dockingState != DockingState.None;
    }

    // SE-style GPS records remain parseable for player input pasted into the timer.
    string navCmd = null;
    if (record.StartsWith("Nav;", StringComparison.OrdinalIgnoreCase))
        navCmd = record.Substring(4).Trim();
    else if (record.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
        navCmd = record;

    if (navCmd != null)
    {
        Vector3D gps, forward, up;
        if (!TryParseGpsCommand(navCmd, out gps, out forward, out up))
            return false;
        targetPosition = gps;
        desiredForward = forward;
        desiredUp = up;
        hasTarget = true;
        autopilotEnabled = true;
        return true;
    }

    // Compact records (mine area / path point) are decoded against the loaded anchor.
    if (!pathAnchorValid)
        return false;

    if (LineLooksLikeMineArea(record))
    {
        Vector3D cornerA, cornerB, areaUp, areaForward;
        double depth;
        if (!TryParseMineAreaLine(record, pathAnchorPos,
                                  out cornerA, out cornerB, out areaUp, out areaForward, out depth))
            return false;
        Vector3D entryPose = GetInferredMineAreaEntryPose(cornerA, cornerB);
        if (!IsAtTargetPose(entryPose, areaForward, areaUp))
        {
            pathIndex = Math.Max(0, pathIndex - 1);
            targetPosition = entryPose;
            desiredForward = areaForward;
            desiredUp = areaUp;
            hasTarget = true;
            autopilotEnabled = true;
            activeMaxSpeed = SPEEDB;
            return true;
        }

        if (autoServicePreviewReturnActive)
        {
            int recordIndex = Math.Max(0, pathIndex - 1);
            if (recordIndex == autoServiceResumeMineAreaRecordIndex)
                return CompletePreviewAutoServiceReturnToMineArea();
            return false;
        }

        activeMineAreaRecordIndex = Math.Max(0, pathIndex - 1);
        activeMineAreaRecordLine = record;
        StartAreaMiningWithCorners(cornerA, cornerB, areaUp, areaForward, depth);
        return miningEnabled || autopilotEnabled;
    }

    Vector3D pos, fwd, upN;
    if (TryParsePathPointLine(record, pathAnchorPos, out pos, out fwd, out upN))
    {
        targetPosition = pos;
        desiredForward = fwd;
        desiredUp = upN;
        hasTarget = true;
        autopilotEnabled = true;
        return true;
    }

    return false;
}

bool TryLoadPathRecordsFromTimer(out List<string> records, out string timerName)
{
    records = new List<string>();
    timerName = "";
    pathAnchorValid = false;
    pathAnchorPos = Vector3D.Zero;
    pathAnchorForward = Vector3D.Zero;
    pathAnchorUp = Vector3D.Zero;

    IMyTimerBlock timer = FindPathTimer();
    if (timer == null)
        return false;

    timerName = timer.CustomName;
    string data = timer.CustomData ?? "";
    string[] lines = data.Split(new [] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
    foreach (string line in lines)
    {
        string rec = line.Trim();
        if (string.IsNullOrWhiteSpace(rec))
            continue;
        if (rec.StartsWith("\"") && rec.EndsWith("\"") && rec.Length >= 2)
            rec = rec.Substring(1, rec.Length - 2).Trim();
        if (string.IsNullOrWhiteSpace(rec))
            continue;
        if (LooksLikeRuntimeLine(rec))
            continue;
        if (!pathAnchorValid)
        {
            Vector3D ap, af, au;
            if (TryParseCarrierAnchorLine(rec, out ap, out af, out au))
            {
                pathAnchorPos = ap;
                pathAnchorForward = af;
                pathAnchorUp = au;
                pathAnchorValid = true;
                continue; // header is consumed, not run as a record
            }
        }
        records.Add(rec);
    }

    return records.Count > 0 || pathAnchorValid;
}

void StartSingleLaneMining(string command)
{
    string[] args = command.Split(';');
    if (args.Length < 2)
    {
        Echo("Usage: minelane;depth");
        return;
    }

    double depth;
    if (!double.TryParse(args[1], out depth) || depth <= 0)
    {
        Echo("Invalid depth.");
        return;
    }

    laneDepth = depth;
    laneAnchor = hasTarget ? targetPosition : rc.GetPosition();
    areaMiningMode = false;
    areaLaneAnchors.Clear();
    areaLaneIndex = 0;
    areaLaneCount = 0;
    areaPlanValid = false;
    ClearAreaLaneSkipState();
    retryCurrentLane = false;
    stuckRetryCount = 0;

    Vector3D fwd = desiredForward;
    if (fwd.LengthSquared() < 0.001)
        fwd = rc.WorldMatrix.Forward;
    drillAxis = Vector3D.Normalize(fwd);

    if (desiredUp.LengthSquared() < 0.001)
    {
        Vector3D gravity = rc.GetNaturalGravity();
        desiredUp = gravity.LengthSquared() > 0.001 ? Vector3D.Normalize(-gravity) : rc.WorldMatrix.Up;
    }

    desiredForward = drillAxis;
    targetPosition = laneAnchor;
    activeMaxSpeed = SPEEDB;
    hasTarget = true;
    autopilotEnabled = true;
    miningEnabled = true;
    miningState = MiningState.EnterLane;
    _invCached = false; // refresh inventory block list for ore tracking
    ResetDepthAutoTracker();
    Echo($"Mining lane started. Depth={laneDepth:0.00}m");
}

void StartAreaMining(string command)
{
    TryStartAreaMiningCommandFromLane(command, 0);
}

bool TryStartAreaMiningCommandFromLane(string command, int startLane)
{
    // minearea;<gps or x,y,z>;<gps or x,y,z>;Faceup,Faceforward;depth
    string[] args = command.Split(';');
    if (args.Length < 5)
    {
        Echo("Usage: minearea;<gps or x,y,z>;<gps or x,y,z>;Faceup,Faceforward;depth");
        return false;
    }

    Vector3D leftUpper;
    Vector3D rightBottom;
    if (!TryParsePoint(args[1], out leftUpper) || !TryParsePoint(args[2], out rightBottom))
    {
        Echo("Invalid point format. Use GPS:Name:X:Y:Z: or x,y,z");
        return false;
    }

    Vector3D up;
    Vector3D forward;
    if (!TryParseAreaOrientation(args[3], leftUpper, rightBottom, out up, out forward))
    {
        Echo("Invalid orientation mode. Use Faceup,Faceforward or ux,uy,uz,fx,fy,fz");
        return false;
    }

    double depth;
    if (!double.TryParse(args[4], out depth) || depth <= 0)
    {
        Echo("Invalid depth.");
        return false;
    }

    StartAreaMiningWithCornersFromLane(leftUpper, rightBottom, up, forward, depth, startLane);
    return miningEnabled || autopilotEnabled;
}

void StartAreaMiningWithCorners(Vector3D cornerA, Vector3D cornerB, Vector3D up, Vector3D forward, double depth)
{
    StartAreaMiningWithCornersFromLane(cornerA, cornerB, up, forward, depth, 0);
}

void ClearAreaLaneSkipState()
{
    areaSkipLaneIndexes.Clear();
    areaEmptyLaneIndexes.Clear();
    areaCurrentLaneSawOre = false;
    suppressCurrentLaneEmptyRecord = false;
}

void LoadActiveMineAreaSkipMetadata()
{
    ClearAreaLaneSkipState();
    if (activeMineAreaRecordIndex < 0 || activeMineAreaRecordIndex + 1 >= pathRecords.Count)
        return;

    double savedHeight, savedWidth;
    int savedLaneCount;
    List<int> parsedSkipLanes = new List<int>();
    if (!TryParseMineAreaSkipMetaLine(pathRecords[activeMineAreaRecordIndex + 1],
                                      out savedHeight, out savedWidth, out savedLaneCount, parsedSkipLanes))
        return;
    if (!MineAreaSkipMetaMatches(savedHeight, savedWidth, savedLaneCount))
        return;

    for (int i = 0; i < parsedSkipLanes.Count; i++)
        if (parsedSkipLanes[i] >= 0 && parsedSkipLanes[i] < areaLaneCount)
            AddLaneIndexUnique(areaSkipLaneIndexes, parsedSkipLanes[i]);
}

bool AdvancePastSkippedAreaLanes()
{
    int firstSkipped = areaLaneIndex;
    while (areaLaneIndex < areaLaneCount && LaneListContains(areaSkipLaneIndexes, areaLaneIndex))
        areaLaneIndex++;

    if (areaLaneIndex > firstSkipped)
        Echo($"Skipping saved empty lanes {firstSkipped + 1}-{areaLaneIndex}.");

    return areaLaneIndex < areaLaneCount;
}

void ResetCurrentAreaLaneOreTracking()
{
    areaCurrentLaneSawOre = false;
    suppressCurrentLaneEmptyRecord = false;
}

void RecordCurrentAreaLaneIfEmpty()
{
    if (!areaMiningMode || depthMode == DepthMode.Default)
        return;
    if (suppressCurrentLaneEmptyRecord || areaCurrentLaneSawOre || stuckRetryCount > 0)
        return;
    if (areaLaneIndex < 0 || areaLaneIndex >= areaLaneCount)
        return;
    if (LaneListContains(areaSkipLaneIndexes, areaLaneIndex))
        return;

    AddLaneIndexUnique(areaEmptyLaneIndexes, areaLaneIndex);
}

void StartAreaMiningWithCornersFromLane(Vector3D cornerA, Vector3D cornerB, Vector3D up, Vector3D forward, double depth, int startLane)
{
    ClearPathRecordMineBoundaryLock();
    CanonicalizeMineAreaCorners(ref cornerA, ref cornerB, forward, up);
    Vector3D right = Vector3D.Cross(forward, up);
    if (right.LengthSquared() < 0.001)
        right = rc.WorldMatrix.Right;
    right = Vector3D.Normalize(right);

    if (!ConfigureAreaLanePlan(cornerA, cornerB, up, right, MINEH, MINEW))
    {
        Echo("Unable to generate area lanes.");
        return;
    }

    laneDepth = depth;
    pathRecordMineDepth = depth;
    drillAxis = forward;
    desiredUp = up;
    desiredForward = drillAxis;
    areaPlanValid = true;
    areaPlanCornerA = cornerA;
    areaPlanCornerB = cornerB;
    areaPlanUp = up;
    areaPlanForward = forward;
    areaPlanRight = right;
    areaMineEntryPos = GetTargetControlPointPosition();
    areaMineEntryForward = Vector3D.Normalize(rc.WorldMatrix.Forward);
    areaMineEntryUp = Vector3D.Normalize(rc.WorldMatrix.Up);
    returnToMinePoseAfterArea = true;

    areaMiningMode = true;
    areaLaneIndex = Math.Max(0, Math.Min(startLane, areaLaneCount - 1));
    retryCurrentLane = false;
    finishAreaAfterBackout = false;
    stuckRetryCount = 0;
    LoadActiveMineAreaSkipMetadata();
    if (!AdvancePastSkippedAreaLanes())
    {
        miningEnabled = false;
        miningState = MiningState.Idle;
        TriggerPathPointFlash();
        OpenMinerMenu(MiLcdMenu.MineArea);
        miMenuIndex = 1;
        Echo("Area mining skipped; all lanes are marked empty.");
        FinishAreaMining();
        return;
    }
    laneAnchor = GetAreaLaneAnchor(areaLaneIndex);
    targetPosition = laneAnchor;
    activeMaxSpeed = SPEEDB;
    hasTarget = true;
    autopilotEnabled = true;
    miningEnabled = true;
    miningState = MiningState.EnterLane;
    _invCached = false; // refresh inventory block list for ore tracking
    fullStateDirty = true;
    ResetCurrentAreaLaneOreTracking();
    ResetDepthAutoTracker();
    TriggerPathPointFlash();
    OpenMinerMenu(MiLcdMenu.MineArea);
    miMenuIndex = 1;

    if (areaLaneIndex > 0)
        Echo($"Area mining resumed. Lane={areaLaneIndex + 1}/{areaLaneCount}, depth={laneDepth:0.00}m");
    else
        Echo($"Area mining started. Lanes={areaLaneCount}, depth={laneDepth:0.00}m");
}

bool TryParseAreaOrientation(string modeText, Vector3D pointA, Vector3D pointB, out Vector3D up, out Vector3D forward)
{
    up = Vector3D.Zero;
    forward = Vector3D.Zero;

    string [] modes = modeText.Split(new [] { ',' }, StringSplitOptions.RemoveEmptyEntries);
    if (modes.Length == 2)
    {
        string upMode = modes[0].Trim();
        string forwardMode = modes[1].Trim();
        if (!upMode.Equals("Faceup", StringComparison.OrdinalIgnoreCase) ||
            !forwardMode.Equals("Faceforward", StringComparison.OrdinalIgnoreCase))
            return false;

        Vector3D gravity = rc.GetNaturalGravity();
        if (gravity.LengthSquared() > 0.001)
            up = Vector3D.Normalize(-gravity);
        else
            up = rc.WorldMatrix.Up;

        Vector3D toward = pointB - pointA;
        toward = toward - Vector3D.Dot(toward, up) * up; // flatten into the area plane
        if (toward.LengthSquared() > 0.001)
            forward = Vector3D.Normalize(toward);
        else
            forward = rc.WorldMatrix.Forward;
        return true;
    }

    if (modes.Length == 6)
    {
        double ux, uy, uz, fx, fy, fz;
        if (double.TryParse(modes[0].Trim(), out ux) &&
            double.TryParse(modes[1].Trim(), out uy) &&
            double.TryParse(modes[2].Trim(), out uz) &&
            double.TryParse(modes[3].Trim(), out fx) &&
            double.TryParse(modes[4].Trim(), out fy) &&
            double.TryParse(modes[5].Trim(), out fz))
        {
            up = new Vector3D(ux, uy, uz);
            forward = new Vector3D(fx, fy, fz);
            if (up.LengthSquared() > 0.001)
                up = Vector3D.Normalize(up);
            if (forward.LengthSquared() > 0.001)
                forward = Vector3D.Normalize(forward);
            return up.LengthSquared() > 0.001 && forward.LengthSquared() > 0.001;
        }
    }

    return false;
}

bool ConfigureAreaLanePlan(Vector3D leftUpper, Vector3D rightBottom, Vector3D up, Vector3D right, double laneHeight, double laneWidth)
{
    if (laneHeight <= 0 || laneWidth <= 0)
        return false;

    Vector3D down = -up;
    Vector3D delta = rightBottom - leftUpper;
    double height = Math.Abs(Vector3D.Dot(delta, down));
    double width = Math.Abs(Vector3D.Dot(delta, right));

    areaPlanRows = Math.Max(1, (int)Math.Ceiling(height / laneHeight));
    areaPlanCols = Math.Max(1, (int)Math.Ceiling(width / laneWidth));
    areaPlanRowStart = areaPlanRows > 1 ? laneHeight * 0.5 : height * 0.5;
    areaPlanRowStep = areaPlanRows > 1 ? (height - laneHeight) / (areaPlanRows - 1) : 0;
    areaPlanColStart = areaPlanCols > 1 ? laneWidth * 0.5 : width * 0.5;
    areaPlanColStep = areaPlanCols > 1 ? (width - laneWidth) / (areaPlanCols - 1) : 0;
    areaLaneCount = areaPlanRows * areaPlanCols;
    return areaLaneCount > 0;
}

Vector3D GetAreaLaneAnchor(int index)
{
    if (areaPlanCols <= 0)
        return laneAnchor;

    if (index < 0)
        index = 0;
    if (areaLaneCount > 0 && index >= areaLaneCount)
        index = areaLaneCount - 1;

    int r = index / areaPlanCols;
    int c = index % areaPlanCols;
    bool reverse = (r % 2) == 1;
    int ci = reverse ? (areaPlanCols - 1 - c) : c;
    Vector3D down = -areaPlanUp;
    return areaPlanCornerA +
        down * (areaPlanRowStart + r * areaPlanRowStep) +
        areaPlanRight * (areaPlanColStart + ci * areaPlanColStep);
}

List<Vector3D> BuildRectangleLaneAnchors(Vector3D leftUpper, Vector3D rightBottom, Vector3D up, Vector3D right, double laneHeight, double laneWidth)
{
    List<Vector3D> anchors = new List<Vector3D>();
    if (laneHeight <= 0 || laneWidth <= 0)
        return anchors;

    Vector3D down = -up;
    Vector3D delta = rightBottom - leftUpper;
    double height = Math.Abs(Vector3D.Dot(delta, down));
    double width = Math.Abs(Vector3D.Dot(delta, right));

    int rows = Math.Max(1, (int)Math.Ceiling(height / laneHeight));
    int cols = Math.Max(1, (int)Math.Ceiling(width / laneWidth));

    // First anchor inset by half lane, last anchor inset from far edge by half lane.
    // Step distributes remaining span evenly — all anchors stay within bounds.
    double rowStart = rows > 1 ? laneHeight * 0.5 : height * 0.5;
    double rowStep  = rows > 1 ? (height - laneHeight) / (rows - 1) : 0;
    double colStart = cols > 1 ? laneWidth * 0.5 : width * 0.5;
    double colStep  = cols > 1 ? (width - laneWidth) / (cols - 1) : 0;

    for (int r = 0; r < rows; r++)
    {
        Vector3D rowOrigin = leftUpper + down * (rowStart + r * rowStep);
        bool reverse = (r % 2) == 1;
        for (int c = 0; c < cols; c++)
        {
            int ci = reverse ? (cols - 1 - c) : c;
            Vector3D anchor = rowOrigin + right * (colStart + ci * colStep);
            anchors.Add(anchor);
        }
    }

    return anchors;
}

bool TryParseVector3(string csv, out Vector3D value)
{
    value = Vector3D.Zero;
    string[] t = csv.Split(',');
    if (t.Length != 3)
        return false;
    double x, y, z;
    if (!double.TryParse(t[0].Trim(), out x) || !double.TryParse(t[1].Trim(), out y) || !double.TryParse(t[2].Trim(), out z))
        return false;
    value = new Vector3D(x, y, z);
    return true;
}

// === Compact path/zone serialization (anchor + axis-angle deltas) ===
// On-disk record shapes (path timer / Asteroid DB / Zone DB):
//   anchor (header line 1): cx,cy,cz:ax,ay,az,a   -- absolute carrier pos + axis-angle
//   path point             : dx,dy,dz:ax,ay,az,a   -- delta from anchor + axis-angle
//   mine area              : dx,dy,dz:ax,ay,az,a:w,h:depth -- corner A delta, area axis-angle, w/h, depth
// Disambiguation: header by file position; mine area by 3 ':'-segments, path point by 2.

string FormatPosCsv(Vector3D p)
{
    return p.X.ToString("0.00") + "," + p.Y.ToString("0.00") + "," + p.Z.ToString("0.00");
}

string FormatAxisAngle(Vector3D forward, Vector3D up)
{
    if (forward.LengthSquared() < 1e-9 || up.LengthSquared() < 1e-9)
        return "0.0000,0.0000,0.0000,0.0000";
    Quaternion q = Quaternion.CreateFromForwardUp((Vector3)Vector3D.Normalize(forward), (Vector3)Vector3D.Normalize(up));
    double w = MathHelper.Clamp((double)q.W, -1.0, 1.0);
    double angle = 2.0 * Math.Acos(w);
    double s = Math.Sqrt(Math.Max(0.0, 1.0 - w * w));
    if (angle < 1e-6 || s < 1e-9)
        return "0.0000,0.0000,0.0000,0.0000";
    double ax = q.X / s, ay = q.Y / s, az = q.Z / s;
    return ax.ToString("0.0000") + "," + ay.ToString("0.0000") + "," + az.ToString("0.0000") + "," + angle.ToString("0.0000");
}

bool TryParseAxisAngle(string s, out Vector3D forward, out Vector3D up)
{
    forward = new Vector3D(0, 0, -1);
    up = new Vector3D(0, 1, 0);
    if (string.IsNullOrWhiteSpace(s)) return false;
    string[] t = s.Split(',');
    if (t.Length != 4) return false;
    double ax, ay, az, angle;
    if (!double.TryParse(t[0].Trim(), out ax) ||
        !double.TryParse(t[1].Trim(), out ay) ||
        !double.TryParse(t[2].Trim(), out az) ||
        !double.TryParse(t[3].Trim(), out angle))
        return false;
    Vector3D axis = new Vector3D(ax, ay, az);
    if (Math.Abs(angle) < 1e-6 || axis.LengthSquared() < 1e-12)
        return true; // identity orientation
    axis = Vector3D.Normalize(axis);
    Quaternion q = Quaternion.CreateFromAxisAngle((Vector3)axis, (float)angle);
    forward = Vector3D.Normalize(Vector3D.Transform(new Vector3D(0, 0, -1), q));
    up = Vector3D.Normalize(Vector3D.Transform(new Vector3D(0, 1, 0), q));
    return true;
}

string FormatCarrierAnchorLine(Vector3D pos, Vector3D forward, Vector3D up)
{
    return FormatPosCsv(pos) + ":" + FormatAxisAngle(forward, up);
}

bool TryParseCarrierAnchorLine(string line, out Vector3D pos, out Vector3D forward, out Vector3D up)
{
    pos = Vector3D.Zero;
    forward = new Vector3D(0, 0, -1);
    up = new Vector3D(0, 1, 0);
    if (string.IsNullOrWhiteSpace(line)) return false;
    string[] parts = line.Split(':');
    if (parts.Length != 2) return false;
    if (!TryParseVector3(parts[0], out pos)) return false;
    return TryParseAxisAngle(parts[1], out forward, out up);
}

string FormatPathPointLine(Vector3D pos, Vector3D anchor, Vector3D forward, Vector3D up)
{
    return FormatPosCsv(pos - anchor) + ":" + FormatAxisAngle(forward, up);
}

bool TryParsePathPointLine(string line, Vector3D anchor, out Vector3D pos, out Vector3D forward, out Vector3D up)
{
    pos = Vector3D.Zero;
    forward = new Vector3D(0, 0, -1);
    up = new Vector3D(0, 1, 0);
    if (string.IsNullOrWhiteSpace(line)) return false;
    string[] parts = line.Split(':');
    if (parts.Length != 2) return false;
    Vector3D delta;
    if (!TryParseVector3(parts[0], out delta)) return false;
    if (!TryParseAxisAngle(parts[1], out forward, out up)) return false;
    pos = anchor + delta;
    return true;
}

// Mine area line format: dx,dy,dz : ax,ay,az,angle : w,h : depth
//   dx,dy,dz       — corner A as delta from the path-timer anchor position
//   ax,ay,az,angle — axis-angle rotation captured when the area was recorded (step 1 of pathrecordmine)
//   w,h            — corner B offset, projected into the recorded rotation's right/up plane
//   depth          — drill depth along the recorded rotation's forward
string FormatMineAreaLine(Vector3D cornerA, Vector3D cornerB, Vector3D anchor,
                          Vector3D forward, Vector3D up, double depth)
{
    Vector3D fwdN = (forward.LengthSquared() > 1e-9) ? Vector3D.Normalize(forward) : forward;
    Vector3D upN  = (up.LengthSquared() > 1e-9) ? Vector3D.Normalize(up) : up;
    Vector3D right = Vector3D.Cross(fwdN, upN);
    if (right.LengthSquared() > 1e-9) right = Vector3D.Normalize(right);
    Vector3D delta = cornerB - cornerA;
    double w = Vector3D.Dot(delta, right);
    double h = Vector3D.Dot(delta, upN);
    return FormatPosCsv(cornerA - anchor) + ":" +
           FormatAxisAngle(fwdN, upN) + ":" +
           w.ToString("0.00") + "," + h.ToString("0.00") + ":" +
           depth.ToString("0.##");
}

bool TryParseMineAreaLine(string line, Vector3D anchor,
                          out Vector3D cornerA, out Vector3D cornerB,
                          out Vector3D areaUp, out Vector3D areaForward, out double depth)
{
    cornerA = Vector3D.Zero;
    cornerB = Vector3D.Zero;
    areaUp = new Vector3D(0, 1, 0);
    areaForward = new Vector3D(0, 0, -1);
    depth = 0;
    if (string.IsNullOrWhiteSpace(line)) return false;
    string[] parts = line.Split(':');
    if (parts.Length != 4) return false;
    Vector3D aDelta;
    if (!TryParseVector3(parts[0], out aDelta)) return false;
    if (!TryParseAxisAngle(parts[1], out areaForward, out areaUp)) return false;
    string[] wh = parts[2].Split(',');
    if (wh.Length != 2) return false;
    double w, h;
    if (!double.TryParse(wh[0].Trim(), out w) || !double.TryParse(wh[1].Trim(), out h)) return false;
    if (!double.TryParse(parts[3].Trim(), out depth)) return false;
    cornerA = anchor + aDelta;
    areaForward = Vector3D.Normalize(areaForward);
    areaUp = Vector3D.Normalize(areaUp);
    Vector3D right = Vector3D.Cross(areaForward, areaUp);
    if (right.LengthSquared() > 1e-9) right = Vector3D.Normalize(right);
    cornerB = cornerA + right * w + areaUp * h;
    return true;
}

bool LineLooksLikeMineArea(string line)
{
    if (string.IsNullOrWhiteSpace(line)) return false;
    return line.Split(':').Length == 4;
}

bool TryParsePoint(string text, out Vector3D value)
{
    value = Vector3D.Zero;
    if (string.IsNullOrWhiteSpace(text))
        return false;

    string t = text.Trim();
    if (t.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
    {
        string[] parts = t.Split(':');
        if (parts.Length < 5)
            return false;
        double x, y, z;
        if (!double.TryParse(parts[2], out x) || !double.TryParse(parts[3], out y) || !double.TryParse(parts[4], out z))
            return false;
        value = new Vector3D(x, y, z);
        return true;
    }

    return TryParseVector3(t, out value);
}

void UpdateMiningState()
{
    switch (miningState)
    {
        case MiningState.EnterLane:
            targetPosition = laneAnchor;
            desiredForward = drillAxis;
            activeMaxSpeed = SPEEDB;
            if (IsAtTargetPose(targetPosition, desiredForward, desiredUp, miningArrivalTolerance))
            {
                SetDrills(true);
                ResetStuckMonitor();
                ResetDepthAutoTracker();
                miningState = MiningState.DrillForward;
            }
            break;
        case MiningState.DrillForward:
            targetPosition = laneAnchor + drillAxis * GetLaneTargetDepth();
            desiredForward = drillAxis;
            activeMaxSpeed = SPEEDF;
            if (CheckStuckInLane())
            {
                retryCurrentLane = true;
                stuckBackout = true;
                miningState = MiningState.Backout;
                Echo("Stuck detected. Returning to anchor and retrying lane.");
            }
            else if (ShouldFinishDrillForward())
                miningState = MiningState.Backout;
            break;
        case MiningState.Backout:
            targetPosition = laneAnchor;
            desiredForward = drillAxis;
            activeMaxSpeed = SPEEDB;
            if (IsAtTargetPosition(targetPosition, miningArrivalTolerance))
            {
                if (!retryCurrentLane && (!areaMiningMode || finishAreaAfterBackout))
                    SetDrills(false);
                if (mineAreaAdjustPendingAfterBackout)
                {
                    SetDrills(false);
                    miningEnabled = false;
                    miningState = MiningState.Idle;
                    areaMiningMode = false;
                    finishAreaAfterBackout = false;
                    mineAreaAdjustPendingAfterBackout = false;
                    BeginMineAreaCornerAdjustmentFlight(mineAreaAdjustPendingCornerA);
                    return;
                }
                if (pathMode && pathPaused)
                {
                    SetDrills(false);
                    autopilotEnabled = false;
                    activeMaxSpeed = 0;
                    miningEnabled = false; // stop spin loop; pathcontinue re-enables
                    return;
                }
                if (retryCurrentLane)
                {
                    retryCurrentLane = false;
                    bool wasStuck = stuckBackout;
                    stuckBackout = false;
                    if (wasStuck) stuckRetryCount++;
                    bool giveUp = wasStuck && maxStuckRetries > 0 && stuckRetryCount >= maxStuckRetries;
                    if (giveUp && areaMiningMode && areaLaneIndex + 1 < areaLaneCount)
                    {
                        Echo($"Max retries ({maxStuckRetries}) reached. Skipping lane {areaLaneIndex + 1}.");
                        stuckRetryCount = 0;
                        areaLaneIndex++;
                        if (!AdvancePastSkippedAreaLanes())
                        {
                            FinishAreaMining();
                            return;
                        }
                        laneAnchor = GetAreaLaneAnchor(areaLaneIndex);
                        ResetCurrentAreaLaneOreTracking();
                        ResetDepthAutoTracker();
                        miningState = MiningState.EnterLane;
                    }
                    else if (giveUp)
                    {
                        Echo($"Max retries ({maxStuckRetries}) reached. Mining stopped.");
                        SetDrills(false);
                        miningEnabled = false;
                        miningState = MiningState.Idle;
                        autopilotEnabled = false;
                        activeMaxSpeed = 0;
                        areaMiningMode = false;
                        areaLaneAnchors.Clear();
                        areaLaneIndex = 0;
                        areaLaneCount = 0;
                        areaPlanValid = false;
                        ClearAreaLaneSkipState();
                    }
                    else
                    {
                        miningState = MiningState.EnterLane;
                        string retryInfo = maxStuckRetries > 0
                            ? $"attempt {stuckRetryCount + 1}/{maxStuckRetries}"
                            : "no limit";
                        Echo($"Retrying lane {areaLaneIndex + 1}/{Math.Max(1, areaLaneCount)} ({retryInfo})");
                    }
                }
                else if (finishAreaAfterBackout)
                {
                    finishAreaAfterBackout = false;
                    FinishAreaMining();
                }
                else if (areaMiningMode && areaLaneIndex + 1 < areaLaneCount)
                {
                    RecordCurrentAreaLaneIfEmpty();
                    stuckRetryCount = 0;
                    areaLaneIndex++;
                    if (!AdvancePastSkippedAreaLanes())
                    {
                        FinishAreaMining();
                        return;
                    }
                    laneAnchor = GetAreaLaneAnchor(areaLaneIndex);
                    ResetCurrentAreaLaneOreTracking();
                    ResetDepthAutoTracker();
                    miningState = MiningState.EnterLane;
                    Echo($"Proceeding to lane {areaLaneIndex + 1}/{areaLaneCount}");
                }
                else
                {
                    RecordCurrentAreaLaneIfEmpty();
                    FinishAreaMining();
                }
            }
            break;
    }
}

void ResetStuckMonitor()
{
    stuckSamplePos = rc.GetPosition();
    stuckNoMoveSeconds = 0;
}

void ResetDepthAutoTracker()
{
    if (depthMode == DepthMode.Default)
        _oreScanActive = false;
    else
        StartOreAmountScan(depthMode == DepthMode.OrePlusStone);
    lastOreSnapshot = cachedOreAmount;
    lastOreGainDepth = 0;
    noOreGainTicks = 0;
    oreCheckTick = 0;
}

double GetLaneProgressDepth()
{
    return Math.Max(0, Vector3D.Dot(_tickRcPosition - laneAnchor, drillAxis));
}

double GetLaneTargetDepth()
{
    if (depthMode == DepthMode.Default)
        return laneDepth;
    return laneDepth + autoDepthExtraCap;
}

bool ShouldFinishDrillForward()
{
    double depthProgress = GetLaneProgressDepth();
    if (depthMode == DepthMode.Default)
        return depthProgress >= laneDepth || IsAtTargetPosition(targetPosition, miningArrivalTolerance);

    bool includeStone = depthMode == DepthMode.OrePlusStone;
    if (_oreScanActive)
    {
        if (UpdateOreAmountScan())
            oreCheckTick = oreCheckTickInterval;
    }
    else if (oreCheckTick <= 0)
    {
        StartOreAmountScan(includeStone);
        if (UpdateOreAmountScan())
            oreCheckTick = oreCheckTickInterval;
    }
    else
    {
        oreCheckTick--;
    }
    double oreNow = cachedOreAmount;

    if (oreNow > lastOreSnapshot + 0.01)
    {
        lastOreSnapshot = oreNow;
        lastOreGainDepth = depthProgress;
        noOreGainTicks = 0;
        if (areaMiningMode)
            areaCurrentLaneSawOre = true;
    }
    else if (depthProgress >= laneDepth && (depthProgress - lastOreGainDepth) >= autoDepthNoGainMeters)
    {
        noOreGainTicks++;
    }

    if (depthProgress >= laneDepth + autoDepthExtraCap)
        return true;

    return depthProgress >= laneDepth && noOreGainTicks >= noOreGainTickLimit;
}

void RefreshInventoryCache()
{
    _invBlocks.Clear();
    GridTerminalSystem.GetBlocksOfType(_invBlocks, b => b.CubeGrid.EntityId == Me.CubeGrid.EntityId && b.HasInventory);
    _invCached = true;
}

void StartOreAmountScan(bool includeStone)
{
    if (!_invCached)
        RefreshInventoryCache();
    _oreScanActive = true;
    _oreScanIncludeStone = includeStone;
    _oreScanBlockIndex = 0;
    _oreScanTotal = 0;
}

bool UpdateOreAmountScan()
{
    if (!_oreScanActive)
        return true;

    int scannedBlocks = 0;
    while (_oreScanBlockIndex < _invBlocks.Count && scannedBlocks < oreScanBlocksPerTick)
    {
        var block = _invBlocks[_oreScanBlockIndex];
        _oreScanBlockIndex++;
        scannedBlocks++;

        if (block == null || !block.IsFunctional)
            continue;
        int invCount = block.InventoryCount;
        for (int i = 0; i < invCount; i++)
        {
            var inv = block.GetInventory(i);
            if (inv == null)
                continue;
            _invItems.Clear();
            inv.GetItems(_invItems);
            foreach (var item in _invItems)
            {
                if (!string.Equals(item.Type.TypeId, "MyObjectBuilder_Ore", StringComparison.OrdinalIgnoreCase))
                    continue;
                if (!_oreScanIncludeStone && string.Equals(item.Type.SubtypeId, "Stone", StringComparison.OrdinalIgnoreCase))
                    continue;
                _oreScanTotal += (double)item.Amount;
            }
        }
    }

    if (_oreScanBlockIndex < _invBlocks.Count)
        return false;

    cachedOreAmount = _oreScanTotal;
    _oreScanActive = false;
    return true;
}

double GetOreAmount(bool includeStone)
{
    if (!_invCached)
        RefreshInventoryCache();

    double total = 0;
    foreach (var block in _invBlocks)
    {
        if (block == null || !block.IsFunctional)
            continue;
        int invCount = block.InventoryCount;
        for (int i = 0; i < invCount; i++)
        {
            var inv = block.GetInventory(i);
            if (inv == null)
                continue;
            _invItems.Clear();
            inv.GetItems(_invItems);
            foreach (var item in _invItems)
            {
                if (!string.Equals(item.Type.TypeId, "MyObjectBuilder_Ore", StringComparison.OrdinalIgnoreCase))
                    continue;
                if (!includeStone && string.Equals(item.Type.SubtypeId, "Stone", StringComparison.OrdinalIgnoreCase))
                    continue;
                total += (double)item.Amount;
            }
        }
    }

    return total;
}

bool CheckStuckInLane()
{
    Vector3D currentPosition = _tickRcPosition;
    double moved = Vector3D.DistanceSquared(currentPosition, stuckSamplePos);
    if (moved < stuckMoveThreshold * stuckMoveThreshold)
    {
        stuckNoMoveSeconds += secondsPerTick;
        if (stuckNoMoveSeconds >= stuckTimeoutSeconds)
        {
            ResetStuckMonitor();
            return true;
        }
    }
    else
    {
        stuckSamplePos = currentPosition;
        stuckNoMoveSeconds = 0;
    }
    return false;
}

void FinishAreaMining()
{
    ClearPathRecordMineBoundaryLock();
    UpsertActiveMineAreaSkipMetaRecord();
    activeMineAreaRecordIndex = -1;
    activeMineAreaRecordLine = "";
    SetDrills(false);
    miningEnabled = false;
    miningState = MiningState.Idle;
    areaMiningMode = false;
    areaLaneAnchors.Clear();
    areaLaneIndex = 0;
    areaLaneCount = 0;
    areaPlanValid = false;
    ClearAreaLaneSkipState();
    finishAreaAfterBackout = false;
    fullStateDirty = true;
    if (returnToMinePoseAfterArea)
    {
        ReturnToMinePoseAfterArea();
        if (resumePathRecordingAfterMineArea)
        {
            pathRecordingWaitReturn = true;
            pathRecordMineStage = PathRecordMineStage.ReturningToEntry;
        }
        Echo("Mining complete. Returning to mine pose...");
    }
    else
    {
        autopilotEnabled = false;
        activeMaxSpeed = 0;
        Echo("Mining operation complete.");
        if (pathMode && !pathRecordingEnabled)
        {
            OpenMinerMenu(MiLcdMenu.FollowPath);
            miMenuIndex = 1;
        }
    }
}

void NextHole(bool skipToLast = false)
{
    if (areaLaneCount == 0)
    {
        if (skipToLast && (pathRecordMineStage == PathRecordMineStage.CornerCaptured ||
                           pathRecordMineStage == PathRecordMineStage.ReturningToEntry ||
                           pathRecordingWaitReturn))
        {
            ReturnToRecordedMinePoseWithoutPreview();
            Echo("Minearea skipped. Returning to mine pose...");
            return;
        }
        if (skipToLast && returnToMinePoseAfterArea)
        {
            ReturnToMinePoseAfterArea();
            Echo("Minearea skipped. Returning to mine pose...");
            return;
        }
        Echo("No area plan loaded. Start with minearea first.");
        return;
    }
    int targetIndex = skipToLast ? areaLaneCount - 1 : areaLaneIndex + 1;
    bool atLastLane = skipToLast || targetIndex >= areaLaneCount || targetIndex <= areaLaneIndex;

    if (!areaMiningMode)
        SetDrills(false);
    stuckRetryCount = 0;
    retryCurrentLane = false;

    if (atLastLane)
    {
        if (miningState == MiningState.DrillForward || miningState == MiningState.Backout)
        {
            areaMiningMode = true;
            autopilotEnabled = true;
            miningEnabled = true;
            finishAreaAfterBackout = true;
            miningState = MiningState.Backout;
            Echo("Backing out before finishing mining...");
        }
        else
        {
            FinishAreaMining();
        }
        return;
    }

    areaMiningMode = true;
    autopilotEnabled = true;
    miningEnabled = true;
    finishAreaAfterBackout = false;

    if (miningState == MiningState.DrillForward)
    {
        suppressCurrentLaneEmptyRecord = true;
        miningState = MiningState.Backout;
        Echo($"Backing out before advancing to hole {areaLaneIndex + 2}/{areaLaneCount}...");
    }
    else
    {
        areaLaneIndex = targetIndex;
        if (!AdvancePastSkippedAreaLanes())
        {
            FinishAreaMining();
            return;
        }
        laneAnchor = GetAreaLaneAnchor(areaLaneIndex);
        targetPosition = laneAnchor;
        desiredForward = drillAxis.LengthSquared() > 0.001 ? drillAxis : rc.WorldMatrix.Forward;
        activeMaxSpeed = SPEEDB;
        hasTarget = true;
        ResetCurrentAreaLaneOreTracking();
        ResetDepthAutoTracker();
        miningState = MiningState.EnterLane;
        Echo($"Advancing to hole {areaLaneIndex + 1}/{areaLaneCount}");
    }
}

bool IsMineAreaPathRecord(string record)
{
    string normalized = NormalizePathRecord(record);
    return normalized.StartsWith("minearea;", StringComparison.OrdinalIgnoreCase) ||
           LineLooksLikeMineArea(normalized);
}

void ReturnToRecordedMinePoseWithoutPreview()
{
    ClearPathRecordMineBoundaryLock();
    resumePathRecordingAfterMineArea = false;
    bool hasPendingMineArea =
        !string.IsNullOrWhiteSpace(pathRecordPendingMineAreaLine) &&
        (pathRecordMineCornerB - pathRecordMineCornerA).LengthSquared() > 0.01;
    pathRecordMinePreviewActive = hasPendingMineArea;
    if (!hasPendingMineArea)
    {
        pathRecordMineCornerA = Vector3D.Zero;
        pathRecordMineCornerB = Vector3D.Zero;
    }
    pathRecordMineStage = PathRecordMineStage.ReturningToEntry;
    pathRecordingWaitReturn = true;
    targetPosition = pathRecordMineEntry;
    desiredUp = pathRecordMineUp;
    desiredForward = pathRecordMineForward;
    hasTarget = true;
    autopilotEnabled = true;
    activeMaxSpeed = SPEEDB;
}

void ReturnToMinePoseAfterArea()
{
    ClearPathRecordMineBoundaryLock();
    SetDrills(false);
    miningEnabled = false;
    miningState = MiningState.Idle;
    areaMiningMode = false;
    areaLaneAnchors.Clear();
    areaLaneIndex = 0;
    areaLaneCount = 0;
    areaPlanValid = false;
    finishAreaAfterBackout = false;
    targetPosition = areaMineEntryPos;
    desiredUp = areaMineEntryUp;
    desiredForward = areaMineEntryForward;
    hasTarget = true;
    autopilotEnabled = true;
    activeMaxSpeed = SPEEDB;
    returnToMinePoseAfterArea = false;
}

bool IsAtTargetPosition(Vector3D target, double toleranceMeters = -1)
{
    double baseTolerance = toleranceMeters > 0 ? toleranceMeters : arrivalTolerance;
    double tolerance = Math.Max(0.05, baseTolerance);
    return Vector3D.DistanceSquared(_tickRcPosition + GetActiveTargetOffsetWorld(_tickRcMatrix), target) < tolerance * tolerance;
}

bool IsAtTargetPose(Vector3D target, Vector3D forward, Vector3D up, double toleranceMeters = -1)
{
    return IsAtTargetPosition(target, toleranceMeters) && IsOrientationAligned(forward, up, orientationToleranceDeg);
}

void SetDrills(bool enabled)
{
    foreach (var d in drills)
    {
        if (d == null || !d.IsFunctional)
            continue;
        d.Enabled = enabled;
    }
}

void DumpCurrentGpsToCustomData()
{
    StringBuilder sb = new StringBuilder();
    string existing = Me.CustomData ?? "";
    if (!string.IsNullOrWhiteSpace(existing))
        sb.Append(existing.TrimEnd());

    sb.AppendLine();
    sb.AppendLine();
    sb.AppendLine("[AutopilotDump]");
    sb.AppendLine(FormatCurrentGps("Here"));

    Me.CustomData = sb.ToString();
    Echo("Dumped GPS/orientation to Custom Data.");
}

// ---- State persistence (MyIni timer CustomData) ----
// The timer named by stateIniTimerTag owns all runtime persistence for this script.
// PB Storage contains only the small volatile progress overlay used to avoid periodic CustomData write spikes.
// If you need to inspect, backup, reset, or hand-edit full saved state, use that timer's CustomData INI.

string V3ToString(Vector3D v)
{
    return v.X.ToString("R") + ":" + v.Y.ToString("R") + ":" + v.Z.ToString("R");
}

bool TryParseV3(string s, out Vector3D v)
{
    v = Vector3D.Zero;
    if (string.IsNullOrWhiteSpace(s)) return false;
    string[] p = s.Split(':');
    if (p.Length != 3) return false;
    double x, y, z;
    if (!double.TryParse(p[0], out x) || !double.TryParse(p[1], out y) || !double.TryParse(p[2], out z)) return false;
    v = new Vector3D(x, y, z);
    return true;
}

bool ReadStateIni(out MyIni ini)
{
    ini = new MyIni();

    // Load the full snapshot from the dedicated state INI timer.
    IMyTimerBlock timer = FindStateIniTimer();
    if (timer == null)
        return false;

    string data = timer.CustomData ?? "";
    if (string.IsNullOrWhiteSpace(data))
        return false;

    MyIniParseResult result;
    if (!ini.TryParse(data, out result))
    {
        Echo("State INI parse failed: " + result.ToString());
        return false;
    }

    return true;
}

void WriteStateIni(MyIni ini)
{
    // Persist the current state snapshot into the timer CustomData INI.
    IMyTimerBlock timer = FindStateIniTimer();
    if (timer == null)
    {
        Echo($"State INI timer '{stateIniTimerTag}' not found; state was not saved.");
        return;
    }

    timer.CustomData = ini.ToString();
}

bool ReadProgressState()
{
    _progressIni.Clear();
    string data = Storage ?? "";
    if (string.IsNullOrWhiteSpace(data))
        return false;

    MyIniParseResult result;
    if (!_progressIni.TryParse(data, out result))
        return false;

    return true;
}

void WriteProgressState(MyIni ini)
{
    Storage = ini.ToString();
    _hasProgressState = true;
}

string StateString(MyIni ini, string key, string fallback)
{
    if (_hasProgressState)
    {
        string progress = _progressIni.Get(ProgressIniSection, key).ToString(null);
        if (progress != null)
            return progress;
    }
    return ini.Get(StateIniSection, key).ToString(fallback);
}

bool StateBool(MyIni ini, string key, bool fallback)
{
    string s = StateString(ini, key, fallback ? "1" : "0");
    return s == "1" || s.Equals("true", StringComparison.OrdinalIgnoreCase);
}

void LoadLaneIndexList(MyIni ini, string keyPrefix, List<int> lanes)
{
    lanes.Clear();
    int count;
    if (!int.TryParse(StateString(ini, keyPrefix + "Count", "0"), out count) || count <= 0)
        return;

    for (int i = 0; i < count; i++)
    {
        int lane;
        if (int.TryParse(StateString(ini, keyPrefix + i, "-1"), out lane))
            AddLaneIndexUnique(lanes, lane);
    }
    SortLaneIndexes(lanes);
}

IMyTimerBlock FindStateIniTimer()
{
    if (_cachedStateIniTimer != null &&
        _cachedStateIniTimer.CustomName.IndexOf(stateIniTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        return _cachedStateIniTimer;

    foreach (var t in GetTimerBlocksCached())
    {
        if (t.CustomName.IndexOf(stateIniTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        {
            _cachedStateIniTimer = t;
            return _cachedStateIniTimer;
        }
    }

    _cachedStateIniTimer = null;
    return null;
}

void RefreshTimerCache()
{
    _timerBlocks.Clear();
    GridTerminalSystem.GetBlocksOfType(_timerBlocks, b => b.CubeGrid.EntityId == Me.CubeGrid.EntityId);
    _timerBlocksCached = true;
}

List<IMyTimerBlock> GetTimerBlocksCached()
{
