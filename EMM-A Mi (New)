void UpdatePathRunner()
{
    if (!pathMode || pathRecords.Count == 0)
        return;
    if (pathPaused)
        return;
    if (mineAreaAdjustStage != MineAreaAdjustStage.None)
        return;

    if (miningEnabled)
        return;
    if (dockingState != DockingState.None)
        return;
    if (dockRetryPending)
        return;

    if (autopilotEnabled && hasTarget)
    {
        if (IsAtTargetPose(targetPosition, desiredForward, desiredUp))
        {
            autopilotEnabled = false;
            hasTarget = false;
            activeMaxSpeed = 0;
            if (pathDockPending)
            {
                pathDockPending = false;
                StartDock();
                return;
            }
            if (pathMode && !pathRecordingEnabled && miLcdMenu == MiLcdMenu.MineArea)
            {
                OpenMinerMenu(MiLcdMenu.FollowPath);
                miMenuIndex = 1;
            }
        }
        return;
    }

    if (appendPathActive && appendPathStopRecordIndex >= 0 && pathIndex >= appendPathStopRecordIndex)
    {
        CompleteAppendPath();
        return;
    }

    StartNextPathRecord();
}

