    if (useSubgrids)
        GridTerminalSystem.GetBlocksOfType(blocks);
    else
        GridTerminalSystem.GetBlocksOfType(blocks, b => b.CubeGrid.EntityId == Me.CubeGrid.EntityId);
    return blocks;
}

const double gyroP = 10;
const double gyroI = 0;
const double gyroD = 5;
const double gyroMax = 1000;
const double gyroErrorDeadbandRad = 0.003; // ~0.17 deg
const double gyroOutputDeadband = 0.002;
const double gyroFineDampRangeRad = 0.12; // start damping under ~7 deg total error
const double gyroRateLimit = 0.35; // max per-axis command (rad/s equivalent)

class GyroControl
{
    private List<IMyGyro> gyros;
    IMyCubeBlock rc;

    public GyroControl (IMyCubeBlock rc, UpdateFrequency tickSpeed, List<IMyGyro> gyros)
    {
        if (rc == null)
            throw new Exception("Reference block null.");

        this.rc = rc;

        this.gyros = gyros;

        double factor = 1;
        if (tickSpeed == UpdateFrequency.Update10)
            factor = 10;
        else if (tickSpeed == UpdateFrequency.Update100)
            factor = 100;
        double secondsPerTick = (1.0 / 60) * factor;
        anglePID = new VectorPID(gyroP / factor, gyroI / factor, gyroD / factor, -gyroMax, gyroMax, secondsPerTick);

        Reset();
    }
    // In (pitch, yaw, roll)
    VectorPID anglePID;

    public void Reset ()
    {
        for (int i = 0; i < gyros.Count; i++)
        {
            IMyGyro g = gyros [i];
            if (g == null)
            {
                gyros.RemoveAtFast(i);
                continue;
            }
            if (g.GyroOverride)
                g.GyroOverride = false;
        }
        anglePID.Reset();
    }

    /// <summary>
            /// Prioritizes up vector.
            /// </summary>
    Vector3D GetAngles2 (MatrixD current, Vector3D forward, Vector3D up)
    {
        Vector3D error = new Vector3D();

        // yaw
        if (forward != Vector3D.Zero)
        {
            Vector3D temp = Vector3D.Normalize(VectorRejection(forward, current.Up));
            double dot = MathHelper.Clamp(Vector3D.Dot(current.Forward, temp), -1, 1);
            double yawAngle = Math.Acos(dot);
            double scaler = ScalerProjection(temp, current.Right);
            if (scaler > 0)
                yawAngle *= -1;
            error.Y = yawAngle;
        }

        // pitch and roll
        if (up != Vector3D.Zero)
        {
            error.X = SignedAngleOnPlane(current.Up, up, current.Right, current.Forward, true);
            error.Z = SignedAngleOnPlane(current.Up, up, current.Forward, current.Right, true);
        }

        if (Math.Abs(error.X) < 0.001)
            error.X = 0;
        if (Math.Abs(error.Y) < 0.001)
            error.Y = 0;
        if (Math.Abs(error.Z) < 0.001)
            error.Z = 0;

        return error;
    }

    /// <summary>
            /// Prioritizes forward vector.
            /// </summary>
    Vector3D GetAngles (MatrixD current, Vector3D forward, Vector3D up)
    {
        Vector3D error = new Vector3D();

        if (forward != Vector3D.Zero)
        {
            error.X = SignedAngleOnPlane(current.Forward, forward, current.Right, current.Up, false);
            error.Y = SignedAngleOnPlane(current.Forward, forward, current.Up, current.Right, true);
        }

        if (up != Vector3D.Zero)
        {
            Vector3D temp = Vector3D.Normalize(VectorRejection(up, current.Forward));
            double dot = MathHelper.Clamp(Vector3D.Dot(current.Up, temp), -1, 1);
            double rollAngle = Math.Acos(dot);
            double scaler = ScalerProjection(temp, current.Right);
            if (scaler > 0)
                rollAngle *= -1;
            error.Z = rollAngle;
        }

        if (Math.Abs(error.X) < 0.001)
            error.X = 0;
        if (Math.Abs(error.Y) < 0.001)
            error.Y = 0;
        if (Math.Abs(error.Z) < 0.001)
            error.Z = 0;

        return error;
    }
    /// <summary>
            /// Prioritizes up vector.
            /// </summary>
    public void FaceVectors2 (Vector3D forward, Vector3D up)
    {
        FaceVectors2(rc.WorldMatrix, forward, up);
    }

    public void FaceVectors2 (MatrixD current, Vector3D forward, Vector3D up)
    {
        // In (pitch, yaw, roll)
        Vector3D error = -GetAngles2(current, forward, up);
        Vector3D angles = new Vector3D(anglePID.Control(error));
        ApplyFineDamping(error, ref angles);
        ApplyGyroOverride(current, angles);
    }
    /// <summary>
            /// Prioritizes forward vector.
            /// </summary>
    public void FaceVectors (Vector3D forward, Vector3D up)
    {
        FaceVectors(rc.WorldMatrix, forward, up);
    }

    public void FaceVectors (MatrixD current, Vector3D forward, Vector3D up)
    {
        // In (pitch, yaw, roll)
        Vector3D error = -GetAngles(current, forward, up);
        Vector3D angles = new Vector3D(anglePID.Control(error));
        ApplyFineDamping(error, ref angles);
        ApplyGyroOverride(current, angles);
    }

    void ApplyFineDamping(Vector3D error, ref Vector3D angles)
    {
        if (Math.Abs(error.X) < gyroErrorDeadbandRad)
            angles.X = 0;
        if (Math.Abs(error.Y) < gyroErrorDeadbandRad)
            angles.Y = 0;
        if (Math.Abs(error.Z) < gyroErrorDeadbandRad)
            angles.Z = 0;

        double errMag = error.Length();
        if (errMag < gyroFineDampRangeRad)
        {
            double s = MathHelper.Clamp(errMag / gyroFineDampRangeRad, 0.2, 1.0);
            angles *= s;
        }

        if (Math.Abs(angles.X) < gyroOutputDeadband)
            angles.X = 0;
        if (Math.Abs(angles.Y) < gyroOutputDeadband)
            angles.Y = 0;
        if (Math.Abs(angles.Z) < gyroOutputDeadband)
            angles.Z = 0;

        angles.X = MathHelper.Clamp(angles.X, -gyroRateLimit, gyroRateLimit);
        angles.Y = MathHelper.Clamp(angles.Y, -gyroRateLimit, gyroRateLimit);
        angles.Z = MathHelper.Clamp(angles.Z, -gyroRateLimit, gyroRateLimit);
    }
    void ApplyGyroOverride (MatrixD current, Vector3D localAngles)
    {
        Vector3D worldAngles = Vector3D.TransformNormal(localAngles, current);
        foreach (IMyGyro gyro in gyros)
        {
            Vector3D transVect = Vector3D.TransformNormal(worldAngles, MatrixD.Transpose(gyro.WorldMatrix));  //Converts To Gyro Local
            if (!transVect.IsValid())
                throw new Exception("Invalid trans vector. " + transVect.ToString());

            gyro.Pitch = (float)transVect.X;
            gyro.Yaw = (float)transVect.Y;
            gyro.Roll = (float)transVect.Z;
            if (!gyro.GyroOverride)
                gyro.GyroOverride = true;
        }
    }

    /// <summary>
            /// Projects a value onto another vector.
            /// </summary>
            /// <param name="guide">Must be of length 1.</param>
    public static double ScalerProjection (Vector3D value, Vector3D guide)
    {
        double returnValue = Vector3D.Dot(value, guide);
        if (double.IsNaN(returnValue))
            return 0;
        return returnValue;
    }

    public static double SignedAngleOnPlane (Vector3D from, Vector3D to, Vector3D planeNormal, Vector3D signGuide, bool negateWhenPositive)
    {
        Vector3D flat = VectorRejection(to, planeNormal);
        if (flat.LengthSquared() < 1e-12)
            return 0;
        flat = Vector3D.Normalize(flat);
        double dot = MathHelper.Clamp(Vector3D.Dot(from, flat), -1, 1);
        double angle = Math.Acos(dot);
        double scaler = ScalerProjection(flat, signGuide);
        if ((negateWhenPositive && scaler > 0) || (!negateWhenPositive && scaler < 0))
            angle *= -1;
        return angle;
    }

    /// <summary>
            /// Projects a value onto another vector.
            /// </summary>
            /// <param name="guide">Must be of length 1.</param>
    public static Vector3D VectorPojection (Vector3D value, Vector3D guide)
    {
        return ScalerProjection(value, guide) * guide;
    }

    /// <summary>
            /// Projects a value onto another vector.
            /// </summary>
            /// <param name="guide">Must be of length 1.</param>
    public static Vector3D VectorRejection (Vector3D value, Vector3D guide)
    {
        return value - VectorPojection(value, guide);
    }
}

//Whip's PID controller class v6 - 11/22/17
public class PID
{
    double _kP = 0;
    double _kI = 0;
    double _kD = 0;
    double _integralDecayRatio = 0;
    double _lowerBound = 0;
    double _upperBound = 0;
    double _timeStep = 0;
    double _inverseTimeStep = 0;
    double _errorSum = 0;
    double _lastError = 0;
    bool _firstRun = true;
    bool _integralDecay = false;
    public double Value
    {
        get; private set;
    }

    public PID (double kP, double kI, double kD, double lowerBound, double upperBound, double timeStep)
    {
        _kP = kP;
        _kI = kI;
        _kD = kD;
        _lowerBound = lowerBound;
        _upperBound = upperBound;
        _timeStep = timeStep;
        _inverseTimeStep = 1 / _timeStep;
        _integralDecay = false;
    }

    public PID (double kP, double kI, double kD, double integralDecayRatio, double timeStep)
    {
        _kP = kP;
        _kI = kI;
        _kD = kD;
        _timeStep = timeStep;
        _inverseTimeStep = 1 / _timeStep;
        _integralDecayRatio = integralDecayRatio;
        _integralDecay = true;
    }

    public double Control (double error)
    {
        //Compute derivative term
        var errorDerivative = (error - _lastError) * _inverseTimeStep;

        if (_firstRun)
        {
            errorDerivative = 0;
            _firstRun = false;
        }

        //Compute integral term
        if (!_integralDecay)
        {
            _errorSum += error * _timeStep;

            //Clamp integral term
            if (_errorSum > _upperBound)
                _errorSum = _upperBound;
            else if (_errorSum < _lowerBound)
                _errorSum = _lowerBound;
        }
        else
        {
            _errorSum = _errorSum * (1.0 - _integralDecayRatio) + error * _timeStep;
        }

        //Store this error as last error
        _lastError = error;

        //Construct output
        this.Value = _kP * error + _kI * _errorSum + _kD * errorDerivative;
        return this.Value;
    }

    public double Control (double error, double timeStep)
    {
        _timeStep = timeStep;
        _inverseTimeStep = 1 / _timeStep;
        return Control(error);
    }

    public void Reset ()
    {
        _errorSum = 0;
        _lastError = 0;
        _firstRun = true;
    }
}

public class VectorPID
{
    private PID X;
    private PID Y;
    private PID Z;

    public VectorPID (double kP, double kI, double kD, double lowerBound, double upperBound, double timeStep)
    {
        X = new PID(kP, kI, kD, lowerBound, upperBound, timeStep);
        Y = new PID(kP, kI, kD, lowerBound, upperBound, timeStep);
        Z = new PID(kP, kI, kD, lowerBound, upperBound, timeStep);
    }

    public VectorPID (double kP, double kI, double kD, double integralDecayRatio, double timeStep)
    {
        X = new PID(kP, kI, kD, integralDecayRatio, timeStep);
        Y = new PID(kP, kI, kD, integralDecayRatio, timeStep);
        Z = new PID(kP, kI, kD, integralDecayRatio, timeStep);
    }

    public Vector3D Control (Vector3D error)
    {
        return new Vector3D(X.Control(error.X), Y.Control(error.Y), Z.Control(error.Z));
    }

    public void Reset ()
    {
        X.Reset();
        Y.Reset();
        Z.Reset();
    }
}

const double thrustP = 3;
const double thrustI = 2;
const double thrustD = 5;
const double thrustDecay = 0.2;
const float minThrust = 1.0000001f;

class ThrusterForceSample
{
    public Vector3D LocalForward;
    public double MaxEffectiveThrust;

    public ThrusterForceSample(Vector3D localForward, double maxEffectiveThrust)
    {
        LocalForward = localForward;
        MaxEffectiveThrust = maxEffectiveThrust;
    }
}

class ThrusterControl
{
    private List<IMyThrust> thrusters = new List<IMyThrust>();
    private List<ThrusterDriveSample> thrustCache = new List<ThrusterDriveSample>();
    IMyShipController rc;

    VectorPID pid;
    double cachedTotalMass = 0;
    int massCacheTicks = 0;
    const int massRefreshIntervalTicks = 10;
    int thrustCacheTicks = 0;
    const int thrustRefreshIntervalTicks = 60;

    class ThrusterDriveSample
    {
        public IMyThrust Block;
        public Vector3D LocalForward;
        public float MaxEffectiveThrust;
        public float MaxThrust;

        public ThrusterDriveSample(IMyThrust block, Vector3D localForward, float maxEffectiveThrust, float maxThrust)
        {
            Block = block;
            LocalForward = localForward;
            MaxEffectiveThrust = maxEffectiveThrust;
            MaxThrust = maxThrust;
        }
    }

    public void Reset ()
    {
        foreach (IMyThrust t in thrusters)
            if (t.ThrustOverride != 0)
                t.ThrustOverride = 0;
    }

    public ThrusterControl (IMyShipController rc, UpdateFrequency tickSpeed, List<IMyThrust> thrusters)
    {
        if (rc == null)
            throw new Exception("Ship controller null.");

        double factor = 1;
        if (tickSpeed == UpdateFrequency.Update10)
            factor = 10;
        else if (tickSpeed == UpdateFrequency.Update100)
            factor = 100;
        double secondsPerTick = (1.0 / 60) * factor;

        pid = new VectorPID(thrustP / factor, thrustI / factor, thrustD / factor, thrustDecay / factor, secondsPerTick);
        this.rc = rc;
        this.thrusters = thrusters;
        RefreshThrustCache();
        Reset();
    }

    void RefreshThrustCache()
    {
        thrustCache.Clear();
        MatrixD rcTranspose = MatrixD.Transpose(rc.WorldMatrix);
        foreach (IMyThrust t in thrusters)
        {
            if (t == null || !t.IsFunctional || t.MaxEffectiveThrust <= 0 || t.MaxThrust <= 0)
                continue;
            Vector3D localForward = Vector3D.TransformNormal(t.WorldMatrix.Forward, rcTranspose);
            thrustCache.Add(new ThrusterDriveSample(t, localForward, t.MaxEffectiveThrust, t.MaxThrust));
        }
        thrustCacheTicks = thrustRefreshIntervalTicks;
    }

    void RefreshThrustCacheIfNeeded()
    {
        if (thrustCacheTicks > 0)
        {
            thrustCacheTicks--;
            return;
        }
        RefreshThrustCache();
    }

    public Vector3D ControlPosition (Vector3D targetPosition, Vector3D targetVelocity, double maxSpeed = double.PositiveInfinity)
    {
        return ControlPositionFrom(rc.GetPosition(), targetPosition, targetVelocity, maxSpeed);
    }

    public Vector3D ControlPositionFrom(Vector3D currentPosition, Vector3D targetPosition, Vector3D targetVelocity, double maxSpeed = double.PositiveInfinity)
    {
        return ControlVelocity(targetVelocity + VectorClamp(-pid.Control(currentPosition - targetPosition), maxSpeed));
    }

    // Like ControlPosition but caps vertical speed (along verticalAxis) to 30% of maxSpeed,
    // letting lateral and forward/backward movement use the full budget.
    public Vector3D ControlPositionPrioritized(Vector3D targetPosition, Vector3D targetVelocity, double maxSpeed, Vector3D verticalAxis, double verticalFraction = 0.2)
    {
        return ControlPositionPrioritizedFrom(rc.GetPosition(), targetPosition, targetVelocity, maxSpeed, verticalAxis, verticalFraction);
    }

    public Vector3D ControlPositionPrioritizedFrom(Vector3D currentPosition, Vector3D targetPosition, Vector3D targetVelocity, double maxSpeed, Vector3D verticalAxis, double verticalFraction = 0.2)
    {
        Vector3D rawVel = targetVelocity + VectorClamp(-pid.Control(currentPosition - targetPosition), maxSpeed);

        double vertComp = Vector3D.Dot(rawVel, verticalAxis);
        Vector3D horizVel = rawVel - vertComp * verticalAxis;

        horizVel = VectorClamp(horizVel, maxSpeed);
        double vertCap = maxSpeed * verticalFraction;
        vertComp = MathHelper.Clamp(vertComp, -vertCap, vertCap);

        return ControlVelocity(horizVel + vertComp * verticalAxis);
    }

    public Vector3D VectorClamp (Vector3D v, double max)
    {
        double len2 = v.LengthSquared();
        if (len2 > max * max)
            v = (v / Math.Sqrt(len2)) * max;
        return v;
    }

    public Vector3D ControlVelocity (Vector3D targetVelocity)
    {
        // Calculate the needed thrust to get to velocity
        Vector3D myVel = rc.GetShipVelocities().LinearVelocity;
        Vector3D deltaV = myVel - targetVelocity;

        if (Vector3D.IsZero(deltaV))
            return Vector3D.Zero;

        Vector3D gravity = rc.GetNaturalGravity();
        return 2 * deltaV + gravity;
    }

    public void ApplyAccel (Vector3D accel)
    {
        ApplyAccel(accel, double.PositiveInfinity);
    }

    public void ApplyAccel (Vector3D accel, double maxTotalThrust)
    {
        if (accel.Equals(Vector3D.Zero, 0.1))
            accel = Vector3D.Zero;

        if (massCacheTicks <= 0 || cachedTotalMass <= 0)
        {
            cachedTotalMass = rc.CalculateShipMass().TotalMass;
            massCacheTicks = massRefreshIntervalTicks;
        }
        else
        {
            massCacheTicks--;
        }

        Vector3D thrust = accel * cachedTotalMass;
        double thrustLength = thrust.Length();
        if (thrustLength > maxTotalThrust && thrustLength > 0)
            thrust *= maxTotalThrust / thrustLength;

        RefreshThrustCacheIfNeeded();
        for (int i = 0; i < thrustCache.Count; i++)
        {
            ThrusterDriveSample sample = thrustCache[i];
            IMyThrust t = sample.Block;
            if (t == null || !t.IsFunctional)
                continue;

            Vector3D thrustForward = Vector3D.TransformNormal(sample.LocalForward, rc.WorldMatrix);
            float outputThrust = (float)Vector3D.Dot(thrustForward, thrust);
            if (outputThrust > 0)
            {
                float outputProportion = MathHelper.Clamp(outputThrust / sample.MaxEffectiveThrust, minThrust / sample.MaxThrust, 1);
                if (Math.Abs(t.ThrustOverridePercentage - outputProportion) > 0.001f)
                    t.ThrustOverridePercentage = outputProportion;
                thrust -= thrustForward * outputProportion * sample.MaxEffectiveThrust;
            }
            else
            {
                if (t.ThrustOverride != minThrust)
                    t.ThrustOverride = minThrust;
            }
        }
    }

}
