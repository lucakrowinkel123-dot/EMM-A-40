bool RemovePathTimerLine(string lineToRemove)
{
    if (string.IsNullOrWhiteSpace(lineToRemove))
        return false;
    List<string> lines;
    string timerName;
    if (!TryReadPathTimerLines(out lines, out timerName))
        return false;

    for (int i = lines.Count - 1; i >= 0; i--)
    {
        if (!string.Equals(lines[i].Trim(), lineToRemove.Trim(), StringComparison.OrdinalIgnoreCase))
            continue;
        lines.RemoveAt(i);
        bool ok = RewritePathTimerLines(lines);
        if (ok)
            RecountPathTimerRecords(lines);
        return ok;
    }
    return false;
}

void ConfirmCurrentExcavationZoneAdjustment()
{
    if (pathRecordMineConfirmPending)
    {
        ReleasePathRecordMineConfirmHold();
        if (!RewriteCurrentMineAreaRecord(false))
        {
            Echo("Excavation Zone confirm warning: could not rewrite path timer.");
            return;
        }
        if (mineAreaAdjustmentDirty && areaPlanValid)
        {
            pathRecordMineConfirmPending = false;
            mineAreaAdjustmentDirty = false;
            pathRecordingPaused = true;
            resumePathRecordingAfterMineArea = true;
            pathRecordMinePreviewActive = true;
            pathRecordMineCornerA = areaPlanCornerA;
            pathRecordMineCornerB = areaPlanCornerB;
            pathRecordMineEntry = GetInferredMineAreaEntryPose(areaPlanCornerA, areaPlanCornerB);
            StartAreaMiningWithCorners(areaPlanCornerA, areaPlanCornerB, areaPlanUp, areaPlanForward, pathRecordMineDepth);
            Echo("Started adjusted Excavation Zone preview.");
            return;
        }
        ConfirmRecordedExcavationZone();
        return;
    }

    if (mineAreaAdjustSaveToCarrier)
    {
        if (RewriteCurrentMineAreaRecord(true))
            Echo("Excavation Zone updated. Carrier save requested.");
        else
            Echo("Excavation Zone update failed.");
    }
    if (mineAreaAdjustmentDirty && areaPlanValid && !pathRecordMineConfirmPending)
    {
        mineAreaAdjustmentDirty = false;
        pathPaused = false;
        pathPausedNavResume = false;
        StartAreaMiningWithCorners(areaPlanCornerA, areaPlanCornerB, areaPlanUp, areaPlanForward, pathRecordMineDepth);
        return;
