void RecoverPathRecordsAfterLoad()
{
    if (!pathMode || pathRecords.Count > 0)
        return;

    List<string> loaded;
    string timerName;
    if (TryLoadPathRecordsFromTimer(out loaded, out timerName))
    {
        pathRecords = loaded;
        if (pathIndex < 0)
            pathIndex = 0;
        if (pathIndex > pathRecords.Count)
            pathIndex = pathRecords.Count;
    }
    else
    {
        pathMode = false;
        pathIndex = 0;
    }
}

void RecoverPathRecordReverseAfterLoad()
{
    if (pathRecordReverseMode == PathRecordReverseMode.None ||
        pathRecordReverseRecords.Count > 0)
        return;

    List<string> lines;
    string timerName;
    if (!TryReadPathTimerLines(out lines, out timerName))
    {
        ClearPathRecordReverseState();
        return;
    }

    int anchorIndex;
    Vector3D anchorPos, anchorForward, anchorUp;
    if (!TryFindPathAnchor(lines, out anchorIndex, out anchorPos, out anchorForward, out anchorUp))
    {
        ClearPathRecordReverseState();
        return;
    }

    List<string> reverseRecords = new List<string>();
    int keepLineCount = anchorIndex + 1;

    if (pathRecordReverseMode == PathRecordReverseMode.Undo)
    {
        int lastMineAreaIndex = -1;
        Vector3D cornerA, cornerB, areaUp, areaForward;
        double depth;
        for (int i = anchorIndex + 1; i < lines.Count; i++)
            if (LineLooksLikeMineArea(lines[i]) &&
                TryParseMineAreaLine(lines[i], anchorPos, out cornerA, out cornerB, out areaUp, out areaForward, out depth))
                lastMineAreaIndex = i;

        if (lastMineAreaIndex >= 0)
        {
            Vector3D lastCornerA, lastCornerB, lastAreaUp, lastAreaForward;
            if (!TryParseMineAreaLine(lines[lastMineAreaIndex], anchorPos,
                                      out lastCornerA, out lastCornerB, out lastAreaUp, out lastAreaForward, out depth))
            {
                ClearPathRecordReverseState();
                return;
            }

            Vector3D pos, fwd, up;
            for (int i = lines.Count - 1; i > lastMineAreaIndex; i--)
            {
                if (TryParsePathPointLine(lines[i], anchorPos, out pos, out fwd, out up))
                    reverseRecords.Add(lines[i]);
            }
            reverseRecords.Add(FormatPathPointLine(GetInferredMineAreaEntryPose(lastCornerA, lastCornerB), anchorPos, lastAreaForward, lastAreaUp));
            keepLineCount = lastMineAreaIndex + 1;
        }
        else
        {
            Vector3D pos, fwd, up;
            for (int i = lines.Count - 1; i > anchorIndex; i--)
                if (TryParsePathPointLine(lines[i], anchorPos, out pos, out fwd, out up))
                    reverseRecords.Add(lines[i]);
            reverseRecords.Add(FormatPathPointLine(anchorPos, anchorPos, anchorForward, anchorUp));
            keepLineCount = anchorIndex + 1;
        }
    }
    else
    {
        Vector3D pos, fwd, up;
        for (int i = lines.Count - 1; i > anchorIndex; i--)
            if (TryParsePathPointLine(lines[i], anchorPos, out pos, out fwd, out up))
                reverseRecords.Add(lines[i]);
        reverseRecords.Add(FormatPathPointLine(anchorPos, anchorPos, anchorForward, anchorUp));
        keepLineCount = anchorIndex + 1;
    }

    pathRecordReverseRecords = reverseRecords;
    pathRecordReverseKeepLineCount = keepLineCount;
    if (pathRecordReverseIndex < 0)
        pathRecordReverseIndex = 0;
    if (pathRecordReverseIndex > pathRecordReverseRecords.Count)
        pathRecordReverseIndex = pathRecordReverseRecords.Count;
    pathRecordingPaused = true;
    pathAnchorValid = true;
    pathAnchorPos = anchorPos;
    pathAnchorForward = anchorForward;
    pathAnchorUp = anchorUp;
}

