public Program ()
{
    // Prioritize the given cockpit name
    rc = GetBlock<IMyShipController>(cockpitName, true);
    if (rc == null) // Second priority cockpit
        rc = GetBlock<IMyCockpit>();
    if (rc == null) // Third priority remote control
        rc = GetBlock<IMyRemoteControl>();
    if (rc == null) // No cockpits found.
        throw new Exception("No cockpit/remote control found. Set the cockpitName field at the top of the script.");
    rcCanControlGyros = rc.GetProperty("ControlGyros") != null;
    RefreshTickPose();

    allGyros = GetBlocks<IMyGyro>().FindAll(b => HasMinerTag(b));
    allThrusters = GetBlocks<IMyThrust>().FindAll(b => HasMinerTag(b));
    thrust = new ThrusterControl(rc, tickSpeed, allThrusters);
    gyros = new GyroControl(rc, tickSpeed, allGyros);
    drills = GetBlocks<IMyShipDrill>();
    antennas = GetBlocks<IMyRadioAntenna>();
    batteries = GetBlocks<IMyBatteryBlock>();
    hydrogenTanks = GetBlocks<IMyGasTank>();
    minerConnector = GetBlock<IMyShipConnector>(minerConnectorName, true) ?? GetBlock<IMyShipConnector>();
    carrierConnector = GetBlock<IMyShipConnector>(carrierConnectorName, true);
    carrierRemote = GetBlock<IMyRemoteControl>(carrierRemoteName, true);
    minerMerger = GetBlock<IMyShipMergeBlock>(minerMergerName, true);
    carrierMerger = GetBlock<IMyShipMergeBlock>(carrierMergerName, true);
    indicatorLight = GetBlock<IMyLightingBlock>(indicatorLightName, true);
    pathRecordSoundBlock = GetBlock<IMySoundBlock>(pathRecordSoundBlockName, true);
    minerLcd = GridTerminalSystem.GetBlockWithName(minerLcdName) as IMyTextPanel;
    ConfigureMinerLcd();
    RefreshTimerCache();
    dockListener = IGC.RegisterBroadcastListener(dockBroadcastTag);
    carrierStatusListener = IGC.RegisterBroadcastListener(carrierStatusTag);
    minerCommandListener = IGC.RegisterBroadcastListener(minerCommandTag);
    UpdateConnectorOffsetLocal();
    RefreshCachedShipDimensions();

    if (tickSpeed == UpdateFrequency.Update10)
    { secondsPerTick = 10.0 / 60.0; echoFrequency = 10; }
    else if (tickSpeed == UpdateFrequency.Update100)
    { secondsPerTick = 100.0 / 60.0; echoFrequency = 1; }

    LoadState();
    InitializeMineIndicatorSensors();
    Echo("Ready.");
    Runtime.UpdateFrequency = scriptPaused ? UpdateFrequency.None : tickSpeed;
}

void ResetMovement()
{
    if (movementResetApplied)
        return;
    gyros.Reset();
    thrust.Reset();
    movementResetApplied = true;
}

void ClearPathRecordMineGyroOverride()
{
    if (!pathRecordMineGyroOverrideActive)
        return;
    gyros.Reset();
    pathRecordMineGyroOverrideActive = false;
}

void ClearPathRecordMineBoundaryLock()
{
    if (pathRecordMineCorrectionThrustActive)
    {
        movementResetApplied = false;
        thrust.Reset();
        pathRecordMineCorrectionThrustActive = false;
    }
    ClearPathRecordMineGyroOverride();
}

void HoldPathRecordMineOrientation(MatrixD current, Vector3D forward, Vector3D up)
{
    if (forward.LengthSquared() < 0.001 || up.LengthSquared() < 0.001)
    {
        ClearPathRecordMineGyroOverride();
        return;
    }

    if (IsOrientationAligned(current, forward, up, orientationToleranceDeg))
    {
        ClearPathRecordMineGyroOverride();
        return;
    }

    gyros.FaceVectors(current, forward, up);
    pathRecordMineGyroOverrideActive = true;
}

public void Main (string argument, UpdateType updateSource)
{
    if (updateSource == UpdateType.Update100 || updateSource == UpdateType.Update10 || updateSource == UpdateType.Update1)
    {
        UpdateRuntimeMetrics();
        RefreshTickPose();
        UpdateDockPoseAge();
        if (dockPosePollTicks > 0)
            dockPosePollTicks--;
        else
        {
            dockPosePollTicks = igcPollIntervalTicks - 1;
            UpdateDockPoseFromBroadcast();
            PollCarrierStatus();
            PollMinerCommands();
        }
        if (runtime % echoFrequency == 0)
        {
            WriteEcho();
            if (fullStateDirty)
                SaveState();
            else
                SaveStateProgressOnly();
        }
        UpdatePathRecordAsteroidSpacing();

        if (miningEnabled)
            UpdateMiningState();
        if (dockingState != DockingState.None)
            UpdateDockingState();
        UpdateDockRetry();

        bool reverseActive = UpdatePathRecordReverseReturn();
        bool usedAdjustLock = UpdateMineAreaAdjustState();
        bool usedSoftLock = usedAdjustLock ? true : (reverseActive ? false : UpdatePathRecordState());

        UpdateAutoServiceReturn();
        if (autopilotEnabled && hasTarget)
            Move();
        else if (!usedSoftLock)
            ResetMovement();

        UpdateRecallRunner();
        if (!recallActive)
            UpdatePathRunner();
        UpdatePathRunTimer();
        UpdatePathCompleteBroadcast();
        UpdateOreTransferStartDelay();
        if (oreTransferActive)
            UpdateOreTransfer();
        UpdateIndicatorLight();
        BroadcastMinerProgress();
        if (carrierStatusAgeSeconds < 9999)
            carrierStatusAgeSeconds += secondsPerTick;
        AutoAdvanceMinerLcdMenu();
        if (lcdRefreshTicks > 0)
            lcdRefreshTicks--;
        else
        {
            lcdRefreshTicks = lcdRefreshIntervalTicks - 1;
            UpdateMinerLcd();
        }
        runtime++;
    }
    else
    {
        RemoteCommand(argument);
        SaveState();
        UpdateMinerLcd();
    }
}

void WriteEcho()
{
    StringBuilder sb = _echoSb;
    sb.Clear();
    sb.AppendLine("Autopilot Mode");
    sb.AppendLine(autopilotEnabled ? "State: Enabled" : "State: Disabled");
    if (hasTarget)
        sb.AppendLine($"Target: {targetPosition.ToString("0.00")}");
    else
        sb.AppendLine("Target: <none>");
    sb.AppendLine($"Runtime (last tick): {Runtime.LastRunTimeMs:0.000} ms");
    sb.AppendLine($"Runtime peak (last minute): {runtimePeakLastMinuteMs:0.000} ms");

    Echo(sb.ToString());
}

void UpdateRuntimeMetrics()
{
    double lastTickMs = Runtime.LastRunTimeMs;
    if (lastTickMs > runtimePeakLastMinuteMs)
        runtimePeakLastMinuteMs = lastTickMs;

    runtimePeakWindowElapsedSeconds += secondsPerTick;
    if (runtimePeakWindowElapsedSeconds >= 60.0)
    {
        runtimePeakLastMinuteMs = lastTickMs;
        runtimePeakWindowElapsedSeconds = 0;
    }
}

