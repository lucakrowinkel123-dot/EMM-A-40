}

double GetAdjustAreaWidthMultiple()
{
    if (!areaPlanValid)
        return GetRecordAreaWidthMultiple();
    Vector3D cornerA = areaPlanCornerA;
    Vector3D cornerB = areaPlanCornerB;
    if (mineAreaAdjustStage == MineAreaAdjustStage.Editing)
    {
        Vector3D controlPoint = GetTargetControlPointPosition();
        if (mineAreaAdjustCornerA)
            cornerA = GetMineAreaFootprintCornerFromControlPoint(controlPoint, cornerB, areaPlanForward, areaPlanUp);
        else
            cornerB = GetMineAreaFootprintCornerFromControlPoint(controlPoint, cornerA, areaPlanForward, areaPlanUp);
        CanonicalizeMineAreaCorners(ref cornerA, ref cornerB, areaPlanForward, areaPlanUp);
    }
    return Math.Abs(Vector3D.Dot(cornerB - cornerA, areaPlanRight)) / Math.Max(0.1, MINEW);
}

double GetAdjustAreaHeightMultiple()
{
    if (!areaPlanValid)
        return GetRecordAreaHeightMultiple();
    Vector3D cornerA = areaPlanCornerA;
    Vector3D cornerB = areaPlanCornerB;
    if (mineAreaAdjustStage == MineAreaAdjustStage.Editing)
    {
        Vector3D controlPoint = GetTargetControlPointPosition();
        if (mineAreaAdjustCornerA)
            cornerA = GetMineAreaFootprintCornerFromControlPoint(controlPoint, cornerB, areaPlanForward, areaPlanUp);
        else
            cornerB = GetMineAreaFootprintCornerFromControlPoint(controlPoint, cornerA, areaPlanForward, areaPlanUp);
        CanonicalizeMineAreaCorners(ref cornerA, ref cornerB, areaPlanForward, areaPlanUp);
    }
    return Math.Abs(Vector3D.Dot(cornerB - cornerA, -areaPlanUp)) / Math.Max(0.1, MINEH);
}

