void BeginMinerEdit(int index)
{
    miEditingIndex = index;
    if (index == 1) miEditValue = pathRecordMineDepth;
    else if (index == 2) miEditValue = MINEW;
    else if (index == 3) miEditValue = MINEH;
    else if (index == 4) miEditValue = SPEEDF;
    else if (index == 5) miEditValue = SPEEDB;
    else if (index == 7) miEditValue = lcdRefreshIntervalTicks;
    else if (index == 9) miEditValue = autoServiceCargoTriggerPercent;
    else if (index == 10) miEditValue = autoServiceHydrogenTriggerPercent;
    miEditingValue = true;
}

void AdjustMinerEdit(int direction)
{
    double step = 1.0;
    if (miEditingIndex == 1) step = 2.5;
    else if (miEditingIndex == 2 || miEditingIndex == 3) step = 0.5;
    if (miEditingIndex == 4 || miEditingIndex == 5) step = 0.1;
    if (miEditingIndex == 7) step = 1.0;
    if (miEditingIndex == 9 || miEditingIndex == 10) step = 2.5;
    miEditValue = Math.Max(0, miEditValue + step * direction);
    if (miEditingIndex == 7)
        miEditValue = Math.Max(lcdRefreshMinTicks, miEditValue);
    else if (miEditingIndex == 9 || miEditingIndex == 10)
        miEditValue = MathHelper.Clamp(miEditValue, 0, 100);
}

void SaveMinerEdit()
{
    if (miEditingIndex == 1)
    {
        if ((miLcdMenu == MiLcdMenu.AdjustExcavationZone || miLcdMenu == MiLcdMenu.SetAdjustCorner) &&
            Math.Abs(pathRecordMineDepth - miEditValue) > 0.001)
            mineAreaAdjustmentDirty = true;
        pathRecordMineDepth = miEditValue;
        laneDepth = pathRecordMineDepth;
    }
    else if (miEditingIndex == 2) MINEW = Math.Max(0.1, miEditValue);
    else if (miEditingIndex == 3) MINEH = Math.Max(0.1, miEditValue);
    else if (miEditingIndex == 4) SPEEDF = Math.Max(0.1, miEditValue);
    else if (miEditingIndex == 5) SPEEDB = Math.Max(0.1, miEditValue);
    else if (miEditingIndex == 7) lcdRefreshIntervalTicks = Math.Max(lcdRefreshMinTicks, (int)Math.Round(miEditValue));
    else if (miEditingIndex == 9) autoServiceCargoTriggerPercent = MathHelper.Clamp(miEditValue, 0, 100);
    else if (miEditingIndex == 10) autoServiceHydrogenTriggerPercent = MathHelper.Clamp(miEditValue, 0, 100);
    CancelMinerEdit();
}

void CancelMinerEdit()
{
    miEditingValue = false;
    miEditingIndex = -1;
}

