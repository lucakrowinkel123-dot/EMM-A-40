void UpdatePathRecordAsteroidSpacing()
{
    if (pathRecordAsteroidSensorTicks > 0)
    {
        pathRecordAsteroidSensorTicks--;
        return;
    }
    pathRecordAsteroidSensorTicks = Math.Max(1, pathRecordAsteroidSensorPollTicks) - 1;

    if (!pathRecordingEnabled)
    {
        ClearPathRecordAsteroidSpacing();
        return;
    }

    if (AnyAsteroidSensorActive())
    {
        pathRecordAsteroidClearPolls = 0;
        if (!pathRecordAsteroidDenseActive)
        {
            pathRecordAsteroidDenseActive = true;
            pathRecordAsteroidManualOverride = false;
            if (IsNear(pathRecordMeters, pathRecordAsteroidSparseMeters))
            {
                pathRecordMeters = pathRecordAsteroidDenseMeters;
                pathRecordAsteroidAutoChangedMeters = true;
            }
            else
                pathRecordAsteroidAutoChangedMeters = false;
        }
        return;
    }

    if (!pathRecordAsteroidDenseActive)
        return;

    pathRecordAsteroidClearPolls++;
    if (pathRecordAsteroidClearPolls < Math.Max(1, pathRecordAsteroidClearPollsRequired))
        return;

    if (pathRecordAsteroidAutoChangedMeters && IsNear(pathRecordMeters, pathRecordAsteroidDenseMeters))
        pathRecordMeters = pathRecordAsteroidSparseMeters;
    pathRecordAsteroidDenseActive = false;
    pathRecordAsteroidAutoChangedMeters = false;
    pathRecordAsteroidManualOverride = false;
    pathRecordAsteroidClearPolls = 0;
}

bool AnyAsteroidSensorActive()
{
    foreach (var s in GetAsteroidSensors())
        if (s != null && s.IsActive)
            return true;
    return false;
}

void ClearPathRecordAsteroidSpacing()
{
    if (pathRecordAsteroidAutoChangedMeters && IsNear(pathRecordMeters, pathRecordAsteroidDenseMeters))
