double GetRecordAreaWidthMultiple()
{
    if (pathRecordMineStage != PathRecordMineStage.CornerCaptured)
        return 0;
    Vector3D cornerA = pathRecordMineCornerA;
    Vector3D cornerB = GetTargetControlPointPosition();
    ResolveMineAreaCornersFromControlPoints(ref cornerA, ref cornerB, pathRecordMineForward, pathRecordMineUp);
    Vector3D right = Vector3D.Normalize(Vector3D.Cross(pathRecordMineForward, pathRecordMineUp));
    Vector3D delta = cornerB - cornerA;
    return Math.Abs(Vector3D.Dot(delta, right)) / Math.Max(0.1, MINEW);
}

double GetRecordAreaHeightMultiple()
{
    if (pathRecordMineStage != PathRecordMineStage.CornerCaptured)
        return 0;
    Vector3D cornerA = pathRecordMineCornerA;
    Vector3D cornerB = GetTargetControlPointPosition();
    ResolveMineAreaCornersFromControlPoints(ref cornerA, ref cornerB, pathRecordMineForward, pathRecordMineUp);
    Vector3D down = -Vector3D.Normalize(pathRecordMineUp);
    Vector3D delta = cornerB - cornerA;
    return Math.Abs(Vector3D.Dot(delta, down)) / Math.Max(0.1, MINEH);
}

double GetAreaWidthMultiple()
{
    if (!areaPlanValid)
        return GetRecordAreaWidthMultiple();
    return Math.Abs(Vector3D.Dot(areaPlanCornerB - areaPlanCornerA, areaPlanRight)) / Math.Max(0.1, MINEW);
}

double GetAreaHeightMultiple()
{
    if (!areaPlanValid)
        return GetRecordAreaHeightMultiple();
