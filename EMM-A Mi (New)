void StartAppendPath()
{
    if (!pathMode || pathRecords.Count == 0)
    {
        Echo("AppendPath denied: no active path.");
        OpenMinerMenu(MiLcdMenu.FollowPath);
        return;
    }

    int lastMineArea = -1;
    for (int i = 0; i < pathRecords.Count; i++)
        if (LineLooksLikeMineArea(pathRecords[i]) || pathRecords[i].StartsWith("minearea;", StringComparison.OrdinalIgnoreCase))
            lastMineArea = i;

    if (lastMineArea < 0)
    {
        Echo("AppendPath denied: no Excavation Zone in active path.");
        OpenMinerMenu(MiLcdMenu.FollowPath);
        return;
    }

    appendPathActive = true;
    appendPathStopRecordIndex = lastMineArea + 1;
    suppressPathRuntimeWrite = true;
    fullStateDirty = true;
    pathPaused = false;
    pathPausedNavResume = false;
    OpenMinerMenu(MiLcdMenu.FollowPath);
    miMenuIndex = 4;
    Echo("AppendPath armed. Continuing to last Excavation Zone.");
}

void CompleteAppendPath()
{
    int keepRecordIndex = Math.Max(0, appendPathStopRecordIndex - 1);
    if (!TrimPathTimerAfterRecord(keepRecordIndex))
    {
        Echo("AppendPath failed: could not trim path timer.");
        appendPathActive = false;
        appendPathStopRecordIndex = -1;
        return;
    }

    appendPathActive = false;
    appendPathStopRecordIndex = -1;
    pathMode = false;
    pathPaused = false;
    pathPausedNavResume = false;
    pathRecords.Clear();
    pathIndex = 0;
    StopPathRunTimer();
    suppressPathRuntimeWrite = false;
    updateAsteroidAfterDock = true;
    BeginPathRecording();
    OpenMinerMenu(MiLcdMenu.RecordPath);
    miMenuIndex = 1;
    Echo("AppendPath ready. Last section removed; recording resumed.");
}

bool TrimPathTimerAfterRecord(int recordIndexInclusive)
{
    List<string> lines;
    string timerName;
    if (!TryReadPathTimerLines(out lines, out timerName))
        return false;

    Vector3D ap, af, au;
    int anchorIndex;
    TryFindPathAnchor(lines, out anchorIndex, out ap, out af, out au);

    List<string> kept = new List<string>();
    int recordIndex = -1;
    for (int i = 0; i < lines.Count; i++)
    {
        if (i == anchorIndex)
        {
            kept.Add(lines[i]);
            continue;
        }
        if (LooksLikeRuntimeLine(lines[i]))
            continue;

        recordIndex++;
        if (recordIndex <= recordIndexInclusive)
            kept.Add(lines[i]);
    }

    bool ok = RewritePathTimerLines(kept);
    if (ok)
        RecountPathTimerRecords(kept);
    return ok;
}

