    minerLcd.ContentType = ContentType.TEXT_AND_IMAGE;
    minerLcd.Font = "Debug";
    minerLcd.FontSize = 1.225f;
    minerLcd.TextPadding = 0f;
    minerLcd.Alignment = TextAlignment.LEFT;
}

void PollCarrierStatus()
{
    if (carrierStatusListener == null)
        return;
    while (carrierStatusListener.HasPendingMessage)
    {
        MyIGCMessage msg = carrierStatusListener.AcceptMessage();
        string payload = msg.Data as string;
        if (string.IsNullOrWhiteSpace(payload))
            continue;
        if (payload.Equals("autopilot:on", StringComparison.OrdinalIgnoreCase))
        {
            carrierAutopilotOn = true;
            carrierStatusAgeSeconds = 0;
        }
        else if (payload.Equals("autopilot:off", StringComparison.OrdinalIgnoreCase))
        {
            carrierAutopilotOn = false;
            carrierStatusAgeSeconds = 0;
        }
    }
}

void PollMinerCommands()
{
    if (minerCommandListener == null)
        return;
    while (minerCommandListener.HasPendingMessage)
    {
        MyIGCMessage msg = minerCommandListener.AcceptMessage();
        string payload = msg.Data as string;
        if (string.IsNullOrWhiteSpace(payload))
            continue;
        if (payload.Trim().Equals("Recall", StringComparison.OrdinalIgnoreCase))
            StartRecallPath();
    }
}

void BroadcastMinerProgress()
{
    if (!recallActive)
        return;

    if (minerProgressBroadcastTicks > 0)
    {
        minerProgressBroadcastTicks--;
        return;
    }
    minerProgressBroadcastTicks = minerProgressBroadcastIntervalTicks - 1;
    SendRecallProgress(recallLastDone, recallLastTotal);
}

bool TryHandleMinerLcdCommand(string trimmed)
{
    if (trimmed.Equals("up", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("w", StringComparison.OrdinalIgnoreCase))
    {
        if (miEditingValue) AdjustMinerEdit(1);
        else MoveMinerCursor(-1);
        UpdateMinerLcd();
        return true;
    }
    if (trimmed.Equals("down", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("s", StringComparison.OrdinalIgnoreCase))
    {
        if (miEditingValue) AdjustMinerEdit(-1);
        else MoveMinerCursor(1);
        UpdateMinerLcd();
        return true;
    }
    if (trimmed.Equals("apply", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("e", StringComparison.OrdinalIgnoreCase))
    {
        if (miEditingValue) SaveMinerEdit();
        else SelectMinerCursor();
        UpdateMinerLcd();
        return true;
    }
    if (trimmed.Equals("back", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("cancel", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("c", StringComparison.OrdinalIgnoreCase))
    {
        if (miEditingValue) CancelMinerEdit();
        else OpenMinerMenu(MiLcdMenu.Main);
        UpdateMinerLcd();
        return true;
    }

    if (trimmed.Equals("cursortoggle", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("cursor toggle", StringComparison.OrdinalIgnoreCase))
    {
        miCursorControl = true;
        UpdateMinerLcd();
        Echo("LCD commands: up, down, apply, back.");
        return true;
    }
    return false;
}

int GetMinerMenuItemCount()
{
    if (miLcdMenu == MiLcdMenu.Main) return 4;
    if (miLcdMenu == MiLcdMenu.BehaviorSettings) return miBehaviorPage == 0 ? 8 : 6;
    if (miLcdMenu == MiLcdMenu.RecordPath) return 6;
    if (miLcdMenu == MiLcdMenu.SetMinePose) return 4;
    if (miLcdMenu == MiLcdMenu.SetCornerA) return 4;
    if (miLcdMenu == MiLcdMenu.MineArea) return 4;
    if (miLcdMenu == MiLcdMenu.FollowPath) return IsExcavationZoneActive() ? 5 : 4;
    if (miLcdMenu == MiLcdMenu.AppendPathConfirm) return 2;
    if (miLcdMenu == MiLcdMenu.ConfirmExcavationZone) return 3;
    if (miLcdMenu == MiLcdMenu.AdjustExcavationZone) return 5;
    if (miLcdMenu == MiLcdMenu.SetAdjustCorner) return 3;
    return 1;
}

void MoveMinerCursor(int delta)
{
    int count = Math.Max(1, GetMinerMenuItemCount());
    for (int i = 0; i < count; i++)
    {
        miMenuIndex += delta;
        if (miMenuIndex < 0) miMenuIndex = count - 1;
        if (miMenuIndex >= count) miMenuIndex = 0;
        if (IsMinerMenuIndexEnabled(miMenuIndex))
            return;
    }
}

bool IsMinerMenuIndexEnabled(int index)
{
    if (miLcdMenu == MiLcdMenu.Main && index == 1)
        return MainDockItemVisible();
    if (miLcdMenu == MiLcdMenu.AdjustExcavationZone && index == 1)
        return mineAreaAdjustmentDirty;
    if (miLcdMenu == MiLcdMenu.FollowPath && index == GetFollowPathAppendIndex())
        return !appendPathActive;
    return true;
}

void SelectMinerCursor()
{
    if (miLcdMenu == MiLcdMenu.Main)
    {
        if (miMenuIndex == 0)
        {
            if (pathMode)
            {
                OpenMinerMenu(MiLcdMenu.FollowPath);
                miMenuIndex = 1;
                return;
            }
            if (IsPathRecordingFlowActive())
            {
                if (pathRecordMineConfirmPending)
                    OpenMinerMenu(MiLcdMenu.ConfirmExcavationZone);
                else
                {
                    OpenMinerMenu(MiLcdMenu.RecordPath);
                    miMenuIndex = 1;
                }
                return;
            }
            if (IsExcavationZoneActive())
            {
                OpenMinerMenu(MiLcdMenu.MineArea);
                miMenuIndex = 1;
                return;
            }
            if (PathTimerHasRecordedPath())
            {
                StartPathRecordContinue("pathrecordcontinue");
            }
            else
                StartPathRecording("pathrecordstart");
            OpenMinerMenu(MiLcdMenu.RecordPath);
            miMenuIndex = 1;
            return;
        }
        if (miMenuIndex == 1 && MainDockItemVisible())
        {
            if (IsMinerDocked())
                StartUndock();
            else
                StartManualDock();
            return;
        }
        if (miMenuIndex == 2)
        {
            OpenMinerMenu(MiLcdMenu.BehaviorSettings);
            miMenuIndex = 1;
        }
        else if (miMenuIndex == 3)
            OpenMinerMenu(MiLcdMenu.Info);
        return;
    }

    if (miMenuIndex == 0 && miLcdMenu != MiLcdMenu.ConfirmExcavationZone)
    {
        if (miLcdMenu == MiLcdMenu.AppendPathConfirm)
        {
            OpenMinerMenu(MiLcdMenu.FollowPath);
            miMenuIndex = 4;
            return;
        }
        if (miLcdMenu == MiLcdMenu.AdjustExcavationZone)
        {
            OpenMinerMenu(pathRecordMineConfirmPending ? MiLcdMenu.ConfirmExcavationZone : MiLcdMenu.MineArea);
            return;
        }
        if (miLcdMenu == MiLcdMenu.SetAdjustCorner)
        {
            CancelMineAreaAdjustment();
            OpenMinerMenu(MiLcdMenu.AdjustExcavationZone);
            miMenuIndex = mineAreaAdjustCornerA ? 2 : 3;
            return;
        }
        if (miLcdMenu == MiLcdMenu.MineArea && pathMode)
        {
            OpenMinerMenu(MiLcdMenu.FollowPath);
            miMenuIndex = 1;
            return;
        }
        OpenMinerMenu(MiLcdMenu.Main);
        return;
    }

    if (miLcdMenu == MiLcdMenu.BehaviorSettings)
    {
        if (miMenuIndex == 1)
        {
            miBehaviorPage = (miBehaviorPage + 1) % 2;
            miMenuIndex = 1;
            CancelMinerEdit();
            return;
        }

        int settingIndex = GetMinerBehaviorSettingIndexForRow(miMenuIndex);
        if (settingIndex == 6)
            CycleDepthMode();
        else if (settingIndex == 8)
            autoServiceReturnEnabled = !autoServiceReturnEnabled;
        else if (settingIndex > 0)
            BeginMinerEdit(settingIndex);
        return;
    }

    if (miLcdMenu == MiLcdMenu.RecordPath && miMenuIndex == 1)
    {
        if (pathRecordMineConfirmPending)
        {
            OpenMinerMenu(MiLcdMenu.ConfirmExcavationZone);
            miMenuIndex = 0;
            return;
        }
        if (IsExcavationZoneActive())
        {
            OpenMinerMenu(MiLcdMenu.MineArea);
            miMenuIndex = 1;
            return;
        }
        HandlePathRecordMineStep();
        OpenMinerMenu(MiLcdMenu.SetCornerA);
        miMenuIndex = 1;
        return;
    }
    if (miLcdMenu == MiLcdMenu.RecordPath && miMenuIndex == 2)
    {
        TogglePathRecordMeters();
        return;
    }
    if (miLcdMenu == MiLcdMenu.RecordPath && miMenuIndex == 3)
    {
        StartManualDock();
        return;
    }
    if (miLcdMenu == MiLcdMenu.RecordPath && miMenuIndex == 4)
    {
        StartPathRecordReverseReturn(PathRecordReverseMode.Undo);
        return;
    }
    if (miLcdMenu == MiLcdMenu.RecordPath && miMenuIndex == 5)
    {
        StartPathRecordReverseReturn(PathRecordReverseMode.Cancel);
        OpenMinerMenu(MiLcdMenu.Main);
        return;
    }

    if (miLcdMenu == MiLcdMenu.SetMinePose)
    {
        if (miMenuIndex == 1)
        {
            HandlePathRecordMineStep();
            OpenMinerMenu(MiLcdMenu.SetCornerA);
            miMenuIndex = 1;
        }
        else if (miMenuIndex == 2)
            BeginMinerEdit(1);
        else if (miMenuIndex == 3)
            CancelPathRecordMineSetup();
        return;
    }

    if (miLcdMenu == MiLcdMenu.SetCornerA)
    {
        if (miMenuIndex == 1)
        {
            HandlePathRecordMineStep();
            OpenMinerMenu(MiLcdMenu.MineArea);
            miMenuIndex = 1;
        }
        else if (miMenuIndex == 2)
            BeginMinerEdit(1);
        else if (miMenuIndex == 3)
            CancelPathRecordMineSetup();
        return;
    }

    if (miLcdMenu == MiLcdMenu.MineArea)
    {
        if (miMenuIndex == 1)
            NextHole(false);
        else if (miMenuIndex == 2)
            NextHole(true);
        else if (miMenuIndex == 3)
        {
            OpenMinerMenu(MiLcdMenu.AdjustExcavationZone);
            miMenuIndex = 2;
        }
        return;
    }

    if (miLcdMenu == MiLcdMenu.FollowPath)
    {
        if (miMenuIndex == 1)
            RemoteCommand(pathPaused ? "pathcontinue" : "pathpause");
        else if (miMenuIndex == 2)
            RemoteCommand("pathstop");
        else if (miMenuIndex == 3 && IsExcavationZoneActive())
            OpenMinerMenu(MiLcdMenu.MineArea);
        else if (miMenuIndex == GetFollowPathAppendIndex() && !appendPathActive)
            RemoteCommand("AppendPath");
        return;
    }

    if (miLcdMenu == MiLcdMenu.AppendPathConfirm)
    {
        if (miMenuIndex == 1)
            StartAppendPath();
        return;
    }

    if (miLcdMenu == MiLcdMenu.ConfirmExcavationZone)
    {
        if (miMenuIndex == 0)
            ConfirmRecordedExcavationZone();
        else if (miMenuIndex == 1)
        {
            OpenMinerMenu(MiLcdMenu.AdjustExcavationZone);
            miMenuIndex = 2;
        }
        else if (miMenuIndex == 2)
            CancelRecordedExcavationZone();
        return;
    }

    if (miLcdMenu == MiLcdMenu.AdjustExcavationZone)
    {
        if (miMenuIndex == 1 && mineAreaAdjustmentDirty)
            ConfirmCurrentExcavationZoneAdjustment();
        else if (miMenuIndex == 2)
            RemoteCommand("Adjust Corner A");
        else if (miMenuIndex == 3)
            RemoteCommand("Adjust Corner B");
        else if (miMenuIndex == 4)
            BeginMinerEdit(1);
        return;
    }

    if (miLcdMenu == MiLcdMenu.SetAdjustCorner)
    {
        if (miMenuIndex == 1)
            SetAdjustedMineAreaCorner();
        else if (miMenuIndex == 2)
            BeginMinerEdit(1);
    }
}

