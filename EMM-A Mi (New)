bool IsOrientationAligned(Vector3D forward, Vector3D up, double toleranceDeg)
{
    return IsOrientationAligned(_tickRcMatrix, forward, up, toleranceDeg);
}

bool IsOrientationAligned(MatrixD wm, Vector3D forward, Vector3D up, double toleranceDeg)
{
    double minDot = Math.Cos(Math.Max(0.1, toleranceDeg) * Math.PI / 180.0);
    double forwardLenSq = forward.LengthSquared();
    if (forwardLenSq > 0.001)
    {
        if (Math.Abs(forwardLenSq - 1) > 0.001)
            forward /= Math.Sqrt(forwardLenSq);
        if (Vector3D.Dot(wm.Forward, forward) < minDot)
            return false;
    }
    double upLenSq = up.LengthSquared();
    if (upLenSq > 0.001)
    {
        if (Math.Abs(upLenSq - 1) > 0.001)
            up /= Math.Sqrt(upLenSq);
        if (Vector3D.Dot(wm.Up, up) < minDot)
            return false;
    }
    return true;
}

double GetActiveArrivalTolerance()
{
    if (dockingState == DockingState.DockingFinalApproach)
        return Math.Max(0.05, dockConnectDistance);
    if (dockingState != DockingState.None)
        return Math.Max(0.05, dockPoseTolerance);
    if (miningEnabled)
        return Math.Max(0.05, miningArrivalTolerance);
    return Math.Max(0.05, arrivalTolerance);
}

bool TrySetPositiveDouble(string cmd, int skip, ref double field, string label, string unit = "m/s", double minVal = 0, string fmt = "0.00")
{
    double v;
    if (double.TryParse(cmd.Substring(skip).Trim(), out v) && v > minVal)
    {
        field = v;
        Echo(label + " set to " + field.ToString(fmt) + " " + unit);
        return true;
    }
    Echo("Invalid " + label + " value.");
    return false;
}

bool TrySetPercentDouble(string cmd, int skip, ref double field, string label)
{
    double v;
    if (double.TryParse(cmd.Substring(skip).Trim(), out v) && v >= 0 && v <= 100)
    {
        field = v;
        Echo(label + " set to " + field.ToString("0.0") + "%");
        return true;
    }
    Echo("Invalid " + label + " value. Use 0-100.");
    return false;
}

void RemoteCommand (string command)
{
    if (string.IsNullOrWhiteSpace(command))
        return;

    string trimmed = command.Trim();
    if (TryHandleMinerLcdCommand(trimmed))
        return;

    if (trimmed.StartsWith("Nav;", StringComparison.OrdinalIgnoreCase))
    {
        string navArgs = trimmed.Substring(4).Trim();
        if (!TryParseGpsCommand(navArgs, out targetPosition, out desiredForward, out desiredUp))
        {
            Echo("Invalid Nav command format. Use Nav;GPS:Name:X:Y:Z:|Faceup,Faceforward");
            return;
        }
        hasTarget = true;
        autopilotEnabled = true;
        WriteEcho();
        return;
    }

    if (trimmed.StartsWith("SPEEDF ", StringComparison.OrdinalIgnoreCase))
    {
        TrySetPositiveDouble(trimmed, 7, ref SPEEDF, "SPEEDF");
        return;
    }
    if (trimmed.StartsWith("SPEEDB ", StringComparison.OrdinalIgnoreCase))
    {
        TrySetPositiveDouble(trimmed, 7, ref SPEEDB, "SPEEDB");
        return;
    }
    if (trimmed.StartsWith("MINEH ", StringComparison.OrdinalIgnoreCase))
    {
        TrySetPositiveDouble(trimmed, 6, ref MINEH, "MINEH", "m");
        return;
    }
    if (trimmed.StartsWith("MINEW ", StringComparison.OrdinalIgnoreCase))
    {
        TrySetPositiveDouble(trimmed, 6, ref MINEW, "MINEW", "m");
        return;
    }
    if (trimmed.StartsWith("DEPTHMODE ", StringComparison.OrdinalIgnoreCase))
    {
        string mode = trimmed.Substring(10).Trim().ToUpperInvariant();
        if (mode == "DEFAULT")
            depthMode = DepthMode.Default;
        else if (mode == "ORE")
            depthMode = DepthMode.Ore;
        else if (mode == "ORESTONE")
            depthMode = DepthMode.OrePlusStone;
        else
        {
            Echo("Invalid DEPTHMODE. Use DEFAULT, ORE, or ORESTONE.");
            return;
        }
        Echo($"DEPTHMODE set to {depthMode}");
        return;
    }
    if (trimmed.StartsWith("AUTOSERVICE ", StringComparison.OrdinalIgnoreCase))
    {
        string mode = trimmed.Substring(12).Trim().ToUpperInvariant();
        if (mode == "ON" || mode == "TRUE" || mode == "1")
            autoServiceReturnEnabled = true;
        else if (mode == "OFF" || mode == "FALSE" || mode == "0")
            autoServiceReturnEnabled = false;
        else
        {
            Echo("Invalid AUTOSERVICE. Use ON or OFF.");
            return;
        }
        Echo("AUTOSERVICE " + (autoServiceReturnEnabled ? "ON" : "OFF"));
        return;
    }
    if (trimmed.StartsWith("AUTOCARGO ", StringComparison.OrdinalIgnoreCase))
    {
        TrySetPercentDouble(trimmed, 10, ref autoServiceCargoTriggerPercent, "AUTOCARGO");
        return;
    }
    if (trimmed.StartsWith("AUTOHYDRO ", StringComparison.OrdinalIgnoreCase))
    {
        TrySetPercentDouble(trimmed, 10, ref autoServiceHydrogenTriggerPercent, "AUTOHYDRO");
        return;
    }
    if (trimmed.StartsWith("TOFF ", StringComparison.OrdinalIgnoreCase))
    {
        Vector3D off;
        if (TryParseVector3(trimmed.Substring(5).Trim(), out off))
        {
            TOFFR = off.X;
            TOFFU = off.Y;
            TOFFF = off.Z;
            Echo($"TOFF set. R/U/F = {TOFFR:0.00}/{TOFFU:0.00}/{TOFFF:0.00} m");
        }
        else
            Echo("Invalid TOFF. Use: TOFF r,u,f");
        return;
    }
    if (trimmed.StartsWith("PATHRECORDMETERS ", StringComparison.OrdinalIgnoreCase))
    {
        MarkPathRecordMetersManualChange();
        TrySetPositiveDouble(trimmed, 17, ref pathRecordMeters, "PATHRECORDMETERS", "m", 0.1, "0.0");
        return;
    }
    if (trimmed.StartsWith("PATHRECORDDEPTH ", StringComparison.OrdinalIgnoreCase))
    {
        TrySetPositiveDouble(trimmed, 16, ref pathRecordMineDepth, "PATHRECORDDEPTH", "m", 0, "0.0");
        return;
    }
    if (trimmed.StartsWith("pathrecordstart", StringComparison.OrdinalIgnoreCase))
    {
        StartPathRecording(trimmed);
        return;
    }
    if (trimmed.StartsWith("pathrecordcontinue", StringComparison.OrdinalIgnoreCase))
    {
        StartPathRecordContinue(trimmed);
        return;
    }
    if (trimmed.Equals("pathrecordstop", StringComparison.OrdinalIgnoreCase))
    {
        StopPathRecording();
        return;
    }
    if (trimmed.Equals("pathrecordmine", StringComparison.OrdinalIgnoreCase))
    {
        HandlePathRecordMineStep();
        return;
    }
    if (trimmed.Equals("pathrecordundo", StringComparison.OrdinalIgnoreCase))
    {
        StartPathRecordReverseReturn(PathRecordReverseMode.Undo);
        return;
    }
    if (trimmed.Equals("pathrecordcancel", StringComparison.OrdinalIgnoreCase))
    {
        StartPathRecordReverseReturn(PathRecordReverseMode.Cancel);
        return;
    }
    if (trimmed.Equals("pathcancel", StringComparison.OrdinalIgnoreCase))
    {
        StartPathRecordReverseReturn(PathRecordReverseMode.Cancel);
        return;
    }
    if (trimmed.Equals("appendpath", StringComparison.OrdinalIgnoreCase))
    {
        OpenMinerMenu(MiLcdMenu.AppendPathConfirm);
        miMenuIndex = 1;
        return;
    }
    if (trimmed.Equals("adjust corner a", StringComparison.OrdinalIgnoreCase))
    {
        StartMineAreaCornerAdjustment(true);
        return;
    }
    if (trimmed.Equals("adjust corner b", StringComparison.OrdinalIgnoreCase))
    {
        StartMineAreaCornerAdjustment(false);
        return;
    }

    switch (trimmed.ToLower())
    {
        case "pause":
            pauseResumeAutopilot = autopilotEnabled;
            scriptPaused = true;
            Runtime.UpdateFrequency = UpdateFrequency.None;
            ResetMovement();
            autopilotEnabled = false;
            SetIndicatorOffNow();
            Echo("Paused.");
            break;
        case "resume":
        case "start":
            autopilotEnabled = scriptPaused ? pauseResumeAutopilot : hasTarget;
            scriptPaused = false;
            Runtime.UpdateFrequency = tickSpeed;
            pauseResumeAutopilot = false;
            WriteEcho();
            break;
        case "stop":
        case "reset":
            scriptPaused = false;
            pauseResumeAutopilot = false;
            Runtime.UpdateFrequency = tickSpeed;
            autopilotEnabled = false;
            hasTarget = false;
            targetPosition = Vector3D.Zero;
            desiredForward = Vector3D.Zero;
            desiredUp = Vector3D.Zero;
            miningEnabled = false;
            miningState = MiningState.Idle;
            areaMiningMode = false;
            areaLaneAnchors.Clear();
            areaLaneIndex = 0;
            areaLaneCount = 0;
            areaPlanValid = false;
            ClearAreaLaneSkipState();
            retryCurrentLane = false;
            stuckRetryCount = 0;
            finishAreaAfterBackout = false;
            returnToMinePoseAfterArea = false;
            activeMineAreaRecordIndex = -1;
            activeMineAreaRecordLine = "";
            pathMode = false;
            pathPaused = false;
            pathPausedNavResume = false;
            pathDockPending = false;
            pathRecords.Clear();
            pathIndex = 0;
            ResetPathRunTimer();
            pathAnchorValid = false;
            pathRecordingEnabled = false;
            pathRecordingPaused = false;
            pathRecordingWaitReturn = false;
            pathRecordingStartPendingAfterUndock = false;
            ClearPathRecordAsteroidSpacing();
            pathRecordMineStage = PathRecordMineStage.Idle;
            resumePathRecordingAfterMineArea = false;
            pathRecordMinePreviewActive = false;
            pathRecordMineConfirmPending = false;
            pathRecordMineConfirmHoldActive = false;
            pathRecordPendingMineAreaLine = "";
            mineAreaAdjustStage = MineAreaAdjustStage.None;
            mineAreaAdjustmentDirty = false;
            mineAreaAdjustPendingAfterBackout = false;
            appendPathActive = false;
            appendPathStopRecordIndex = -1;
            suppressPathRuntimeWrite = false;
            updateAsteroidAfterDock = false;
            pathRecordMineCorrectionThrustActive = false;
            ClearPathRecordMineGyroOverride();
            ClearPathRecordReverseState();
            ClearRecallState();
            ClearAutoServiceState();
            oreTransferActive = false;
            oreTransferStartDelayTicks = 0;
            dockingState = DockingState.None;
            ClearDockRetry();
            SetCockpitGyroControl(true);
            activeMaxSpeed = 0;
            SetMineIndicatorSensor(false);
            SetDrills(false);
            ResetMovement();
            SetIndicatorOffNow();
            WriteEcho();
            if (trimmed.Equals("stop", StringComparison.OrdinalIgnoreCase))
                Echo("Stopped.");
            break;
        case "dumpgps":
            DumpCurrentGpsToCustomData();
            break;
        case "cancelmine":
            ClearPathRecordMineBoundaryLock();
            miningEnabled = false;
            miningState = MiningState.Idle;
            areaMiningMode = false;
            areaLaneAnchors.Clear();
            areaLaneIndex = 0;
            areaLaneCount = 0;
            areaPlanValid = false;
            ClearAreaLaneSkipState();
            retryCurrentLane = false;
            finishAreaAfterBackout = false;
            returnToMinePoseAfterArea = false;
            activeMineAreaRecordIndex = -1;
            activeMineAreaRecordLine = "";
            resumePathRecordingAfterMineArea = false;
            mineAreaAdjustStage = MineAreaAdjustStage.None;
            mineAreaAdjustPendingAfterBackout = false;
            mineAreaAdjustmentDirty = false;
            SetCockpitGyroControl(true);
            autopilotEnabled = false;
            hasTarget = false;
            activeMaxSpeed = 0;
            SetDrills(false);
            Echo("Mining cancelled.");
            break;
        case "nexthole":
            NextHole(false);
            break;
        case "nexthole all":
            NextHole(true);
            break;
        case "recall":
            StartRecallPath();
            break;
        case "pathstart":
            StartPathFromTimer();
            break;
        case "pathpause":
            if (recallActive)
            {
                Echo("Cannot pause while recall is active.");
                break;
            }
            if (!pathMode)
                Echo("Path mode is not active.");
            else
            {
                pathPaused = true;
                if (miningEnabled)
                {
                    SetDrills(false);
                    retryCurrentLane = true;
                    miningState = MiningState.Backout;
                    autopilotEnabled = true; // return to anchor
                    Echo("Path mode paused. Returning to current anchor.");
                }
                else if (autopilotEnabled && hasTarget)
                {
                    autopilotEnabled = false; // freeze movement in place
                    pathPausedNavResume = true;
                    Echo("Path mode paused. Movement halted.");
                }
                else
                {
                    Echo("Path mode paused.");
                }
            }
            break;
        case "pathcontinue":
            if (!pathMode)
                Echo("Path mode is not active.");
            else
            {
                pathPaused = false;
                Echo("Path mode resumed.");
                if (!miningEnabled && miningState != MiningState.Idle)
                {
                    // Mining was parked at anchor waiting for pathcontinue — re-enable it
                    miningEnabled = true;
                    autopilotEnabled = true;
                }
                else if (miningEnabled && hasTarget)
                    autopilotEnabled = true;
                else if (pathPausedNavResume && hasTarget)
                {
                    autopilotEnabled = true;
                    pathPausedNavResume = false;
                }
                else if (!autopilotEnabled && !miningEnabled)
                    StartNextPathRecord();
            }
            break;
        case "pathstop":
            StopPathExecution();
            OpenMinerMenu(MiLcdMenu.Main);
            Echo("Path mode stopped.");
            break;
        case "pathclear":
            ClearPathTimerAndCounters(true);
            Echo("Path timer cleared.");
            break;
        case "dock":
            StartManualDock();
            if (!miningEnabled && !areaMiningMode)
                OpenMinerMenu(MiLcdMenu.Main);
            break;
        case "undock":
            StartUndock();
            break;
        case "toffreset":
            TOFFR = 0;
            TOFFU = 0;
            TOFFF = 0;
            Echo("TOFF reset to 0,0,0.");
            break;
        default:
            if (trimmed.StartsWith("minelane;", StringComparison.OrdinalIgnoreCase))
                StartSingleLaneMining(trimmed);
            else if (trimmed.StartsWith("minearea;", StringComparison.OrdinalIgnoreCase))
            {
                activeMineAreaRecordIndex = -1;
                activeMineAreaRecordLine = "";
                StartAreaMining(trimmed);
            }
            break;
    }
}

void StartManualDock()
{
    if (pathRecordingEnabled)
    {
        saveAsteroidAfterDock = !updateAsteroidAfterDock;
        if (!AppendPathRecordLine("dock"))
            Echo($"Warning: could not write 'dock' to timer '{pathTimerTag}'; timer not found.");
        StopPathRecording();
    }
    else
    {
        saveAsteroidAfterDock = false;
        updateAsteroidAfterDock = false;
    }
    StartDock();
}

string GetMainPathMenuText()
{
    if (pathMode)
        return "Path follow tools.";
    if (IsPathRecordingFlowActive())
        return "Path recording tools";
    if (IsExcavationZoneActive())
        return "Excavation Zone";
    return PathTimerHasRecordedPath() ? "Continue recording path" : "Record path";
}

bool IsPathRecordingFlowActive()
{
    return pathRecordingEnabled &&
           (pathRecordingPaused ||
            pathRecordingWaitReturn ||
            pathRecordMineStage != PathRecordMineStage.Idle ||
            pathRecordMineConfirmPending ||
            IsExcavationZoneActive());
}

void StartPathRecording(string command)
{
    ClearPathTimerAndCounters(true);
    updateAsteroidAfterDock = false;
    StartPathRecordingCore(command);
}

void StartPathRecordContinue(string command)
{
    if (IsExcavationZoneActive())
    {
        Echo("Path recording continue denied: Excavation Zone is active.");
        OpenMinerMenu(MiLcdMenu.MineArea);
        miMenuIndex = 1;
        return;
    }
    StartPathRecordingCore(command);
}

void StartPathRecordingCore(string command)
{
    string[] parts = command.Split(new[] { ';', ' ' }, StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length > 1)
    {
        double v;
        if (double.TryParse(parts[1], out v) && v > 0.1)
        {
            MarkPathRecordMetersManualChange();
            pathRecordMeters = v;
        }
    }

    if (IsMinerDocked())
    {
        pathRecordingStartPendingAfterUndock = false;
        if (!MainDockItemVisible())
        {
            Echo("Path recording denied: carrier autopilot is active.");
            return;
        }
        StartUndock();
        if (dockingState == DockingState.UndockingRecompile ||
            dockingState == DockingState.UndockingToPose)
        {
            pathRecordingStartPendingAfterUndock = true;
            Echo("Path recording will start at dock pose.");
        }
        return;
    }

    BeginPathRecording();
}

void BeginPathRecording()
{
    pathRecordingStartPendingAfterUndock = false;
    pathRecordingEnabled = true;
    pathRecordingPaused = false;
    pathRecordingWaitReturn = false;
    pathRecordAsteroidSensorTicks = 0;
    pathRecordMineStage = PathRecordMineStage.Idle;
    pathRecordMineCorrectionThrustActive = false;
    pathRecordMineConfirmHoldActive = false;
    ClearPathRecordMineGyroOverride();
    pathRecordLastPos = rc.GetPosition();
    // Seed the anchor header now so it exists before any path points are appended.
    Vector3D _ap, _af, _au;
    TryGetOrInitPathTimerAnchor(out _ap, out _af, out _au);
    Echo($"Path recording started ({pathRecordMeters:0.0} m interval).");
}

void StopPathRecording()
{
    bool reverseWasActive = pathRecordReverseMode != PathRecordReverseMode.None;
    ReleasePathRecordMineConfirmHold();
    ClearPathRecordAsteroidSpacing();
    ClearPathRecordReverseState();
    pathRecordingEnabled = false;
    pathRecordingPaused = false;
    pathRecordingWaitReturn = false;
    pathRecordingStartPendingAfterUndock = false;
    pathRecordMineStage = PathRecordMineStage.Idle;
    resumePathRecordingAfterMineArea = false;
    pathRecordMinePreviewActive = false;
    pathRecordMineConfirmPending = false;
    pathRecordMineConfirmHoldActive = false;
    pathRecordPendingMineAreaLine = "";
    mineAreaAdjustStage = MineAreaAdjustStage.None;
    mineAreaAdjustmentDirty = false;
    mineAreaAdjustPendingAfterBackout = false;
    if (pathRecordMineCorrectionThrustActive)
    {
        movementResetApplied = false;
        thrust.Reset();
    }
    pathRecordMineCorrectionThrustActive = false;
    ClearPathRecordMineGyroOverride();
    if (reverseWasActive)
    {
        autopilotEnabled = false;
        hasTarget = false;
        activeMaxSpeed = 0;
        ResetMovement();
    }
    SetCockpitGyroControl(true);
    SetMineIndicatorSensor(false);
    Echo("Path recording stopped.");
}

bool UpdatePathRecordState()
{
    if (pathRecordingEnabled &&
        !pathRecordingPaused &&
        !pathRecordingWaitReturn &&
        pathRecordMineStage == PathRecordMineStage.Idle &&
        !pathRecordMineConfirmPending)
    {
        Vector3D now = _tickRcPosition;
        if (Vector3D.DistanceSquared(now, pathRecordLastPos) >= pathRecordMeters * pathRecordMeters)
        {
            SavePathGpsRecord();
            pathRecordLastPos = now;
        }
    }

    if (pathRecordingWaitReturn)
    {
        SetCockpitGyroControl(false);
        if (IsAtTargetPose(pathRecordMineEntry, pathRecordMineForward, pathRecordMineUp))
        {
            autopilotEnabled = false;
            hasTarget = false;
            pathRecordingWaitReturn = false;
            pathRecordMineStage = PathRecordMineStage.Idle;
            pathRecordMineCorrectionThrustActive = false;
            ClearPathRecordMineGyroOverride();
            pathRecordLastPos = _tickRcPosition;
            SetCockpitGyroControl(true);
            SetMineIndicatorSensor(false);
            if (pathRecordMinePreviewActive)
            {
                pathRecordMinePreviewActive = false;
                pathRecordMineConfirmPending = true;
                ArmPathRecordMineConfirmHold();
                OpenMinerMenu(MiLcdMenu.ConfirmExcavationZone);
                miMenuIndex = 0;
                Echo("Excavation Zone ready. Confirm or adjust.");
                return false;
            }
            // Auto-start area mining for the area just recorded (corners cleared after to prevent re-trigger)
            if ((pathRecordMineCornerB - pathRecordMineCornerA).LengthSquared() > 0.01)
            {
                StartAreaMiningWithCorners(
                    pathRecordMineCornerA, pathRecordMineCornerB,
                    pathRecordMineUp, pathRecordMineForward,
                    pathRecordMineDepth);
                if (miningEnabled)
                {
                    resumePathRecordingAfterMineArea = true;
                    pathRecordMinePreviewActive = true;
                    Echo("Started minearea preview for recorded area.");
                    return false;
                }
            }
            resumePathRecordingAfterMineArea = false;
            pathRecordingPaused = false;
            Echo("Returned to mine entry. Path recording resumed.");
        }
        return false;
    }

    if (pathRecordMineStage == PathRecordMineStage.EntryCaptured)
    {
        SetCockpitGyroControl(false);
        HoldPathRecordMineOrientation(_tickRcMatrix, pathRecordMineForward, pathRecordMineUp);
        if (pathRecordMineCorrectionThrustActive)
        {
            movementResetApplied = false;
            thrust.Reset();
            pathRecordMineCorrectionThrustActive = false;
        }
        return true;
    }

    if (pathRecordMineStage != PathRecordMineStage.CornerCaptured)
    {
        if (cockpitGyroControlForcedOff)
            SetCockpitGyroControl(true);
        return false;
    }

    SetCockpitGyroControl(false);
    HoldPathRecordMineOrientation(_tickRcMatrix, pathRecordMineForward, pathRecordMineUp);
    if (pathRecordMineCorrectionThrustActive)
    {
        movementResetApplied = false;
        thrust.Reset();
        pathRecordMineCorrectionThrustActive = false;
    }
    return true;
}

void StartPathRecordReverseReturn(PathRecordReverseMode mode)
{
    if (!pathRecordingEnabled)
    {
        Echo("Start path recording first: pathrecordstart");
        return;
    }
    if (pathRecordMineStage != PathRecordMineStage.Idle)
    {
        Echo("Cannot reverse path record while pathrecordmine is active.");
        return;
    }
    if (pathRecordingWaitReturn)
    {
        Echo("Cannot reverse path record while returning from pathrecordmine.");
        return;
    }
    if (pathMode)
    {
        Echo("Cannot reverse path record while path playback is active.");
        return;
    }
    if (miningEnabled)
    {
        Echo("Cannot reverse path record while mining is active.");
        return;
    }
    if (dockingState != DockingState.None)
    {
        Echo("Cannot reverse path record while docking is active.");
        return;
    }
    if (pathRecordReverseMode != PathRecordReverseMode.None)
    {
        Echo("Path record reverse return is already active.");
        return;
    }
    if (autopilotEnabled && hasTarget)
    {
        Echo("Cannot reverse path record while autopilot target is active.");
        return;
    }

    if (mode == PathRecordReverseMode.Cancel && IsWithinDockRangeForPathCancel())
    {
        CancelPathRecordingWithoutReverse();
        return;
    }

    List<string> lines;
    string timerName;
    if (!TryReadPathTimerLines(out lines, out timerName))
    {
        Echo($"Path timer '{pathTimerTag}' not found.");
        return;
    }

    int anchorIndex;
    Vector3D anchorPos, anchorForward, anchorUp;
    if (!TryFindPathAnchor(lines, out anchorIndex, out anchorPos, out anchorForward, out anchorUp))
    {
        Echo("Path timer has no valid anchor.");
        return;
    }

    List<string> reverseRecords = new List<string>();
    int keepLineCount = anchorIndex + 1;

    if (mode == PathRecordReverseMode.Undo)
    {
        int lastMineAreaIndex = -1;
        Vector3D cornerA, cornerB, areaUp, areaForward;
        double depth;
        for (int i = anchorIndex + 1; i < lines.Count; i++)
            if (LineLooksLikeMineArea(lines[i]) &&
                TryParseMineAreaLine(lines[i], anchorPos, out cornerA, out cornerB, out areaUp, out areaForward, out depth))
                lastMineAreaIndex = i;

        if (lastMineAreaIndex >= 0)
        {
            Vector3D lastCornerA, lastCornerB, lastAreaUp, lastAreaForward;
            if (!TryParseMineAreaLine(lines[lastMineAreaIndex], anchorPos,
                                      out lastCornerA, out lastCornerB, out lastAreaUp, out lastAreaForward, out depth))
            {
                Echo("Cannot undo: latest mine area record is invalid.");
                return;
            }

            Vector3D pos, fwd, up;
            for (int i = lines.Count - 1; i > lastMineAreaIndex; i--)
            {
                if (TryParsePathPointLine(lines[i], anchorPos, out pos, out fwd, out up))
                    reverseRecords.Add(lines[i]);
            }
            reverseRecords.Add(FormatPathPointLine(GetInferredMineAreaEntryPose(lastCornerA, lastCornerB), anchorPos, lastAreaForward, lastAreaUp));
            keepLineCount = lastMineAreaIndex + 1;
        }
        else
        {
            Vector3D pos, fwd, up;
            for (int i = lines.Count - 1; i > anchorIndex; i--)
                if (TryParsePathPointLine(lines[i], anchorPos, out pos, out fwd, out up))
                    reverseRecords.Add(lines[i]);
            reverseRecords.Add(FormatPathPointLine(anchorPos, anchorPos, anchorForward, anchorUp));
            keepLineCount = anchorIndex + 1;
        }
    }
    else
    {
        Vector3D pos, fwd, up;
        for (int i = lines.Count - 1; i > anchorIndex; i--)
            if (TryParsePathPointLine(lines[i], anchorPos, out pos, out fwd, out up))
                reverseRecords.Add(lines[i]);
        reverseRecords.Add(FormatPathPointLine(anchorPos, anchorPos, anchorForward, anchorUp));
        keepLineCount = anchorIndex + 1;
    }

    pathRecordReverseMode = mode;
    pathRecordReverseRecords = reverseRecords;
    pathRecordReverseIndex = 0;
    pathRecordReverseKeepLineCount = keepLineCount;
    pathRecordingPaused = true;
    pathRecordingWaitReturn = false;
    pathAnchorValid = true;
    pathAnchorPos = anchorPos;
    pathAnchorForward = anchorForward;
    pathAnchorUp = anchorUp;
    fullStateDirty = true;
    StartNextPathRecordReverseTarget();
}

bool UpdatePathRecordReverseReturn()
{
    if (pathRecordReverseMode == PathRecordReverseMode.None)
        return false;

    if (autopilotEnabled && hasTarget)
    {
        if (IsAtTargetPose(targetPosition, desiredForward, desiredUp))
        {
            autopilotEnabled = false;
            hasTarget = false;
            activeMaxSpeed = 0;
        }
        return true;
    }

    if (pathRecordReverseIndex < pathRecordReverseRecords.Count)
    {
        StartNextPathRecordReverseTarget();
        return true;
    }

    CompletePathRecordReverseReturn();
    return true;
}

void StartNextPathRecordReverseTarget()
{
    while (pathRecordReverseMode != PathRecordReverseMode.None &&
           pathRecordReverseIndex < pathRecordReverseRecords.Count)
    {
        string record = pathRecordReverseRecords[pathRecordReverseIndex];
        pathRecordReverseIndex++;
        if (ExecuteReversePathRecord(record))
            return;
    }
}

bool ExecuteReversePathRecord(string rawRecord)
{
    if (string.IsNullOrWhiteSpace(rawRecord))
        return false;

    string record = rawRecord.Trim();
    if (record.StartsWith("\"") && record.EndsWith("\"") && record.Length >= 2)
        record = record.Substring(1, record.Length - 2).Trim();
    if (string.IsNullOrWhiteSpace(record))
        return false;
    if (record.Equals("dock", StringComparison.OrdinalIgnoreCase) ||
        record.Equals("undock", StringComparison.OrdinalIgnoreCase) ||
        LineLooksLikeMineArea(record))
        return false;

    Vector3D pos, fwd, up;
    if (pathAnchorValid && TryParsePathPointLine(record, pathAnchorPos, out pos, out fwd, out up))
    {
        targetPosition = pos;
        desiredForward = fwd;
        desiredUp = up;
        hasTarget = true;
        autopilotEnabled = true;
        activeMaxSpeed = SPEEDB;
        return true;
    }

    string navCmd = null;
    if (record.StartsWith("Nav;", StringComparison.OrdinalIgnoreCase))
        navCmd = record.Substring(4).Trim();
    else if (record.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
        navCmd = record;

    if (navCmd != null && TryParseGpsCommand(navCmd, out pos, out fwd, out up))
    {
        targetPosition = pos;
        desiredForward = fwd;
        desiredUp = up;
        hasTarget = true;
        autopilotEnabled = true;
        activeMaxSpeed = SPEEDB;
        return true;
    }

    return false;
}

void CompletePathRecordReverseReturn()
{
    PathRecordReverseMode mode = pathRecordReverseMode;
    if (mode == PathRecordReverseMode.Undo)
    {
        List<string> lines;
        string timerName;
        if (TryReadPathTimerLines(out lines, out timerName))
        {
            int keep = Math.Max(0, Math.Min(pathRecordReverseKeepLineCount, lines.Count));
            List<string> kept = new List<string>();
            for (int i = 0; i < keep; i++)
                kept.Add(lines[i]);
            RewritePathTimerLines(kept);
            RecountPathTimerRecords(kept);
        }

        ClearPathRecordReverseState();
        ClearPathRecordAsteroidSpacing();
        pathRecordingEnabled = true;
        pathRecordingPaused = false;
        pathRecordingWaitReturn = false;
        pathRecordMineStage = PathRecordMineStage.Idle;
        resumePathRecordingAfterMineArea = false;
        pathRecordMinePreviewActive = false;
        pathRecordMineConfirmPending = false;
        pathRecordMineConfirmHoldActive = false;
        pathRecordPendingMineAreaLine = "";
        pathRecordMineCorrectionThrustActive = false;
        ClearPathRecordMineGyroOverride();
        pathRecordLastPos = rc.GetPosition();
        SetMineIndicatorSensor(false);
        Echo("Path record undo complete. Recording resumed.");
        return;
    }

    ClearPathRecordReverseState();
    ClearPathRecordAsteroidSpacing();
    pathRecordingEnabled = false;
    pathRecordingPaused = false;
    pathRecordingWaitReturn = false;
    pathRecordMineStage = PathRecordMineStage.Idle;
    resumePathRecordingAfterMineArea = false;
    pathRecordMinePreviewActive = false;
    pathRecordMineConfirmPending = false;
    pathRecordMineConfirmHoldActive = false;
    pathRecordPendingMineAreaLine = "";
    pathRecordMineCorrectionThrustActive = false;
    ClearPathRecordMineGyroOverride();
    SetCockpitGyroControl(true);
    SetMineIndicatorSensor(false);
    ClearPathTimerAndCounters(false);
    Echo("Path recording cancelled. Returned to anchor and cleared path.");
}

bool IsWithinDockRangeForPathCancel()
{
    RefreshDockHardware();
    if (!HasFreshCarrierPose())
        return false;

    Vector3D from = minerConnector != null ? minerConnector.GetPosition() : _tickRcPosition;
    double range = Math.Max(0.1, dockPoseGateDistance);
    return Vector3D.DistanceSquared(from, GetDockPosePosition()) <= range * range;
}

void CancelPathRecordingWithoutReverse()
{
    ReleasePathRecordMineConfirmHold();
    ClearPathRecordAsteroidSpacing();
    ClearPathRecordReverseState();
    pathRecordingEnabled = false;
    pathRecordingPaused = false;
    pathRecordingWaitReturn = false;
    pathRecordMineStage = PathRecordMineStage.Idle;
    resumePathRecordingAfterMineArea = false;
    pathRecordMinePreviewActive = false;
    pathRecordMineConfirmPending = false;
    pathRecordMineConfirmHoldActive = false;
    pathRecordPendingMineAreaLine = "";
    pathRecordMineCorrectionThrustActive = false;
    ClearPathRecordMineGyroOverride();
    SetCockpitGyroControl(true);
    SetMineIndicatorSensor(false);
    ClearPathTimerAndCounters(false);
    Echo("Path recording cancelled near dock. Cleared path without reverse return.");
}

void ClearPathRecordReverseState()
{
    pathRecordReverseMode = PathRecordReverseMode.None;
    pathRecordReverseRecords.Clear();
    pathRecordReverseIndex = 0;
    pathRecordReverseKeepLineCount = 0;
}

void HandlePathRecordMineStep()
{
    if (!pathRecordingEnabled)
    {
        Echo("Start path recording first: pathrecordstart");
        return;
    }
    if (pathRecordMineConfirmPending)
    {
        Echo("Confirm or cancel the current Excavation Zone first.");
        return;
    }
    if (pathRecordingWaitReturn || pathRecordMineStage == PathRecordMineStage.ReturningToEntry)
    {
        Echo("Mine pose is still returning. Wait until the Excavation Zone is ready.");
        return;
    }

    if (pathRecordMineStage == PathRecordMineStage.Idle)
    {
        pathRecordMineEntry = GetTargetControlPointPosition();
        pathRecordMineCornerA = pathRecordMineEntry;
        pathRecordMineCornerB = Vector3D.Zero;
        // Live recording (soft-lock, return-to-entry, auto-mine) uses the miner's own
        // orientation. The on-disk record projects corners into the anchor's coordinate frame.
        pathRecordMineUp = Vector3D.Normalize(rc.WorldMatrix.Up);
        pathRecordMineForward = Vector3D.Normalize(rc.WorldMatrix.Forward);
        pathRecordingPaused = true;
        pathRecordMineStage = PathRecordMineStage.CornerCaptured;
        pathRecordMineCorrectionThrustActive = false;
        SetMineIndicatorSensor(true);
        TriggerPathPointFlash();
        Echo("Mine step 1/2 saved. Move freely to Corner B.");
        return;
    }

    if (pathRecordMineStage == PathRecordMineStage.EntryCaptured)
    {
        pathRecordMineCornerA = GetTargetControlPointPosition();
        pathRecordMineStage = PathRecordMineStage.CornerCaptured;
        TriggerPathPointFlash();
        Echo("Corner A saved. Move freely to Corner B.");
        return;
    }

    if (pathRecordMineStage != PathRecordMineStage.CornerCaptured)
    {
        Echo("Mine pose is busy. Wait until the current step finishes.");
        return;
    }

    Vector3D cornerB = GetTargetControlPointPosition();
    pathRecordMineCornerB = cornerB;
    ResolveMineAreaCornersFromControlPoints(ref pathRecordMineCornerA, ref pathRecordMineCornerB, pathRecordMineForward, pathRecordMineUp);
    pathRecordMineEntry = GetInferredMineAreaEntryPose(pathRecordMineCornerA, pathRecordMineCornerB);
    ClearPathRecordMineBoundaryLock();
    pathRecordMineCounter++;
    Vector3D anchorPos, anchorForward, anchorUp;
    if (!TryGetOrInitPathTimerAnchor(out anchorPos, out anchorForward, out anchorUp))
    {
        Echo($"Mine area record ready but path timer/anchor missing.");
        return;
    }
    string rec = FormatMineAreaLine(pathRecordMineCornerA, pathRecordMineCornerB, anchorPos, pathRecordMineForward, pathRecordMineUp, pathRecordMineDepth);
    if (!AppendPathRecordLine(rec))
    {
        Echo($"Mine area record ready but timer tag '{pathTimerTag}' not found.");
        return;
    }
    int estimatedLaneCount;
    if (TryEstimateMineAreaLaneCount(pathRecordMineCornerA, pathRecordMineCornerB, pathRecordMineUp, pathRecordMineForward, out estimatedLaneCount))
    {
        List<int> emptySkipList = new List<int>();
        AppendPathRecordLine(FormatMineAreaSkipMetaLine(MINEH, MINEW, estimatedLaneCount, emptySkipList));
    }
    activeMineAreaRecordIndex = FindPathTimerRecordIndexByLine(rec);
    activeMineAreaRecordLine = rec;
    pathRecordPendingMineAreaLine = rec;
    TriggerPathPointFlash();

    targetPosition = pathRecordMineEntry;
    desiredUp = pathRecordMineUp;
    desiredForward = pathRecordMineForward;
    hasTarget = true;
    autopilotEnabled = true;
    activeMaxSpeed = SPEEDB;
    pathRecordingWaitReturn = true;
    pathRecordMineStage = PathRecordMineStage.ReturningToEntry;
    Echo("Mine area saved. Returning to entry point...");
}

void ProjectMineAreaToShallowPlane(ref Vector3D cornerA, ref Vector3D cornerB, Vector3D forward)
{
    if (forward.LengthSquared() < 0.001)
        return;

    Vector3D fwd = Vector3D.Normalize(forward);
    double depthA = Vector3D.Dot(cornerA, fwd);
    double depthB = Vector3D.Dot(cornerB, fwd);
    double shallowDepth = Math.Min(depthA, depthB);
    cornerA -= fwd * (depthA - shallowDepth);
    cornerB -= fwd * (depthB - shallowDepth);
}

bool TryGetMineAreaBasis(Vector3D forward, Vector3D up, out Vector3D forwardN, out Vector3D upN, out Vector3D rightN, out Vector3D downN)
{
    forwardN = Vector3D.Zero;
    upN = Vector3D.Zero;
    rightN = Vector3D.Zero;
    downN = Vector3D.Zero;

    if (forward.LengthSquared() <= 0.001 || up.LengthSquared() <= 0.001)
        return false;

    forwardN = Vector3D.Normalize(forward);
    upN = Vector3D.Normalize(up);
    rightN = Vector3D.Cross(forwardN, upN);
    if (rightN.LengthSquared() <= 0.001)
        return false;

    rightN = Vector3D.Normalize(rightN);
    downN = -upN;
    return true;
}

void ResolveMineAreaCornersFromControlPoints(ref Vector3D cornerA, ref Vector3D cornerB, Vector3D forward, Vector3D up)
{
    Vector3D forwardN, upN, right, down;
    if (!TryGetMineAreaBasis(forward, up, out forwardN, out upN, out right, out down))
    {
        ProjectMineAreaToShallowPlane(ref cornerA, ref cornerB, forward);
        return;
    }

    ProjectMineAreaToShallowPlane(ref cornerA, ref cornerB, forwardN);

    double halfWidth = Math.Max(0, MINEW) * 0.5;
    double halfHeight = Math.Max(0, MINEH) * 0.5;
    double aRight = Vector3D.Dot(cornerA, right);
    double bRight = Vector3D.Dot(cornerB, right);
    double aDown = Vector3D.Dot(cornerA, down);
    double bDown = Vector3D.Dot(cornerB, down);

    double minRight = Math.Min(aRight, bRight) - halfWidth;
    double maxRight = Math.Max(aRight, bRight) + halfWidth;
    double minDown = Math.Min(aDown, bDown) - halfHeight;
    double maxDown = Math.Max(aDown, bDown) + halfHeight;

    Vector3D origin = cornerA +
        right * (minRight - aRight) +
        down * (minDown - aDown);
    cornerA = origin;
    cornerB = origin +
        right * (maxRight - minRight) +
        down * (maxDown - minDown);
}

Vector3D ProjectPointToMineAreaPlane(Vector3D point, Vector3D planePoint, Vector3D forward)
{
    if (forward.LengthSquared() <= 0.001)
        return point;

    Vector3D forwardN = Vector3D.Normalize(forward);
    double pointDepth = Vector3D.Dot(point, forwardN);
    double planeDepth = Vector3D.Dot(planePoint, forwardN);
    return point - forwardN * (pointDepth - planeDepth);
}

Vector3D GetMineAreaFootprintCornerFromControlPoint(Vector3D controlPoint, Vector3D otherCorner, Vector3D forward, Vector3D up)
{
    Vector3D forwardN, upN, right, down;
    if (!TryGetMineAreaBasis(forward, up, out forwardN, out upN, out right, out down))
        return controlPoint;

    controlPoint = ProjectPointToMineAreaPlane(controlPoint, otherCorner, forwardN);
    Vector3D delta = controlPoint - otherCorner;
    double signRight = Vector3D.Dot(delta, right) >= 0 ? 1 : -1;
    double signDown = Vector3D.Dot(delta, down) >= 0 ? 1 : -1;
    return controlPoint +
        right * signRight * Math.Max(0, MINEW) * 0.5 +
        down * signDown * Math.Max(0, MINEH) * 0.5;
}

void CanonicalizeMineAreaCorners(ref Vector3D cornerA, ref Vector3D cornerB, Vector3D forward, Vector3D up)
{
    Vector3D forwardN, upN, right, down;
    if (!TryGetMineAreaBasis(forward, up, out forwardN, out upN, out right, out down))
    {
        ProjectMineAreaToShallowPlane(ref cornerA, ref cornerB, forward);
        return;
    }

    ProjectMineAreaToShallowPlane(ref cornerA, ref cornerB, forwardN);

    double aRight = Vector3D.Dot(cornerA, right);
    double bRight = Vector3D.Dot(cornerB, right);
    double aDown = Vector3D.Dot(cornerA, down);
    double bDown = Vector3D.Dot(cornerB, down);

    double minRight = Math.Min(aRight, bRight);
    double maxRight = Math.Max(aRight, bRight);
    double minDown = Math.Min(aDown, bDown);
    double maxDown = Math.Max(aDown, bDown);

    Vector3D origin = cornerA +
        right * (minRight - aRight) +
        down * (minDown - aDown);
    cornerA = origin;
    cornerB = origin +
        right * (maxRight - minRight) +
        down * (maxDown - minDown);
}

Vector3D GetInferredMineAreaEntryPose(Vector3D cornerA, Vector3D cornerB)
{
    return (cornerA + cornerB) * 0.5;
}

// SE-style GPS string for human copy-paste (used by `dumpgps` only). Persistent records use
// the compact anchor+delta format instead.
string FormatCurrentGps(string name)
{
    Vector3D p = rc.GetPosition();
    Vector3D f = Vector3D.Normalize(rc.WorldMatrix.Forward);
    Vector3D u = Vector3D.Normalize(rc.WorldMatrix.Up);
    return $"GPS:{name}:{p.X:0.00}:{p.Y:0.00}:{p.Z:0.00}:|{u.X:0.0000},{u.Y:0.0000},{u.Z:0.0000},{f.X:0.0000},{f.Y:0.0000},{f.Z:0.0000}";
}

void SavePathGpsRecord()
{
    pathRecordCounter++;
    string idx = pathRecordCounter.ToString("000");
    Vector3D anchorPos, anchorForward, anchorUp;
    if (!TryGetOrInitPathTimerAnchor(out anchorPos, out anchorForward, out anchorUp))
    {
        Echo($"Could not save path point {idx}; no path-timer anchor available.");
        return;
    }
    Vector3D p = rc.GetPosition();
    Vector3D f = Vector3D.Normalize(rc.WorldMatrix.Forward);
    Vector3D u = Vector3D.Normalize(rc.WorldMatrix.Up);
    string line = FormatPathPointLine(p, anchorPos, f, u);
    if (AppendPathRecordLine(line))
    {
        TriggerPathPointFlash();
        Echo($"Path point saved: {idx}");
    }
    else
        Echo($"Could not save path point {idx}; timer tag '{pathTimerTag}' not found.");
}

int GetIndicatorDelayTicks()
{
    return Math.Max(1, (int)Math.Ceiling(indicatorLightDelaySeconds / Math.Max(0.001, secondsPerTick)));
}

int GetFlashGreenTicks()
{
    return Math.Max(1, (int)Math.Ceiling(indicatorFlashGreenSeconds / Math.Max(0.001, secondsPerTick)));
}

void TriggerPathPointFlash()
{
    int minTicks = GetIndicatorDelayTicks() + GetFlashGreenTicks();
    indicatorFlashTicksRemaining = Math.Max(indicatorFlashTicksRemaining, minTicks);
    PlayPathRecordSound();
}

void PlayPathRecordSound()
{
    if (pathRecordSoundBlock == null)
        pathRecordSoundBlock = GetBlock<IMySoundBlock>(pathRecordSoundBlockName, true);
    if (pathRecordSoundBlock == null)
        return;

    pathRecordSoundBlock.SelectedSound = pathRecordSoundName;
    pathRecordSoundBlock.Play();
}

void UpdateIndicatorLight()
{
    if (indicatorLight == null)
        indicatorLight = GetBlock<IMyLightingBlock>(indicatorLightName, true);
    if (indicatorLight == null)
        return;

    bool flashGreen = indicatorFlashTicksRemaining > 0;
    if (indicatorFlashTicksRemaining > 0)
        indicatorFlashTicksRemaining--;

    bool desiredOn = autopilotEnabled || flashGreen;
    Color desiredOnColor = flashGreen ? indicatorFlashColor : indicatorAutopilotColor;

    if (desiredOn)
    {
        if (indicatorTransition == IndicatorTransitionState.WaitNeutralAfterDisable)
        {
            indicatorTransition = IndicatorTransitionState.None;
            indicatorDelayTicksRemaining = 0;
        }

        if (!indicatorLight.Enabled)
        {
            if (indicatorTransition != IndicatorTransitionState.WaitEnableAfterColor)
            {
                SetIndicatorColor(desiredOnColor); // set color first
                indicatorDelayTicksRemaining = GetIndicatorDelayTicks();
                indicatorTransition = IndicatorTransitionState.WaitEnableAfterColor;
            }
            else
            {
                SetIndicatorColor(desiredOnColor);
                indicatorDelayTicksRemaining--;
                if (indicatorDelayTicksRemaining <= 0)
                {
                    SetIndicatorEnabled(true); // enable after delay
                    indicatorTransition = IndicatorTransitionState.None;
                }
            }
        }
        else
        {
            SetIndicatorColor(desiredOnColor);
            indicatorTransition = IndicatorTransitionState.None;
            indicatorDelayTicksRemaining = 0;
        }
        return;
    }

    if (indicatorTransition == IndicatorTransitionState.WaitEnableAfterColor)
    {
        indicatorTransition = IndicatorTransitionState.None;
        indicatorDelayTicksRemaining = 0;
    }

    if (indicatorLight.Enabled)
    {
        SetIndicatorEnabled(false); // off first
        indicatorDelayTicksRemaining = GetIndicatorDelayTicks();
        indicatorTransition = IndicatorTransitionState.WaitNeutralAfterDisable;
        return;
    }

    if (indicatorTransition == IndicatorTransitionState.WaitNeutralAfterDisable)
    {
        indicatorDelayTicksRemaining--;
        if (indicatorDelayTicksRemaining <= 0)
        {
            SetIndicatorColor(indicatorNeutralColor); // neutral after delay while off
            indicatorTransition = IndicatorTransitionState.None;
        }
        return;
    }

    SetIndicatorColor(indicatorNeutralColor);
}

// Returns the anchor for the path timer. If the timer is empty, seeds a header using the
// miner's current RC position and orientation as the anchor reference point.
bool TryGetOrInitPathTimerAnchor(out Vector3D anchorPos, out Vector3D anchorForward, out Vector3D anchorUp)
{
    anchorPos = Vector3D.Zero;
    anchorForward = Vector3D.Zero;
    anchorUp = Vector3D.Zero;

    IMyTimerBlock timer = FindPathTimer();
    if (timer == null)
        return false;

    string existing = timer.CustomData ?? "";
    string[] lines = existing.Split(new [] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
    bool hasAny = false;
    foreach (string raw in lines)
    {
        string t = raw.Trim();
        if (string.IsNullOrWhiteSpace(t)) continue;
        hasAny = true;
        if (TryParseCarrierAnchorLine(t, out anchorPos, out anchorForward, out anchorUp))
            return true;
    }
    if (hasAny)
        return false; // existing content but no anchor line — don't overwrite with a fresh seed

    // Empty timer: seed with the miner's current RC position and orientation as anchor.
    if (rc == null)
    {
        Echo("Path record: no remote control to anchor on.");
        return false;
    }
    anchorPos = rc.GetPosition();
    anchorForward = Vector3D.Normalize(rc.WorldMatrix.Forward);
    anchorUp = Vector3D.Normalize(rc.WorldMatrix.Up);
    timer.CustomData = FormatCarrierAnchorLine(anchorPos, anchorForward, anchorUp) + "\n";
    TriggerPathPointFlash();
    return true;
}

bool AppendPathRecordLine(string line)
{
    IMyTimerBlock timer = FindPathTimer();
    if (timer == null)
        return false;
    string existing = timer.CustomData ?? "";
    if (!string.IsNullOrWhiteSpace(existing) && !existing.EndsWith("\n"))
        existing += "\n";
    timer.CustomData = existing + line + "\n";
    return true;
}

bool TryReadPathTimerLines(out List<string> lines, out string timerName)
{
    lines = new List<string>();
    timerName = "";
    IMyTimerBlock timer = FindPathTimer();
    if (timer == null)
        return false;

    timerName = timer.CustomName;
    string data = timer.CustomData ?? "";
    string[] rawLines = data.Split(new [] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
    foreach (string raw in rawLines)
    {
        string rec = raw.Trim();
        if (string.IsNullOrWhiteSpace(rec))
            continue;
        if (rec.StartsWith("\"") && rec.EndsWith("\"") && rec.Length >= 2)
            rec = rec.Substring(1, rec.Length - 2).Trim();
        if (!string.IsNullOrWhiteSpace(rec))
            lines.Add(rec);
    }
    return true;
}

bool PathTimerHasRecordedPath()
{
    List<string> lines;
    string timerName;
    if (!TryReadPathTimerLines(out lines, out timerName))
        return false;

    Vector3D ap, af, au;
    int anchorIndex;
    if (!TryFindPathAnchor(lines, out anchorIndex, out ap, out af, out au))
        anchorIndex = -1;

    for (int i = 0; i < lines.Count; i++)
    {
        if (i == anchorIndex)
            continue;
        string line = lines[i];
        if (LooksLikeRuntimeLine(line))
            continue;
        if (IsPathMetadataRecord(line))
            continue;
        if (!string.IsNullOrWhiteSpace(line))
            return true;
    }
    return false;
}

bool RewritePathTimerLines(List<string> lines)
{
    IMyTimerBlock timer = FindPathTimer();
    if (timer == null)
        return false;

    StringBuilder sb = new StringBuilder();
    foreach (string raw in lines)
    {
        string rec = raw == null ? "" : raw.Trim();
        if (string.IsNullOrWhiteSpace(rec))
            continue;
        sb.AppendLine(rec);
    }
    timer.CustomData = sb.ToString();
    return true;
}

bool IsMineAreaSkipMetaLine(string line)
{
    if (string.IsNullOrWhiteSpace(line))
        return false;
    string trimmed = line.Trim();
    return trimmed.StartsWith(mineAreaSkipMetaPrefix, StringComparison.OrdinalIgnoreCase);
}

bool IsPathMetadataRecord(string line)
{
    return IsMineAreaSkipMetaLine(line);
}

bool LaneListContains(List<int> lanes, int laneIndex)
{
    for (int i = 0; i < lanes.Count; i++)
        if (lanes[i] == laneIndex)
            return true;
    return false;
}

void AddLaneIndexUnique(List<int> lanes, int laneIndex)
{
    if (laneIndex < 0 || LaneListContains(lanes, laneIndex))
        return;
    lanes.Add(laneIndex);
}

void SortLaneIndexes(List<int> lanes)
{
    lanes.Sort();
}

string FormatMineAreaSkipMetaLine(double mineHeight, double mineWidth, int laneCount, List<int> skipLanes)
{
    if (skipLanes == null)
        skipLanes = new List<int>();
    SortLaneIndexes(skipLanes);
    return mineAreaSkipMetaPrefix + FormatCompactMineAreaSkipMetaPayload(mineHeight, mineWidth, laneCount, skipLanes);
}

string FormatCompactMineAreaSkipMetaPayload(double mineHeight, double mineWidth, int laneCount, List<int> skipLanes)
{
    StringBuilder sb = new StringBuilder();
    sb.Append(FormatCompactMetaDouble(mineHeight));
    sb.Append(",");
    sb.Append(FormatCompactMetaDouble(mineWidth));
    sb.Append(",");
    sb.Append(laneCount);
    sb.Append(":");
    sb.Append(FormatCompactLaneRanges(skipLanes));
    return sb.ToString();
}

string FormatCompactMetaDouble(double value)
{
    return value.ToString("0.##");
}

string FormatCompactLaneRanges(List<int> skipLanes)
{
    if (skipLanes == null || skipLanes.Count == 0)
        return "";

    StringBuilder sb = new StringBuilder();
    int start = skipLanes[0] + 1;
    int end = start;
    for (int i = 1; i <= skipLanes.Count; i++)
    {
        int lane = i < skipLanes.Count ? skipLanes[i] + 1 : -1;
        if (lane == end + 1)
        {
            end = lane;
            continue;
        }

        if (sb.Length > 0)
            sb.Append(",");
        sb.Append(start);
        if (end != start)
        {
            sb.Append("-");
            sb.Append(end);
        }
        start = lane;
        end = lane;
    }
    return sb.ToString();
}

bool TryParseMineAreaSkipMetaLine(string line, out double mineHeight, out double mineWidth, out int laneCount, List<int> skipLanes)
{
    mineHeight = 0;
    mineWidth = 0;
    laneCount = 0;
    skipLanes.Clear();

    if (!IsMineAreaSkipMetaLine(line))
        return false;

    string trimmed = line.Trim();
    if (!TryParseCompactMineAreaSkipMetaPayload(trimmed.Substring(mineAreaSkipMetaPrefix.Length),
                                                out mineHeight, out mineWidth, out laneCount, skipLanes))
        return false;
    SortLaneIndexes(skipLanes);
    return mineHeight > 0 && mineWidth > 0 && laneCount > 0;
}

bool TryParseCompactMineAreaSkipMetaPayload(string payload, out double mineHeight, out double mineWidth, out int laneCount, List<int> skipLanes)
{
    mineHeight = 0;
    mineWidth = 0;
    laneCount = 0;
    if (string.IsNullOrWhiteSpace(payload))
        return false;

    string[] parts = payload.Split(':');
    if (parts.Length < 1 || parts.Length > 2)
        return false;

    string[] header = parts[0].Split(',');
    if (header.Length != 3)
        return false;

    if (!double.TryParse(header[0].Trim(), out mineHeight) ||
        !double.TryParse(header[1].Trim(), out mineWidth) ||
        !int.TryParse(header[2].Trim(), out laneCount))
        return false;

    if (parts.Length == 2 && !string.IsNullOrWhiteSpace(parts[1]))
    {
        string[] laneParts = parts[1].Split(',');
        for (int i = 0; i < laneParts.Length; i++)
            if (!TryAddCompactLaneToken(laneParts[i].Trim(), skipLanes))
                return false;
    }

    return mineHeight > 0 && mineWidth > 0 && laneCount > 0;
}

bool TryAddCompactLaneToken(string token, List<int> lanes)
{
    if (string.IsNullOrWhiteSpace(token))
        return true;

    int dash = token.IndexOf('-');
    if (dash > 0)
    {
        int first;
        int last;
        if (!int.TryParse(token.Substring(0, dash).Trim(), out first) ||
            !int.TryParse(token.Substring(dash + 1).Trim(), out last) ||
            first <= 0 ||
            last < first)
            return false;

        for (int lane = first; lane <= last; lane++)
            AddLaneIndexUnique(lanes, lane - 1);
        return true;
    }

    int oneBasedLane;
    if (!int.TryParse(token.Trim(), out oneBasedLane) || oneBasedLane <= 0)
        return false;
    AddLaneIndexUnique(lanes, oneBasedLane - 1);
    return true;
}

bool MineAreaSkipMetaMatches(double mineHeight, double mineWidth, int laneCount)
{
    return Math.Abs(mineHeight - MINEH) < 0.01 &&
           Math.Abs(mineWidth - MINEW) < 0.01 &&
           laneCount == areaLaneCount;
}

bool FindMineAreaRecordLineIndex(List<string> lines, int recordIndexToFind, out int lineIndex)
{
    lineIndex = -1;
    Vector3D ap, af, au;
    int anchorIndex;
    TryFindPathAnchor(lines, out anchorIndex, out ap, out af, out au);
    int recordIndex = -1;
    for (int i = 0; i < lines.Count; i++)
    {
        if (i == anchorIndex || LooksLikeRuntimeLine(lines[i]))
            continue;
        recordIndex++;
        if (recordIndex == recordIndexToFind)
        {
            lineIndex = i;
            return true;
        }
    }
    return false;
}

int FindPathTimerRecordIndexByLine(string targetLine)
{
    if (string.IsNullOrWhiteSpace(targetLine))
        return -1;

    List<string> lines;
    string timerName;
    if (!TryReadPathTimerLines(out lines, out timerName))
        return -1;

    Vector3D ap, af, au;
    int anchorIndex;
    TryFindPathAnchor(lines, out anchorIndex, out ap, out af, out au);
    int recordIndex = -1;
    int foundIndex = -1;
    for (int i = 0; i < lines.Count; i++)
    {
        if (i == anchorIndex || LooksLikeRuntimeLine(lines[i]))
            continue;
        recordIndex++;
        if (string.Equals(lines[i].Trim(), targetLine.Trim(), StringComparison.OrdinalIgnoreCase))
            foundIndex = recordIndex;
    }
    return foundIndex;
}

bool UpsertMineAreaSkipMetaRecord(int mineAreaRecordIndex, string metaLine)
{
    List<string> lines;
    string timerName;
    if (!TryReadPathTimerLines(out lines, out timerName))
        return false;

    int mineAreaLineIndex;
    if (!FindMineAreaRecordLineIndex(lines, mineAreaRecordIndex, out mineAreaLineIndex))
        return false;

    int metaIndex = mineAreaLineIndex + 1;
    if (metaIndex < lines.Count && IsMineAreaSkipMetaLine(lines[metaIndex]))
        lines[metaIndex] = metaLine;
    else
        lines.Insert(metaIndex, metaLine);

    bool ok = RewritePathTimerLines(lines);
    if (ok)
        RecountPathTimerRecords(lines);
    return ok;
}

void UpsertActiveMineAreaSkipMetaRecord()
{
    if (activeMineAreaRecordIndex < 0)
        return;

    List<int> merged = new List<int>();
    for (int i = 0; i < areaSkipLaneIndexes.Count; i++)
        AddLaneIndexUnique(merged, areaSkipLaneIndexes[i]);
    for (int i = 0; i < areaEmptyLaneIndexes.Count; i++)
        AddLaneIndexUnique(merged, areaEmptyLaneIndexes[i]);

    string metaLine = FormatMineAreaSkipMetaLine(MINEH, MINEW, areaLaneCount, merged);
    if (UpsertMineAreaSkipMetaRecord(activeMineAreaRecordIndex, metaLine))
    {
        if (activeMineAreaRecordIndex + 1 < pathRecords.Count && IsMineAreaSkipMetaLine(pathRecords[activeMineAreaRecordIndex + 1]))
            pathRecords[activeMineAreaRecordIndex + 1] = metaLine;
        else if (activeMineAreaRecordIndex + 1 <= pathRecords.Count)
            pathRecords.Insert(activeMineAreaRecordIndex + 1, metaLine);
    }
}

bool TryFindPathAnchor(List<string> lines, out int anchorIndex, out Vector3D anchorPos, out Vector3D anchorForward, out Vector3D anchorUp)
{
    anchorIndex = -1;
    anchorPos = Vector3D.Zero;
    anchorForward = Vector3D.Zero;
    anchorUp = Vector3D.Zero;
    for (int i = 0; i < lines.Count; i++)
    {
        if (TryParseCarrierAnchorLine(lines[i], out anchorPos, out anchorForward, out anchorUp))
        {
            anchorIndex = i;
            return true;
        }
    }
    return false;
}

void RecountPathTimerRecords(List<string> lines)
{
    pathRecordCounter = 0;
    pathRecordMineCounter = 0;

    int anchorIndex;
    Vector3D anchorPos, anchorForward, anchorUp;
    if (!TryFindPathAnchor(lines, out anchorIndex, out anchorPos, out anchorForward, out anchorUp))
        return;

    for (int i = anchorIndex + 1; i < lines.Count; i++)
    {
        Vector3D pos, fwd, up;
        Vector3D cornerA, cornerB, areaUp, areaForward;
        double depth;
        if (LineLooksLikeMineArea(lines[i]) &&
            TryParseMineAreaLine(lines[i], anchorPos, out cornerA, out cornerB, out areaUp, out areaForward, out depth))
            pathRecordMineCounter++;
        else if (TryParsePathPointLine(lines[i], anchorPos, out pos, out fwd, out up))
            pathRecordCounter++;
    }
}

