string GetMineAreaLaneHeaderText()
{
    int total = GetMineAreaLaneHeaderTotal();
    if (total <= 0)
        return pathRecordCounter.ToString("000");

    int lane = GetMineAreaLaneHeaderCurrent(total);
    return lane.ToString() + "/" + total.ToString();
}

int GetMineAreaLaneHeaderTotal()
{
    if (areaLaneCount > 0)
        return areaLaneCount;
    if (areaPlanRows > 0 && areaPlanCols > 0)
        return areaPlanRows * areaPlanCols;

    int total;
    if (TryEstimateMineAreaLaneCount(pathRecordMineCornerA, pathRecordMineCornerB, pathRecordMineUp, pathRecordMineForward, out total))
        return total;
    if (TryEstimateMineAreaLaneCount(areaPlanCornerA, areaPlanCornerB, areaPlanUp, areaPlanForward, out total))
        return total;
    return 0;
}

int GetMineAreaLaneHeaderCurrent(int total)
{
    if (total <= 0)
        return 0;
    if (pathRecordMineConfirmPending && areaLaneCount <= 0)
        return total;

    int completed = areaLaneIndex;
    if (miningState == MiningState.Backout ||
        finishAreaAfterBackout ||
        mineAreaAdjustStage != MineAreaAdjustStage.None ||
        mineAreaAdjustPendingAfterBackout)
        completed = areaLaneIndex + 1;

    if (completed < 0)
        completed = 0;
    if (completed > total)
        completed = total;
    return completed;
}

bool TryEstimateMineAreaLaneCount(Vector3D cornerA, Vector3D cornerB, Vector3D up, Vector3D forward, out int total)
{
    total = 0;
    if ((cornerB - cornerA).LengthSquared() <= 0.01 || up.LengthSquared() <= 0.001 || forward.LengthSquared() <= 0.001)
        return false;

    Vector3D upN = Vector3D.Normalize(up);
    Vector3D forwardN = Vector3D.Normalize(forward);
    Vector3D right = Vector3D.Cross(forwardN, upN);
    if (right.LengthSquared() <= 0.001 || MINEH <= 0 || MINEW <= 0)
        return false;

    right = Vector3D.Normalize(right);
    Vector3D delta = cornerB - cornerA;
    double height = Math.Abs(Vector3D.Dot(delta, -upN));
    double width = Math.Abs(Vector3D.Dot(delta, right));
    int rows = Math.Max(1, (int)Math.Ceiling(height / MINEH));
    int cols = Math.Max(1, (int)Math.Ceiling(width / MINEW));
    total = rows * cols;
    return total > 0;
}

