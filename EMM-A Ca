// ---- SaveAsteroid ----

void SaveAsteroid()
{
    Echo("SaveAsteroid: simulating recompile...");
    SimulateRecompile();

    if (rc == null)
    {
        Echo("SaveAsteroid: no remote control found after recompile. Aborting.");
        return;
    }

    ZoneDescriptor activeZone;
    IMyTimerBlock activeZoneDb;
    string zoneReason;
    if (!TryGetActiveZone(out activeZone, out activeZoneDb, out zoneReason))
    {
        Echo("SaveAsteroid: " + zoneReason);
        return;
    }

    // Determine next asteroid number and which DB timer it belongs to
    int asteroidNum   = FindNextAsteroidNumber();
    string label      = asteroidNum.ToString("D3");
    int dbIndex       = (asteroidNum - 1) / asteroidsPerDb + 1;
    string dbTimerName = asteroidDbTagPfx + dbIndex.ToString("D2");

    Echo($"SaveAsteroid: saving Asteroid {label} -> {dbTimerName}");

    // Carrier position and orientation from RC
    string carrierGps = FormatCarrierGps();

    // Ore totals from miner containers
    var oreMap = CollectMinerOre();
    EnsureOreNamesListed(oreMap);

    // Path lines from miner's Path timer
    List<string> pathLines = ReadMinerPathLines();

    // Build the Asteroid Record
    var sb = new StringBuilder();
    sb.AppendLine(asteroidHeaderLine);
    sb.AppendLine("Asteroid " + label);
    sb.AppendLine();
    sb.AppendLine("Carrier pos:");
    sb.AppendLine(carrierGps);
    sb.AppendLine();
    sb.AppendLine("Ore:");
    if (oreMap.Count == 0)
    {
        sb.AppendLine("(none)");
    }
    else
    {
        var oreNames = new List<string>(oreMap.Keys);
        oreNames.Sort(StringComparer.OrdinalIgnoreCase);
        foreach (string ore in oreNames)
        {
            long rounded = (long)Math.Round(oreMap[ore]);
            sb.AppendLine(ore + " " + FormatOreAmount(rounded));
        }
    }
    sb.AppendLine(asteroidHeaderLine);
    sb.AppendLine("undock");
    foreach (string line in pathLines)
        sb.AppendLine(line);

    // Insert record into the Asteroid DB timer in ascending number order.
    IMyTimerBlock dbTimer = FindTimerByExactName(dbTimerName);
    if (dbTimer == null)
    {
        Echo($"SaveAsteroid: timer '{dbTimerName}' not found. Aborting.");
        return;
    }
    string existingDb = dbTimer.CustomData ?? "";
    string newRecord  = sb.ToString(); // starts with asteroidHeaderLine
    bool inserted = false;
    int searchFrom = 0;
    while (true)
    {
        int sepIdx = existingDb.IndexOf(asteroidHeaderLine, searchFrom, StringComparison.Ordinal);
        if (sepIdx < 0) break;
        // Skip newlines after the separator to reach the first content line
        int pos = sepIdx + asteroidHeaderLine.Length;
        while (pos < existingDb.Length && (existingDb[pos] == '\n' || existingDb[pos] == '\r'))
            pos++;
        int lineEnd = existingDb.IndexOfAny(new char[] { '\n', '\r' }, pos);
        if (lineEnd < 0) lineEnd = existingDb.Length;
        string firstLine = existingDb.Substring(pos, lineEnd - pos).Trim();
        if (firstLine.StartsWith("Asteroid ", StringComparison.OrdinalIgnoreCase))
        {
            int existingNum;
            if (int.TryParse(firstLine.Substring(9).Trim(), out existingNum) && existingNum > asteroidNum)
            {
                string before = existingDb.Substring(0, sepIdx);
                if (before.Length > 0 && !before.EndsWith("\n")) before += "\n";
                dbTimer.CustomData = before + newRecord + existingDb.Substring(sepIdx);
                inserted = true;
                break;
            }
        }
        searchFrom = sepIdx + 1;
    }
    if (!inserted)
    {
        if (existingDb.Length > 0 && !existingDb.EndsWith("\n")) existingDb += "\n";
        dbTimer.CustomData = existingDb + newRecord;
    }

    // Update the Zone DB (GPS + ore summary + mined status)
    UpdateZoneDb(activeZone, asteroidNum, carrierGps, oreMap);

    Echo($"SaveAsteroid: Asteroid {label} saved in zone '{activeZone.Name}'.");
    ClearMinerPathTimer("SaveAsteroid");
}

