void GetCarrierZoneStats(out string zoneName, out int mined, out int selected)
{
    if (runtime - cachedCarrierZoneStatsRuntime < carrierZoneStatsRefreshIntervalTicks)
    {
        zoneName = cachedCarrierZoneName;
        mined = cachedCarrierZoneMined;
        selected = cachedCarrierZoneSelected;
        return;
    }

    zoneName = "---";
    mined = 0;
    selected = 0;

    ZoneDescriptor zone;
    IMyTimerBlock zoneDb;
    string reason;
    if (!TryGetActiveZone(out zone, out zoneDb, out reason))
    {
        cachedCarrierZoneName = zoneName;
        cachedCarrierZoneMined = mined;
        cachedCarrierZoneSelected = selected;
        cachedCarrierZoneStatsRuntime = runtime;
        return;
    }
    zoneName = string.IsNullOrWhiteSpace(zone.Name) ? "---" : zone.Name;

    HashSet<string> enabledOres;
    string oreReason;
    bool haveOres = TryGetEnabledOreSet(out enabledOres, out oreReason) && enabledOres.Count > 0;
    foreach (var rec in GetZoneDbRecordsCached(zone.Name, zone.TimerName))
    {
        if (rec.Status.Equals("Complete", StringComparison.OrdinalIgnoreCase) ||
            rec.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase))
            mined++;
        if (!haveOres || RecordHasEnabledOre(rec, enabledOres))
            selected++;
    }

    cachedCarrierZoneName = zoneName;
    cachedCarrierZoneMined = mined;
    cachedCarrierZoneSelected = selected;
    cachedCarrierZoneStatsRuntime = runtime;
}

string FormatCarrierMiningDistance()
{
    if (fullAutoEscapeStage == 1)
        return FormatDistance(Vector3D.Distance(GetControlledPosition(), fullAutoEscapeLinePoint));
    if (fullAutoEscapeStage == 2)
        return FormatDistance(Vector3D.Distance(GetControlledPosition(), fullAutoEscapeFrontPoint));
    if (mineSequenceState == MineSequenceState.ReturningToFrontApproach)
        return FormatDistance(Vector3D.Distance(GetControlledPosition(), mineCompletionApproachPoint));

    ZoneAsteroidRecord rec;
    ZoneDescriptor zone;
    string reason;
    if (mineAsteroidNum > 0 && TryGetZoneAsteroidRecordInActiveZone(mineAsteroidNum, out rec, out zone, out reason))
        return FormatDistance(Vector3D.Distance(GetControlledPosition(), rec.Position));
    if (fullAutoActiveAsteroid > 0 && TryGetZoneAsteroidRecordInActiveZone(fullAutoActiveAsteroid, out rec, out zone, out reason))
        return FormatDistance(Vector3D.Distance(GetControlledPosition(), rec.Position));

    return "---";
}

string FormatDistance(double meters)
{
    if (meters >= 1000)
        return FormatThreeSignificantDigits(meters / 1000.0) + " km";
    return FormatThreeSignificantDigits(meters) + " m";
}

string FormatThreeSignificantDigits(double value)
{
    double abs = Math.Abs(value);
    if (abs >= 100)
        return value.ToString("0");
    if (abs >= 10)
        return value.ToString("0.0");
    return value.ToString("0.00");
}

