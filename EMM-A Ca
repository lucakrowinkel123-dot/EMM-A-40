void LoadState()
{
    MyIni ini;
    if (!ReadStateIni(out ini)) return;
    _hasProgressState = ReadProgressState();

    string s;
    int n;
    double d;
    Vector3D v;

    autopilotEnabled = StateBool(ini, "autopilotEnabled", autopilotEnabled);
    scriptPaused = StateBool(ini, "scriptPaused", scriptPaused);
    pauseResumeAutopilot = StateBool(ini, "pauseResumeAutopilot", pauseResumeAutopilot);
    hasTarget = StateBool(ini, "hasTarget", hasTarget);
    if (TryParseV3(StateString(ini, "targetPosition", V3ToString(targetPosition)), out v)) targetPosition = v;
    if (TryParseV3(StateString(ini, "desiredForward", V3ToString(desiredForward)), out v)) desiredForward = v;
    if (TryParseV3(StateString(ini, "desiredUp", V3ToString(desiredUp)), out v)) desiredUp = v;
    if (double.TryParse(StateString(ini, "activeMaxSpeed", activeMaxSpeed.ToString("R")), out d)) activeMaxSpeed = d;
    if (int.TryParse(StateString(ini, "carrierAutopilotMode", ((int)carrierAutopilotMode).ToString()), out n))
    {
        if (n < 0 || n > (int)CarrierAutopilotMode.CruiseDecel)
            n = 0;
        carrierAutopilotMode = (CarrierAutopilotMode)n;
    }
    if (TryParseV3(StateString(ini, "cruiseFinalPosition", V3ToString(cruiseFinalPosition)), out v)) cruiseFinalPosition = v;
    if (TryParseV3(StateString(ini, "cruiseFinalForward", V3ToString(cruiseFinalForward)), out v)) cruiseFinalForward = v;
    if (TryParseV3(StateString(ini, "cruiseFinalUp", V3ToString(cruiseFinalUp)), out v)) cruiseFinalUp = v;
    if (TryParseV3(StateString(ini, "cruiseStagingPosition", V3ToString(cruiseStagingPosition)), out v)) cruiseStagingPosition = v;
    if (TryParseV3(StateString(ini, "cruiseDirection", V3ToString(cruiseDirection)), out v)) cruiseDirection = v;
    if (double.TryParse(StateString(ini, "measuredFlipSeconds", measuredFlipSeconds.ToString("R")), out d)) measuredFlipSeconds = Math.Max(0, d);
    if (double.TryParse(StateString(ini, "measuredFlipMass", measuredFlipMass.ToString("R")), out d)) measuredFlipMass = Math.Max(0, d);
    if (double.TryParse(StateString(ini, "maxSpeed", maxSpeed.ToString("R")), out d)) maxSpeed = d;
    if (double.TryParse(StateString(ini, "orientationToleranceDeg", orientationToleranceDeg.ToString("R")), out d)) orientationToleranceDeg = d;
    if (double.TryParse(StateString(ini, "arrivalTolerance", arrivalTolerance.ToString("R")), out d)) arrivalTolerance = d;
    if (double.TryParse(StateString(ini, "goToBubbleRadiusMeters", goToBubbleRadiusMeters.ToString("R")), out d)) goToBubbleRadiusMeters = d;
    if (int.TryParse(StateString(ini, "fullAutoRetryTicks", fullAutoRetryTicks.ToString()), out n)) fullAutoRetryTicks = n;
    if (int.TryParse(StateString(ini, "fullAutoRecordsPerTick", fullAutoRecordsPerTick.ToString()), out n)) fullAutoRecordsPerTick = Math.Max(1, n);
    if (double.TryParse(StateString(ini, "shortRangeDistanceMeters", shortRangeDistanceMeters.ToString("R")), out d)) shortRangeDistanceMeters = Math.Max(100, d);
    if (double.TryParse(StateString(ini, "cruiseOffsetMeters", cruiseOffsetMeters.ToString("R")), out d)) cruiseOffsetMeters = Math.Max(100, d);
    if (double.TryParse(StateString(ini, "thrustLimitKn", thrustLimitKn.ToString("R")), out d)) thrustLimitKn = Math.Max(1, d);
    if (double.TryParse(StateString(ini, "thrustUsePercent", thrustUsePercent.ToString("R")), out d)) thrustUsePercent = MathHelper.Clamp(d, 1, 100);
    if (int.TryParse(StateString(ini, "caThrustStepIndex", caThrustStepIndex.ToString()), out n)) caThrustStepIndex = Math.Max(0, Math.Min(GetCarrierThrustStepCount() - 1, n));
    if (double.TryParse(StateString(ini, "accelerationLimit", accelerationLimit.ToString("R")), out d)) accelerationLimit = Math.Max(0.1, d);
    turnTestEnabled = StateBool(ini, "turnTestEnabled", turnTestEnabled);
    if (double.TryParse(StateString(ini, "goToLeadDistanceMeters", goToLeadDistanceMeters.ToString("R")), out d)) goToLeadDistanceMeters = d;
    if (int.TryParse(StateString(ini, "lcdRefreshIntervalTicks", lcdRefreshIntervalTicks.ToString()), out n)) lcdRefreshIntervalTicks = Math.Max(lcdRefreshMinTicks, n);
