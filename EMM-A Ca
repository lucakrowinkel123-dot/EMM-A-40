string FormatOreList(List<string> ores)
{
    if (ores == null || ores.Count == 0)
        return "(none)";

    var names = new List<string>(ores);
    names.RemoveAll(s => string.IsNullOrWhiteSpace(s));
    names.Sort(StringComparer.OrdinalIgnoreCase);
    if (names.Count == 0)
        return "(none)";
    if (names.Count == 1)
        return names[0];
    if (names.Count == 2)
        return names[0] + " & " + names[1];

    var sb = new StringBuilder();
    for (int i = 0; i < names.Count; i++)
    {
        if (i > 0)
            sb.Append(i == names.Count - 1 ? " & " : ", ");
        sb.Append(names[i]);
    }
    return sb.ToString();
}

string FormatTicksAsMinutes(int ticks)
{
    int totalSeconds = Math.Max(0, (int)Math.Round(ticks / 60.0));
    int minutes = totalSeconds / 60;
    int seconds = totalSeconds % 60;
    return minutes.ToString("00") + ":" + seconds.ToString("00");
}

