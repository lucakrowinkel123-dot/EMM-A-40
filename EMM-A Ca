    else if (caEditingIndex == 7) lcdRefreshIntervalTicks = Math.Max(lcdRefreshMinTicks, (int)Math.Round(caEditValue));
    else if (caEditingIndex == 8) fullAutoRecordsPerTick = Math.Max(1, (int)Math.Round(caEditValue));
