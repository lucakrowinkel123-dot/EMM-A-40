void UpdateCarrierOreCacheScan()
{
    carrierOreScanElapsedSeconds += secondsPerTick;
    if (!carrierOreScanActive)
    {
        if (carrierOreScanElapsedSeconds < carrierOreScanIntervalSeconds && carrierOreCache.Count > 0)
            return;
        StartCarrierOreCacheScan();
    }

    if (!carrierOreScanActive)
        return;

    if (carrierOreScanIndex >= carrierOreScanBlocks.Count)
    {
        carrierOreCache = new Dictionary<string, double>(carrierOreScanTotals, StringComparer.OrdinalIgnoreCase);
        carrierOreScanTotals.Clear();
        carrierOreScanBlocks.Clear();
        carrierOreScanItems.Clear();
        carrierOreScanActive = false;
        carrierOreScanElapsedSeconds = 0;
        return;
    }

    ScanCarrierOreBlock(carrierOreScanBlocks[carrierOreScanIndex]);
    carrierOreScanIndex++;
}

bool ShouldUpdateCarrierOreCacheScan()
{
    return caLcdMenu == CaLcdMenu.SelectOres;
}

void StopCarrierOreCacheScan()
{
    carrierOreScanElapsedSeconds += secondsPerTick;
    if (!carrierOreScanActive)
        return;
    carrierOreScanBlocks.Clear();
    carrierOreScanItems.Clear();
    carrierOreScanTotals.Clear();
    carrierOreScanIndex = 0;
    carrierOreScanActive = false;
}

void StartCarrierOreCacheScan()
{
    carrierOreScanBlocks.Clear();
    carrierOreScanTotals.Clear();
    carrierOreScanItems.Clear();
    carrierOreScanIndex = 0;
    GridTerminalSystem.GetBlocksOfType(carrierOreScanBlocks, b =>
        b.CubeGrid.EntityId == Me.CubeGrid.EntityId &&
        b.CustomName.IndexOf(carrierOreCargoTag, StringComparison.OrdinalIgnoreCase) >= 0 &&
        b.HasInventory);
    carrierOreScanActive = true;
}

void ScanCarrierOreBlock(IMyTerminalBlock block)
{
    if (block == null || !block.IsFunctional)
        return;

    for (int i = 0; i < block.InventoryCount; i++)
    {
        var inv = block.GetInventory(i);
        if (inv == null) continue;
        carrierOreScanItems.Clear();
        inv.GetItems(carrierOreScanItems);
        foreach (var item in carrierOreScanItems)
        {
            if (!string.Equals(item.Type.TypeId, "MyObjectBuilder_Ore", StringComparison.OrdinalIgnoreCase))
                continue;

            string sub = item.Type.SubtypeId;
            double cur;
            carrierOreScanTotals.TryGetValue(sub, out cur);
            carrierOreScanTotals[sub] = cur + (double)item.Amount;
        }
    }
}

