public Program()
{
    rc = GridTerminalSystem.GetBlockWithName(carrierRemoteName) as IMyRemoteControl;
    if (rc == null)
        rc = GetBlock<IMyRemoteControl>();
    if (rc == null)
        throw new Exception("No remote control found. Set carrierRemoteName.");
    RefreshTickPose();

    carrierConnector = GridTerminalSystem.GetBlockWithName(carrierConnectorName) as IMyShipConnector;
    indicatorLight = GridTerminalSystem.GetBlockWithName(indicatorLightName) as IMyLightingBlock;
    carrierLcd = GridTerminalSystem.GetBlockWithName(carrierLcdName) as IMyTextPanel;
    ConfigureCarrierLcd();

    RefreshTimerCache();
    RefreshCachedCarrierDimensions();
    RefreshCachedCarrierHydrogen();
    allGyros     = GetBlocks<IMyGyro>().FindAll(b => HasCarrierTag(b));
    allThrusters = GetBlocks<IMyThrust>().FindAll(b => HasCarrierTag(b));
    thrust = new ThrusterControl(rc, tickSpeed, allThrusters);
    gyros  = new GyroControl(rc, tickSpeed, allGyros);

    if (tickSpeed == UpdateFrequency.Update10)
        secondsPerTick = 10.0 / 60.0;
    else if (tickSpeed == UpdateFrequency.Update100)
        secondsPerTick = 100.0 / 60.0;

    LoadState();
    minerPathCompleteListener = IGC.RegisterBroadcastListener(minerPathCompleteTag);
    minerProgressListener = IGC.RegisterBroadcastListener(minerProgressTag);
    Echo("Ready.");
    Runtime.UpdateFrequency = scriptPaused ? UpdateFrequency.None : tickSpeed;
}

void ResetMovement()
{
    if (movementResetApplied)
        return;
    rc.DampenersOverride = true;
    gyros.Reset();
    thrust.Reset();
    movementResetApplied = true;
}

public void Main(string argument, UpdateType updateSource)
{
    if (updateSource == UpdateType.Update1 || updateSource == UpdateType.Update10 || updateSource == UpdateType.Update100)
    {
        UpdateRuntimeMetrics();
        RefreshTickPose();
        if (carrierConnector == null)
            carrierConnector = GridTerminalSystem.GetBlockWithName(carrierConnectorName) as IMyShipConnector;
        UpdateCarrierConnectorMassWatch();

        BroadcastDockPose();
        BroadcastCarrierStatus();
        if (minerPathCompletePollTicks > 0)
            minerPathCompletePollTicks--;
        else
        {
            minerPathCompletePollTicks = igcPollIntervalTicks - 1;
            PollMinerPathCompletion();
        }
        if (minerProgressPollTicks > 0)
            minerProgressPollTicks--;
        else
        {
            minerProgressPollTicks = minerProgressPollIntervalTicks - 1;
            PollMinerProgress();
        }
        UpdateCarrierAuditTask();

        if (runtime % echoFrequency == 0)
        {
            WriteEcho();
            SaveStateProgressOnly();
        }

        UpdateCarrierAutopilotRunner();
        if (autopilotEnabled && hasTarget)
            Move();
        else
            ResetMovement();

        UpdateGoToRunner();
        UpdateMineSequence();
        UpdateMinePathElapsedTimer();
        UpdateFullAutoEnableStationaryGate();
        UpdateFullAuto();
        UpdatePathRunner();
        UpdateIndicatorLight();
        if (ShouldUpdateCarrierOreCacheScan())
            UpdateCarrierOreCacheScan();
        else
            StopCarrierOreCacheScan();
        if (ShouldUpdateCarrierInfoCache())
            UpdateCarrierInfoCache();
        if (minerProgressAgeSeconds < 9999)
            minerProgressAgeSeconds += secondsPerTick;
        if (mineRecallFailedTicks > 0)
            mineRecallFailedTicks--;
        if (lcdRefreshTicks > 0)
            lcdRefreshTicks--;
        else
        {
            lcdRefreshTicks = lcdRefreshIntervalTicks - 1;
            UpdateCarrierLcd();
        }
        runtime++;
    }
    else
    {
        RemoteCommand(argument);
        SendCarrierStatusNow();
        SaveState();
        UpdateCarrierLcd();
    }
}

int GetIndicatorDelayTicks()
{
    return Math.Max(1, (int)Math.Ceiling(indicatorLightDelaySeconds / Math.Max(0.001, secondsPerTick)));
}

void UpdateIndicatorLight()
{
    if (indicatorLight == null)
        indicatorLight = GridTerminalSystem.GetBlockWithName(indicatorLightName) as IMyLightingBlock;
    if (indicatorLight == null)
        return;

    bool desiredOn = autopilotEnabled;
    Color desiredOnColor = indicatorAutopilotColor;

    if (desiredOn)
    {
        if (indicatorTransition == IndicatorTransitionState.WaitNeutralAfterDisable)
        {
            indicatorTransition = IndicatorTransitionState.None;
            indicatorDelayTicksRemaining = 0;
        }

        if (!indicatorLight.Enabled)
        {
            if (indicatorTransition != IndicatorTransitionState.WaitEnableAfterColor)
            {
                SetIndicatorColor(desiredOnColor); // set color first
                indicatorDelayTicksRemaining = GetIndicatorDelayTicks();
                indicatorTransition = IndicatorTransitionState.WaitEnableAfterColor;
            }
            else
            {
                SetIndicatorColor(desiredOnColor);
                indicatorDelayTicksRemaining--;
                if (indicatorDelayTicksRemaining <= 0)
                {
                    SetIndicatorEnabled(true); // turn on after delay
                    indicatorTransition = IndicatorTransitionState.None;
                }
            }
        }
        else
        {
            SetIndicatorColor(desiredOnColor);
            indicatorTransition = IndicatorTransitionState.None;
            indicatorDelayTicksRemaining = 0;
        }
        return;
    }

    if (indicatorTransition == IndicatorTransitionState.WaitEnableAfterColor)
    {
        indicatorTransition = IndicatorTransitionState.None;
        indicatorDelayTicksRemaining = 0;
    }

    if (indicatorLight.Enabled)
    {
        SetIndicatorEnabled(false); // turn off first
        indicatorDelayTicksRemaining = GetIndicatorDelayTicks();
        indicatorTransition = IndicatorTransitionState.WaitNeutralAfterDisable;
        return;
    }

    if (indicatorTransition == IndicatorTransitionState.WaitNeutralAfterDisable)
    {
        indicatorDelayTicksRemaining--;
        if (indicatorDelayTicksRemaining <= 0)
        {
            SetIndicatorColor(indicatorNeutralColor); // set neutral after off delay
            indicatorTransition = IndicatorTransitionState.None;
        }
        return;
    }

    SetIndicatorColor(indicatorNeutralColor);
}

void BroadcastDockPose()
{
    if (carrierConnector == null)
        return;
    if (dockBroadcastTicks > 0)
    {
        dockBroadcastTicks--;
        return;
    }
    dockBroadcastTicks = dockBroadcastIntervalTicks - 1;

    MatrixD m    = carrierConnector.WorldMatrix;
    Vector3D pos = carrierConnector.GetPosition();
    Vector3D f   = m.Forward;
    Vector3D u   = m.Up;
    pos += f * broadcastForwardOffset;
    _dockPoseSb.Clear();
    AppendCsv(_dockPoseSb, pos);
    _dockPoseSb.Append('|');
    AppendCsv(_dockPoseSb, f);
    _dockPoseSb.Append('|');
    AppendCsv(_dockPoseSb, u);
    IGC.SendBroadcastMessage(dockBroadcastTag, _dockPoseSb.ToString());
}

void AppendCsv(StringBuilder sb, Vector3D v)
{
    sb.Append(v.X.ToString("0.000"));
    sb.Append(',');
    sb.Append(v.Y.ToString("0.000"));
    sb.Append(',');
    sb.Append(v.Z.ToString("0.000"));
}

void ConfigureCarrierLcd()
{
    if (carrierLcd == null)
    {
        carrierLcd = GridTerminalSystem.GetBlockWithName(carrierLcdName) as IMyTextPanel;
        carrierLcdConfigured = false;
    }
    if (carrierLcd == null)
        return;
    if (carrierLcdConfigured)
        return;

    carrierLcd.ContentType = ContentType.TEXT_AND_IMAGE;
    carrierLcd.Font = "Debug";
    carrierLcd.FontSize = 1.225f;
    carrierLcd.TextPadding = 0f;
    carrierLcd.Alignment = TextAlignment.LEFT;
    carrierLcdConfigured = true;
}

void BroadcastCarrierStatus()
{
    if (carrierStatusBroadcastTicks > 0)
    {
        carrierStatusBroadcastTicks--;
        return;
    }
    carrierStatusBroadcastTicks = carrierStatusBroadcastIntervalTicks - 1;
    SendCarrierStatusNow();
}

void SendCarrierStatusNow()
{
    IGC.SendBroadcastMessage(carrierStatusTag, autopilotEnabled ? "autopilot:on" : "autopilot:off");
}

void PollMinerProgress()
{
    if (minerProgressListener == null)
        return;

    while (minerProgressListener.HasPendingMessage)
    {
        MyIGCMessage msg = minerProgressListener.AcceptMessage();
        string payload = msg.Data as string;
        if (string.IsNullOrWhiteSpace(payload))
            continue;

        string[] parts = payload.Split(':');
        if (parts.Length < 2 || !parts[0].Equals("progress", StringComparison.OrdinalIgnoreCase))
            continue;

        string[] nums = parts[1].Split('/');
        int done, total;
        if (nums.Length == 2 && int.TryParse(nums[0], out done) && int.TryParse(nums[1], out total))
        {
            if (!mineRecallRequested && !mineRecallActive)
                continue;
            minerProgressDone = Math.Max(0, done);
            minerProgressTotal = Math.Max(0, total);
            minerProgressAgeSeconds = 0;
            mineRecallRequested = false;
            mineRecallActive = true;
            mineRecallAcknowledged = true;
            if (caLcdMenu == CaLcdMenu.AutonomousMining && caMenuIndex >= GetCarrierMenuItemCount())
                caMenuIndex = Math.Max(0, GetCarrierMenuItemCount() - 1);
        }
    }
}

bool TryHandleCarrierLcdCommand(string trimmed)
{
    if (trimmed.Equals("up", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("w", StringComparison.OrdinalIgnoreCase))
    {
        if (caEditingValue && caLcdMenu == CaLcdMenu.ThrustLimit) AdjustCarrierThrustLimitEdit(1);
        else if (caEditingValue) AdjustCarrierEdit(1);
        else MoveCarrierCursor(-1);
        UpdateCarrierLcd();
        return true;
    }
    if (trimmed.Equals("down", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("s", StringComparison.OrdinalIgnoreCase))
    {
        if (caEditingValue && caLcdMenu == CaLcdMenu.ThrustLimit) AdjustCarrierThrustLimitEdit(-1);
        else if (caEditingValue) AdjustCarrierEdit(-1);
        else MoveCarrierCursor(1);
        UpdateCarrierLcd();
        return true;
    }
    if (trimmed.Equals("apply", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("e", StringComparison.OrdinalIgnoreCase))
    {
        if (caEditingValue && caLcdMenu == CaLcdMenu.ThrustLimit) EndCarrierThrustLimitEdit();
        else if (caEditingValue) SaveCarrierEdit();
        else SelectCarrierCursor();
        UpdateCarrierLcd();
        return true;
    }
    if (trimmed.Equals("back", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("c", StringComparison.OrdinalIgnoreCase))
    {
        if (caEditingValue)
            CancelCarrierEdit();
        else if (caLcdMenu == CaLcdMenu.ThrustLimit)
            CloseCarrierThrustLimitMenu();
        else
        {
            caLcdMenu = CaLcdMenu.Main;
            caMenuIndex = 0;
        }
        UpdateCarrierLcd();
        return true;
    }

    if (trimmed.Equals("cursortoggle", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("cursor toggle", StringComparison.OrdinalIgnoreCase))
    {
        caCursorControl = true;
        UpdateCarrierLcd();
        Echo("LCD commands: up, down, apply, back.");
        return true;
    }

    return false;
}

int GetCarrierMenuItemCount()
{
    if (caLcdMenu == CaLcdMenu.Main) return 4;
    if (caLcdMenu == CaLcdMenu.AutonomousMining) return ShowRecallMinerMenuItem() ? 4 : 3;
    if (caLcdMenu == CaLcdMenu.SelectOres) return 1 + GetCarrierOreCount();
    if (caLcdMenu == CaLcdMenu.BehaviorSettings)
    {
        if (caBehaviorPage == 0) return 8;
        if (caBehaviorPage == 1) return 7;
        return 4;
    }
    if (caLcdMenu == CaLcdMenu.ThrustLimit) return 5;
    if (caLcdMenu == CaLcdMenu.ResetAsteroidsConfirm) return 2;
    if (caLcdMenu == CaLcdMenu.Info) return 2;
    return 1;
}

void MoveCarrierCursor(int delta)
{
    int count = Math.Max(1, GetCarrierMenuItemCount());
    caMenuIndex += delta;
    if (caMenuIndex < 0) caMenuIndex = count - 1;
    if (caMenuIndex >= count) caMenuIndex = 0;
}

void SelectCarrierCursor()
{
    if (caLcdMenu == CaLcdMenu.Main)
    {
        if (caMenuIndex == 0)
        {
            OpenCarrierMenu(CaLcdMenu.AutonomousMining);
            caMenuIndex = 1;
        }
        else if (caMenuIndex == 1)
            StartCarrierAuditMenu();
        else if (caMenuIndex == 2)
        {
            OpenCarrierMenu(CaLcdMenu.BehaviorSettings);
        }
        else if (caMenuIndex == 3)
            OpenCarrierMenu(CaLcdMenu.Info);
        return;
    }

    if (caLcdMenu == CaLcdMenu.ThrustLimit && caMenuIndex == 0)
    {
        CloseCarrierThrustLimitMenu();
        return;
    }

    if (caMenuIndex == 0)
    {
        OpenCarrierMenu(CaLcdMenu.Main);
        return;
    }

    if (caLcdMenu == CaLcdMenu.AutonomousMining)
    {
        if (caMenuIndex == 1)
        {
            SetFullAutoEnabledFromUi(!fullAutoEnabled);
        }
        else if (caMenuIndex == 2)
        {
            OpenCarrierMenu(CaLcdMenu.SelectOres);
            if (GetCarrierOreCount() > 0)
                caMenuIndex = 1;
        }
        else if (caMenuIndex == 3 && ShowRecallMinerMenuItem())
            StartMinerRecall();
        return;
    }

    if (caLcdMenu == CaLcdMenu.Info)
    {
        if (caMenuIndex == 1)
            OpenCarrierMenu(CaLcdMenu.ResetAsteroidsConfirm);
        return;
    }

    if (caLcdMenu == CaLcdMenu.SelectOres)
    {
        ToggleCarrierOre(caMenuIndex - 1);
        return;
    }

    if (caLcdMenu == CaLcdMenu.BehaviorSettings)
    {
        if (caMenuIndex == 1)
        {
            caBehaviorPage = (caBehaviorPage + 1) % 3;
            caMenuIndex = 1;
            CancelCarrierEdit();
            return;
        }

        int settingIndex = GetCarrierBehaviorSettingIndexForRow(caMenuIndex);
        if (settingIndex == 11)
            OpenCarrierThrustLimitMenu();
        else if (settingIndex == 14)
            turnTestEnabled = !turnTestEnabled;
        else if (settingIndex > 0)
            BeginCarrierEdit(settingIndex);
        return;
    }

    if (caLcdMenu == CaLcdMenu.ThrustLimit)
    {
        if (caMenuIndex == 1)
        {
            SaveCarrierThrustLimitMenu();
            return;
        }
        if (caMenuIndex == 2)
            BeginCarrierThrustLimitEdit(11);
        else if (caMenuIndex == 3)
            BeginCarrierThrustLimitEdit(15);
        else if (caMenuIndex == 4)
            BeginCarrierThrustLimitEdit(12);
        return;
    }

    if (caLcdMenu == CaLcdMenu.ResetAsteroidsConfirm)
    {
        if (caMenuIndex == 1)
        {
            SetAllAsteroidsOpen();
            OpenCarrierMenu(CaLcdMenu.Info);
            caMenuIndex = 1;
        }
        return;
    }
}

