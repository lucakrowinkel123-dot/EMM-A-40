void RecoverPathRecordsAfterLoad()
{
    if (!pathMode || pathRecords.Count > 0)
        return;

    List<string> loaded;
    string timerName;
    if (TryLoadPathRecordsFromTimer(out loaded, out timerName))
    {
        pathRecords = loaded;
        if (pathIndex < 0)
            pathIndex = 0;
        if (pathIndex > pathRecords.Count)
            pathIndex = pathRecords.Count;
    }
    else
    {
        pathMode = false;
        pathIndex = 0;
    }
}

// ---- Parse helpers ----

bool TryParseGpsCommand(string command, out Vector3D gps, out Vector3D forward, out Vector3D up)
{
    gps     = Vector3D.Zero;
    forward = Vector3D.Zero;
    up      = Vector3D.Zero;

    string[] parts     = command.Split('|');
    string gpsPart     = parts[0];
    string[] gpsTokens = gpsPart.Split(':');
    if (gpsTokens.Length < 5) return false;

    double x, y, z;
    if (!double.TryParse(gpsTokens[2], out x) || !double.TryParse(gpsTokens[3], out y) || !double.TryParse(gpsTokens[4], out z))
        return false;

    gps = new Vector3D(x, y, z);

    if (parts.Length > 1)
    {
        string[] modes = parts[1].Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries);
        if (modes.Length == 6)
        {
            double ux, uy, uz, fx, fy, fz;
            if (double.TryParse(modes[0].Trim(), out ux) &&
                double.TryParse(modes[1].Trim(), out uy) &&
                double.TryParse(modes[2].Trim(), out uz) &&
                double.TryParse(modes[3].Trim(), out fx) &&
                double.TryParse(modes[4].Trim(), out fy) &&
                double.TryParse(modes[5].Trim(), out fz))
            {
                up      = new Vector3D(ux, uy, uz);
                forward = new Vector3D(fx, fy, fz);
                if (up.LengthSquared() > 0.001)      up      = Vector3D.Normalize(up);
                if (forward.LengthSquared() > 0.001) forward = Vector3D.Normalize(forward);
                return true;
            }
        }

        Vector3D toTarget = gps - rc.GetPosition();
        foreach (string rawMode in modes)
        {
            string mode = rawMode.Trim().ToLower();
            if (mode == "faceforward")
            {
                if (toTarget.LengthSquared() > 0.001)
                    forward = Vector3D.Normalize(toTarget);
            }
            else if (mode == "faceup")
            {
                Vector3D gravity = rc.GetNaturalGravity();
                if (gravity.LengthSquared() > 0.001)
                    up = Vector3D.Normalize(-gravity);
                else
                    up = rc.WorldMatrix.Up;
            }
        }
    }
    return true;
}

bool TryParseVector3(string csv, out Vector3D value)
{
    value = Vector3D.Zero;
    string[] t = csv.Split(',');
    if (t.Length != 3) return false;
    double x, y, z;
    if (!double.TryParse(t[0].Trim(), out x) || !double.TryParse(t[1].Trim(), out y) || !double.TryParse(t[2].Trim(), out z))
        return false;
    value = new Vector3D(x, y, z);
    return true;
}

// === Compact path/zone serialization (anchor + axis-angle deltas) ===
// On-disk record shapes (path timer / Asteroid DB / Zone DB):
//   anchor (header line 1): cx,cy,cz:ax,ay,az,a   -- absolute carrier pos + axis-angle
//   path point             : dx,dy,dz:ax,ay,az,a   -- delta from anchor + axis-angle
//   mine area              : dx,dy,dz:ax,ay,az,a:w,h:depth -- corner A delta, area axis-angle, w/h, depth

string FormatPosCsv(Vector3D p)
{
    return p.X.ToString("0.00") + "," + p.Y.ToString("0.00") + "," + p.Z.ToString("0.00");
}

string FormatAxisAngle(Vector3D forward, Vector3D up)
{
    if (forward.LengthSquared() < 1e-9 || up.LengthSquared() < 1e-9)
        return "0.0000,0.0000,0.0000,0.0000";
    Quaternion q = Quaternion.CreateFromForwardUp((Vector3)Vector3D.Normalize(forward), (Vector3)Vector3D.Normalize(up));
    double w = MathHelper.Clamp((double)q.W, -1.0, 1.0);
    double angle = 2.0 * Math.Acos(w);
    double s = Math.Sqrt(Math.Max(0.0, 1.0 - w * w));
    if (angle < 1e-6 || s < 1e-9)
        return "0.0000,0.0000,0.0000,0.0000";
    double ax = q.X / s, ay = q.Y / s, az = q.Z / s;
    return ax.ToString("0.0000") + "," + ay.ToString("0.0000") + "," + az.ToString("0.0000") + "," + angle.ToString("0.0000");
}

bool TryParseAxisAngle(string s, out Vector3D forward, out Vector3D up)
{
    forward = new Vector3D(0, 0, -1);
    up = new Vector3D(0, 1, 0);
    if (string.IsNullOrWhiteSpace(s)) return false;
    string[] t = s.Split(',');
    if (t.Length != 4) return false;
    double ax, ay, az, angle;
    if (!double.TryParse(t[0].Trim(), out ax) ||
        !double.TryParse(t[1].Trim(), out ay) ||
        !double.TryParse(t[2].Trim(), out az) ||
        !double.TryParse(t[3].Trim(), out angle))
        return false;
    Vector3D axis = new Vector3D(ax, ay, az);
    if (Math.Abs(angle) < 1e-6 || axis.LengthSquared() < 1e-12)
        return true;
    axis = Vector3D.Normalize(axis);
    Quaternion q = Quaternion.CreateFromAxisAngle((Vector3)axis, (float)angle);
    forward = Vector3D.Normalize(Vector3D.Transform(new Vector3D(0, 0, -1), q));
    up = Vector3D.Normalize(Vector3D.Transform(new Vector3D(0, 1, 0), q));
    return true;
}

string FormatCarrierAnchorLine(Vector3D pos, Vector3D forward, Vector3D up)
{
    return FormatPosCsv(pos) + ":" + FormatAxisAngle(forward, up);
}

bool TryParseCarrierAnchorLine(string line, out Vector3D pos, out Vector3D forward, out Vector3D up)
{
    pos = Vector3D.Zero;
    forward = new Vector3D(0, 0, -1);
    up = new Vector3D(0, 1, 0);
    if (string.IsNullOrWhiteSpace(line)) return false;
    string[] parts = line.Split(':');
    if (parts.Length != 2) return false;
    if (!TryParseVector3(parts[0], out pos)) return false;
    return TryParseAxisAngle(parts[1], out forward, out up);
}

bool TryParsePathPointLine(string line, Vector3D anchor, out Vector3D pos, out Vector3D forward, out Vector3D up)
{
    pos = Vector3D.Zero;
    forward = new Vector3D(0, 0, -1);
    up = new Vector3D(0, 1, 0);
    if (string.IsNullOrWhiteSpace(line)) return false;
    string[] parts = line.Split(':');
    if (parts.Length != 2) return false;
    Vector3D delta;
    if (!TryParseVector3(parts[0], out delta)) return false;
    if (!TryParseAxisAngle(parts[1], out forward, out up)) return false;
    pos = anchor + delta;
    return true;
}

bool LineLooksLikeMineArea(string line)
{
    if (string.IsNullOrWhiteSpace(line)) return false;
    return line.Split(':').Length == 3;
}

bool HasCarrierTag(IMyTerminalBlock b)
{
    return b.CustomName.IndexOf("EMM-A Ca ", StringComparison.OrdinalIgnoreCase) >= 0;
}

T GetBlock<T>(bool useSubgrids = false) where T : class, IMyTerminalBlock
{
    return GetBlocks<T>(useSubgrids).FirstOrDefault();
}

List<T> GetBlocks<T>(bool useSubgrids = false) where T : class, IMyTerminalBlock
{
    List<T> blocks = new List<T>();
    if (useSubgrids)
        GridTerminalSystem.GetBlocksOfType(blocks);
    else
        GridTerminalSystem.GetBlocksOfType(blocks, b => b.CubeGrid.EntityId == Me.CubeGrid.EntityId);
    return blocks;
}

// ---- GyroControl ----

const double gyroP               = 10;
const double gyroI               = 0;
const double gyroD               = 5;
const double gyroMax             = 1000;
const double gyroErrorDeadbandRad = 0.003;
const double gyroOutputDeadband  = 0.002;
const double gyroFineDampRangeRad = 0.12;
const double gyroRateLimit       = 0.35;

class GyroControl
{
    private List<IMyGyro> gyros;
    IMyCubeBlock rc;
    VectorPID anglePID;

    public GyroControl(IMyCubeBlock rc, UpdateFrequency tickSpeed, List<IMyGyro> gyros)
    {
        if (rc == null) throw new Exception("Reference block null.");
        this.rc    = rc;
        this.gyros = gyros;
        double factor = 1;
        if (tickSpeed == UpdateFrequency.Update10)       factor = 10;
        else if (tickSpeed == UpdateFrequency.Update100) factor = 100;
        double spt = (1.0 / 60) * factor;
        anglePID = new VectorPID(gyroP / factor, gyroI / factor, gyroD / factor, -gyroMax, gyroMax, spt);
        Reset();
    }

    public void Reset()
    {
        for (int i = 0; i < gyros.Count; i++)
        {
            IMyGyro g = gyros[i];
            if (g == null) { gyros.RemoveAtFast(i); continue; }
            if (g.GyroOverride)
                g.GyroOverride = false;
        }
        anglePID.Reset();
    }

    Vector3D GetAngles(MatrixD current, Vector3D forward, Vector3D up)
    {
        Vector3D error = new Vector3D();

        if (forward != Vector3D.Zero)
        {
            Quaternion quat    = Quaternion.CreateFromForwardUp(current.Forward, current.Up);
            Quaternion invQuat = Quaternion.Inverse(quat);
            Vector3D rcRef     = Vector3D.Transform(forward, invQuat);
            Vector3D.GetAzimuthAndElevation(rcRef, out error.Y, out error.X);
        }

        if (up != Vector3D.Zero)
        {
            Vector3D temp = Vector3D.Normalize(VectorRejection(up, current.Forward));
            double dot    = MathHelper.Clamp(Vector3D.Dot(current.Up, temp), -1, 1);
            double roll   = Math.Acos(dot);
            double scaler = ScalerProjection(temp, current.Right);
            if (scaler > 0) roll *= -1;
            error.Z = roll;
        }

        if (Math.Abs(error.X) < 0.001) error.X = 0;
        if (Math.Abs(error.Y) < 0.001) error.Y = 0;
        if (Math.Abs(error.Z) < 0.001) error.Z = 0;
        return error;
    }

    public void FaceVectors(Vector3D forward, Vector3D up)
    {
        FaceVectors(rc.WorldMatrix, forward, up);
    }

    public void FaceVectors(MatrixD current, Vector3D forward, Vector3D up)
    {
        Vector3D error  = -GetAngles(current, forward, up);
        Vector3D angles = new Vector3D(anglePID.Control(error));
        ApplyFineDamping(error, ref angles);
        ApplyGyroOverride(current, angles);
    }

    void ApplyFineDamping(Vector3D error, ref Vector3D angles)
    {
        if (Math.Abs(error.X) < gyroErrorDeadbandRad) angles.X = 0;
        if (Math.Abs(error.Y) < gyroErrorDeadbandRad) angles.Y = 0;
        if (Math.Abs(error.Z) < gyroErrorDeadbandRad) angles.Z = 0;

        double errMag = error.Length();
        if (errMag < gyroFineDampRangeRad)
        {
            double s = MathHelper.Clamp(errMag / gyroFineDampRangeRad, 0.2, 1.0);
            angles *= s;
        }

        if (Math.Abs(angles.X) < gyroOutputDeadband) angles.X = 0;
        if (Math.Abs(angles.Y) < gyroOutputDeadband) angles.Y = 0;
        if (Math.Abs(angles.Z) < gyroOutputDeadband) angles.Z = 0;

        angles.X = MathHelper.Clamp(angles.X, -gyroRateLimit, gyroRateLimit);
        angles.Y = MathHelper.Clamp(angles.Y, -gyroRateLimit, gyroRateLimit);
        angles.Z = MathHelper.Clamp(angles.Z, -gyroRateLimit, gyroRateLimit);
    }

    void ApplyGyroOverride(MatrixD current, Vector3D localAngles)
    {
        Vector3D worldAngles = Vector3D.TransformNormal(localAngles, current);
        foreach (IMyGyro gyro in gyros)
        {
            Vector3D tv = Vector3D.TransformNormal(worldAngles, MatrixD.Transpose(gyro.WorldMatrix));
            if (!tv.IsValid()) throw new Exception("Invalid trans vector: " + tv.ToString());
            gyro.Pitch        = (float)tv.X;
            gyro.Yaw          = (float)tv.Y;
            gyro.Roll         = (float)tv.Z;
            if (!gyro.GyroOverride)
                gyro.GyroOverride = true;
        }
    }

    static double ScalerProjection(Vector3D value, Vector3D guide)
    {
        double r = Vector3D.Dot(value, guide);
        return double.IsNaN(r) ? 0 : r;
    }

    static Vector3D VectorPojection(Vector3D value, Vector3D guide)
    {
        return ScalerProjection(value, guide) * guide;
    }

    static Vector3D VectorRejection(Vector3D value, Vector3D guide)
    {
        return value - VectorPojection(value, guide);
    }
}

// ---- ThrusterControl ----

const double thrustP     = 3;
const double thrustI     = 2;
const double thrustD     = 2;
const double thrustDecay = 0.2;
const float  minThrust   = 1.0000001f;

class ThrusterControl
{
    private List<IMyThrust> thrusters;
    IMyShipController rc;
    VectorPID pid;
    double cachedTotalMass = 0;
    int massCacheTicks = 0;
    const int massRefreshIntervalTicks = 10;

    public ThrusterControl(IMyShipController rc, UpdateFrequency tickSpeed, List<IMyThrust> thrusters)
    {
        if (rc == null) throw new Exception("Ship controller null.");
        double factor = 1;
        if (tickSpeed == UpdateFrequency.Update10)       factor = 10;
        else if (tickSpeed == UpdateFrequency.Update100) factor = 100;
        double spt = (1.0 / 60) * factor;
        pid = new VectorPID(thrustP / factor, thrustI / factor, thrustD / factor, thrustDecay / factor, spt);
        this.rc        = rc;
        this.thrusters = thrusters;
        Reset();
    }

    public void Reset()
    {
        foreach (IMyThrust t in thrusters)
            if (t.ThrustOverride != 0)
                t.ThrustOverride = 0;
    }

    public Vector3D ControlPosition(Vector3D targetPosition, Vector3D targetVelocity, double maxSpeed = double.PositiveInfinity)
    {
        return ControlPositionFrom(rc.GetPosition(), targetPosition, targetVelocity, maxSpeed);
    }

    public Vector3D ControlPositionFrom(Vector3D currentPosition, Vector3D targetPosition, Vector3D targetVelocity, double maxSpeed = double.PositiveInfinity)
    {
        return ControlVelocity(targetVelocity + VectorClamp(-pid.Control(currentPosition - targetPosition), maxSpeed));
    }

    public Vector3D VectorClamp(Vector3D v, double max)
    {
        double len2 = v.LengthSquared();
        if (len2 > max * max) v = (v / Math.Sqrt(len2)) * max;
        return v;
    }

    public Vector3D ControlVelocity(Vector3D targetVelocity)
    {
        Vector3D myVel   = rc.GetShipVelocities().LinearVelocity;
        Vector3D deltaV  = myVel - targetVelocity;
        if (Vector3D.IsZero(deltaV)) return Vector3D.Zero;
        Vector3D gravity = rc.GetNaturalGravity();
        return 2 * deltaV + gravity;
    }

    public void ApplyAccel(Vector3D accel)
    {
        ApplyAccel(accel, double.PositiveInfinity);
    }

    public void ApplyAccel(Vector3D accel, double maxTotalThrust)
    {
        if (accel.Equals(Vector3D.Zero, 0.1)) accel = Vector3D.Zero;

        if (massCacheTicks <= 0 || cachedTotalMass <= 0)
        {
            cachedTotalMass = rc.CalculateShipMass().TotalMass;
            massCacheTicks = massRefreshIntervalTicks;
        }
        else
        {
            massCacheTicks--;
        }

        Vector3D thrustVec = accel * cachedTotalMass;
        double len = thrustVec.Length();
        if (len > maxTotalThrust && len > 0)
            thrustVec *= maxTotalThrust / len;
        foreach (IMyThrust t in thrusters)
        {
            if (!t.IsFunctional) continue;
            Vector3D thrustForward = t.WorldMatrix.Forward;
            float outputThrust = (float)Vector3D.Dot(thrustForward, thrustVec);
            if (outputThrust > 0)
            {
                float outputProportion = MathHelper.Clamp(outputThrust / t.MaxEffectiveThrust, minThrust / t.MaxThrust, 1);
                if (Math.Abs(t.ThrustOverridePercentage - outputProportion) > 0.001f)
                    t.ThrustOverridePercentage = outputProportion;
                thrustVec -= thrustForward * outputProportion * t.MaxEffectiveThrust;
            }
            else
            {
                if (t.ThrustOverride != minThrust)
                    t.ThrustOverride = minThrust;
            }
        }
    }
}

// ---- PID Classes ----

public class PID
{
    double _kP, _kI, _kD, _integralDecayRatio, _lowerBound, _upperBound,
           _timeStep, _inverseTimeStep, _errorSum, _lastError;
    bool _firstRun = true, _integralDecay = false;
    public double Value { get; private set; }

    public PID(double kP, double kI, double kD, double lowerBound, double upperBound, double timeStep)
    {
        _kP = kP; _kI = kI; _kD = kD;
        _lowerBound = lowerBound; _upperBound = upperBound;
        _timeStep = timeStep; _inverseTimeStep = 1 / timeStep;
    }

    public PID(double kP, double kI, double kD, double integralDecayRatio, double timeStep)
    {
        _kP = kP; _kI = kI; _kD = kD;
        _timeStep = timeStep; _inverseTimeStep = 1 / timeStep;
        _integralDecayRatio = integralDecayRatio; _integralDecay = true;
    }

    public double Control(double error)
    {
        var errorDerivative = (error - _lastError) * _inverseTimeStep;
        if (_firstRun) { errorDerivative = 0; _firstRun = false; }

        if (!_integralDecay)
        {
            _errorSum += error * _timeStep;
            if (_errorSum > _upperBound) _errorSum = _upperBound;
            else if (_errorSum < _lowerBound) _errorSum = _lowerBound;
        }
        else
            _errorSum = _errorSum * (1.0 - _integralDecayRatio) + error * _timeStep;

        _lastError = error;
        this.Value = _kP * error + _kI * _errorSum + _kD * errorDerivative;
        return this.Value;
    }

    public void Reset() { _errorSum = 0; _lastError = 0; _firstRun = true; }
}

public class VectorPID
{
    private PID X, Y, Z;

    public VectorPID(double kP, double kI, double kD, double lowerBound, double upperBound, double timeStep)
    {
        X = new PID(kP, kI, kD, lowerBound, upperBound, timeStep);
        Y = new PID(kP, kI, kD, lowerBound, upperBound, timeStep);
        Z = new PID(kP, kI, kD, lowerBound, upperBound, timeStep);
    }

    public VectorPID(double kP, double kI, double kD, double integralDecayRatio, double timeStep)
    {
        X = new PID(kP, kI, kD, integralDecayRatio, timeStep);
        Y = new PID(kP, kI, kD, integralDecayRatio, timeStep);
        Z = new PID(kP, kI, kD, integralDecayRatio, timeStep);
    }

    public Vector3D Control(Vector3D error)
    {
        return new Vector3D(X.Control(error.X), Y.Control(error.Y), Z.Control(error.Z));
    }

    public void Reset() { X.Reset(); Y.Reset(); Z.Reset(); }
}
