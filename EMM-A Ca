void TrySaveCurrentMineRuntime()
{
    if (minerPathRuntimeSaved || mineAsteroidNum <= 0)
        return;
    minerPathRuntimeSaved = TrySaveMinerPathRuntimeToAsteroidDb(mineAsteroidNum);
}

void UpdateMinePathElapsedTimer()
{
    if (mineSequenceState == MineSequenceState.WaitingMinerPathComplete && !minerPathCompleteReceived && !mineRecallActive)
        minerPathElapsedTicks += UpdateTickDelta();
}

int UpdateTickDelta()
{
    if (tickSpeed == UpdateFrequency.Update10)
        return 10;
    if (tickSpeed == UpdateFrequency.Update100)
        return 100;
    return 1;
}

void UpdateFullAuto()
{
    if (!fullAutoEnabled)
        return;

    if (fullAutoWaitingForMine)
    {
        if (mineSequenceState != MineSequenceState.None)
            return;

        if (fullAutoPendingAsteroid > 0)
        {
            fullAutoWaitingForMine = false;
            fullAutoActiveAsteroid = 0;
            StartFullAutoPendingMine();
            return;
        }

        Echo($"Fullauto: asteroid {fullAutoActiveAsteroid:D3} complete.");
        fullAutoWaitingForMine = false;
        fullAutoActiveAsteroid = 0;
        fullAutoCooldownTicks = 30;
        return;
    }

    if (mineSequenceState != MineSequenceState.None)
    {
        ResetFullAutoSelection();
        return;
    }

    if (UpdateFullAutoEscape())
        return;

    if (fullAutoPendingAsteroid > 0)
    {
        StartFullAutoPendingMine();
        return;
    }

    if (fullAutoEscapeStage == 0 && TryStartFullAutoEscape())
        return;

    if (fullAutoCooldownTicks > 0)
    {
        fullAutoCooldownTicks--;
        return;
    }

    if (!fullAutoSelecting)
    {
        string startReason;
        if (!StartFullAutoSelection(out startReason))
        {
            Echo("Fullauto: " + startReason);
            fullAutoCooldownTicks = Math.Max(1, fullAutoRetryTicks);
            return;
        }
    }

    ZoneAsteroidRecord selected;
    string reason;
    bool done = UpdateFullAutoSelection(out selected, out reason);
    if (!done)
        return;

    ResetFullAutoSelection();
    if (selected == null)
    {
        Echo("Fullauto: " + reason);
        fullAutoCooldownTicks = Math.Max(1, fullAutoRetryTicks);
        return;
    }

    StartMineSequence("Mine " + selected.Number.ToString("D3"));
    if (mineSequenceState == MineSequenceState.None)
    {
        Echo($"Fullauto: Mine {selected.Number:D3} did not start. Retrying later.");
        fullAutoCooldownTicks = Math.Max(1, fullAutoRetryTicks);
        return;
    }

    fullAutoWaitingForMine = true;
    fullAutoActiveAsteroid = selected.Number;
    Echo($"Fullauto: started Mine {selected.Number:D3}.");
}

void StartFullAutoPendingMine()
{
    int asteroidNum = fullAutoPendingAsteroid;
    fullAutoPendingAsteroid = 0;
    if (asteroidNum <= 0)
        return;

    StartMineSequence("Mine " + asteroidNum.ToString("D3"));
    if (mineSequenceState == MineSequenceState.None)
    {
        Echo($"Fullauto: Mine {asteroidNum:D3} did not start. Retrying later.");
        fullAutoCooldownTicks = Math.Max(1, fullAutoRetryTicks);
        return;
    }

    fullAutoWaitingForMine = true;
    fullAutoActiveAsteroid = asteroidNum;
    Echo($"Fullauto: started Mine {asteroidNum:D3}.");
}

bool StartFullAutoSelection(out string reason)
{
    reason = "";
    ZoneDescriptor zone;
    IMyTimerBlock zoneDb;
    if (!TryGetActiveZone(out zone, out zoneDb, out reason))
        return false;

    HashSet<string> enabledOres;
    if (!TryGetEnabledOreSet(out enabledOres, out reason))
        return false;
    if (enabledOres.Count == 0)
    {
        reason = $"no enabled ores in timer '{oreNameTimerTag}'.";
        return false;
    }

    List<ZoneAsteroidRecord> records = GetZoneDbRecordsCached(zone.Name, zone.TimerName);
    if (records.Count == 0)
    {
        reason = $"Zone DB '{zone.TimerName}' has no asteroid records.";
        return false;
    }

    fullAutoSelecting = true;
    fullAutoScanRecords = records;
    fullAutoScanEnabledOres = enabledOres;
    fullAutoScanIndex = 0;
    fullAutoScanCurrent = GetControlledPosition();
    fullAutoScanBest = null;
    fullAutoScanBestDistSq = double.MaxValue;
    fullAutoScanFailureReason = "no Open asteroid matches enabled ores with a safe path.";
    return true;
}

bool UpdateFullAutoSelection(out ZoneAsteroidRecord selected, out string reason)
{
    selected = null;
    reason = fullAutoScanFailureReason;

    if (!fullAutoSelecting || fullAutoScanRecords == null || fullAutoScanEnabledOres == null)
    {
        reason = "no eligible asteroid found.";
        return true;
    }

    int processed = 0;
    int recordsThisTick = Math.Max(1, fullAutoRecordsPerTick);
    while (fullAutoScanIndex < fullAutoScanRecords.Count && processed < recordsThisTick)
    {
        ZoneAsteroidRecord rec = fullAutoScanRecords[fullAutoScanIndex];
        fullAutoScanIndex++;
        processed++;

        if (!string.Equals(rec.Status, "Open", StringComparison.OrdinalIgnoreCase))
            continue;
        if (!RecordHasEnabledOre(rec, fullAutoScanEnabledOres))
            continue;
        if (!IsFullAutoPathSafe(fullAutoScanCurrent, rec, fullAutoScanRecords))
            continue;

        double distSq = Vector3D.DistanceSquared(fullAutoScanCurrent, rec.Position);
        if (distSq < fullAutoScanBestDistSq)
        {
            fullAutoScanBestDistSq = distSq;
            fullAutoScanBest = rec;
        }
    }

    if (fullAutoScanIndex < fullAutoScanRecords.Count)
        return false;

    selected = fullAutoScanBest;
    return true;
}

void ResetFullAutoSelection()
{
    fullAutoSelecting = false;
    fullAutoScanRecords = null;
    fullAutoScanEnabledOres = null;
    fullAutoScanIndex = 0;
    fullAutoScanBest = null;
    fullAutoScanBestDistSq = double.MaxValue;
}

void ResetFullAutoEscape()
{
    fullAutoEscapeStage = 0;
    fullAutoEscapeAsteroidNum = 0;
    fullAutoEscapeLinePoint = Vector3D.Zero;
    fullAutoEscapeFrontPoint = Vector3D.Zero;
    fullAutoEscapeForward = Vector3D.Zero;
    fullAutoEscapeUp = Vector3D.Zero;
}

bool UpdateFullAutoEscape()
{
    if (fullAutoEscapeStage == 0)
        return false;

    if (!autopilotEnabled || !hasTarget)
    {
        ResetFullAutoEscape();
        fullAutoPendingAsteroid = 0;
        return false;
    }

    if (fullAutoEscapeStage == 1)
    {
        if (!IsAtTargetPosition(fullAutoEscapeLinePoint))
            return true;

        StartPrecisionTarget(fullAutoEscapeFrontPoint, Vector3D.Zero, Vector3D.Zero);
        activeMaxSpeed = maxSpeed;
        fullAutoEscapeStage = 2;
        Echo($"Fullauto: corridor reached for asteroid {fullAutoEscapeAsteroidNum:D3}. Moving to selected approach.");
        return true;
    }

    if (fullAutoEscapeStage == 2)
    {
        if (!IsAtTargetPosition(fullAutoEscapeFrontPoint))
            return true;

        int asteroidNum = fullAutoEscapeAsteroidNum;
        ResetFullAutoEscape();
        fullAutoCooldownTicks = 0;
        Echo($"Fullauto: approach reached for asteroid {asteroidNum:D3}. Starting selected Mine.");
        return false;
    }

    ResetFullAutoEscape();
    return false;
}

bool TryStartFullAutoEscape()
{
    ZoneDescriptor zone;
    IMyTimerBlock zoneDb;
    string reason;
    if (!TryGetActiveZone(out zone, out zoneDb, out reason))
        return false;

    List<ZoneAsteroidRecord> records = GetZoneDbRecordsCached(zone.Name, zone.TimerName);
    if (records.Count == 0)
        return false;

    Vector3D current = GetControlledPosition();
    ZoneAsteroidRecord bestRec = null;
    Vector3D bestLinePoint = Vector3D.Zero;
    Vector3D bestApproachPoint = Vector3D.Zero;
    Vector3D bestForward = Vector3D.Zero;
    Vector3D bestUp = Vector3D.Zero;
    int bestNextAsteroid = 0;
    double bestDistSq = double.MaxValue;

    for (int i = 0; i < records.Count; i++)
    {
        Vector3D linePoint, backPoint, frontPoint, forward, up;
        double distSq;
        if (!TryGetFullAutoCorridorEscape(records[i], current, out linePoint, out backPoint, out frontPoint, out forward, out up, out distSq))
            continue;

        ZoneAsteroidRecord selected;
        string selectReason;
        Vector3D approachPoint = frontPoint;
        if (!TrySelectFullAutoAsteroidFrom(frontPoint, out selected, out selectReason))
        {
            if (!TrySelectFullAutoAsteroidFrom(backPoint, out selected, out selectReason))
                continue;
            approachPoint = backPoint;
        }

        if (distSq < bestDistSq)
        {
            bestDistSq = distSq;
            bestRec = records[i];
            bestLinePoint = linePoint;
            bestApproachPoint = approachPoint;
            bestForward = forward;
            bestUp = up;
            bestNextAsteroid = selected.Number;
        }
    }

    if (bestRec == null)
        return false;

    ResetFullAutoSelection();
    fullAutoEscapeAsteroidNum = bestRec.Number;
    fullAutoEscapeLinePoint = bestLinePoint;
    fullAutoEscapeFrontPoint = bestApproachPoint;
    fullAutoEscapeForward = bestForward;
    fullAutoEscapeUp = bestUp;
    fullAutoPendingAsteroid = bestNextAsteroid;

    if (Vector3D.DistanceSquared(current, bestLinePoint) <= Math.Max(0.05, arrivalTolerance) * Math.Max(0.05, arrivalTolerance))
    {
        fullAutoEscapeStage = 2;
        StartPrecisionTarget(fullAutoEscapeFrontPoint, Vector3D.Zero, Vector3D.Zero);
        activeMaxSpeed = maxSpeed;
        Echo($"Fullauto: inside asteroid {bestRec.Number:D3} corridor. Moving to selected approach.");
    }
    else
    {
        fullAutoEscapeStage = 1;
        StartPrecisionTarget(fullAutoEscapeLinePoint, _tickRcMatrix.Forward, _tickRcMatrix.Up);
        activeMaxSpeed = maxSpeed;
        Echo($"Fullauto: inside asteroid {bestRec.Number:D3} bubble. Moving straight to corridor.");
    }

    return true;
}

bool TryGetFullAutoCorridorEscape(ZoneAsteroidRecord rec, Vector3D current,
                                  out Vector3D linePoint, out Vector3D backPoint, out Vector3D frontPoint,
                                  out Vector3D forward, out Vector3D up, out double distSq)
{
    linePoint = Vector3D.Zero;
    backPoint = Vector3D.Zero;
    frontPoint = Vector3D.Zero;
    forward = Vector3D.Zero;
    up = Vector3D.Zero;
    distSq = double.MaxValue;

    if (rec.Forward.LengthSquared() < 0.001 || rec.Up.LengthSquared() < 0.001)
        return false;

    double bubbleRadius = Math.Max(0.1, goToBubbleRadiusMeters);
    if (Vector3D.DistanceSquared(current, rec.BubbleCenter) > bubbleRadius * bubbleRadius)
        return false;

    forward = Vector3D.Normalize(rec.Forward);
    up = Vector3D.Normalize(rec.Up);
    backPoint = rec.Position - forward * goToLeadDistanceMeters;
    frontPoint = rec.Position + forward * goToLeadDistanceMeters;
    linePoint = ClosestPointOnSegment(current, backPoint, frontPoint);
    distSq = Vector3D.DistanceSquared(current, linePoint);

    double corridor = Math.Max(0.1, fullAutoCorridorLineToleranceMeters);
    return distSq <= corridor * corridor;
}

Vector3D ClosestPointOnSegment(Vector3D point, Vector3D a, Vector3D b)
{
    Vector3D ab = b - a;
    double abLenSq = ab.LengthSquared();
    if (abLenSq < 1e-6)
        return a;

    double t = Vector3D.Dot(point - a, ab) / abLenSq;
    t = MathHelper.Clamp(t, 0, 1);
    return a + ab * t;
}

bool TrySelectFullAutoAsteroid(out ZoneAsteroidRecord selected, out string reason)
{
    return TrySelectFullAutoAsteroidFrom(GetControlledPosition(), out selected, out reason);
}

bool TrySelectFullAutoAsteroidFrom(Vector3D current, out ZoneAsteroidRecord selected, out string reason)
{
    selected = null;
    reason = "no eligible asteroid found.";
    ZoneDescriptor zone;
    IMyTimerBlock zoneDb;
    if (!TryGetActiveZone(out zone, out zoneDb, out reason))
        return false;

    HashSet<string> enabledOres;
    if (!TryGetEnabledOreSet(out enabledOres, out reason))
        return false;
    if (enabledOres.Count == 0)
    {
        reason = $"no enabled ores in timer '{oreNameTimerTag}'.";
        return false;
    }

    List<ZoneAsteroidRecord> records = GetZoneDbRecordsCached(zone.Name, zone.TimerName);
    if (records.Count == 0)
    {
        reason = $"Zone DB '{zone.TimerName}' has no asteroid records.";
        return false;
    }

    ZoneAsteroidRecord best = null;
    double bestDistSq = double.MaxValue;

    foreach (var rec in records)
    {
        if (mineAsteroidNum > 0 && rec.Number == mineAsteroidNum)
            continue;
        if (!string.Equals(rec.Status, "Open", StringComparison.OrdinalIgnoreCase))
            continue;
        if (!RecordHasEnabledOre(rec, enabledOres))
            continue;
        if (!IsFullAutoPathSafe(current, rec, records))
            continue;

        double distSq = Vector3D.DistanceSquared(current, rec.Position);
        if (distSq < bestDistSq)
        {
            bestDistSq = distSq;
            best = rec;
        }
    }

    if (best == null)
    {
        reason = "no Open asteroid matches enabled ores with a safe path.";
        return false;
    }

    selected = best;
    return true;
}

bool TryGetEnabledOreSet(out HashSet<string> enabledOres, out string error)
{
    enabledOres = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    error = "";

    IMyTimerBlock oreTimer = GridTerminalSystem.GetBlockWithName(oreNameTimerTag) as IMyTimerBlock;
    if (oreTimer == null)
    {
        error = $"ore timer '{oreNameTimerTag}' not found.";
        return false;
    }

    string data = oreTimer.CustomData ?? "";
    foreach (string rawLine in data.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
    {
        string line = rawLine.Trim();
        if (line.Length == 0) continue;
        if (line.StartsWith("//")) continue;

        string[] parts = line.Split(new[] { ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) continue;

        bool isOn = parts.Length < 2 || parts[1].Equals("on", StringComparison.OrdinalIgnoreCase);
        if (isOn)
            enabledOres.Add(parts[0].Trim());
    }
    return true;
}

List<ZoneAsteroidRecord> ParseZoneDbRecords(string customData, string zoneName, string zoneTimerName)
{
    var records = new List<ZoneAsteroidRecord>();
    string[] lines = customData.Split(new[] { '\n', '\r' }, StringSplitOptions.None);

    for (int i = 0; i < lines.Length; i++)
    {
        int asteroidNum;
        if (!IsAsteroidLabelLine(lines[i].Trim(), out asteroidNum))
            continue;

        Vector3D pos = Vector3D.Zero, f = Vector3D.Zero, u = Vector3D.Zero;
        string status = "";
        string gpsLine = "";
        var ores = new List<string>();
        bool hasGps = false;

        int j;
        for (j = i + 1; j < lines.Length; j++)
        {
            string t = lines[j].Trim();
            if (string.IsNullOrWhiteSpace(t))
                continue;

            int nextNum;
            if (IsAsteroidLabelLine(t, out nextNum) ||
                t.IndexOf(asteroidDbTagPfx, StringComparison.OrdinalIgnoreCase) >= 0)
                break;

            if (t.StartsWith("Ores:", StringComparison.OrdinalIgnoreCase))
            {
                ores = ParseOresLine(t.Substring("Ores:".Length).Trim());
            }
            else if (t.StartsWith("Status:", StringComparison.OrdinalIgnoreCase))
            {
                status = t.Substring("Status:".Length).Trim();
            }
            else if (!hasGps && TryParseCarrierAnchorLine(t, out pos, out f, out u))
            {
                hasGps = true;
                gpsLine = t;
            }
        }

        i = j - 1;

        if (!hasGps)
            continue;

        var rec = new ZoneAsteroidRecord();
        rec.Number = asteroidNum;
        rec.Position = pos;
        rec.Forward = f;
        rec.Up = u;
        rec.BubbleCenter = u.LengthSquared() < 0.001 ? pos : pos - Vector3D.Normalize(u) * goToBubbleOffsetMeters;
        rec.GpsLine = gpsLine;
        rec.Status = status;
        rec.Ores = ores;
        rec.ZoneName = zoneName ?? "";
        rec.ZoneTimerName = zoneTimerName ?? "";
        records.Add(rec);
    }

    return records;
}

IMyTimerBlock FindZoneRegistryTimer()
{
    if (_cachedZoneRegistryTimer != null &&
        _cachedZoneRegistryTimer.CustomName.IndexOf(zoneRegistryTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        return _cachedZoneRegistryTimer;

    _cachedZoneRegistryTimer = FindTimerByExactName(zoneRegistryTimerTag);
    return _cachedZoneRegistryTimer;
}

bool TryParseZoneDescriptor(string sectionName, MyIni ini, out ZoneDescriptor zone)
{
    zone = null;

    string timerName = ini.Get(sectionName, "Timer").ToString("").Trim();
    string centerText = ini.Get(sectionName, "Center").ToString("").Trim();
    double radius = ini.Get(sectionName, "Radius").ToDouble(-1);
    if (string.IsNullOrWhiteSpace(timerName) || string.IsNullOrWhiteSpace(centerText) || radius <= 0)
        return false;

    Vector3D center, forward, up;
    if (!TryParseGpsCommand(centerText, out center, out forward, out up))
        return false;

    zone = new ZoneDescriptor();
    zone.Name = sectionName;
    zone.TimerName = timerName;
    zone.Center = center;
    zone.Radius = radius;
    return true;
}

List<ZoneDescriptor> GetZoneRegistryCached()
{
    IMyTimerBlock registry = FindZoneRegistryTimer();
    if (registry == null)
    {
        InvalidateZoneRegistryCache();
        return _zoneRegistryCacheZones;
    }

    string text = registry.CustomData ?? "";
    if (_zoneRegistryCacheText != null && string.Equals(_zoneRegistryCacheText, text, StringComparison.Ordinal))
        return _zoneRegistryCacheZones;

    _zoneRegistryCacheZones.Clear();
    _zoneRegistryCacheText = text;

    MyIni ini = new MyIni();
    MyIniParseResult parseResult;
    if (!ini.TryParse(text, out parseResult))
    {
        Echo("Zone registry parse error: " + parseResult.ToString());
        return _zoneRegistryCacheZones;
    }

    var sections = new List<string>();
    ini.GetSections(sections);
    foreach (string section in sections)
    {
        ZoneDescriptor zone;
        if (TryParseZoneDescriptor(section, ini, out zone))
            _zoneRegistryCacheZones.Add(zone);
        else
            Echo($"Zone registry: skipped invalid section '{section}'.");
    }
    return _zoneRegistryCacheZones;
}

bool TryGetActiveZone(out ZoneDescriptor zone, out IMyTimerBlock zoneDb, out string reason)
{
    zone = null;
    zoneDb = null;
    reason = "";

    IMyTimerBlock registry = FindZoneRegistryTimer();
    if (registry == null)
    {
        reason = $"Zone registry timer '{zoneRegistryTimerTag}' not found.";
        return false;
    }

    List<ZoneDescriptor> zones = GetZoneRegistryCached();
    if (zones.Count == 0)
    {
        reason = $"Zone registry timer '{registry.CustomName}' has no valid zone definitions.";
        return false;
    }

    Vector3D current = _tickRcPosition;
    double bestDistSq = double.MaxValue;
    ZoneDescriptor best = null;
    for (int i = 0; i < zones.Count; i++)
    {
        ZoneDescriptor candidate = zones[i];
        double distSq = Vector3D.DistanceSquared(current, candidate.Center);
        if (distSq > candidate.Radius * candidate.Radius)
            continue;
        if (distSq < bestDistSq)
        {
            bestDistSq = distSq;
            best = candidate;
        }
    }

    if (best == null)
    {
        reason = "no active zone matches current carrier position.";
        return false;
    }

    zoneDb = FindTimerByExactName(best.TimerName);
    if (zoneDb == null)
    {
        reason = $"active zone '{best.Name}' references missing timer '{best.TimerName}'.";
        return false;
    }

    zone = best;
    return true;
}

List<ZoneAsteroidRecord> GetZoneDbRecordsCached(string zoneName, string zoneTimerName)
{
    IMyTimerBlock zoneDb = FindTimerByExactName(zoneTimerName);
    if (zoneDb == null)
    {
        InvalidateZoneDbCache(zoneTimerName);
        return new List<ZoneAsteroidRecord>();
    }

    string text = zoneDb.CustomData ?? "";
    string cachedText;
    List<ZoneAsteroidRecord> cachedRecords;
    if (_zoneDbCacheTextByTimer.TryGetValue(zoneTimerName, out cachedText) &&
        _zoneDbCacheRecordsByTimer.TryGetValue(zoneTimerName, out cachedRecords) &&
        string.Equals(cachedText, text, StringComparison.Ordinal))
        return cachedRecords;

    List<ZoneAsteroidRecord> records = ParseZoneDbRecords(text, zoneName, zoneTimerName);
    var byNumber = new Dictionary<int, ZoneAsteroidRecord>();
    for (int i = 0; i < records.Count; i++)
    {
        ZoneAsteroidRecord rec = records[i];
        if (!byNumber.ContainsKey(rec.Number))
            byNumber.Add(rec.Number, rec);
    }

    _zoneDbCacheTextByTimer[zoneTimerName] = text;
    _zoneDbCacheRecordsByTimer[zoneTimerName] = records;
    _zoneDbCacheByNumberByTimer[zoneTimerName] = byNumber;
    return records;
}

bool TryGetZoneAsteroidRecordInZone(ZoneDescriptor zone, int asteroidNum, out ZoneAsteroidRecord rec)
{
    rec = null;
    if (zone == null)
        return false;

    GetZoneDbRecordsCached(zone.Name, zone.TimerName);
    Dictionary<int, ZoneAsteroidRecord> byNumber;
    if (!_zoneDbCacheByNumberByTimer.TryGetValue(zone.TimerName, out byNumber))
        return false;
    return byNumber.TryGetValue(asteroidNum, out rec);
}

bool TryGetZoneAsteroidRecordInActiveZone(int asteroidNum, out ZoneAsteroidRecord rec, out ZoneDescriptor zone, out string reason)
{
    rec = null;
    zone = null;
    IMyTimerBlock zoneDb;
    if (!TryGetActiveZone(out zone, out zoneDb, out reason))
        return false;
    if (!TryGetZoneAsteroidRecordInZone(zone, asteroidNum, out rec))
    {
        reason = $"Asteroid {asteroidNum:D3} not found in active zone '{zone.Name}'.";
        return false;
    }
    return true;
}

void InvalidateZoneRegistryCache()
{
    _zoneRegistryCacheText = null;
    _zoneRegistryCacheZones.Clear();
}

void InvalidateZoneDbCache(string zoneTimerName = null)
{
    if (string.IsNullOrWhiteSpace(zoneTimerName))
    {
        _zoneDbCacheTextByTimer.Clear();
        _zoneDbCacheRecordsByTimer.Clear();
        _zoneDbCacheByNumberByTimer.Clear();
        return;
    }

    _zoneDbCacheTextByTimer.Remove(zoneTimerName);
    _zoneDbCacheRecordsByTimer.Remove(zoneTimerName);
    _zoneDbCacheByNumberByTimer.Remove(zoneTimerName);
}

List<string> ParseOresLine(string oresText)
{
    var ores = new List<string>();
    if (string.IsNullOrWhiteSpace(oresText) || oresText.Equals("(none)", StringComparison.OrdinalIgnoreCase))
        return ores;

    foreach (string token in oresText.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries))
    {
        string ore = token.Trim();
        if (ore.Length > 0)
            ores.Add(ore);
    }
    return ores;
}

bool RecordHasEnabledOre(ZoneAsteroidRecord rec, HashSet<string> enabledOres)
{
    for (int i = 0; i < rec.Ores.Count; i++)
    {
        if (enabledOres.Contains(rec.Ores[i]))
            return true;
    }
    return false;
}

bool IsFullAutoPathSafe(Vector3D from, ZoneAsteroidRecord candidate, List<ZoneAsteroidRecord> allRecords)
{
    Vector3D approachPoint;
    string approachName;
    return TryGetSafeAsteroidApproachPoint(from, candidate, allRecords, out approachPoint, out approachName);
}

void StartPathFromTimer()
{
    List<string> loaded;
    string timerName;
    if (!TryLoadPathRecordsFromTimer(out loaded, out timerName))
    {
        Echo($"Unable to load path records from timer tag '{pathTimerTag}'.");
        return;
    }

    pathRecords         = loaded;
    pathIndex           = 0;
    pathMode            = true;
    pathPaused          = false;
    pathPausedNavResume = false;
    Echo($"Loaded {pathRecords.Count} records from timer '{timerName}'.");
    StartNextPathRecord();
}

void StartNextPathRecord()
{
    while (pathMode && pathIndex < pathRecords.Count)
    {
        string record = pathRecords[pathIndex];
        pathIndex++;
        if (ExecutePathRecord(record))
            return;
        Echo($"Skipping invalid path record #{pathIndex}.");
    }

    if (pathMode && pathIndex >= pathRecords.Count)
    {
        pathMode = false;
        Echo("Path execution complete.");
    }
}

bool ExecutePathRecord(string rawRecord)
{
    if (string.IsNullOrWhiteSpace(rawRecord))
        return false;

    string record = rawRecord.Trim();
    if (record.StartsWith("\"") && record.EndsWith("\"") && record.Length >= 2)
        record = record.Substring(1, record.Length - 2).Trim();
    if (string.IsNullOrWhiteSpace(record))
        return false;

    string navCmd = null;
    if (record.StartsWith("Nav;", StringComparison.OrdinalIgnoreCase))
        navCmd = record.Substring(4).Trim();
    else if (record.StartsWith("GPS:", StringComparison.OrdinalIgnoreCase))
        navCmd = record;

    if (navCmd != null)
    {
        Vector3D gps, forward, up;
        if (!TryParseGpsCommand(navCmd, out gps, out forward, out up))
            return false;
        StartPrecisionTarget(gps, forward, up);
        return true;
    }

    if (pathAnchorValid)
    {
        Vector3D pos, fwd, upN;
        if (TryParsePathPointLine(record, pathAnchorPos, out pos, out fwd, out upN))
        {
            StartPrecisionTarget(pos, fwd, upN);
            return true;
        }
    }

    return false;
}

bool TryLoadPathRecordsFromTimer(out List<string> records, out string timerName)
{
    records   = new List<string>();
    timerName = "";
    pathAnchorValid = false;
    pathAnchorPos = Vector3D.Zero;
    pathAnchorForward = Vector3D.Zero;
    pathAnchorUp = Vector3D.Zero;

    IMyTimerBlock timer = FindPathTimer();
    if (timer == null)
        return false;

    timerName = timer.CustomName;
    string data = timer.CustomData ?? "";
    string[] lines = data.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
    foreach (string line in lines)
    {
        string rec = line.Trim();
        if (string.IsNullOrWhiteSpace(rec)) continue;
        if (rec.StartsWith("\"") && rec.EndsWith("\"") && rec.Length >= 2)
            rec = rec.Substring(1, rec.Length - 2).Trim();
        if (string.IsNullOrWhiteSpace(rec)) continue;
        if (LooksLikeRuntimeLine(rec)) continue;
        if (!pathAnchorValid)
        {
            Vector3D ap, af, au;
            if (TryParseCarrierAnchorLine(rec, out ap, out af, out au))
            {
                pathAnchorPos = ap;
                pathAnchorForward = af;
                pathAnchorUp = au;
                pathAnchorValid = true;
                continue;
            }
        }
        records.Add(rec);
    }

    return records.Count > 0 || pathAnchorValid;
}

IMyTimerBlock FindPathTimer()
{
    if (_cachedPathTimer != null &&
        _cachedPathTimer.CustomName.IndexOf(pathTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        return _cachedPathTimer;
    foreach (var t in GetTimerBlocksCached())
        if (t != null && !string.IsNullOrWhiteSpace(t.CustomName) &&
            t.CustomName.IndexOf(pathTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        {
            _cachedPathTimer = t;
            return t;
        }
    _cachedPathTimer = null;
    return null;
}

