string BuildAsteroidDbRecord(string label, string carrierGps, Dictionary<string, double> oreMap, List<string> pathLines)
{
    var sb = new StringBuilder();
    sb.AppendLine(asteroidHeaderLine);
    sb.AppendLine("Asteroid " + label);
    sb.AppendLine();
    sb.AppendLine("Carrier pos:");
    sb.AppendLine(carrierGps);
    sb.AppendLine();
    sb.AppendLine("Ore:");
    if (oreMap.Count == 0)
        sb.AppendLine("(none)");
    else
    {
        var oreNames = new List<string>(oreMap.Keys);
        oreNames.Sort(StringComparer.OrdinalIgnoreCase);
        foreach (string ore in oreNames)
        {
            long rounded = (long)Math.Round(oreMap[ore]);
            sb.AppendLine(ore + " " + FormatOreAmount(rounded));
        }
    }
    sb.AppendLine(asteroidHeaderLine);
    sb.AppendLine("undock");
    foreach (string line in pathLines)
        sb.AppendLine(line);
    return sb.ToString();
}

bool ReplaceAsteroidRecordInDb(IMyTimerBlock dbTimer, int asteroidNum, string newRecord)
{
    string label = "Asteroid " + asteroidNum.ToString("D3");
    string text = dbTimer.CustomData ?? "";
    int labelIdx = text.IndexOf(label, StringComparison.OrdinalIgnoreCase);
    if (labelIdx < 0)
        return false;

    int start = text.LastIndexOf(asteroidHeaderLine, labelIdx, StringComparison.Ordinal);
    if (start < 0)
        return false;

    int next = text.IndexOf(asteroidHeaderLine, labelIdx + label.Length, StringComparison.Ordinal);
    if (next >= 0)
        next = text.IndexOf(asteroidHeaderLine, next + asteroidHeaderLine.Length, StringComparison.Ordinal);
    if (next < 0)
        next = text.Length;

    string before = text.Substring(0, start);
    string after = text.Substring(next);
    if (before.Length > 0 && !before.EndsWith("\n"))
        before += "\n";
    if (after.Length > 0 && !after.StartsWith("\n"))
        after = "\n" + after;
    dbTimer.CustomData = (before + newRecord + after).TrimEnd();
    return true;
}

void EnsureOreNamesListed(Dictionary<string, double> oreMap)
{
    if (oreMap == null || oreMap.Count == 0)
        return;

    IMyTimerBlock oreTimer = GridTerminalSystem.GetBlockWithName(oreNameTimerTag) as IMyTimerBlock;
    if (oreTimer == null)
    {
        Echo($"SaveAsteroid: ore timer '{oreNameTimerTag}' not found. Skipping ore-name update.");
        return;
    }

    string data = oreTimer.CustomData ?? "";
    var knownOreNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    foreach (string rawLine in data.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
    {
        string line = rawLine.Trim();
        if (line.Length == 0) continue;

        string[] parts = line.Split(new[] { ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) continue;
        knownOreNames.Add(parts[0].Trim());
    }

    var missingOreNames = new List<string>();
    foreach (string ore in oreMap.Keys)
    {
        if (!knownOreNames.Contains(ore))
            missingOreNames.Add(ore);
    }

    if (missingOreNames.Count == 0)
        return;

    missingOreNames.Sort(StringComparer.OrdinalIgnoreCase);

    var sb = new StringBuilder();
    if (!string.IsNullOrWhiteSpace(data))
    {
        sb.Append(data);
        if (!data.EndsWith("\n"))
            sb.AppendLine();
    }

    foreach (string ore in missingOreNames)
        sb.AppendLine(ore + " on");

    oreTimer.CustomData = sb.ToString();
    Echo($"SaveAsteroid: added {missingOreNames.Count} ore name(s) to '{oreNameTimerTag}'.");
}

bool TryHandleOreNameStateCommand(string command)
{
    string[] parts = command.Split(new[] { ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length != 2)
        return false;

    string oreName = parts[0].Trim();
    string mode = parts[1].Trim().ToLowerInvariant();
    if (oreName.Length == 0 || (mode != "on" && mode != "off"))
        return false;

    // Avoid hijacking existing single-word commands that happen to end with on/off.
    if (oreName.Equals("fullauto", StringComparison.OrdinalIgnoreCase) ||
        oreName.Equals("autopilot", StringComparison.OrdinalIgnoreCase))
        return false;

    IMyTimerBlock oreTimer = GridTerminalSystem.GetBlockWithName(oreNameTimerTag) as IMyTimerBlock;
    if (oreTimer == null)
    {
        Echo($"Ore state: ore timer '{oreNameTimerTag}' not found.");
        return true;
    }

    var lines = new List<string>((oreTimer.CustomData ?? "").Split('\n'));
    bool updated = false;

    for (int i = 0; i < lines.Count; i++)
    {
        string line = lines[i] ?? "";
        string trimmed = line.Trim();
        if (trimmed.Length == 0 || trimmed.StartsWith("//")) continue;

        string[] rowParts = trimmed.Split(new[] { ' ', '\t' }, StringSplitOptions.RemoveEmptyEntries);
        if (rowParts.Length == 0) continue;

        if (rowParts[0].Equals(oreName, StringComparison.OrdinalIgnoreCase))
        {
            lines[i] = oreName + " " + mode;
            updated = true;
            break;
        }
    }

    if (!updated)
        lines.Add(oreName + " " + mode);

    oreTimer.CustomData = string.Join("\n", lines).Replace("\r", "").TrimEnd();
    Echo($"Ore state: {oreName} set to {mode}.");
    return true;
}

// Refreshes all cached block references, mirroring a script recompile.
void SimulateRecompile()
{
    rc = GridTerminalSystem.GetBlockWithName(carrierRemoteName) as IMyRemoteControl;
    if (rc == null)
        rc = GetBlock<IMyRemoteControl>();
    if (rc != null)
        RefreshTickPose();

    carrierConnector = GridTerminalSystem.GetBlockWithName(carrierConnectorName) as IMyShipConnector;

    allGyros     = GetBlocks<IMyGyro>().FindAll(b => HasCarrierTag(b));
    allThrusters = GetBlocks<IMyThrust>().FindAll(b => HasCarrierTag(b));
    if (rc != null)
    {
        thrust = new ThrusterControl(rc, tickSpeed, allThrusters);
        gyros  = new GyroControl(rc, tickSpeed, allGyros);
    }

    RefreshTimerCache();
    _cachedPathTimer   = null;
    _cachedZoneRegistryTimer = null;
    _cachedStateIniTimer = null;
    InvalidateZoneRegistryCache();
    InvalidateZoneDbCache();
    Echo("SaveAsteroid: recompile done.");
}

// Returns all asteroid numbers stored in Asteroid DB timers.
HashSet<int> CollectAsteroidDbNumbers()
{
    var nums = new HashSet<int>();
    foreach (var t in GetTimerBlocksCached())
    {
        if (t == null || string.IsNullOrWhiteSpace(t.CustomName)) continue;
        if (t.CustomName.IndexOf(asteroidDbTagPfx, StringComparison.OrdinalIgnoreCase) < 0) continue;
        foreach (string line in (t.CustomData ?? "").Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
        {
            string trimmed = line.Trim();
            if (!trimmed.StartsWith("Asteroid ", StringComparison.OrdinalIgnoreCase)) continue;
            int num;
            if (int.TryParse(trimmed.Substring(9).Trim(), out num) && num > 0)
                nums.Add(num);
        }
    }
    return nums;
}

// Returns all asteroid numbers stored in the Zone DB.
HashSet<int> CollectZoneDbNumbers()
{
    var nums = new HashSet<int>();
    foreach (var zone in GetZoneRegistryCached())
        foreach (var rec in GetZoneDbRecordsCached(zone.Name, zone.TimerName))
            nums.Add(rec.Number);
    return nums;
}

Dictionary<int, List<ZoneDbNumberEntry>> CollectZoneDbNumberEntriesByNumber()
{
    var entriesByNumber = new Dictionary<int, List<ZoneDbNumberEntry>>();
    foreach (var zone in GetZoneRegistryCached())
    {
        foreach (var rec in GetZoneDbRecordsCached(zone.Name, zone.TimerName))
        {
            List<ZoneDbNumberEntry> entries;
            if (!entriesByNumber.TryGetValue(rec.Number, out entries))
            {
                entries = new List<ZoneDbNumberEntry>();
                entriesByNumber.Add(rec.Number, entries);
            }

            var entry = new ZoneDbNumberEntry();
            entry.Number = rec.Number;
            entry.ZoneName = zone.Name;
            entries.Add(entry);
        }
    }
    return entriesByNumber;
}

// Finds the lowest unused asteroid number across both the Asteroid DB and Zone DB,
// so that manually deleted entries are reused before allocating new slots.
int FindNextAsteroidNumber()
{
    var used = CollectAsteroidDbNumbers();
    foreach (int n in CollectZoneDbNumbers()) used.Add(n);
    int next = 1;
    while (used.Contains(next)) next++;
    return next;
}

// dbcheck   : report orphaned entries across all registered Zone DB timers and Asteroid DB timers.
// dbcheck;fix : also remove orphaned Zone DB entries (entries with no Asteroid DB path data).
void RunDbCheck(bool fix)
{
    var asteroidNums = CollectAsteroidDbNumbers();
    var zoneNums     = CollectZoneDbNumbers();

    var orphanedZone     = new List<int>(); // Zone entry but no path data
    var orphanedAsteroid = new List<int>(); // path data but no Zone entry
    foreach (int n in zoneNums)     if (!asteroidNums.Contains(n)) orphanedZone.Add(n);
    foreach (int n in asteroidNums) if (!zoneNums.Contains(n))     orphanedAsteroid.Add(n);
    orphanedZone.Sort();
    orphanedAsteroid.Sort();

    int healthy = zoneNums.Count - orphanedZone.Count;
    Echo($"DB check: {healthy} healthy, {orphanedZone.Count} orphaned Zone, {orphanedAsteroid.Count} orphaned Asteroid.");
    if (orphanedZone.Count > 0)
        Echo("Orphaned Zone (no path data): " + string.Join(", ", orphanedZone.ConvertAll(n => n.ToString("D3"))));
    if (orphanedAsteroid.Count > 0)
        Echo("Orphaned Asteroid (no Zone entry): " + string.Join(", ", orphanedAsteroid.ConvertAll(n => n.ToString("D3"))));

    if (!fix || orphanedZone.Count == 0) return;

    var orphanSet = new HashSet<int>(orphanedZone);
    int removed = 0;
    foreach (var zone in GetZoneRegistryCached())
    {
        IMyTimerBlock zoneDb = FindTimerByExactName(zone.TimerName);
        if (zoneDb == null)
        {
            Echo($"dbcheck;fix: Zone DB timer '{zone.TimerName}' not found for zone '{zone.Name}'.");
            continue;
        }

        var kept = new List<ZoneAsteroidRecord>();
        foreach (var rec in GetZoneDbRecordsCached(zone.Name, zone.TimerName))
            if (!orphanSet.Contains(rec.Number))
                kept.Add(rec);

        if (kept.Count == GetZoneDbRecordsCached(zone.Name, zone.TimerName).Count)
            continue;

        var sb = new StringBuilder();
        for (int i = 0; i < kept.Count; i++)
        {
            var rec = kept[i];
            if (sb.Length > 0)
                sb.AppendLine();
            sb.AppendLine(rec.Number.ToString("D3"));
            sb.AppendLine(rec.GpsLine);
            sb.AppendLine("Ores: " + (rec.Ores.Count > 0 ? string.Join(",", rec.Ores) : "(none)"));
            sb.AppendLine("Status: " + (string.IsNullOrWhiteSpace(rec.Status) ? "Open" : rec.Status));
        }

        removed += GetZoneDbRecordsCached(zone.Name, zone.TimerName).Count - kept.Count;
        zoneDb.CustomData = sb.ToString().TrimEnd();
        InvalidateZoneDbCache(zone.TimerName);
    }
    Echo($"dbcheck;fix: removed {removed} orphaned Zone entr{(removed == 1 ? "y" : "ies")}.");
}

string DumpDuplicateZoneIdCheckToCustomData()
{
    var entriesByNumber = CollectZoneDbNumberEntriesByNumber();
    var duplicateNums = new List<int>();
    foreach (var kv in entriesByNumber)
        if (kv.Value.Count > 1)
            duplicateNums.Add(kv.Key);
    duplicateNums.Sort();

    var report = new StringBuilder();
    string lcdSummary;
    report.AppendLine("[DuplicateZoneIdCheck]");
    if (duplicateNums.Count == 0)
    {
        report.AppendLine("Duplicate check: no duplicate Zone IDs found.");
        lcdSummary = "No duplicate Zone IDs found.";
    }
    else
    {
        report.AppendLine($"Duplicate check: {duplicateNums.Count} duplicate Zone IDs found.");
        lcdSummary = duplicateNums.Count + " duplicate Zone IDs found.";
        for (int i = 0; i < duplicateNums.Count; i++)
        {
            int num = duplicateNums[i];
            var zoneNames = new List<string>();
            foreach (var entry in entriesByNumber[num])
                if (!zoneNames.Contains(entry.ZoneName))
                    zoneNames.Add(entry.ZoneName);
            report.AppendLine(num.ToString("D3") + ": " + string.Join(", ", zoneNames));
        }
    }

    var sb = new StringBuilder();
    string existing = Me.CustomData ?? "";
    if (!string.IsNullOrWhiteSpace(existing))
        sb.Append(existing.TrimEnd());
    sb.AppendLine();
    sb.AppendLine();
    sb.Append(report.ToString().TrimEnd());
    Me.CustomData = sb.ToString();
    Echo("Duplicate check dumped to Custom Data.");
    return lcdSummary;
}

// Finds a timer block whose name contains the given tag (case-insensitive).
IMyTimerBlock FindTimerByTag(string tag)
{
    foreach (var t in GetTimerBlocksCached())
        if (t != null && !string.IsNullOrWhiteSpace(t.CustomName) &&
            t.CustomName.IndexOf(tag, StringComparison.OrdinalIgnoreCase) >= 0)
            return t;
    return null;
}

IMyTimerBlock FindTimerByExactName(string name)
{
    foreach (var t in GetTimerBlocksCached())
        if (t != null && string.Equals(t.CustomName, name, StringComparison.OrdinalIgnoreCase))
