// Returns the compact carrier-anchor line for the carrier's current RC position and orientation.
string FormatCarrierGps()
{
    Vector3D p = rc.GetPosition();
    Vector3D f = Vector3D.Normalize(rc.WorldMatrix.Forward);
    Vector3D u = Vector3D.Normalize(rc.WorldMatrix.Up);
    return FormatCarrierAnchorLine(p, f, u);
}

// Formats a non-negative integer with dots as thousands separators (e.g. 9343432 -> "9.343.432").
string FormatOreAmount(long amount)
{
    string raw = amount.ToString();
    if (raw.Length <= 3) return raw;
    var result = new StringBuilder();
    int start = raw.Length % 3;
    if (start > 0) result.Append(raw.Substring(0, start));
    for (int i = start; i < raw.Length; i += 3)
    {
        if (result.Length > 0) result.Append('.');
        result.Append(raw.Substring(i, 3));
    }
    return result.ToString();
}

// Scans all blocks on the grid whose names contain minerContainerTag for ore items.
// Returns a map of ore subtype -> total amount, excluding Stone.
Dictionary<string, double> CollectMinerOre()
{
    var result = new Dictionary<string, double>(StringComparer.OrdinalIgnoreCase);
    var blocks = new List<IMyTerminalBlock>();
    var items  = new List<MyInventoryItem>();

    GridTerminalSystem.GetBlocksOfType(blocks, b =>
        b.CubeGrid.EntityId == Me.CubeGrid.EntityId &&
        b.CustomName.IndexOf(minerContainerTag, StringComparison.OrdinalIgnoreCase) >= 0 &&
        b.HasInventory);

    foreach (var block in blocks)
    {
        if (!block.IsFunctional) continue;
        for (int i = 0; i < block.InventoryCount; i++)
        {
            var inv = block.GetInventory(i);
            if (inv == null) continue;
            items.Clear();
            inv.GetItems(items);
            foreach (var item in items)
            {
                if (!string.Equals(item.Type.TypeId, "MyObjectBuilder_Ore", StringComparison.OrdinalIgnoreCase))
                    continue;
                string sub = item.Type.SubtypeId;
                if (string.Equals(sub, "Stone", StringComparison.OrdinalIgnoreCase))
                    continue;
                double cur;
                result.TryGetValue(sub, out cur);
                result[sub] = cur + (double)item.Amount;
            }
        }
    }
    return result;
}

// Finds and returns the miner's Path timer block (null if not found).
IMyTimerBlock FindMinerPathTimer()
{
    IMyTimerBlock exact = GridTerminalSystem.GetBlockWithName(minerPathTimerTag) as IMyTimerBlock;
    if (exact != null)
        return exact;

    var allTimers = new List<IMyTimerBlock>();
    GridTerminalSystem.GetBlocksOfType(allTimers);

    foreach (var t in allTimers)
    {
        if (t == null || string.IsNullOrWhiteSpace(t.CustomName)) continue;
        if (string.Equals(t.CustomName, minerPathTimerTag, StringComparison.OrdinalIgnoreCase))
            return t;
    }

    foreach (var t in allTimers)
    {
        if (t == null || string.IsNullOrWhiteSpace(t.CustomName)) continue;
        if (t.CustomName.IndexOf(minerPathTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
            return t;
    }
    return null;
}

bool ClearMinerPathTimer(string logPrefix)
{
    IMyTimerBlock timer = FindMinerPathTimer();
    if (timer == null)
    {
        Echo($"{logPrefix}: miner path timer '{minerPathTimerTag}' not found; cannot clear.");
        return false;
    }

    timer.CustomData = "";
    Echo($"{logPrefix}: miner path timer cleared.");
    return true;
}

// Reads and returns all non-empty lines from the miner's Path timer custom data.
List<string> ReadMinerPathLines()
{
    var lines = new List<string>();
    IMyTimerBlock timer = FindMinerPathTimer();
    if (timer == null)
    {
        Echo($"SaveAsteroid: miner path timer '{minerPathTimerTag}' not found.");
        return lines;
    }
    foreach (string line in (timer.CustomData ?? "").Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries))
    {
        string trimmed = line.Trim();
        if (!string.IsNullOrWhiteSpace(trimmed) && !LooksLikeRuntimeLine(trimmed))
            lines.Add(trimmed);
    }
    return lines;
}

// Sends a command string to the miner's programmable block.
bool SendMinerCommand(string command)
{
    var allPbs = new List<IMyProgrammableBlock>();
    GridTerminalSystem.GetBlocksOfType(allPbs);
    foreach (var pb in allPbs)
    {
        if (pb == Me) continue;
        if (pb.CustomName.IndexOf(minerPbTag, StringComparison.OrdinalIgnoreCase) >= 0)
        {
            bool sent = pb.TryRun(command);
            Echo(sent ? $"Sent '{command}' to '{pb.CustomName}'." : $"SendMinerCommand: '{pb.CustomName}' rejected '{command}'.");
            return sent;
        }
    }
    Echo($"SendMinerCommand: miner PB '{minerPbTag}' not found.");
    return false;
}

// Loads the path records of a saved asteroid into the miner's Path timer.
// Usage: LoadAsteroid 002
bool LoadAsteroid(string argument)
{
    RefreshTimerCache();

    string[] parts = argument.Split(new[] { ' ' }, 2, StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length < 2)
    {
        Echo("Usage: LoadAsteroid <number>  e.g. LoadAsteroid 002");
        return false;
    }
    int asteroidNum;
    if (!int.TryParse(parts[1].Trim(), out asteroidNum) || asteroidNum < 1)
    {
        Echo($"LoadAsteroid: invalid number '{parts[1].Trim()}'.");
        return false;
    }
    string label = asteroidNum.ToString("D3");

    IMyTimerBlock pathTimer = FindMinerPathTimer();
    if (pathTimer == null)
    {
        Echo($"LoadAsteroid: miner path timer '{minerPathTimerTag}' not found.");
        return false;
    }

    int dbIndex = (asteroidNum - 1) / asteroidsPerDb + 1;
    string dbTimerName = asteroidDbTagPfx + dbIndex.ToString("D2");
    IMyTimerBlock dbTimer = FindTimerByExactName(dbTimerName);
    if (dbTimer == null)
    {
        Echo($"LoadAsteroid: DB timer '{dbTimerName}' not found.");
        return false;
    }

    List<string> pathLines = ExtractAsteroidPathLines(dbTimer.CustomData ?? "", asteroidNum);
    if (pathLines.Count == 0)
    {
        Echo($"LoadAsteroid: no path data found for Asteroid {label} in '{dbTimerName}'.");
        return false;
    }

    var sb = new StringBuilder();
    foreach (string line in pathLines)
        sb.AppendLine(line);
    pathTimer.CustomData = sb.ToString();

    Echo($"LoadAsteroid: Asteroid {label} loaded to '{pathTimer.CustomName}' ({pathLines.Count} records).");
    return true;
}

void StartPrecisionTarget(Vector3D pos, Vector3D forward, Vector3D up)
{
    rc.DampenersOverride = true;
    targetPosition = pos;
    desiredForward = forward;
    desiredUp = up;
    hasTarget = true;
    autopilotEnabled = true;
    carrierAutopilotMode = CarrierAutopilotMode.Precision;
    Runtime.UpdateFrequency = tickSpeed;
}

void StartCruiseTarget(Vector3D finalPos, Vector3D finalForward, Vector3D finalUp)
{
    Vector3D from = GetControlledPosition();
    Vector3D toFinal = finalPos - from;
    double distance = toFinal.Length();
    if (distance < Math.Max(100, shortRangeDistanceMeters))
    {
        StartPrecisionTarget(finalPos, finalForward, finalUp);
        return;
    }

    Vector3D dir = Vector3D.Normalize(toFinal);
    cruiseFinalPosition = finalPos;
    cruiseFinalForward = finalForward;
    cruiseFinalUp = finalUp;
    cruiseDirection = dir;
    cruiseStagingPosition = finalPos - dir * Math.Min(Math.Max(100, cruiseOffsetMeters), Math.Max(0, distance - 100));
    targetPosition = cruiseStagingPosition;
    desiredForward = dir;
    desiredUp = Vector3D.Zero;
    hasTarget = true;
    autopilotEnabled = true;
    Runtime.UpdateFrequency = tickSpeed;
    rc.DampenersOverride = false;

    double mass = GetShipMass();
    bool staleTurnTest = measuredFlipSeconds <= 0 || measuredFlipMass <= 0 ||
        Math.Abs(mass - measuredFlipMass) / Math.Max(1, measuredFlipMass) > 0.10;
    if (turnTestEnabled && staleTurnTest)
    {
        carrierAutopilotMode = CarrierAutopilotMode.CruiseTurnTest;
        cruiseTurnTestTicks = 0;
        cruiseTurnTestStartForward = _tickRcMatrix.Forward;
        targetPosition = GetControlledPosition();
        desiredForward = -dir;
        desiredUp = Vector3D.Zero;
        Echo("Cruise: measuring turn rate before departure.");
    }
    else
    {
        carrierAutopilotMode = CarrierAutopilotMode.CruiseAccel;
        Echo("Cruise: starting long-range transit.");
    }
}

void UpdateCarrierAutopilotRunner()
{
    if (!autopilotEnabled || !hasTarget)
        return;

    if (carrierAutopilotMode == CarrierAutopilotMode.CruiseTurnTest)
    {
        cruiseTurnTestTicks += UpdateTickDelta();
        if (cruiseTurnTestTicks < cruiseTurnTestDurationTicks)
            return;

        double elapsed = Math.Max(secondsPerTick, cruiseTurnTestTicks / 60.0);
        double angle = AngleBetween(cruiseTurnTestStartForward, _tickRcMatrix.Forward);
        double turnRate = angle / elapsed;
        if (turnRate > 0.001)
            measuredFlipSeconds = Math.Max(5, Math.PI / turnRate * 1.25);
        else
            measuredFlipSeconds = Math.Max(measuredFlipSeconds, 60);
        measuredFlipMass = GetShipMass();
        carrierAutopilotMode = CarrierAutopilotMode.CruiseAccel;
        targetPosition = cruiseStagingPosition;
        desiredForward = cruiseDirection;
        desiredUp = Vector3D.Zero;
        Echo($"Cruise: measured flip time {measuredFlipSeconds:0}s.");
        return;
    }

    if (carrierAutopilotMode == CarrierAutopilotMode.CruiseAccel)
    {
        Vector3D dir = Vector3D.Normalize(cruiseDirection);
        Vector3D toStage = cruiseStagingPosition - GetControlledPosition();
        double dist = Math.Max(0, Vector3D.Dot(toStage, dir));
        double speed = Math.Max(0, Vector3D.Dot(rc.GetShipVelocities().LinearVelocity, dir));
        double brakeAccel = GetPlannedAcceleration(dir);
        double flipSeconds = (turnTestEnabled && measuredFlipSeconds > 0) ? Math.Max(measuredFlipSeconds, 5) : 5;
        double required = brakeAccel > 0 ? ((speed * speed) / (2 * brakeAccel) + speed * flipSeconds) * 1.25 + speed * 2 : double.MaxValue;
        if (dist <= required)
        {
            carrierAutopilotMode = CarrierAutopilotMode.CruiseFlip;
            targetPosition = GetControlledPosition();
            desiredForward = -dir;
            desiredUp = Vector3D.Zero;
            Echo("Cruise: flipping for braking.");
        }
        return;
    }

    if (carrierAutopilotMode == CarrierAutopilotMode.CruiseFlip)
    {
        if (IsOrientationAligned(desiredForward, desiredUp, orientationToleranceDeg))
        {
            carrierAutopilotMode = CarrierAutopilotMode.CruiseDecel;
            targetPosition = cruiseStagingPosition;
            Echo("Cruise: braking to staging point.");
        }
        return;
    }

    if (carrierAutopilotMode == CarrierAutopilotMode.CruiseDecel)
    {
        Vector3D dir = Vector3D.Normalize(cruiseDirection);
        Vector3D toStage = cruiseStagingPosition - GetControlledPosition();
        double dist = toStage.Length();
        Vector3D vel = rc.GetShipVelocities().LinearVelocity;
        double speed = vel.Length();
        double speedToward = Vector3D.Dot(vel, dir);
        bool atOrPastStage = Vector3D.Dot(toStage, dir) <= 0;
        if ((dist <= Math.Max(arrivalTolerance * 5, 500) || atOrPastStage || speedToward <= 0) && speed <= 2)
        {
            Echo("Cruise: staging reached. Handing off to precision.");
            StartPrecisionTarget(cruiseFinalPosition, cruiseFinalForward, cruiseFinalUp);
        }
    }
}

double AngleBetween(Vector3D a, Vector3D b)
{
    if (a.LengthSquared() < 0.001 || b.LengthSquared() < 0.001)
        return 0;
    double dot = MathHelper.Clamp(Vector3D.Dot(Vector3D.Normalize(a), Vector3D.Normalize(b)), -1, 1);
    return Math.Acos(dot);
}

void HandleGoTo(string argument)
{
    string[] parts = argument.Split(new[] { ' ' }, 2, StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length < 2)
    {
        Echo("Usage: GoTo <number>  e.g. GoTo 032");
        return;
    }

    int asteroidNum;
    if (!int.TryParse(parts[1].Trim(), out asteroidNum) || asteroidNum < 1)
    {
        Echo($"GoTo: invalid number '{parts[1].Trim()}'.");
        return;
    }

    ZoneAsteroidRecord rec;
    ZoneDescriptor zone;
    string reason;
    if (!TryGetZoneAsteroidRecordInActiveZone(asteroidNum, out rec, out zone, out reason))
    {
        Echo($"GoTo: asteroid {asteroidNum:D3} not found in the active zone DB.");
        return;
    }

    Vector3D savedPos = rec.Position;
    Vector3D savedForward = rec.Forward;
    Vector3D savedUp = rec.Up;
    if (savedForward.LengthSquared() < 0.001 || savedUp.LengthSquared() < 0.001)
    {
        Echo($"GoTo: asteroid {asteroidNum:D3} saved carrier orientation is invalid.");
        return;
    }

    Vector3D currentPos = GetControlledPosition();
    List<ZoneAsteroidRecord> allRecords = GetZoneDbRecordsCached(zone.Name, zone.TimerName);
    Vector3D chosenPoint;
    string approachName;
    if (!TryGetSafeAsteroidApproachPoint(currentPos, rec, allRecords, out chosenPoint, out approachName))
    {
        Echo($"GoTo: both approach lines intersect an asteroid bubble (r={goToBubbleRadiusMeters:0}).");
        return;
    }

    goToMode         = true;
    goToStage        = 1;
    pathMode         = false;
    pathPaused       = false;
    pathPausedNavResume = false;
    pathRecords.Clear();
    pathIndex = 0;
    pathAnchorValid = false;

    _goToFinalPosition = savedPos;
    _goToFinalForward  = savedForward;
    _goToFinalUp       = savedUp;
    _goToTravelForward = Vector3D.Zero;

    if (Vector3D.Distance(currentPos, chosenPoint) >= Math.Max(100, shortRangeDistanceMeters))
        StartCruiseTarget(chosenPoint, Vector3D.Zero, Vector3D.Zero);
    else
        StartPrecisionTarget(chosenPoint, Vector3D.Zero, Vector3D.Zero);

    Echo($"GoTo: Asteroid {asteroidNum:D3} using {approachName} approach point.");
}

Vector3D _goToFinalPosition = Vector3D.Zero;
Vector3D _goToFinalForward  = Vector3D.Zero;
Vector3D _goToFinalUp       = Vector3D.Zero;
Vector3D _goToTravelForward = Vector3D.Zero;

void UpdateGoToRunner()
{
    if (!goToMode || !autopilotEnabled || !hasTarget)
        return;

    if (goToStage == 1 && IsAtTargetPosition(targetPosition))
    {
        _goToTravelForward = GetTravelForward(targetPosition, _goToFinalPosition, _goToFinalForward);
        StartPrecisionTarget(_goToFinalPosition, _goToTravelForward, _goToFinalUp);
        goToStage      = 2;
        Echo("GoTo: side-point reached. Flying to saved position.");
        return;
    }

    if (goToStage == 2 && _goToTravelForward.LengthSquared() < 0.001)
        _goToTravelForward = desiredForward.LengthSquared() > 0.001 ? desiredForward : _goToFinalForward;

    if (goToStage == 2 && IsAtTargetPose(_goToFinalPosition, _goToTravelForward, _goToFinalUp))
    {
        StartPrecisionTarget(_goToFinalPosition, _goToFinalForward, _goToFinalUp);
        goToStage = 3;
        Echo("GoTo: saved position reached. Rotating to saved pose.");
        return;
    }

    if (goToStage == 3 && IsAtTargetPose(_goToFinalPosition, _goToFinalForward, _goToFinalUp))
    {
        goToMode      = false;
        goToStage     = 0;
        _goToTravelForward = Vector3D.Zero;
        Echo("GoTo: final pose reached.");
    }
}

Vector3D GetTravelForward(Vector3D from, Vector3D to, Vector3D fallback)
{
    Vector3D travel = to - from;
    if (travel.LengthSquared() > 0.001)
        return Vector3D.Normalize(travel);
    if (fallback.LengthSquared() > 0.001)
        return Vector3D.Normalize(fallback);
    return _tickRcMatrix.Forward;
}

bool TryGetCarrierPoseFromZoneDb(int asteroidNum, out Vector3D pos, out Vector3D forward, out Vector3D up)
{
    pos = Vector3D.Zero;
    forward = Vector3D.Zero;
    up = Vector3D.Zero;

    ZoneAsteroidRecord rec;
    ZoneDescriptor zone;
    string reason;
    if (!TryGetZoneAsteroidRecordInActiveZone(asteroidNum, out rec, out zone, out reason))
        return false;

    pos = rec.Position;
    forward = rec.Forward;
    up = rec.Up;
    return forward.LengthSquared() >= 0.001 && up.LengthSquared() >= 0.001;
}

bool TryGetSafeAsteroidApproachPoint(Vector3D from, ZoneAsteroidRecord candidate, List<ZoneAsteroidRecord> allRecords, out Vector3D approachPoint, out string approachName)
{
    approachPoint = Vector3D.Zero;
    approachName = "";

    if (candidate.Forward.LengthSquared() < 0.001 || candidate.Up.LengthSquared() < 0.001)
        return false;

    Vector3D forward = Vector3D.Normalize(candidate.Forward);
    Vector3D rearPoint = candidate.Position - forward * goToLeadDistanceMeters;
    if (IsAsteroidApproachRouteSafe(from, rearPoint, allRecords))
    {
        approachPoint = rearPoint;
        approachName = "rear";
        return true;
    }

    Vector3D frontPoint = candidate.Position + forward * goToLeadDistanceMeters;
    if (IsAsteroidApproachRouteSafe(from, frontPoint, allRecords))
    {
        approachPoint = frontPoint;
        approachName = "front";
        return true;
    }

    return false;
}

bool IsAsteroidApproachRouteSafe(Vector3D from, Vector3D approachPoint, List<ZoneAsteroidRecord> allRecords)
{
    Vector3D route = approachPoint - from;
    double routeLen = Math.Sqrt(route.LengthSquared());
    double radius = goToBubbleRadiusMeters;
    double maxDist = routeLen + radius;
    double maxDistSq = maxDist * maxDist;
    for (int i = 0; i < allRecords.Count; i++)
    {
        ZoneAsteroidRecord other = allRecords[i];
        if (other.Up.LengthSquared() < 0.001)
            continue;

        Vector3D bubbleCenter = other.BubbleCenter;
        Vector3D toBubble = bubbleCenter - from;
        if (Vector3D.Dot(route, toBubble) < -radius * routeLen)
            continue;
        if (toBubble.LengthSquared() > maxDistSq)
            continue;

        if (SegmentIntersectsSphere(from, approachPoint, bubbleCenter, radius))
            return false;
    }
    return true;
}

bool SegmentIntersectsSphere(Vector3D a, Vector3D b, Vector3D center, double radius)
{
    Vector3D ab = b - a;
    double abLenSq = ab.LengthSquared();
    if (abLenSq < 1e-6)
        return Vector3D.DistanceSquared(a, center) <= radius * radius;

    double t = Vector3D.Dot(center - a, ab) / abLenSq;
    t = MathHelper.Clamp(t, 0, 1);
    Vector3D closest = a + ab * t;
    return Vector3D.DistanceSquared(closest, center) <= radius * radius;
}

// Extracts only the path lines for the given asteroid number from a DB timer's CustomData.
// Path lines are stored after the second separator line ("---...") in each asteroid record.
List<string> ExtractAsteroidPathLines(string dbContent, int asteroidNum)
{
    string label = asteroidNum.ToString("D3");
    string[] allLines = dbContent.Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);

    var result = new List<string>();
    // state 0: searching for "Asteroid NNN"
    // state 1: found it, waiting for the second --- separator (before path data)
    // state 2: collecting path lines (stop at next ---)
    int state = 0;

    foreach (string rawLine in allLines)
    {
        string line = rawLine.Trim();
        if (string.IsNullOrWhiteSpace(line)) continue;

        if (state == 0)
        {
            if (string.Equals(line, "Asteroid " + label, StringComparison.OrdinalIgnoreCase))
                state = 1;
        }
        else if (state == 1)
        {
            if (line == asteroidHeaderLine)
                state = 2;
        }
        else
        {
            if (line == asteroidHeaderLine)
                break; // start of next asteroid record
            result.Add(line);
        }
    }

    return result;
}

bool TrySaveMinerPathRuntimeToAsteroidDb(int asteroidNum)
{
    int runtimeTicks;
    if (!TryReadMinerPathRuntimeTicks(out runtimeTicks))
        return false;

    minerPathElapsedTicks = runtimeTicks;
    return UpdateAsteroidRuntimeInDb(asteroidNum, runtimeTicks);
}

bool TryReadMinerPathRuntimeTicks(out int runtimeTicks)
{
    runtimeTicks = 0;
    IMyTimerBlock timer = FindMinerPathTimer();
    if (timer == null)
        return false;

    string[] lines = (timer.CustomData ?? "").Split(new[] { '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries);
    for (int i = lines.Length - 1; i >= 0; i--)
    {
        string line = (lines[i] ?? "").Trim();
        if (TryParseRuntimeLine(line, out runtimeTicks))
            return true;
    }
    return false;
}

bool LooksLikeRuntimeLine(string line)
{
    int runtimeTicks;
    return TryParseRuntimeLine(line, out runtimeTicks);
}

bool TryGetAsteroidRuntimeTicks(int asteroidNum, out int runtimeTicks)
{
    runtimeTicks = 0;
    IMyTimerBlock dbTimer;
    List<string> lines;
    int labelIdx, metadataEndIdx;
    if (!TryGetAsteroidDbMetadataRange(asteroidNum, out dbTimer, out lines, out labelIdx, out metadataEndIdx))
        return false;

    for (int i = labelIdx + 1; i < metadataEndIdx; i++)
    {
        string line = (lines[i] ?? "").Trim();
        if (!LooksLikeRuntimeLine(line))
            continue;
        return TryParseRuntimeLine(line, out runtimeTicks);
    }
    return false;
}

bool TryGetAsteroidRuntimeTicksCached(int asteroidNum, out int runtimeTicks)
{
    runtimeTicks = 0;
    if (cachedAsteroidRuntimeNum == asteroidNum)
    {
        runtimeTicks = cachedAsteroidRuntimeTicks;
        return cachedAsteroidRuntimeValid;
    }

    cachedAsteroidRuntimeNum = asteroidNum;
    cachedAsteroidRuntimeValid = TryGetAsteroidRuntimeTicks(asteroidNum, out cachedAsteroidRuntimeTicks);
    runtimeTicks = cachedAsteroidRuntimeTicks;
    return cachedAsteroidRuntimeValid;
}

bool TryParseRuntimeLine(string line, out int runtimeTicks)
{
    runtimeTicks = 0;
    if (string.IsNullOrWhiteSpace(line))
        return false;

    string value = line.Trim();
    if (value.StartsWith("Runtime:", StringComparison.OrdinalIgnoreCase))
        value = value.Substring("Runtime:".Length).Trim();

    string[] parts = value.Split(':');
    int minutes, seconds;
    if (parts.Length != 2 ||
        !int.TryParse(parts[0].Trim(), out minutes) ||
        !int.TryParse(parts[1].Trim(), out seconds))
        return false;

    if (minutes < 0 || seconds < 0 || seconds >= 60)
        return false;

    runtimeTicks = minutes * 3600 + seconds * 60;
    return true;
}

bool UpdateAsteroidRuntimeInDb(int asteroidNum, int runtimeTicks)
{
    IMyTimerBlock dbTimer;
    List<string> lines;
    int labelIdx, metadataEndIdx;
    if (!TryGetAsteroidDbMetadataRange(asteroidNum, out dbTimer, out lines, out labelIdx, out metadataEndIdx))
        return false;

    string runtimeLine = FormatTicksAsMinutes(runtimeTicks);
    for (int i = labelIdx + 1; i < metadataEndIdx; i++)
    {
        string line = (lines[i] ?? "").Trim();
        if (!LooksLikeRuntimeLine(line))
            continue;

        lines[i] = runtimeLine;
        dbTimer.CustomData = string.Join("\n", lines).TrimEnd();
        cachedAsteroidRuntimeNum = asteroidNum;
        cachedAsteroidRuntimeTicks = runtimeTicks;
        cachedAsteroidRuntimeValid = true;
        return true;
    }

    lines.Insert(metadataEndIdx, runtimeLine);
    dbTimer.CustomData = string.Join("\n", lines).TrimEnd();
    cachedAsteroidRuntimeNum = asteroidNum;
    cachedAsteroidRuntimeTicks = runtimeTicks;
    cachedAsteroidRuntimeValid = true;
    return true;
}

bool TryGetAsteroidDbMetadataRange(int asteroidNum, out IMyTimerBlock dbTimer, out List<string> lines, out int labelIdx, out int metadataEndIdx)
{
    dbTimer = null;
    lines = null;
    labelIdx = -1;
    metadataEndIdx = -1;

    int dbIndex = (asteroidNum - 1) / asteroidsPerDb + 1;
    string dbTimerName = asteroidDbTagPfx + dbIndex.ToString("D2");
    dbTimer = FindTimerByExactName(dbTimerName);
    if (dbTimer == null)
        return false;

    string label = "Asteroid " + asteroidNum.ToString("D3");
    lines = new List<string>((dbTimer.CustomData ?? "").Replace("\r", "").Split('\n'));
    for (int i = 0; i < lines.Count; i++)
    {
        if (!string.Equals((lines[i] ?? "").Trim(), label, StringComparison.OrdinalIgnoreCase))
            continue;

        labelIdx = i;
        for (int j = i + 1; j < lines.Count; j++)
        {
            if (string.Equals((lines[j] ?? "").Trim(), asteroidHeaderLine, StringComparison.Ordinal))
            {
                metadataEndIdx = j;
                return true;
            }
        }
        return false;
    }
    return false;
}

// Appends one asteroid entry to the active zone's Zone DB timer.
// Entry layout:
//   001
//   cx,cy,cz:ax,ay,az,a
//   Ores: Ice,Iron,Nickel
//   Status: Complete
void UpdateZoneDb(ZoneDescriptor zone, int asteroidNum, string carrierGps, Dictionary<string, double> oreMap)
{
    if (zone == null)
    {
        Echo("SaveAsteroid: no active zone resolved. Skipping Zone DB update.");
        return;
    }

    IMyTimerBlock zoneDb = FindTimerByExactName(zone.TimerName);
    if (zoneDb == null)
    {
        Echo($"SaveAsteroid: Zone DB timer '{zone.TimerName}' not found. Skipping.");
        return;
    }

    string existing = zoneDb.CustomData ?? "";
    var sb = new StringBuilder();
    if (!string.IsNullOrWhiteSpace(existing))
    {
        sb.Append(existing.TrimEnd());
        sb.AppendLine();
    }

    sb.AppendLine(asteroidNum.ToString("D3"));
    sb.AppendLine(carrierGps);
    sb.AppendLine("Ores: " + BuildOreSummary(oreMap));
    sb.AppendLine("Status: " + BuildAsteroidStatus(oreMap));

    zoneDb.CustomData = sb.ToString();
    InvalidateZoneDbCache(zone.TimerName);
}

void ReplaceZoneDbEntry(ZoneDescriptor zone, int asteroidNum, string carrierGps, Dictionary<string, double> oreMap)
{
    if (zone == null)
    {
        Echo("UpdateAsteroid: no active zone resolved. Skipping Zone DB update.");
        return;
    }

    IMyTimerBlock zoneDb = FindTimerByExactName(zone.TimerName);
    if (zoneDb == null)
    {
        Echo($"UpdateAsteroid: Zone DB timer '{zone.TimerName}' not found. Skipping.");
        return;
    }

    var lines = new List<string>((zoneDb.CustomData ?? "").Replace("\r", "").Split('\n'));
    string label = asteroidNum.ToString("D3");
    int start = -1;
    int end = lines.Count;
    for (int i = 0; i < lines.Count; i++)
    {
        if (!string.Equals((lines[i] ?? "").Trim(), label, StringComparison.OrdinalIgnoreCase))
            continue;
        start = i;
        for (int j = i + 1; j < lines.Count; j++)
        {
            int nextNum;
            if (IsAsteroidLabelLine((lines[j] ?? "").Trim(), out nextNum))
            {
                end = j;
                break;
            }
        }
        break;
    }

    var replacement = new List<string>();
    replacement.Add(label);
    replacement.Add(carrierGps);
    replacement.Add("Ores: " + BuildOreSummary(oreMap));
    replacement.Add("Status: " + BuildAsteroidStatus(oreMap));

    if (start >= 0)
    {
        lines.RemoveRange(start, end - start);
        lines.InsertRange(start, replacement);
    }
    else
    {
        if (lines.Count > 0 && !string.IsNullOrWhiteSpace(lines[lines.Count - 1]))
            lines.Add("");
        lines.AddRange(replacement);
    }

    zoneDb.CustomData = string.Join("\n", lines).TrimEnd();
    InvalidateZoneDbCache(zone.TimerName);
}


string BuildOreSummary(Dictionary<string, double> oreMap)
{
    if (oreMap == null || oreMap.Count == 0)
        return "(none)";

    var oreNames = new List<string>(oreMap.Keys);
    oreNames.Sort(StringComparer.OrdinalIgnoreCase);
    return string.Join(",", oreNames);
}

string BuildAsteroidStatus(Dictionary<string, double> _oreMap)
{
    return "Complete";
}



void SetAllAsteroidsOpen()
{
    ZoneDescriptor zone;
    IMyTimerBlock zoneDb;
    string reason;
    if (!TryGetActiveZone(out zone, out zoneDb, out reason))
    {
        Echo("SetAllOpen: " + reason);
        return;
    }

    var lines = new List<string>((zoneDb.CustomData ?? "").Split('\n'));
    int updated = 0;
    int added = 0;

    // First, normalize any existing status lines.
    for (int i = 0; i < lines.Count; i++)
    {
        string t = lines[i].Trim();
        if (t.StartsWith("Status:", StringComparison.OrdinalIgnoreCase))
        {
            lines[i] = "Status: Open";
            updated++;
        }
    }

    // Then ensure every asteroid entry has a status line.
    for (int i = 0; i < lines.Count; i++)
    {
        int asteroidNum;
        if (!IsAsteroidLabelLine(lines[i].Trim(), out asteroidNum))
            continue;

        int gpsIdx = -1;
        int oresIdx = -1;
        int statusIdx = -1;

        for (int j = i + 1; j < lines.Count; j++)
        {
            string t = lines[j].Trim();
            if (string.IsNullOrWhiteSpace(t))
                continue;

            int nextNum;
            if (IsAsteroidLabelLine(t, out nextNum) ||
                t.IndexOf(asteroidDbTagPfx, StringComparison.OrdinalIgnoreCase) >= 0)
                break;

            Vector3D _ap, _af, _au;
            if (gpsIdx < 0 && TryParseCarrierAnchorLine(t, out _ap, out _af, out _au))
                gpsIdx = j;
            else if (t.StartsWith("Ores:", StringComparison.OrdinalIgnoreCase))
                oresIdx = j;
            else if (t.StartsWith("Status:", StringComparison.OrdinalIgnoreCase))
            {
                statusIdx = j;
                break;
            }
        }

        if (statusIdx >= 0)
            continue;

        int insertAt = oresIdx >= 0 ? oresIdx + 1 : (gpsIdx >= 0 ? gpsIdx + 1 : i + 1);
        lines.Insert(insertAt, "Status: Open");
        added++;
        i = insertAt;
    }

    zoneDb.CustomData = string.Join("\n", lines).TrimEnd();
    InvalidateZoneDbCache(zone.TimerName);
    Echo($"SetAllOpen: zone '{zone.Name}' status set to Open (updated {updated}, added {added}).");
}

bool IsAsteroidLabelLine(string line, out int asteroidNum)
{
    asteroidNum = 0;
    if (string.IsNullOrWhiteSpace(line))
        return false;
    if (line.Length != 3)
        return false;
    return int.TryParse(line, out asteroidNum);
}

bool TryGetAsteroidStatus(int asteroidNum, out string status)
{
    status = "";
    ZoneAsteroidRecord rec;
    ZoneDescriptor zone;
    string reason;
    if (!TryGetZoneAsteroidRecordInActiveZone(asteroidNum, out rec, out zone, out reason))
        return false;

    status = rec.Status;
    return !string.IsNullOrWhiteSpace(status);
}

bool TrySetAsteroidStatus(int asteroidNum, string newStatus)
{
    ZoneDescriptor zone;
    IMyTimerBlock zoneDb;
    string reason;
    if (TryGetActiveZone(out zone, out zoneDb, out reason) &&
        TrySetAsteroidStatusInZoneDb(zone, zoneDb, asteroidNum, newStatus))
        return true;

    foreach (ZoneDescriptor candidateZone in GetZoneRegistryCached())
    {
        IMyTimerBlock candidateDb = FindTimerByExactName(candidateZone.TimerName);
        if (candidateDb == null)
            continue;
        if (TrySetAsteroidStatusInZoneDb(candidateZone, candidateDb, asteroidNum, newStatus))
            return true;
    }

    return false;
}

bool TrySetMineAsteroidStatus(int asteroidNum, string newStatus)
{
    if (!string.IsNullOrWhiteSpace(mineZoneTimerName))
    {
        IMyTimerBlock zoneDb = FindTimerByExactName(mineZoneTimerName);
        if (zoneDb != null)
        {
            ZoneDescriptor zone = new ZoneDescriptor();
            zone.Name = mineZoneName;
            zone.TimerName = mineZoneTimerName;
            if (TrySetAsteroidStatusInZoneDb(zone, zoneDb, asteroidNum, newStatus))
                return true;
        }
    }

    return TrySetAsteroidStatus(asteroidNum, newStatus);
}

bool TrySetAsteroidStatusInZoneDb(ZoneDescriptor zone, IMyTimerBlock zoneDb, int asteroidNum, string newStatus)
{
    if (zone == null || zoneDb == null)
        return false;

    var lines = new List<string>((zoneDb.CustomData ?? "").Split('\n'));
    string label = asteroidNum.ToString("D3");
    for (int i = 0; i < lines.Count; i++)
    {
        if (!string.Equals(lines[i].Trim(), label, StringComparison.OrdinalIgnoreCase))
            continue;

        int gpsIdx = -1;
        int oresIdx = -1;
        int statusIdx = -1;
        int insertAt = i + 1;

        for (int j = i + 1; j < lines.Count; j++)
        {
            string t = lines[j].Trim();
            if (string.IsNullOrWhiteSpace(t))
                continue;

            int nextNum;
            if (IsAsteroidLabelLine(t, out nextNum) ||
                t.IndexOf(asteroidDbTagPfx, StringComparison.OrdinalIgnoreCase) >= 0)
                break;

            insertAt = j + 1;
            Vector3D _ap, _af, _au;
            if (gpsIdx < 0 && TryParseCarrierAnchorLine(t, out _ap, out _af, out _au))
                gpsIdx = j;
            else if (t.StartsWith("Ores:", StringComparison.OrdinalIgnoreCase))
                oresIdx = j;
            else if (t.StartsWith("Status:", StringComparison.OrdinalIgnoreCase))
            {
                statusIdx = j;
                break;
            }
        }

        string statusLine = "Status: " + newStatus;
        if (statusIdx >= 0)
            lines[statusIdx] = statusLine;
        else
        {
            int at = oresIdx >= 0 ? oresIdx + 1 : (gpsIdx >= 0 ? gpsIdx + 1 : insertAt);
            lines.Insert(Math.Max(i + 1, at), statusLine);
        }

        zoneDb.CustomData = string.Join("\n", lines).TrimEnd();
        InvalidateZoneDbCache(zone.TimerName);
        return true;
    }

    return false;
}

// ---- State persistence (MyIni timer CustomData) ----
// The timer named by stateIniTimerTag owns all runtime persistence for this script.
// PB Storage contains only the small volatile progress overlay used to avoid periodic CustomData write spikes.
// If you need to inspect, backup, reset, or hand-edit full saved state, use that timer's CustomData INI.

string V3ToString(Vector3D v)
{
    return v.X.ToString("R") + ":" + v.Y.ToString("R") + ":" + v.Z.ToString("R");
}

bool TryParseV3(string s, out Vector3D v)
{
    v = Vector3D.Zero;
    if (string.IsNullOrWhiteSpace(s)) return false;
    string[] p = s.Split(':');
    if (p.Length != 3) return false;
    double x, y, z;
    if (!double.TryParse(p[0], out x) || !double.TryParse(p[1], out y) || !double.TryParse(p[2], out z)) return false;
    v = new Vector3D(x, y, z);
    return true;
}

bool ReadStateIni(out MyIni ini)
{
    ini = new MyIni();

    // Load the full snapshot from the dedicated state INI timer.
    IMyTimerBlock timer = FindStateIniTimer();
    if (timer == null)
        return false;

    string data = timer.CustomData ?? "";
    if (string.IsNullOrWhiteSpace(data))
        return false;

    MyIniParseResult result;
    if (!ini.TryParse(data, out result))
    {
        Echo("State INI parse failed: " + result.ToString());
        return false;
    }

    return true;
}

void WriteStateIni(MyIni ini)
{
    // Persist the current state snapshot into the timer CustomData INI.
    IMyTimerBlock timer = FindStateIniTimer();
    if (timer == null)
    {
        Echo($"State INI timer '{stateIniTimerTag}' not found; state was not saved.");
        return;
    }

    timer.CustomData = ini.ToString();
}

bool ReadProgressState()
{
    _progressIni.Clear();
    string data = Storage ?? "";
    if (string.IsNullOrWhiteSpace(data))
        return false;

    MyIniParseResult result;
    if (!_progressIni.TryParse(data, out result))
        return false;

    return true;
}

void WriteProgressState(MyIni ini)
{
    Storage = ini.ToString();
    _hasProgressState = true;
}

string StateString(MyIni ini, string key, string fallback)
{
    if (_hasProgressState)
    {
        string progress = _progressIni.Get(ProgressIniSection, key).ToString(null);
        if (progress != null)
            return progress;
    }
    return ini.Get(StateIniSection, key).ToString(fallback);
}

bool StateBool(MyIni ini, string key, bool fallback)
{
    string s = StateString(ini, key, fallback ? "1" : "0");
    return s == "1" || s.Equals("true", StringComparison.OrdinalIgnoreCase);
}

IMyTimerBlock FindStateIniTimer()
{
    if (_cachedStateIniTimer != null &&
        _cachedStateIniTimer.CustomName.IndexOf(stateIniTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        return _cachedStateIniTimer;

    foreach (var t in GetTimerBlocksCached())
    {
        if (t.CustomName.IndexOf(stateIniTimerTag, StringComparison.OrdinalIgnoreCase) >= 0)
        {
            _cachedStateIniTimer = t;
            return _cachedStateIniTimer;
        }
    }

    _cachedStateIniTimer = null;
    return null;
}

void RefreshTimerCache()
{
    _timerBlocks.Clear();
    GridTerminalSystem.GetBlocksOfType(_timerBlocks, b => b.CubeGrid.EntityId == Me.CubeGrid.EntityId);
    _timerBlocksCached = true;
}

List<IMyTimerBlock> GetTimerBlocksCached()
{
    if (!_timerBlocksCached)
        RefreshTimerCache();
    return _timerBlocks;
}

