void AppendActiveMineDetails(StringBuilder sb)
{
    ZoneAsteroidRecord rec = null;
    ZoneDescriptor zone = null;
    string reason = "";
    bool haveRec = mineAsteroidNum > 0 && TryGetZoneAsteroidRecordInActiveZone(mineAsteroidNum, out rec, out zone, out reason);

    sb.Append("   ");
    sb.AppendLine(mineAsteroidNum > 0 ? mineAsteroidNum.ToString("D3") : "---");
    sb.Append("   ");
    sb.AppendLine(haveRec ? FormatOreList(rec.Ores) : "---");
    sb.Append("   ");
    sb.AppendLine(GetActiveMineStatusLine());

    if (mineSequenceState == MineSequenceState.GoingTo ||
        mineSequenceState == MineSequenceState.WaitingForStationary ||
        mineSequenceState == MineSequenceState.ReturningToFrontApproach)
    {
        sb.Append("   ");
        sb.AppendLine("Distance: " + FormatCarrierMiningDistance());
    }
    else if (mineSequenceState == MineSequenceState.WaitingMinerPathComplete)
    {
        if (mineRecallActive && mineRecallAcknowledged)
        {
            sb.Append("   ");
            sb.Append(minerProgressDone);
            sb.Append("/");
            sb.AppendLine(minerProgressTotal.ToString());
            return;
        }
        int savedRuntimeTicks = 0;
        bool haveRuntime = mineAsteroidNum > 0 && TryGetAsteroidRuntimeTicksCached(mineAsteroidNum, out savedRuntimeTicks);
        if (!haveRuntime)
            sb.AppendLine("   Remaining --:--");
        else if (minerPathElapsedTicks <= savedRuntimeTicks)
            sb.AppendLine("   Remaining " + FormatTicksAsMinutes(savedRuntimeTicks - minerPathElapsedTicks));
        else
            sb.AppendLine("   Overrun " + FormatTicksAsMinutes(minerPathElapsedTicks - savedRuntimeTicks));
    }
}

string GetActiveMineStatusLine()
{
    if (mineSequenceState == MineSequenceState.GoingTo)
        return "Carrier: Going to asteroid";
    if (mineSequenceState == MineSequenceState.WaitingForStationary)
        return "Miner: Waiting";
    if (mineSequenceState == MineSequenceState.WaitingMinerPathComplete)
    {
        if (mineRecallAcknowledged)
            return "Miner: Recalled";
        if (mineRecallRequested)
            return "Miner: Recall sent";
        if (mineRecallFailedTicks > 0)
            return "Miner: Recall failed";
        return "Miner: Path running " + GetLoadingSymbol();
