void Move()
{
    movementResetApplied = false;
    MatrixD rcMatrix     = _tickRcMatrix;
    Vector3D worldOffset = GetTargetOffsetWorld(rcMatrix);
    Vector3D rcPosition  = _tickRcPosition;
    Vector3D position    = rcPosition + worldOffset;
    Vector3D toTarget    = targetPosition - position;
    double tolerance = Math.Max(0.05, arrivalTolerance);
    bool atPosition  = toTarget.LengthSquared() < tolerance * tolerance;

    Vector3D forward = desiredForward;
    bool precisionTravelFacing = carrierAutopilotMode == CarrierAutopilotMode.Precision &&
        desiredForward == Vector3D.Zero &&
        !atPosition &&
        toTarget.LengthSquared() > 0.001;
    if (precisionTravelFacing)
        forward = Vector3D.Normalize(toTarget);
    else if (forward == Vector3D.Zero && toTarget.LengthSquared() > 0.001)
        forward = Vector3D.Normalize(toTarget);

    Vector3D up = precisionTravelFacing ? Vector3D.Zero : desiredUp;
    bool freeRollFacing = precisionTravelFacing || carrierAutopilotMode != CarrierAutopilotMode.Precision;
    if (up == Vector3D.Zero && !freeRollFacing)
    {
        Vector3D gravity = rc.GetNaturalGravity();
        if (gravity.LengthSquared() > 0.001)
            up = Vector3D.Normalize(-gravity);
        else
            up = rcMatrix.Up;
    }

    gyros.FaceVectors(rcMatrix, forward, up);

    bool aligned     = IsOrientationAligned(rcMatrix, forward, up, orientationToleranceDeg);
    if (carrierAutopilotMode != CarrierAutopilotMode.Precision)
    {
        MoveCruise(rcMatrix, rcPosition, position, toTarget, forward, up, aligned);
        return;
    }

    if (atPosition)
    {
        thrust.Reset();
        if (aligned)
            gyros.Reset();
        return;
    }
    if (!aligned)
    {
        thrust.Reset();
        return;
    }

    double maxSpeedNow = GetPrecisionSafeSpeed(toTarget);
    if (activeMaxSpeed > 0)
        maxSpeedNow = Math.Min(maxSpeedNow, activeMaxSpeed);
    maxSpeedNow = Math.Min(maxSpeedNow, maxSpeed);
    Vector3D rcTarget  = targetPosition - worldOffset;
    Vector3D accel = thrust.ControlPositionFrom(rcPosition, rcTarget, Vector3D.Zero, maxSpeedNow);
    ApplyCarrierAccel(accel, ShouldUseEmergencyThrust(toTarget));
}

void MoveCruise(MatrixD rcMatrix, Vector3D rcPosition, Vector3D position, Vector3D toTarget, Vector3D forward, Vector3D up, bool aligned)
{
    if (carrierAutopilotMode == CarrierAutopilotMode.CruiseTurnTest ||
        carrierAutopilotMode == CarrierAutopilotMode.CruiseFlip)
    {
        thrust.Reset();
        return;
    }

    if (!aligned)
    {
        thrust.Reset();
        return;
    }

    if (cruiseDirection.LengthSquared() < 0.001)
    {
        rc.DampenersOverride = true;
        carrierAutopilotMode = CarrierAutopilotMode.Precision;
        return;
    }

    Vector3D dir = Vector3D.Normalize(cruiseDirection);
    if (carrierAutopilotMode == CarrierAutopilotMode.CruiseDecel)
    {
        Vector3D vel = rc.GetShipVelocities().LinearVelocity;
        if (vel.LengthSquared() < 0.01)
        {
            thrust.Reset();
            return;
        }
        ApplyCarrierAccel(thrust.ControlVelocity(Vector3D.Zero), ShouldUseCruiseEmergencyThrust());
    }
    else
    {
        double accelMag = GetPlannedAcceleration(-dir);
        if (accelMag <= 0)
        {
            thrust.Reset();
            return;
        }
        ApplyCarrierAccel(-dir * accelMag, false);
    }
}

double GetPrecisionSafeSpeed(Vector3D toTarget)
{
    double distance = Math.Max(0, toTarget.Length() - Math.Max(0.05, arrivalTolerance));
    if (distance <= 0)
        return 0;
    Vector3D dir = Vector3D.Normalize(toTarget);
    double brakeAccel = GetPlannedAcceleration(-dir);
    if (brakeAccel <= 0)
        return Math.Max(1, maxSpeed);
    return Math.Sqrt(Math.Max(0, 2 * brakeAccel * distance));
}

bool ShouldUseEmergencyThrust(Vector3D toTarget)
{
    Vector3D vel = rc.GetShipVelocities().LinearVelocity;
    double dist = Math.Max(0, toTarget.Length() - Math.Max(0.05, arrivalTolerance));
    if (dist <= 0 || vel.LengthSquared() < 0.01 || toTarget.LengthSquared() < 0.01)
        return false;
    Vector3D dir = Vector3D.Normalize(toTarget);
    double speedToward = Vector3D.Dot(vel, dir);
    if (speedToward <= 0)
        return false;
    double accel = GetPlannedAcceleration(-dir);
    if (accel <= 0)
        return false;
    return (speedToward * speedToward) / (2 * accel) > dist;
}

bool ShouldUseCruiseEmergencyThrust()
{
    if (cruiseDirection.LengthSquared() < 0.001)
        return false;
    Vector3D dir = Vector3D.Normalize(cruiseDirection);
    Vector3D toStage = cruiseStagingPosition - GetControlledPosition();
    double dist = Math.Max(0, Vector3D.Dot(toStage, dir));
    double speed = Vector3D.Dot(rc.GetShipVelocities().LinearVelocity, dir);
    if (dist <= 0 || speed <= 0)
        return true;
    double accel = GetPlannedAcceleration(dir);
    if (accel <= 0)
        return false;
    return (speed * speed) / (2 * accel) > dist;
}

double GetShipMass()
{
    return Math.Max(1, rc.CalculateShipMass().TotalMass);
}

double GetEffectiveThrustInDirection(Vector3D direction)
{
    if (direction.LengthSquared() < 0.001)
        return 0;
    Vector3D dir = Vector3D.Normalize(direction);
    double total = 0;
    foreach (var t in allThrusters)
    {
        if (t == null || !t.IsFunctional)
            continue;
        double dot = Vector3D.Dot(t.WorldMatrix.Forward, dir);
        if (dot > 0)
            total += t.MaxEffectiveThrust * dot;
    }
    return total;
}

double GetDetectedMaxCarrierThrustN()
{
    MatrixD m = rc == null ? _tickRcMatrix : rc.WorldMatrix;
    double max = 0;
    max = Math.Max(max, GetEffectiveThrustInDirection(m.Forward));
    max = Math.Max(max, GetEffectiveThrustInDirection(m.Backward));
    max = Math.Max(max, GetEffectiveThrustInDirection(m.Left));
    max = Math.Max(max, GetEffectiveThrustInDirection(m.Right));
    max = Math.Max(max, GetEffectiveThrustInDirection(m.Up));
    max = Math.Max(max, GetEffectiveThrustInDirection(m.Down));
    return max;
}

string FormatCompactThrustN(double thrustN)
{
    double abs = Math.Abs(thrustN);
    double scaled;
    string unit;
    if (abs >= 1000000000.0)
    {
        scaled = thrustN / 1000000000.0;
        unit = "GN";
    }
    else if (abs >= 1000000.0)
    {
        scaled = thrustN / 1000000.0;
        unit = "MN";
    }
    else
    {
        scaled = thrustN / 1000.0;
        unit = "kN";
    }
    return scaled.ToString("000.0").Replace(',', '.') + " " + unit;
}

double GetHardThrustLimitN()
{
    return Math.Max(1, thrustLimitKn) * 1000.0;
}

double GetPlannedThrustLimitN()
{
    return GetHardThrustLimitN() * MathHelper.Clamp(thrustUsePercent, 1, 100) / 100.0;
}

double GetPlannedAcceleration(Vector3D direction)
{
    double mass = GetShipMass();
    double force = Math.Min(GetEffectiveThrustInDirection(direction), GetPlannedThrustLimitN());
    return Math.Min(Math.Max(0.1, accelerationLimit), force / mass);
}

double GetHardAcceleration(Vector3D direction)
{
    double mass = GetShipMass();
    double force = Math.Min(GetEffectiveThrustInDirection(direction), GetHardThrustLimitN());
    return force / mass;
}

void ApplyCarrierAccel(Vector3D accel, bool emergency)
{
    double mass = GetShipMass();
    double maxForce = emergency ? GetHardThrustLimitN() : GetPlannedThrustLimitN();
    if (!emergency)
        maxForce = Math.Min(maxForce, mass * Math.Max(0.1, accelerationLimit));
    thrust.ApplyAccel(accel, maxForce);
}

Vector3D GetControlledPosition()
{
    return _tickRcPosition + GetTargetOffsetWorld(_tickRcMatrix);
}

void UpdateCarrierConnectorMassWatch()
{
    if (carrierConnector == null)
        return;

    bool connected = carrierConnector.Status == MyShipConnectorStatus.Connected;
    if (!carrierConnectorStateKnown)
    {
        carrierConnectorStateKnown = true;
        lastCarrierConnectorConnected = connected;
        return;
    }

    if (connected == lastCarrierConnectorConnected)
        return;

    lastCarrierConnectorConnected = connected;
    measuredFlipSeconds = 0;
    measuredFlipMass = 0;
    Echo("Cruise: connector state changed; turn test cache cleared.");
}

Vector3D GetTargetOffsetWorld()
{
    return GetTargetOffsetWorld(_tickRcMatrix);
}

Vector3D GetTargetOffsetWorld(MatrixD wm)
{
    return wm.Right * TOFFR + wm.Up * TOFFU + wm.Forward * TOFFF;
}

bool IsOrientationAligned(Vector3D forward, Vector3D up, double toleranceDeg)
{
    return IsOrientationAligned(_tickRcMatrix, forward, up, toleranceDeg);
}

bool IsOrientationAligned(MatrixD wm, Vector3D forward, Vector3D up, double toleranceDeg)
{
    double minDot = Math.Cos(Math.Max(0.1, toleranceDeg) * Math.PI / 180.0);
    double forwardLenSq = forward.LengthSquared();
    if (forwardLenSq > 0.001)
    {
        if (Math.Abs(forwardLenSq - 1) > 0.001)
            forward /= Math.Sqrt(forwardLenSq);
        if (Vector3D.Dot(wm.Forward, forward) < minDot)
            return false;
    }
    double upLenSq = up.LengthSquared();
    if (upLenSq > 0.001)
    {
        if (Math.Abs(upLenSq - 1) > 0.001)
            up /= Math.Sqrt(upLenSq);
        if (Vector3D.Dot(wm.Up, up) < minDot)
            return false;
    }
    return true;
}

bool IsAtTargetPosition(Vector3D target, double toleranceMeters = -1)
{
    double baseTolerance = toleranceMeters > 0 ? toleranceMeters : arrivalTolerance;
    double tolerance     = Math.Max(0.05, baseTolerance);
    return Vector3D.DistanceSquared(_tickRcPosition + GetTargetOffsetWorld(_tickRcMatrix), target) < tolerance * tolerance;
}

bool IsAtTargetPose(Vector3D target, Vector3D forward, Vector3D up, double toleranceMeters = -1)
{
    return IsAtTargetPosition(target, toleranceMeters) && IsOrientationAligned(forward, up, orientationToleranceDeg);
}

void RemoteCommand(string command)
{
    if (string.IsNullOrWhiteSpace(command))
        return;

    string trimmed = command.Trim();

    if (TryHandleCarrierLcdCommand(trimmed))
        return;

    if (trimmed.StartsWith("Nav;", StringComparison.OrdinalIgnoreCase))
    {
        string navArgs = trimmed.Substring(4).Trim();
        Vector3D pos, forward, up;
        if (!TryParseGpsCommand(navArgs, out pos, out forward, out up))
        {
            Echo("Invalid Nav command. Use: Nav;GPS:Name:X:Y:Z:|Faceup,Faceforward");
            return;
        }
        StartPrecisionTarget(pos, forward, up);
        WriteEcho();
        return;
    }

    if (trimmed.StartsWith("Cruise;", StringComparison.OrdinalIgnoreCase))
    {
        string navArgs = trimmed.Substring(7).Trim();
        Vector3D pos, forward, up;
        if (!TryParseGpsCommand(navArgs, out pos, out forward, out up))
        {
            Echo("Invalid Cruise command. Use: Cruise;GPS:Name:X:Y:Z:|Faceup,Faceforward");
            return;
        }
        StartCruiseTarget(pos, forward, up);
        WriteEcho();
        return;
    }

    if (trimmed.StartsWith("TOFF ", StringComparison.OrdinalIgnoreCase))
    {
        Vector3D off;
        if (TryParseVector3(trimmed.Substring(5).Trim(), out off))
        {
            TOFFR = off.X; TOFFU = off.Y; TOFFF = off.Z;
            Echo($"TOFF set. R/U/F = {TOFFR:0.00}/{TOFFU:0.00}/{TOFFF:0.00} m");
        }
        else
            Echo("Invalid TOFF. Use: TOFF r,u,f");
        return;
    }

    if (trimmed.StartsWith("loadasteroid ", StringComparison.OrdinalIgnoreCase))
    {
        LoadAsteroid(trimmed);
        return;
    }

    if (trimmed.StartsWith("goto ", StringComparison.OrdinalIgnoreCase))
    {
        HandleGoTo(trimmed);
        return;
    }
    if (trimmed.StartsWith("mine ", StringComparison.OrdinalIgnoreCase))
    {
        StartMineSequence(trimmed);
        return;
    }
    if (trimmed.Equals("recall miner", StringComparison.OrdinalIgnoreCase) ||
        trimmed.Equals("recallminer", StringComparison.OrdinalIgnoreCase))
    {
        StartMinerRecall();
        return;
    }
    if (TryHandleOreNameStateCommand(trimmed))
        return;
    switch (trimmed.ToLower())
    {
        case "pause":
            pauseResumeAutopilot = autopilotEnabled;
            scriptPaused = true;
            Runtime.UpdateFrequency = UpdateFrequency.None;
            ResetMovement();
            autopilotEnabled = false;
            SetIndicatorOffNow();
            Echo("Paused.");
            break;
        case "resume":
        case "start":
            autopilotEnabled = scriptPaused ? pauseResumeAutopilot : hasTarget;
            scriptPaused = false;
            Runtime.UpdateFrequency = tickSpeed;
            pauseResumeAutopilot = false;
            WriteEcho();
            break;
        case "stop":
        case "clear":
        case "reset":
            scriptPaused        = false;
            pauseResumeAutopilot = false;
            Runtime.UpdateFrequency = tickSpeed;
            autopilotEnabled    = false;
            hasTarget           = false;
            targetPosition      = Vector3D.Zero;
            desiredForward      = Vector3D.Zero;
            desiredUp           = Vector3D.Zero;
            goToMode            = false;
            goToStage           = 0;
            _goToTravelForward  = Vector3D.Zero;
            carrierAutopilotMode = CarrierAutopilotMode.Precision;
            mineSequenceState   = MineSequenceState.None;
            mineAsteroidNum     = 0;
            mineZoneName        = "";
            mineZoneTimerName   = "";
            mineCompletionApproachPoint = Vector3D.Zero;
            mineCompletionForward = Vector3D.Zero;
            mineCompletionUp = Vector3D.Zero;
            minerPathCompleteReceived = false;
            minerPathElapsedTicks = 0;
            minerPathRuntimeSaved = false;
            mineRecallRequested = false;
            mineRecallActive = false;
            mineRecallAcknowledged = false;
            mineRecallFailedTicks = 0;
            minerProgressDone = 0;
            minerProgressTotal = 0;
            minerProgressAgeSeconds = 9999;
            mineStationaryTicks = 0;
            fullAutoEnabled = false;
            fullAutoWaitingForMine = false;
            fullAutoCooldownTicks = 0;
            fullAutoActiveAsteroid = 0;
            fullAutoPendingAsteroid = 0;
            fullAutoEnableStationaryTicks = 0;
            ResetFullAutoSelection();
            ResetFullAutoEscape();
            pathMode            = false;
            pathPaused          = false;
            pathPausedNavResume = false;
            pathRecords.Clear();
            pathIndex           = 0;
            pathAnchorValid     = false;
            activeMaxSpeed      = 0;
            ResetMovement();
            SetIndicatorOffNow();
            WriteEcho();
            if (trimmed.Equals("stop", StringComparison.OrdinalIgnoreCase))
                Echo("Stopped.");
            break;
        case "dumpgps":
            DumpCurrentGpsToCustomData();
            break;
        case "pathstart":
            StartPathFromTimer();
            break;
        case "pathpause":
            if (!pathMode)
                Echo("Path mode is not active.");
            else
            {
                pathPaused = true;
                if (autopilotEnabled && hasTarget)
                {
                    autopilotEnabled    = false;
                    pathPausedNavResume = true;
                    Echo("Path mode paused. Movement halted.");
                }
                else
                    Echo("Path mode paused.");
            }
            break;
        case "pathcontinue":
            if (!pathMode)
                Echo("Path mode is not active.");
            else
            {
                pathPaused = false;
                Echo("Path mode resumed.");
                if (pathPausedNavResume && hasTarget)
                {
                    autopilotEnabled    = true;
                    pathPausedNavResume = false;
                }
                else if (!autopilotEnabled)
                    StartNextPathRecord();
            }
            break;
        case "pathstop":
            StopPathExecution();
            Echo("Path mode stopped.");
            break;
        case "toffreset":
            TOFFR = 0; TOFFU = 0; TOFFF = 0;
            Echo("TOFF reset to 0,0,0.");
            break;
        case "saveasteroid":
            SaveAsteroid();
            break;
        case "updateasteroid":
            UpdateCurrentAsteroidFromMinerPath();
            break;
        case "setallopen":
            SetAllAsteroidsOpen();
            break;
        case "dbcheck":
            RunDbCheck(false);
            break;
        case "dbcheck;fix":
            RunDbCheck(true);
            break;
        case "audit":
            DumpDuplicateZoneIdCheckToCustomData();
            break;
        case "fullauto":
            SetFullAutoEnabledFromUi(true);
            break;
        case "fullautostop":
            SetFullAutoEnabledFromUi(false);
            break;
    }
}

void UpdatePathRunner()
{
    if (!pathMode || pathRecords.Count == 0) return;
    if (pathPaused) return;

    if (autopilotEnabled && hasTarget)
    {
        if (IsAtTargetPose(targetPosition, desiredForward, desiredUp))
        {
            autopilotEnabled = false;
            hasTarget        = false;
            activeMaxSpeed   = 0;
        }
        return;
    }

    StartNextPathRecord();
}

void StopPathExecution()
{
    pathMode = false;
    pathPaused = false;
    pathPausedNavResume = false;
    pathRecords.Clear();
    pathIndex = 0;
    pathAnchorValid = false;
    autopilotEnabled = false;
    hasTarget = false;
    activeMaxSpeed = 0;
    ResetMovement();
}

void PollMinerPathCompletion()
{
    if (minerPathCompleteListener == null)
        return;

    while (minerPathCompleteListener.HasPendingMessage)
    {
        MyIGCMessage msg = minerPathCompleteListener.AcceptMessage();
        string payload = msg.Data as string;
        if (!string.IsNullOrWhiteSpace(payload))
        {
            Echo($"Miner broadcast: {payload}");
            if (payload.IndexOf("Recall complete", StringComparison.OrdinalIgnoreCase) >= 0)
            {
                mineRecallRequested = false;
                mineRecallActive = true;
                mineRecallAcknowledged = true;
            }
        }
        minerPathCompleteReceived = true;
    }
}

void StartMineSequence(string argument)
{
    string[] parts = argument.Split(new[] { ' ' }, 2, StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length < 2)
    {
        Echo("Usage: Mine <number>  e.g. Mine 032");
        return;
    }

    int asteroidNum;
    if (!int.TryParse(parts[1].Trim(), out asteroidNum) || asteroidNum < 1)
    {
        Echo($"Mine: invalid number '{parts[1].Trim()}'.");
        return;
    }

    string asteroidStatus;
    if (TryGetAsteroidStatus(asteroidNum, out asteroidStatus))
    {
        string normalized = asteroidStatus.Trim().ToLowerInvariant();
        if (normalized == "complete" || normalized == "completed")
        {
            Echo($"Mine: asteroid {asteroidNum:D3} is already marked '{asteroidStatus}'. Aborting.");
            return;
        }
    }
    else
        Echo($"Mine: asteroid {asteroidNum:D3} has no status entry in the active zone DB. Proceeding.");

    ZoneAsteroidRecord mineRec;
    ZoneDescriptor mineZone;
    string mineZoneReason;
    if (!TryGetZoneAsteroidRecordInActiveZone(asteroidNum, out mineRec, out mineZone, out mineZoneReason))
    {
        Echo($"Mine: asteroid {asteroidNum:D3} not found in the active zone DB.");
        return;
    }
    Vector3D savedPos = mineRec.Position;
    Vector3D savedForward = mineRec.Forward;
    Vector3D savedUp = mineRec.Up;
    if (savedForward.LengthSquared() < 0.001 || savedUp.LengthSquared() < 0.001)
    {
        Echo($"Mine: asteroid {asteroidNum:D3} saved carrier orientation is invalid.");
        return;
    }

    mineAsteroidNum = asteroidNum;
    mineZoneName = mineZone != null ? mineZone.Name : "";
    mineZoneTimerName = mineZone != null ? mineZone.TimerName : "";
    mineSavedPos = savedPos;
    mineSavedForward = savedForward;
    mineSavedUp = savedUp;
    mineFrontApproachPoint = savedPos + savedForward * goToLeadDistanceMeters;
    mineCompletionApproachPoint = mineFrontApproachPoint;
    mineCompletionForward = savedForward;
    mineCompletionUp = savedUp;
    minerPathCompleteReceived = false;
    minerPathElapsedTicks = 0;
    minerPathRuntimeSaved = false;
    mineRecallRequested = false;
    mineRecallActive = false;
    mineRecallAcknowledged = false;
    mineRecallFailedTicks = 0;
    minerProgressDone = 0;
    minerProgressTotal = 0;
    minerProgressAgeSeconds = 9999;
    mineStationaryTicks = 0;

    HandleGoTo("GoTo " + asteroidNum.ToString("D3"));
    if (!goToMode)
    {
        Echo("Mine: unable to start GoTo.");
        return;
    }

    mineSequenceState = MineSequenceState.GoingTo;
    Echo($"Mine: sequence started for asteroid {asteroidNum:D3}.");
}

void UpdateMineSequence()
{
    if (mineSequenceState == MineSequenceState.None)
        return;

    if (mineSequenceState == MineSequenceState.GoingTo)
    {
        if (goToMode)
            return;

        mineSequenceState = MineSequenceState.WaitingForStationary;
        mineStationaryTicks = 0;
        Echo($"Mine: GoTo complete. Waiting to be stationary before starting miner for asteroid {mineAsteroidNum:D3}.");
        return;
    }

    if (mineSequenceState == MineSequenceState.WaitingForStationary)
    {
        double speed = rc.GetShipVelocities().LinearVelocity.Length();
        if (speed <= Math.Max(0, mineStationarySpeedMps))
            mineStationaryTicks++;
        else
            mineStationaryTicks = 0;

        if (mineStationaryTicks < Math.Max(1, mineStationaryConfirmTicks))
            return;

        if (!LoadAsteroid("LoadAsteroid " + mineAsteroidNum.ToString("D3")))
        {
            Echo($"Mine: failed to load path for asteroid {mineAsteroidNum:D3}. Aborting before PathStart.");
            mineSequenceState = MineSequenceState.None;
            minerPathCompleteReceived = false;
            minerPathElapsedTicks = 0;
            minerPathRuntimeSaved = false;
            mineStationaryTicks = 0;
            if (fullAutoWaitingForMine && fullAutoActiveAsteroid == mineAsteroidNum)
            {
                fullAutoWaitingForMine = false;
                fullAutoActiveAsteroid = 0;
                fullAutoCooldownTicks = Math.Max(1, fullAutoRetryTicks);
            }
            return;
        }
        minerPathElapsedTicks = 0;
        minerPathRuntimeSaved = false;
        if (!SendMinerCommand("PathStart"))
        {
            Echo($"Mine: failed to start miner path for asteroid {mineAsteroidNum:D3}.");
            mineSequenceState = MineSequenceState.None;
            minerPathCompleteReceived = false;
            minerPathElapsedTicks = 0;
            minerPathRuntimeSaved = false;
            mineStationaryTicks = 0;
            if (fullAutoWaitingForMine && fullAutoActiveAsteroid == mineAsteroidNum)
            {
                fullAutoWaitingForMine = false;
                fullAutoActiveAsteroid = 0;
                fullAutoCooldownTicks = Math.Max(1, fullAutoRetryTicks);
            }
            return;
        }
        mineSequenceState = MineSequenceState.WaitingMinerPathComplete;
        mineStationaryTicks = 0;
        Echo($"Mine: waiting for miner completion broadcast for asteroid {mineAsteroidNum:D3}.");
        return;
    }

    if (mineSequenceState == MineSequenceState.WaitingMinerPathComplete)
    {
        if (!minerPathCompleteReceived)
            return;

        if (mineRecallActive)
        {
            CompleteMineRecallSequence();
            return;
        }

        TrySaveCurrentMineRuntime();

        int nextAsteroid;
        string approachName;
        string selectionReason;
        if (TryPlanFullAutoPostMineApproach(out mineCompletionApproachPoint, out mineCompletionForward, out mineCompletionUp, out nextAsteroid, out approachName, out selectionReason))
        {
            fullAutoPendingAsteroid = nextAsteroid;
            StartPrecisionTarget(mineCompletionApproachPoint, mineCompletionForward, mineCompletionUp);
            activeMaxSpeed = maxSpeed;
            mineSequenceState = MineSequenceState.ReturningToFrontApproach;
            Echo($"Mine: miner complete. Next asteroid {nextAsteroid:D3} selected from {approachName} approach; moving there.");
            return;
        }

        if (fullAutoWaitingForMine && fullAutoActiveAsteroid == mineAsteroidNum)
        {
            Echo("Fullauto: " + selectionReason);
            CompleteMineSequence("Mine");
            return;
        }

        mineCompletionApproachPoint = mineFrontApproachPoint;
        mineCompletionForward = mineSavedForward;
        mineCompletionUp = mineSavedUp;
        StartPrecisionTarget(mineCompletionApproachPoint, mineCompletionForward, mineCompletionUp);
        activeMaxSpeed = maxSpeed;
        mineSequenceState = MineSequenceState.ReturningToFrontApproach;
        Echo($"Mine: miner complete. Returning to front approach point for asteroid {mineAsteroidNum:D3}.");
        return;
    }

    if (mineSequenceState == MineSequenceState.ReturningToFrontApproach)
    {
        TrySaveCurrentMineRuntime();

        if (!IsAtTargetPose(mineCompletionApproachPoint, mineCompletionForward, mineCompletionUp))
            return;

        CompleteMineSequence("Mine");
    }
}

bool TryPlanFullAutoPostMineApproach(out Vector3D approachPoint, out Vector3D approachForward, out Vector3D approachUp, out int nextAsteroid, out string approachName, out string reason)
{
    approachPoint = mineFrontApproachPoint;
    approachForward = mineSavedForward;
    approachUp = mineSavedUp;
    nextAsteroid = 0;
    approachName = "front";
    reason = "no Open asteroid matches enabled ores with a safe path from front or back approach.";

    if (!fullAutoEnabled || !fullAutoWaitingForMine || fullAutoActiveAsteroid != mineAsteroidNum)
        return false;
    if (mineSavedForward.LengthSquared() < 0.001)
    {
        reason = "current asteroid saved forward vector is invalid.";
        return false;
    }

    ZoneAsteroidRecord selected;
    string selectReason;
    Vector3D forward = Vector3D.Normalize(mineSavedForward);
    Vector3D frontPoint = mineSavedPos + forward * goToLeadDistanceMeters;
    Vector3D backPoint = mineSavedPos - forward * goToLeadDistanceMeters;

    if (TrySelectFullAutoAsteroidFrom(frontPoint, out selected, out selectReason))
    {
        approachPoint = frontPoint;
        approachForward = GetTravelForward(GetControlledPosition(), frontPoint, forward);
        approachUp = mineSavedUp;
        nextAsteroid = selected.Number;
        approachName = "front";
        reason = "";
        return true;
    }

    reason = selectReason;
    if (TrySelectFullAutoAsteroidFrom(backPoint, out selected, out selectReason))
    {
        approachPoint = backPoint;
        approachForward = GetTravelForward(GetControlledPosition(), backPoint, -forward);
        approachUp = mineSavedUp;
        nextAsteroid = selected.Number;
        approachName = "back";
        reason = "";
        return true;
    }

    if (!string.IsNullOrWhiteSpace(selectReason))
        reason = selectReason;
    return false;
}

void CompleteMineSequence(string logPrefix)
{
    int completedAsteroid = mineAsteroidNum;
    if (completedAsteroid > 0)
    {
        if (TrySetMineAsteroidStatus(completedAsteroid, "Completed"))
            Echo($"{logPrefix}: asteroid {completedAsteroid:D3} status set to Completed.");
        else
            Echo($"{logPrefix}: warning - could not set asteroid {completedAsteroid:D3} status to Completed.");
    }
    ClearMinerPathTimer(logPrefix);

    autopilotEnabled = false;
    hasTarget = false;
    activeMaxSpeed = 0;
    mineSequenceState = MineSequenceState.None;
    mineAsteroidNum = 0;
    mineZoneName = "";
    mineZoneTimerName = "";
    mineCompletionApproachPoint = Vector3D.Zero;
    mineCompletionForward = Vector3D.Zero;
    mineCompletionUp = Vector3D.Zero;
    minerPathCompleteReceived = false;
    minerPathElapsedTicks = 0;
    minerPathRuntimeSaved = false;
    mineRecallRequested = false;
    mineRecallActive = false;
    mineRecallAcknowledged = false;
    mineRecallFailedTicks = 0;
    mineStationaryTicks = 0;
    Echo(logPrefix + ": sequence complete.");
}

